          "id": "fm1_short_grass",
          "description": "Fuel model 1 (short grass): weight=7 s → T_f = 7/0.8514 ≈ 8.222 s. Matches upstream WildlandFire.fuel_weight(1.0) ≈ 7.0/0.8514 (rtol=0.01).",
          "parameter_overrides": {
            "code": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "fuel_weight",
              "time": 0.0,
              "expected": 8.221752407798919,
              "tolerance": {
                "rel": 1e-12
              }
