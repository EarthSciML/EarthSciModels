          "id": "fuel_weight_by_code",
          "description": "T_f for each Anderson 13 fuel model code, showing the three weight classes (7 s, 25 s, 180 s, 900 s). Compare with Table 1 of Mandel et al. (2011).",
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "parameter_sweep": {
            "type": "cartesian",
            "dimensions": [
              {
                "parameter": "code",
                "values": [
