              "expected": 50.0,
              "tolerance": {
                "rel": 1e-12
              }
            }
          ]
        },
        {
          "id": "shrubs_lu5",
          "description": "Land use 5 (Shrubs): α = Float64(Float32(1.3)) = 1.2999999523162842. Float32 representation of 1.3 is 0x3FA66666, which promotes to this Float64 value.",
          "parameter_overrides": {
            "iLandUse": 5.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "α_table",
              "time": 0.0,
              "expected": 1.2999999523162842,
              "tolerance": {
                "rel": 1e-12
              }
            }
          ]
        },
        {
          "id": "clamp_below_lu0",
          "description": "iLandUse=0 (below valid range): interp.linear clamps to α for land use 1 = 1.0 (Evergreen).",
          "parameter_overrides": {
            "iLandUse": 0.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "α_table",
              "time": 0.0,
              "expected": 1.0,
              "tolerance": {
                "rel": 1e-12
              }
            }
          ]
        },
        {
          "id": "clamp_above_lu6",
          "description": "iLandUse=6 (above valid range): interp.linear clamps to α for land use 5 = 1.2999999523162842 (Shrubs).",
          "parameter_overrides": {
            "iLandUse": 6.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "α_table",
              "time": 0.0,
              "expected": 1.2999999523162842,
              "tolerance": {
                "rel": 1e-12
              }
            }
          ]
        },
        {
          "id": "time_invariance",
          "description": "α_table is purely algebraic (no time derivatives): value at t=1 equals value at t=0.",
          "parameter_overrides": {
            "iLandUse": 3.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "α_table",
              "time": 0.0,
              "expected": 1.2000000476837158,
              "tolerance": {
                "rel": 1e-12
              }
