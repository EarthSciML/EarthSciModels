            {
              "variable": "α_table",
              "time": 1.0,
              "expected": 1.2000000476837158,
              "tolerance": {
                "rel": 1e-12
              }
            }
          ]
        }
      ],
      "examples": [
        {
          "id": "alpha_by_land_use",
          "description": "Impaction efficiency α for each Seinfeld land-use category. Note the extreme value for Desert (α=50) vs. vegetated surfaces (α≈0.8–1.3). A high α suppresses particle impaction deposition via term_2 = (St / (α + St))^2.",
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "parameter_sweep": {
            "type": "cartesian",
            "dimensions": [
