        "citation": "Source: EarthSciData.jl@830435a:src/nei2016monthly.jl:99."
      }
    ]
  },
  "models": {
    "dayofweek_itp_CO": {
      "reference": {
        "notes": "source_ref: EarthSciData.jl@830435a:src/nei2016monthly.jl:99\nFactors: [1.076, 1.1076, 1.0706, 1.0706, 1.0706, 0.779, 0.683]\nday_of_week (1=Mon, 7=Sun) = (D+3) mod 7 + 1\n  where D = floor(t_local/86400), t_local = t_utc + floor(lon*180/(pi*15))*3600\nNote: Test timestamps use positive values (>= epoch) to avoid float rounding\nissue where 1/86400 coefficient causes floor error for negative timestamps."
      },
      "tolerance": {
        "rel": 1e-10
      },
      "variables": {
        "t_utc": {
          "type": "parameter",
          "units": "s",
          "default": 0.0,
          "description": "UTC time as seconds since Unix epoch (1970-01-01T00:00:00Z = Thursday)."
        },
        "lon": {
          "type": "parameter",
          "units": "rad",
          "default": 0.0,
          "description": "Longitude in radians. Used to compute local solar time."
        },
        "dayofweek_itp_CO": {
          "type": "observed",
          "units": "1",
          "description": "NEI 2016 day-of-week emission scale factor for CO. Weekday=high, weekend=low. (dimensionless scale factor).",
          "expression": {
