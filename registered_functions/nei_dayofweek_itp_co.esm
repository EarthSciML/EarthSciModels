{
  "esm": "0.4.0",
  "metadata": {
    "name": "dayofweek_itp_CO",
    "description": "NEI 2016 day-of-week emission scale factor for CO. Weekday=high, weekend=low.",
    "tags": [
      "earthsci_data",
      "nei2016",
      "emissions",
      "co",
      "dayofweek",
      "registered_function"
