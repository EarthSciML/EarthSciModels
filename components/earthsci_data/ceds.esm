        "SO2_em_anthro": {
          "type": "observed",
          "units": "kg/m^2/s",
          "description": "Sulfur dioxide (SO2) anthropogenic emission flux (kg m⁻² s⁻¹) at the model grid point and current time, summed over all 8 CEDS sectors. Bilinear spatial interpolation from the 0.5°×0.5° CEDS grid; linear temporal interpolation between monthly midpoints.",
          "expression": "CEDS_SO2.SO2_em_anthro"
