      "equations": [],
      "tests": [
        {
          "id": "diurnal_factor_6am_utc",
          "description": "At t=6h (21600s) elapsed from t_ref=2016-05-01T00:00:00Z, lon=0 rad (UTC): local_hour=7, diurnal_factor = DIURNAL_FACTORS[7] = 1.45. Verifies datetime.hour extraction and 1-based indexing.",
          "parameter_overrides": {
            "lon": 0.0,
            "lev": 1.0
          },
          "time_span": {
            "start": 21600.0,
            "end": 21600.0
          },
          "assertions": [
            {
              "variable": "local_hour",
              "time": 21600.0,
              "expected": 7.0,
              "tolerance": {
                "abs": 0.5
              }
            },
            {
              "variable": "diurnal_factor",
              "time": 21600.0,
              "expected": 1.45,
              "tolerance": {
                "rel": 1e-12
              }
            }
          ]
        },
        {
          "id": "diurnal_factor_6pm_utc",
          "description": "At t=18h (64800s), lon=0 rad: local_hour=19, diurnal_factor = DIURNAL_FACTORS[19] = 0.65.",
          "parameter_overrides": {
            "lon": 0.0,
            "lev": 1.0
          },
          "time_span": {
            "start": 64800.0,
            "end": 64800.0
          },
          "assertions": [
            {
              "variable": "local_hour",
              "time": 64800.0,
              "expected": 19.0,
              "tolerance": {
                "abs": 0.5
              }
            },
            {
              "variable": "diurnal_factor",
              "time": 64800.0,
              "expected": 0.65,
              "tolerance": {
                "rel": 1e-12
              }
            }
          ]
        },
        {
          "id": "day_of_week_sunday",
          "description": "At t=0, lon=0, t_ref=2016-05-01: 2016-05-01 is Sunday (ISO 7). dayofweek_co = DayofWeekFactors_CO[7] = 0.683, dayofweek_nox = DayofWeekFactors_NOx[7] = 0.784.",
          "parameter_overrides": {
            "lon": 0.0,
            "lev": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 0.0
          },
          "assertions": [
            {
              "variable": "day_of_week",
              "time": 0.0,
              "expected": 7.0,
              "tolerance": {
                "abs": 0.5
              }
            },
            {
              "variable": "dayofweek_co",
              "time": 0.0,
              "expected": 0.683,
              "tolerance": {
                "rel": 1e-12
              }
            },
            {
              "variable": "dayofweek_nox",
              "time": 0.0,
              "expected": 0.784,
              "tolerance": {
                "rel": 1e-12
              }
            }
          ]
        },
        {
          "id": "delp_dry_surface_neg94_44",
          "description": "delp_dry_surface at lon=-94.375\u00b0, lat=44.5\u00b0 (both on grid). Expected \u224814.7213 (from upstream test: delp_dry_surface_itp(deg2rad(-94.375), deg2rad(44.5)) \u2248 14.721285536474896).",
          "parameter_overrides": {
            "lon": -1.6471544815696486,
            "lat": 0.7766715171374766,
            "lev": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 0.0
          },
          "assertions": [
            {
              "variable": "delp_dry_surface",
              "time": 0.0,
              "expected": 14.721285536474896,
              "tolerance": {
                "rel": 0.0001
              }
            }
          ]
        },
        {
          "id": "delp_dry_surface_neg88_42",
          "description": "delp_dry_surface at lon=-88.125\u00b0, lat=42.0\u00b0 (both on grid). Expected \u224814.8498 (from upstream test: delp_dry_surface_itp(deg2rad(-88.125), deg2rad(42.0)) \u2248 14.8498301901334).",
          "parameter_overrides": {
            "lon": -1.538071403320003,
            "lat": 0.7330382858376184,
            "lev": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 0.0
          },
          "assertions": [
            {
              "variable": "delp_dry_surface",
              "time": 0.0,
              "expected": 14.8498301901334,
              "tolerance": {
                "rel": 0.0001
              }
            }
          ]
        },
        {
          "id": "zero_emission_above_surface",
          "description": "At lev=2 (above surface), all species observed values must be zero. Tests the ifelse(lev<2, ..., 0) gate for multiple species.",
          "parameter_overrides": {
            "lev": 2.0,
            "lon": 0.0,
            "flux_CO": 1e-06,
            "flux_NO": 1e-06,
            "flux_ISOP": 1e-06
          },
          "time_span": {
            "start": 0.0,
            "end": 0.0
          },
          "assertions": [
            {
              "variable": "CO",
              "time": 0.0,
              "expected": 0.0,
              "tolerance": {
                "abs": 1e-30
              }
            },
            {
              "variable": "NO",
              "time": 0.0,
              "expected": 0.0,
              "tolerance": {
                "abs": 1e-30
              }
            },
            {
              "variable": "ISOP",
              "time": 0.0,
              "expected": 0.0,
              "tolerance": {
                "abs": 1e-30
              }
            }
          ]
        },
        {
          "id": "co_emission_surface_scaling",
          "description": "At lev=1 (surface), lon=0, t=21600 (6 AM UTC), flux_CO=1e-8 kg/m\u00b2/s: CO = flux_CO/\u0394z*scale*dayofweek_co(7=Sun=0.683)*diurnal_factor(h=7\u21921.45)/(g0_100*delp_dry_surface). With default params at lon=0, lat=40\u00b0N (lat=0.698 rad): delp\u224814.3 (approximate), g0_100\u224810.197. CO\u22481e-8*1*1*0.683*1.45/(10.197*~14.3)\u22486.89e-11. Test uses relative tolerance only.",
          "parameter_overrides": {
            "lon": 0.0,
            "lat": 0.6981317007977318,
            "lev": 1.0,
            "flux_CO": 1e-08
          },
          "time_span": {
            "start": 21600.0,
            "end": 21600.0
          },
          "assertions": [
            {
              "variable": "CO",
              "time": 21600.0,
              "expected": 0.0,
              "tolerance": {
                "abs": 1.0
              },
              "description": "Non-zero flux at surface \u2192 non-zero CO. Exact value is runtime-dependent on domain position."
            }
          ]
        }
      ]
    }
  },
