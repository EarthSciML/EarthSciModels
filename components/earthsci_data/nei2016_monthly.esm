        "delp_dry_surface": {
          "type": "observed",
          "units": "1",
          "description": "Dry pressure thickness (hPa, unitless) from 94\u00d749 bilinear table (lon -125..\u221266.875\u00b0, lat 25..49\u00b0). Used in flux-to-mixing-ratio conversion: mixing_ratio_rate=flux/(g0_100\u00d7delp). Typical 10\u201316 hPa.",
          "expression": {
            "op": "table_lookup",
            "table": "delp_dry_surface_table",
            "axes": {
              "lon": "lon_deg",
              "lat": "lat_deg"
            },
            "args": []
          }
        },
        "flux_ACET": {
          "type": "parameter",
