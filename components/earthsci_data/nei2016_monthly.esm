        "ACET": {
          "type": "observed",
          "units": "1/s",
          "description": "NEI2016 ACET mixing ratio source rate (1/s) at surface (lev<2). = flux_ACET/\u0394z\u00d7scale\u00d7(1 (no temporal scaling))/(g0_100\u00d7delp_dry_surface). Zero for lev\u22652.",
          "expression": {
            "op": "ifelse",
            "args": [
              {
                "op": "<",
                "args": [
                  "lev",
                  2.0
                ]
              },
              {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "flux_ACET",
                      {
                        "op": "/",
                        "args": [
                          1.0,
                          "\u0394z"
                        ]
                      },
                      "scale"
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "g0_100",
                      "delp_dry_surface"
                    ]
                  }
                ]
              },
              0.0
            ]
          }
        },
