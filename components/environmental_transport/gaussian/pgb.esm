                                                        "args": [
                                                            "sigma_z",
                                                            2.0
                                                        ]
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    "description": "Ground-level centerline Gaussian concentration per unit puff mass (m^-3). C_gl = exp(-z_agl^2/(2*sigma_z^2)) / ((2*pi)^(3/2) * sigma_h^2 * sigma_z). Maximum at z_agl=0 (puff at ground level)."
                }
            },
            "tests": [
                {
                    "id": "class_a_unstable",
                    "description": "Stability class A (very unstable): strong sun (SWGDN=950 >= 925 W/m^2) and low wind (U10M=1 m/s < v3=3 m/s) \u2192 class A. Puff at 1000 m north of source (lat=1.5696e-4 rad, lon=lon0=lat0=0). z_agl=0. Expected: stab_cls=1, sigma_h = AY_A*1000*(1+by*1000)^(-0.5) = 0.22*1000*(1.1)^(-0.5) = 209.7618 m; sigma_z = AZ_A*1000*(1+0)^(-0.5) = 200 m (BZ_A=0 \u2192 denominator 1); C_gl = exp(0)/((2pi)^(3/2)*sigma_h^2*sigma_z). Verifies class A selection, zero-BZ_A sigma_z, and C_gl formula at ground level.",
