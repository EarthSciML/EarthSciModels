                                ]
                            },
                            {
                                "op": "*",
                                "args": [
                                    {
                                        "op": "cos",
                                        "args": [
                                            "lat0"
                                        ]
                                    },
                                    {
                                        "op": "cos",
                                        "args": [
                                            "lat"
                                        ]
                                    },
                                    {
                                        "op": "^",
                                        "args": [
                                            {
                                                "op": "sin",
                                                "args": [
                                                    {
                                                        "op": "/",
                                                        "args": [
                                                            "delta_lon",
                                                            2.0
                                                        ]
                                                    }
                                                ]
                                            },
                                            2.0
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    "description": "Haversine intermediate a = sin((lat-lat0)/2)^2 + cos(lat0)*cos(lat)*sin((lon-lon0)/2)^2. In [0,1]; equals sin^2(central_angle/2)."
                },
                "hav_c": {
                    "type": "observed",
                    "units": "rad",
                    "expression": {
                        "op": "*",
                        "args": [
                            2.0,
                            {
                                "op": "atan",
                                "args": [
                                    {
                                        "op": "/",
                                        "args": [
                                            {
                                                "op": "sqrt",
                                                "args": [
                                                    "hav_a"
