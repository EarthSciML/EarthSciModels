                                                                ]
                                                            }
                                                        ]
                                                    },
                                                    4.0
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    "description": "Pasquill-Gifford stability class as floating-point integer 1.0-6.0 (A=1, B=2, C=3, D=4, E=5, F=6). Determined from SWGDN, CLDTOT, wind_speed, and dTsurf per EPA MMGRMA Table 6-7."
                },
