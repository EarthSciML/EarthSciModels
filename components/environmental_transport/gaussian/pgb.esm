                                            }
                                        ]
                                    },
                                    -0.5
                                ]
                            }
                        ]
                    },
                    "description": "Horizontal Gaussian dispersion coefficient sigma_h (m). Computed from Briggs formula sigma_h = A_y * x * (1 + B_y * x)^(-0.5)."
                },
                "sigma_z": {
                    "type": "observed",
                    "units": "m",
                    "expression": {
                        "op": "ifelse",
                        "args": [
                            {
                                "op": "and",
                                "args": [
                                    {
                                        "op": "and",
                                        "args": [
                                            {
                                                "op": "<",
