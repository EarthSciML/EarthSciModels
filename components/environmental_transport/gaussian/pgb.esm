                                ]
                            },
                            {
                                "op": "*",
                                "args": [
                                    "az",
                                    "x",
                                    {
                                        "op": "^",
                                        "args": [
                                            {
                                                "op": "+",
                                                "args": [
                                                    1.0,
                                                    {
                                                        "op": "*",
                                                        "args": [
                                                            "bz",
                                                            "x"
                                                        ]
                                                    }
                                                ]
                                            },
                                            -0.5
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    "description": "Vertical Gaussian dispersion coefficient sigma_z (m). Uses sigma_z = A_z*x*(1+B_z*x)^(-0.5) for classes A-D; sigma_z = A_z*x/(1+B_z*x) for classes E-F (stable, stronger vertical confinement)."
                },
                "C_gl": {
                    "type": "observed",
                    "units": "m^-3",
                    "expression": {
                        "op": "*",
                        "args": [
                            {
                                "op": "/",
                                "args": [
                                    1.0,
                                    {
                                        "op": "*",
                                        "args": [
                                            15.749609945722419,
                                            {
                                                "op": "^",
                                                "args": [
                                                    "sigma_h",
                                                    2.0
                                                ]
                                            },
                                            "sigma_z"
