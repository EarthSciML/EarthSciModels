                    "description": "Longitude difference lon - lon0 (radians). Intermediate for haversine downwind distance."
                },
                "delta_lat": {
                    "type": "observed",
                    "units": "rad",
                    "expression": {
                        "op": "-",
                        "args": [
                            "lat",
                            "lat0"
                        ]
                    },
                    "description": "Latitude difference lat - lat0 (radians). Intermediate for haversine downwind distance."
                },
                "hav_a": {
                    "type": "observed",
                    "expression": {
                        "op": "+",
                        "args": [
                            {
                                "op": "^",
                                "args": [
                                    {
                                        "op": "sin",
