                        }
                    ]
                }
            ],
            "examples": [
                {
                    "id": "s_iv_concentration_sweep",
                    "description": "Sweep the total dissolved S(IV) concentration over three orders of magnitude (1.0e-5 to 1.0e-2 mol/m^3, logarithmically) with both transition metals held at their 1 µM defaults. Every oxidation pathway is first-order in S(IV), so the total rate R_FeMn and the synergistic term both rise linearly with [S(IV)] — a straight line of slope 1 on log-log axes.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "S_IV_total",
                                "range": {
                                    "start": 1.0e-5,
                                    "stop": 1.0e-2,
                                    "count": 60,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "total_rate_vs_s_iv",
                            "type": "line",
                            "description": "Total S(IV) oxidation rate R_FeMn as a function of total dissolved S(IV), on log-log axes — the linear S(IV) dependence shared by all three oxidation pathways (Eq. 7.102).",
                            "x": {
                                "variable": "S_IV_total",
                                "label": "total dissolved S(IV) concentration (mol/m^3)"
                            },
                            "y": {
                                "variable": "R_FeMn",
                                "label": "total S(IV) oxidation rate R_FeMn (mol/(m^3*s))"
                            }
                        },
                        {
                            "id": "synergy_term_vs_s_iv",
                            "type": "line",
                            "description": "Fe/Mn synergistic contribution R_synergy_term as a function of total dissolved S(IV), on log-log axes. Like the other pathways it is first-order in S(IV).",
                            "x": {
                                "variable": "S_IV_total",
                                "label": "total dissolved S(IV) concentration (mol/m^3)"
                            },
                            "y": {
                                "variable": "R_synergy_term",
                                "label": "synergistic oxidation rate R_synergy_term (mol/(m^3*s))"
                            }
                        }
                    ]
                },
                {
                    "id": "manganese_loading_sweep",
                    "description": "Sweep the dissolved Mn(II) concentration over three orders of magnitude (1.0e-5 to 1.0e-2 mol/m^3, logarithmically) with Fe(III) and S(IV) held at their 1 µM defaults. Both the Mn-only term and the synergistic term are first-order in Mn(II), so both rise linearly with [Mn(II)]; the total rate R_FeMn rises from the Mn-independent Fe-only floor toward synergism-dominated values at high Mn loading.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
