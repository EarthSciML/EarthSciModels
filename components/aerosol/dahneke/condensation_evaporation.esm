            "examples": [
                {
                    "id": "fluxes_vs_droplet_radius",
                    "description": "Sweep droplet radius r from 1 nm to 100 µm (log-spaced). As r increases, both Kn_D and Kn_K decrease (∝ 1/r), so β_m and β_q increase toward 1. Simultaneously, I_M and Q_M grow linearly with r (∝ r). The product β·I_M transitions from free-molecular (∝ r⁰, rate-limited by molecular collisions) to continuum (∝ r, rate-limited by diffusion). Shows the characteristic transition-regime rollover.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "r",
                                "range": {
                                    "start": 1e-09,
                                    "stop": 0.0001,
                                    "count": 61,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "I_vs_r",
                            "type": "line",
                            "description": "Corrected molecular growth rate I vs. droplet radius r. Free-molecular limit (r ≪ ell_D ≈ 86 nm): I ∝ r² (surface area). Continuum limit (r ≫ ell_D): I ∝ r (diffusion-limited). Transition near r ≈ ell_D ≈ 86 nm.",
                            "x": {
                                "variable": "r",
                                "label": "Droplet radius r (m)"
                            },
                            "y": {
                                "variable": "I",
                                "label": "Corrected molecular growth rate I (s⁻¹)"
                            }
                        },
                        {
                            "id": "Q_vs_r",
                            "type": "line",
                            "description": "Corrected heat conduction rate Q vs. droplet radius r. Similar transition-regime behavior to I, but governed by Kn_K = 2κ/(c_bar_gas n_gas m_gas c_v r) instead of Kn_D. At default conditions Kn_K > Kn_D, so the heat correction β_q < β_m — heat transfer is more strongly suppressed than mass transfer at the same radius.",
                            "x": {
                                "variable": "r",
                                "label": "Droplet radius r (m)"
                            },
                            "y": {
                                "variable": "Q",
                                "label": "Corrected heat conduction rate Q (W)"
                            }
                        },
                        {
                            "id": "beta_corrections_vs_r",
                            "type": "line",
                            "description": "Mass and heat correction factors β_m and β_q vs. r. Both approach 1 in the continuum limit (r → ∞) and approach 0 in the free-molecular limit (r → 0). The heat correction β_q is always ≤ β_m at these default parameters because Kn_K > Kn_D (the heat Knudsen number exceeds the mass Knudsen number).",
                            "x": {
                                "variable": "r",
                                "label": "Droplet radius r (m)"
                            },
                            "y": {
                                "variable": "β_m",
                                "label": "β_m (mass correction, dimensionless)"
                            }
                        }
                    ]
                },
                {
                    "id": "mass_flux_vs_concentration",
                    "description": "Sweep vapor concentration n_inf from 0.1×10²¹ to 10×10²¹ m⁻³ at fixed r=100 nm and n_s=0. I_M = 4π r D_v n_inf is linear in n_inf; I = β_m·I_M follows the same linear dependence (β_m depends only on r, not n_inf). Confirms that the transition-regime correction is a multiplicative factor independent of the driving concentration gradient.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "n_inf",
                                "range": {
                                    "start": 1e+20,
                                    "stop": 1e+22,
                                    "count": 41,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "I_vs_n_inf",
                            "type": "line",
                            "description": "Corrected molecular flux I vs. far-field vapor concentration n_inf. Linear dependence: I = β_m × 4π r D_v × n_inf (for n_s=0). The slope is β_m × 4π r D_v — the transition-regime mass transfer coefficient.",
                            "x": {
                                "variable": "n_inf",
                                "label": "Far-field vapor concentration n_inf (m⁻³)"
                            },
                            "y": {
                                "variable": "I",
                                "label": "Corrected molecular growth rate I (s⁻¹)"
                            }
                        }
                    ]
                }
            ]
