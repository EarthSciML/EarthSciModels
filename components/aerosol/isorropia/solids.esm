      "tests": [
        {
          "id": "all_solids_conserved_at_guess_ic",
          "description": "All 19 solid molarities start at the upstream guess value 1e-20 mol/m³ (no initial_conditions override — defaults apply). D(M)/dt = 0 for every subsystem means each M is conserved at 1e-20 mol/m³ for all t. Checks a representative sample spanning NH4⁺ salts (NH42SO4, NH4NO3), Na⁺ (NaCl), Ca²⁺ (CaNO32), K⁺ (KNO3), and Mg²⁺ (MgCl2) at t = 0 and t = 1 s.",
          "time_span": {"start": 0.0, "end": 1.0},
          "assertions": [
            {"variable": "NH42SO4.M", "time": 0.0, "expected": 1e-20},
            {"variable": "NH42SO4.M", "time": 1.0, "expected": 1e-20},
            {"variable": "NH4NO3.M",  "time": 0.0, "expected": 1e-20},
            {"variable": "NH4NO3.M",  "time": 1.0, "expected": 1e-20},
            {"variable": "NaCl.M",    "time": 0.0, "expected": 1e-20},
            {"variable": "NaCl.M",    "time": 1.0, "expected": 1e-20},
            {"variable": "CaNO32.M",  "time": 0.0, "expected": 1e-20},
            {"variable": "CaNO32.M",  "time": 1.0, "expected": 1e-20},
            {"variable": "KNO3.M",    "time": 0.0, "expected": 1e-20},
            {"variable": "KNO3.M",    "time": 1.0, "expected": 1e-20},
            {"variable": "MgCl2.M",   "time": 0.0, "expected": 1e-20},
            {"variable": "MgCl2.M",   "time": 1.0, "expected": 1e-20}
          ]
        },
        {
          "id": "all_solids_at_representative_concentration",
          "description": "All 19 molarities set to 1e-7 mol/m³ (representative aerosol concentration, similar to NH in Species). D(M)/dt = 0 conserves every M at 1e-7 mol/m³. Checks NH4HSO4, LC (letovicite), NaHSO4, CaSO4, KHSO4, and MgSO4 at t = 0 and t = 1 s.",
          "time_span": {"start": 0.0, "end": 1.0},
          "initial_conditions": {"M": 1e-07},
          "assertions": [
            {"variable": "NH4HSO4.M", "time": 0.0, "expected": 1e-07},
            {"variable": "NH4HSO4.M", "time": 1.0, "expected": 1e-07},
            {"variable": "LC.M",      "time": 0.0, "expected": 1e-07},
            {"variable": "LC.M",      "time": 1.0, "expected": 1e-07},
            {"variable": "NaHSO4.M",  "time": 0.0, "expected": 1e-07},
            {"variable": "NaHSO4.M",  "time": 1.0, "expected": 1e-07},
            {"variable": "CaSO4.M",   "time": 0.0, "expected": 1e-07},
            {"variable": "CaSO4.M",   "time": 1.0, "expected": 1e-07},
            {"variable": "KHSO4.M",   "time": 0.0, "expected": 1e-07},
            {"variable": "KHSO4.M",   "time": 1.0, "expected": 1e-07},
            {"variable": "MgSO4.M",   "time": 0.0, "expected": 1e-07},
            {"variable": "MgSO4.M",   "time": 1.0, "expected": 1e-07}
          ]
        },
        {
          "id": "all_solids_at_zero_concentration",
          "description": "All 19 molarities set to 0.0 mol/m³ (no solid present). D(M)/dt = 0 keeps every M at zero. Checks NH4Cl, Na2SO4, NaNO3, CaCl2, K2SO4, KCl, and MgNO32 at t = 0 and t = 1 s. Uses absolute tolerance because expected value is exactly zero.",
          "time_span": {"start": 0.0, "end": 1.0},
          "initial_conditions": {"M": 0.0},
          "assertions": [
            {"variable": "NH4Cl.M",  "time": 0.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "NH4Cl.M",  "time": 1.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "Na2SO4.M", "time": 0.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "Na2SO4.M", "time": 1.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "NaNO3.M",  "time": 0.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "NaNO3.M",  "time": 1.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "CaCl2.M",  "time": 0.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "CaCl2.M",  "time": 1.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "K2SO4.M",  "time": 0.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "K2SO4.M",  "time": 1.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "KCl.M",    "time": 0.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "KCl.M",    "time": 1.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "MgNO32.M", "time": 0.0, "expected": 0.0, "tolerance": {"abs": 1e-20}},
            {"variable": "MgNO32.M", "time": 1.0, "expected": 0.0, "tolerance": {"abs": 1e-20}}
          ]
        },
        {
          "id": "independence_nh4no3_unit_rest_guess",
          "description": "Verify subsystem independence: NH4NO3.M set to 1.0 mol/m³ while all other solids use the guess default (1e-20 mol/m³). D(M)/dt = 0 is uncoupled across subsystems, so NH4NO3.M must stay at 1.0 and CaNO32.M must stay at 1e-20. Demonstrates that the 19 ODEs evolve independently.",
          "time_span": {"start": 0.0, "end": 1.0},
          "initial_conditions": {
            "Solids.NH4NO3.M": 1.0,
            "M": 1e-20
          },
          "assertions": [
            {"variable": "NH4NO3.M", "time": 0.0, "expected": 1.0},
            {"variable": "NH4NO3.M", "time": 1.0, "expected": 1.0},
            {"variable": "CaNO32.M", "time": 0.0, "expected": 1e-20},
            {"variable": "CaNO32.M", "time": 1.0, "expected": 1e-20},
            {"variable": "MgCl2.M",  "time": 1.0, "expected": 1e-20}
          ]
        }
      ],
      "examples": [
        {
          "id": "nh4no3_molarity_conserved_over_time",
          "description": "Time evolution of NH4NO3 (ammonium nitrate) molarity from t = 0 to 100 s, starting at the guess value 1e-20 mol/m³. Because D(M)/dt = 0, the trajectory is a flat line at 1e-20 mol/m³. Illustrates the conserved-tracer behaviour of a single solid in the standalone Solids container.",
          "initial_state": {
            "type": "per_variable",
            "values": {}
          },
          "time_span": {"start": 0.0, "end": 100.0},
          "plots": [
            {
              "id": "nh4no3_vs_time",
              "type": "line",
              "description": "NH4NO3 molarity M (mol/m³) versus time. Flat at 1e-20 mol/m³, confirming D(M)/dt = 0.",
              "x": {"variable": "t",        "label": "Time (s)"},
              "y": {"variable": "NH4NO3.M", "label": "NH4NO3 molarity M (mol/m³)"}
            }
          ]
        },
        {
          "id": "cano32_molarity_conserved_over_time",
          "description": "Time evolution of CaNO32 (calcium nitrate) molarity from t = 0 to 100 s, starting at 1e-20 mol/m³. Flat trajectory confirms D(M)/dt = 0 and that the Ca²⁺ salt subsystem is independent of the NH₄⁺ salts.",
          "initial_state": {
            "type": "per_variable",
            "values": {}
          },
          "time_span": {"start": 0.0, "end": 100.0},
          "plots": [
            {
              "id": "cano32_vs_time",
              "type": "line",
              "description": "CaNO32 molarity M (mol/m³) versus time. Flat at 1e-20 mol/m³, confirming D(M)/dt = 0.",
              "x": {"variable": "t",        "label": "Time (s)"},
              "y": {"variable": "CaNO32.M", "label": "CaNO32 molarity M (mol/m³)"}
            }
          ]
        }
      ]
    }
