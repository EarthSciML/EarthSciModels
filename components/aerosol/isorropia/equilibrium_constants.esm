            "tests": [
                {
                    "id": "identity_at_T0",
                    "description": "At T=T0=298.15 K the two correction terms in Eq. 5 vanish, so ri.logK_eq=ri.logK0 for all 27 reactions. Verifies coupling and all logK0 defaults.",
                    "parameter_overrides": {
                        "T": 298.15
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "EquilibriumConstants.r1.logK_eq",
                            "time": 0.0,
