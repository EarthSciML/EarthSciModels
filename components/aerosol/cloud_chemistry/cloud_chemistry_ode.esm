            ],
            "tests": [
                {
                    "id": "standard_conditions_pH4_298K",
                    "description": "Standard cloud conditions: T=298.15K, pH=4, p_SO2=p_H2O2=1ppb, p_O3=50ppb, Fe_III=1e-6, Mn_II=1e-7 mol/m\u00b3, L=0.5 g/m\u00b3, xi_SO2=1ppb. Verifies all equilibrium concentrations, oxidation rates, and SO4 accumulation. All inputs constant \u2192 R_total constant \u2192 SO4_2minus(t) = R_total * t exactly. Tolerance rationale (rel=1e-4): covers float64 roundoff in van't Hoff exp chains and H2O2 dissolution; exact for SO4 linear accumulation.",
                    "time_span": {
                        "start": 0.0,
                        "end": 3600.0
                    },
                    "tolerance": {
                        "rel": 0.0001
                    },
                    "assertions": [
                        {
                            "variable": "H_plus",
