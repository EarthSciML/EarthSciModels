                {
                    "id": "sulfate_accumulation_linear",
                    "description": "With constant inputs, R_total is constant, so SO4_2minus(t) = R_total * t exactly (linear ODE). Verifies ODE integration correctness by checking SO4 at multiple times against the exact analytical solution.",
                    "time_span": {
                        "start": 0.0,
                        "end": 7200.0
                    },
                    "tolerance": {
                        "rel": 0.0001
                    },
                    "assertions": [
