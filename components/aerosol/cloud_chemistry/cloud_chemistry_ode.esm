                            "time": 0.0,
                            "expected": 0.00023548295179912852,
                            "tolerance": {
                                "rel": 0.0001
                            }
                        },
                        {
                            "variable": "R_total",
                            "time": 0.0,
                            "expected": 0.00550230379046323,
                            "tolerance": {
                                "rel": 0.0001
                            }
                        }
                    ]
                },
                {
                    "id": "no_metal_catalysts",
                    "description": "Fe_III=Mn_II=0: disables the metal-catalyzed Fe/Mn synergism pathway. R_FeMn terms (R_Mn_term, R_Fe_term, R_synergy_term) must all be zero. Verifies that R_total = R_O3 + R_H2O2 (only two pathways active).",
                    "time_span": {
