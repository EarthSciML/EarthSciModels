                {
                    "id": "cold_cloud_higher_solubility",
                    "description": "T=273.15K (0\u00b0C cloud): negative dissolution enthalpies mean all three gases are more soluble at lower T. At T=273K: H_SO2 \u2248 2.6\u00d7, H_H2O2 \u2248 9.4\u00d7, H_O3 \u2248 2.2\u00d7 larger than at 298K \u2014 verified via assertions. This confirms the van't Hoff temperature dependence direction for all three gases.",
                    "time_span": {
                        "start": 0.0,
                        "end": 100.0
                    },
                    "parameter_overrides": {
                        "T": 273.15
                    },
                    "tolerance": {
                        "rel": 0.0001
                    },
                    "assertions": [
