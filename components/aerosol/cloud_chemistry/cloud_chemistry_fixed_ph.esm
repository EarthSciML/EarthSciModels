              "units": "mol/m^3",
              "description": "Total dissolved inorganic carbon (CO2_aq + HCO3- + CO3^2-)"
            },
            "H_CO2_eff": {
              "type": "state",
              "units": "mol/m^3/Pa",
              "description": "Effective Henry's law constant for CO2 (S&P Eq 7.24)"
            }
          },
          "equations": [
            {
              "lhs": "H_CO2",
              "rhs": {
                "op": "*",
