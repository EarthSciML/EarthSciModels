              "lhs": "HNO3_total",
              "rhs": {
                "op": "+",
                "args": [
                  "HNO3_aq",
                  "NO3_minus"
                ]
              }
            },
            {
              "lhs": "H_HNO3_eff",
              "rhs": {
                "op": "*",
                "args": [
                  "H_HNO3",
                  {
                    "op": "+",
                    "args": [
                      1,
                      {
                        "op": "/",
                        "args": [
                          "K_n1",
                          "H_plus"
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        },
        "h2o2_eq": {
          "variables": {
            "T": {
              "type": "state",
              "units": "K",
              "default": 298.15,
              "description": "Temperature (driven by coupling from parent T)."
            },
            "H_plus": {
              "type": "state",
              "units": "mol/m^3",
              "default": 0.1,
              "description": "Hydrogen ion concentration (driven by parent H_plus coupling)."
            },
            "p_H2O2": {
              "type": "state",
              "units": "Pa",
              "default": 0.000101325,
              "description": "Partial pressure of H2O2 (driven by parent p_H2O2 coupling)."
            },
            "R_gas": {
              "type": "parameter",
              "units": "J/mol/K",
              "default": 8.314,
              "description": "Gas constant (S&P Ch.7, upstream @constants)."
            },
            "T_ref": {
              "type": "parameter",
              "units": "K",
              "default": 298.0,
              "description": "Reference temperature for van't Hoff equation."
            },
            "H_H2O2_298": {
              "type": "parameter",
              "units": "mol/m^3/Pa",
              "default": 986.923267,
              "description": "Henry's law constant for H2O2 at 298 K (1.0e5 M/atm \u00d7 1000/101325, SI). Upstream @constants."
            },
            "dH_H_H2O2": {
              "type": "parameter",
              "units": "J/mol",
              "default": -60668.0,
              "description": "Heat of dissolution for H2O2 (-14.5 kcal/mol \u00d7 4184 J/kcal). Upstream @constants."
            },
            "K_h1_298": {
              "type": "parameter",
              "units": "mol/m^3",
              "default": 2.2e-09,
              "description": "H2O2 dissociation constant at 298 K (2.2e-12 M \u00d7 1000). Very weak acid. Upstream @constants."
            },
            "H_H2O2": {
              "type": "state",
              "units": "mol/m^3/Pa",
              "description": "Henry's law constant for H2O2 at temperature T."
            },
            "K_h1": {
              "type": "state",
              "units": "mol/m^3",
              "description": "H2O2 dissociation constant (effectively constant = K_h1_298)."
            },
            "H2O2_aq": {
              "type": "state",
              "units": "mol/m^3",
              "description": "Aqueous H2O2 concentration [H2O2(aq)]."
            },
            "HO2_minus": {
              "type": "state",
              "units": "mol/m^3",
              "description": "Hydroperoxide anion concentration [HO2-]. Very small due to weak dissociation."
            },
            "H2O2_total": {
              "type": "state",
              "units": "mol/m^3",
              "description": "Total dissolved hydrogen peroxide."
            },
            "H_H2O2_eff": {
              "type": "state",
              "units": "mol/m^3/Pa",
              "description": "Effective Henry's law constant for H2O2."
            }
          },
          "equations": [
            {
              "lhs": "H_H2O2",
              "rhs": {
                "op": "*",
                "args": [
                  "H_H2O2_298",
                  {
                    "op": "exp",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "/",
                            "args": [
                              "dH_H_H2O2",
                              "R_gas"
                            ]
                          },
                          {
                            "op": "+",
                            "args": [
                              {
                                "op": "/",
                                "args": [
                                  1,
                                  "T_ref"
                                ]
                              },
                              {
                                "op": "/",
                                "args": [
                                  -1,
                                  "T"
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "K_h1",
              "rhs": "K_h1_298"
            },
            {
              "lhs": "H2O2_aq",
              "rhs": {
                "op": "*",
                "args": [
                  "H_H2O2",
                  "p_H2O2"
                ]
              }
            },
            {
              "lhs": "HO2_minus",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "K_h1",
                      "H2O2_aq"
                    ]
                  },
                  "H_plus"
                ]
              }
            },
            {
              "lhs": "H2O2_total",
              "rhs": {
                "op": "+",
                "args": [
                  "H2O2_aq",
                  "HO2_minus"
                ]
              }
            },
            {
              "lhs": "H_H2O2_eff",
              "rhs": {
                "op": "*",
                "args": [
                  "H_H2O2",
                  {
                    "op": "+",
                    "args": [
                      1,
                      {
                        "op": "/",
                        "args": [
                          "K_h1",
                          "H_plus"
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        },
        "o3_eq": {
          "variables": {
            "T": {
              "type": "state",
              "units": "K",
              "default": 298.15,
              "description": "Temperature"
            },
            "p_O3": {
              "type": "state",
              "units": "Pa",
              "default": 0.005066,
              "description": "Partial pressure of O3 (default \u2248 40 ppb at 1 atm)"
            },
            "R_gas": {
              "type": "parameter",
              "units": "J/mol/K",
              "default": 8.314,
              "description": "Gas constant"
            },
            "T_ref": {
              "type": "parameter",
              "units": "K",
              "default": 298.0,
              "description": "Reference temperature"
            },
            "H_O3_298": {
              "type": "parameter",
              "units": "mol/m^3/Pa",
              "default": 0.0001085615593387614,
              "description": "Henry's law constant for O3 at 298 K (1.1e-2 M/atm converted to mol/(m\u00b3\u00b7Pa))"
            },
            "dH_H_O3": {
              "type": "parameter",
              "units": "J/mol",
              "default": -21087.36,
              "description": "Heat of dissolution for O3 (\u22125.04 kcal/mol; S&P Table 7.3)"
            },
            "H_O3": {
              "type": "state",
              "units": "mol/m^3/Pa",
              "description": "Temperature-dependent Henry's law constant for O3"
            },
            "O3_aq": {
              "type": "state",
              "units": "mol/m^3",
              "description": "Aqueous O3 concentration (Henry's law: O3_aq = H_O3 \u00d7 p_O3)"
            }
          },
          "equations": [
            {
              "lhs": "H_O3",
              "rhs": {
                "op": "*",
                "args": [
                  "H_O3_298",
                  {
                    "op": "exp",
                    "args": [
                      {
                        "op": "/",
                        "args": [
                          {
                            "op": "*",
