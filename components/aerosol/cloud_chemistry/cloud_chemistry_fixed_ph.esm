            },
            {
              "lhs": "CO2_aq",
              "rhs": {
                "op": "*",
                "args": [
                  "H_CO2",
                  "p_CO2"
                ]
              }
            },
            {
              "lhs": "HCO3_minus",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "K_c1",
                      "CO2_aq"
                    ]
                  },
                  "H_plus"
                ]
              }
            },
            {
              "lhs": "CO3_2minus",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "K_c2",
                      "HCO3_minus"
                    ]
                  },
                  "H_plus"
                ]
              }
            },
            {
              "lhs": "C_total",
              "rhs": {
                "op": "+",
                "args": [
                  "CO2_aq",
                  "HCO3_minus",
                  "CO3_2minus"
                ]
              }
            },
            {
              "lhs": "H_CO2_eff",
              "rhs": {
                "op": "*",
                "args": [
                  "H_CO2",
                  {
