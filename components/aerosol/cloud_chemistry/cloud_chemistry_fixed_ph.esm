                  "p_O3"
                ]
              }
            }
          ]
        },
        "sulfate": {
          "variables": {
            "R_gas": {
              "type": "parameter",
              "units": "J/mol/K",
              "default": 8.31446,
              "description": "Universal gas constant \u2014 used in the Section 7.4 rate-conversion equations (Eqs. 7.75-7.78). Upstream MTK `@constants` value 8.31446 J/mol/K."
            },
            "p_total": {
              "type": "parameter",
              "units": "Pa",
              "default": 101325.0,
              "description": "Total (standard atmospheric) pressure used in the rate-conversion equations. Upstream MTK `@constants` value 101325.0 Pa = 1 atm."
            },
            "rho_w_inv": {
              "type": "parameter",
              "units": "m^3/g",
              "default": 1e-06,
              "description": "Inverse density of liquid water \u2014 converts liquid water content L (g/m^3) to the dimensionless liquid water volume ratio w_L. Upstream MTK `@constants` value 1.0e-6 m^3/g (= 1/(1e6 g/m^3))."
            },
            "s_per_hr": {
              "type": "parameter",
              "units": "s",
              "default": 3600.0,
              "description": "Seconds-per-hour conversion factor for expressing the oxidation rate per hour (Eqs. 7.75-7.76). Upstream MTK `@constants` value 3600.0 s."
            },
            "ppb_factor": {
              "type": "parameter",
              "units": "1",
              "default": 1000000000.0,
              "description": "Parts-per-billion scaling factor for the ppb/hr rate conversion (Eq. 7.75). Dimensionless. Upstream MTK `@constants` value 1.0e9."
            },
            "pct_factor": {
              "type": "parameter",
              "units": "1",
              "default": 100.0,
              "description": "Percent scaling factor for the %/hr rate conversion (Eq. 7.76). Dimensionless. Upstream MTK `@constants` value 100.0."
            },
            "L": {
              "type": "parameter",
              "units": "g/m^3",
              "default": 0.5,
              "description": "Cloud/fog liquid water content \u2014 mass of liquid water per unit volume of air. Default 0.5 g/m^3, a representative cloud value (clouds span ~0.1-1 g/m^3). Sets the liquid water volume ratio w_L = rho_w_inv*L. Upstream `@parameters` (no upstream default; authored here)."
            },
            "xi_SO2": {
              "type": "parameter",
              "units": "1",
              "default": 1e-09,
              "description": "Gas-phase SO2 mixing ratio (dimensionless mole fraction). Default 1.0e-9 (1 ppb). Appears in the %/hr conversion (Eq. 7.76) and the SO2 lifetime (Eq. 7.78). Upstream `@parameters` (no upstream default; authored here)."
            },
            "T": {
              "type": "state",
              "units": "K",
              "default": 298.15,
              "description": "Air/cloud temperature \u2014 feeds the Section 7.4 rate-conversion equations (Eqs. 7.75-7.78). Default 298.15 K. A pure model input (an upstream `@variable` with no defining equation); migrated as a parameter."
            },
            "H_plus": {
              "type": "state",
              "units": "mol/m^3",
              "default": 0.1,
              "description": "Hydrogen-ion concentration [H+] of the cloud droplet, setting its pH. Default 0.1 mol/m^3 (1e-4 M, pH 4). Coupled into the h2o2_ox and fe_ox subsystems. A pure model input; migrated as a parameter."
            },
            "SO2_aq": {
              "type": "state",
              "units": "mol/m^3",
              "default": 1e-05,
              "description": "Aqueous un-ionized sulfur-dioxide concentration [SO2.H2O]. Default 1.0e-5 mol/m^3. Coupled into the o3_ox subsystem. A pure model input; migrated as a parameter."
            },
            "HSO3_minus": {
              "type": "state",
              "units": "mol/m^3",
              "default": 0.001,
              "description": "Bisulfite-ion concentration [HSO3-] \u2014 the dominant dissolved-S(IV) species at cloud pH. Default 1.0e-3 mol/m^3. Coupled into BOTH the o3_ox and h2o2_ox subsystems. A pure model input; migrated as a parameter."
            },
            "SO3_2minus": {
              "type": "state",
              "units": "mol/m^3",
              "default": 1e-06,
              "description": "Sulfite-ion concentration [SO3^2-] \u2014 a trace species, most reactive toward ozone. Default 1.0e-6 mol/m^3. Coupled into the o3_ox subsystem. A pure model input; migrated as a parameter."
            },
            "S_IV_total": {
              "type": "state",
              "units": "mol/m^3",
              "default": 0.001,
              "description": "Total dissolved S(IV) concentration ([SO2.H2O] + [HSO3-] + [SO3^2-]) \u2014 the substrate for the metal-catalyzed pathways. Default 1.0e-3 mol/m^3. Coupled into the fe_ox, mn_ox and femn_ox subsystems. A pure model input; migrated as a parameter."
            },
            "O3_aq": {
              "type": "state",
              "units": "mol/m^3",
              "default": 1e-06,
              "description": "Dissolved (aqueous-phase) ozone concentration [O3(aq)] \u2014 the oxidant of the O3 pathway. Default 1.0e-6 mol/m^3. Coupled into the o3_ox subsystem. A pure model input; migrated as a parameter."
            },
            "H2O2_aq": {
              "type": "state",
              "units": "mol/m^3",
              "default": 0.0001,
              "description": "Aqueous-phase hydrogen-peroxide concentration [H2O2(aq)] \u2014 the oxidant of the H2O2 pathway. Default 1.0e-4 mol/m^3. Coupled into the h2o2_ox subsystem. A pure model input; migrated as a parameter."
            },
            "Fe_III": {
              "type": "state",
              "units": "mol/m^3",
              "default": 0.001,
              "description": "Dissolved Fe(III) concentration \u2014 the catalyst of the Fe pathway. Default 1.0e-3 mol/m^3. Coupled into the fe_ox and femn_ox subsystems. A pure model input; migrated as a parameter."
            },
            "Mn_II": {
              "type": "state",
              "units": "mol/m^3",
              "default": 0.001,
              "description": "Dissolved Mn(II) concentration \u2014 the catalyst of the Mn pathway. Default 1.0e-3 mol/m^3. Coupled into the mn_ox and femn_ox subsystems. A pure model input; migrated as a parameter."
            },
            "R_total": {
              "type": "state",
              "units": "mol/m^3/s",
              "description": "Total aqueous S(IV)->S(VI) oxidation rate \u2014 the sum of the O3, H2O2 and Fe/Mn-synergism pathway rates: R_total = o3_ox.R_O3 + h2o2_ox.R_H2O2 + femn_ox.R_FeMn. The Fe/Mn synergism subsystem (femn_ox) already carries the Fe-only and Mn-only terms, so the standalone fe_ox.R_Fe and mn_ox.R_Mn rates are deliberately EXCLUDED from the sum to avoid double-counting (upstream comment at sulfate_formation.jl)."
            },
            "S_VI_production": {
              "type": "state",
              "units": "mol/m^3/s",
              "description": "Sulfate (S(VI)) production rate \u2014 equal to the total S(IV) oxidation rate R_total (every S(IV) oxidized becomes S(VI))."
            },
            "w_L": {
              "type": "state",
              "units": "1",
              "description": "Liquid water volume ratio (dimensionless) \u2014 volume of cloud liquid water per unit volume of air, w_L = rho_w_inv*L."
            },
            "R_ppb_hr": {
              "type": "state",
              "units": "1",
              "description": "Total oxidation rate expressed as an SO2 mixing-ratio loss rate in ppb per hour (Eq. 7.75): R_ppb_hr = 1e9 * 3600 * w_L * R_gas * T * R_total / p_total."
            },
            "R_percent_hr": {
              "type": "state",
              "units": "1",
              "description": "Total oxidation rate expressed as the percentage of the SO2 burden converted per hour (Eq. 7.76): R_percent_hr = 100 * 3600 * R_total * w_L * R_gas * T / (p_total * xi_SO2)."
            },
            "tau_SO2": {
              "type": "state",
              "units": "s",
              "description": "SO2 lifetime against aqueous-phase oxidation (Eq. 7.78) \u2014 the e-folding time for gas-phase SO2 removal by in-cloud S(IV) oxidation: tau_SO2 = xi_SO2 * p_total / (w_L * R_gas * T * R_total)."
            }
          },
          "subsystems": {
            "o3_ox": {
              "variables": {
                "k0": {
                  "type": "parameter",
                  "units": "m^3/mol/s",
                  "default": 24.0,
                  "description": "Rate constant for the SO2.H2O + O3 oxidation channel (Eq. 7.79). Upstream MTK `@constants` value 2.4e4/1000.0 = 24.0 \u2014 the literature rate constant 2.4e4 M^-1 s^-1 (module constant K0_O3) converted to SI (1 M^-1 = 1e-3 m^3/mol). Mirrors o3.esm."
                },
                "k1": {
                  "type": "parameter",
                  "units": "m^3/mol/s",
                  "default": 370.0,
                  "description": "Rate constant for the HSO3- + O3 oxidation channel (Eq. 7.79). Upstream MTK `@constants` value 3.7e5/1000.0 = 370.0 \u2014 the literature rate constant 3.7e5 M^-1 s^-1 (K1_O3) converted to SI. Mirrors o3.esm."
                },
                "k2": {
                  "type": "parameter",
                  "units": "m^3/mol/s",
                  "default": 1500000.0,
                  "description": "Rate constant for the SO3^2- + O3 oxidation channel (Eq. 7.79). Upstream MTK `@constants` value 1.5e9/1000.0 = 1500000.0 \u2014 the literature rate constant 1.5e9 M^-1 s^-1 (K2_O3) converted to SI; by far the largest of the three, so the O3 channel accelerates sharply as rising droplet pH shifts S(IV) speciation toward sulfite. Mirrors o3.esm."
                },
                "SO2_aq": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 1e-05,
                  "description": "Aqueous un-ionized sulfur-dioxide concentration [SO2.H2O] in the cloud droplet. In the composed model this subsystem input is driven by the coupling equation SulfateFormation.o3_ox.SO2_aq ~ SO2_aq; re-typed parameter -> state (a parameter cannot be an equation LHS). Default 1.0e-5 mol/m^3 seeds the algebraic solve."
                },
                "HSO3_minus": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Bisulfite-ion concentration [HSO3-] in the cloud droplet \u2014 the dominant dissolved-S(IV) species at cloud pH ~4-5. Driven by SulfateFormation.o3_ox.HSO3_minus ~ HSO3_minus; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "SO3_2minus": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 1e-06,
                  "description": "Sulfite-ion concentration [SO3^2-] in the cloud droplet \u2014 a trace species at cloud pH but the most reactive toward ozone. Driven by SulfateFormation.o3_ox.SO3_2minus ~ SO3_2minus; re-typed parameter -> state. Default 1.0e-6 mol/m^3."
                },
                "O3_aq": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 1e-06,
                  "description": "Dissolved (aqueous-phase) ozone concentration [O3(aq)] \u2014 the oxidant. Driven by SulfateFormation.o3_ox.O3_aq ~ O3_aq; re-typed parameter -> state. Default 1.0e-6 mol/m^3."
                },
                "R_O3": {
                  "type": "state",
                  "units": "mol/m^3/s",
                  "description": "S(IV)->S(VI) oxidation rate by the O3 pathway (Eqs. 7.79-7.80): R_O3 = (k0*[SO2.H2O] + k1*[HSO3-] + k2*[SO3^2-])*[O3(aq)]. One of the principal in-cloud sulfate-formation routes, dominant at elevated droplet pH."
                }
              },
              "equations": [
                {
                  "_comment": "Eqs. 7.79-7.80 \u2014 total aqueous S(IV)+O3 oxidation rate summed over the three dissolved-S(IV) species. Inlined from o3.esm (SulfateFormationO3).",
                  "lhs": "R_O3",
                  "rhs": {
                    "op": "*",
                    "args": [
                      {
                        "op": "+",
                        "args": [
                          {
                            "op": "*",
                            "args": [
                              "k0",
                              "SO2_aq"
                            ]
                          },
                          {
                            "op": "*",
                            "args": [
                              "k1",
                              "HSO3_minus"
                            ]
                          },
                          {
                            "op": "*",
                            "args": [
                              "k2",
                              "SO3_2minus"
                            ]
                          }
                        ]
                      },
                      "O3_aq"
                    ]
                  }
                }
              ]
            },
            "h2o2_ox": {
              "variables": {
                "k": {
                  "type": "parameter",
                  "units": "m^6/mol^2/s",
                  "default": 75.0,
                  "description": "Rate constant for the S(IV)+H2O2 oxidation pathway (Eq. 7.84). Upstream MTK `@constants` value 7.5e7/1.0e6 = 75.0 \u2014 the literature rate constant 7.5e7 M^-2 s^-1 converted to SI (1 M^-2 = 1e-6 (mol/m^3)^-2). Mirrors h2o2.esm."
                },
                "K_eq": {
                  "type": "parameter",
                  "units": "m^3/mol",
                  "default": 0.013,
                  "description": "Equilibrium constant in the Eq. 7.84 rate-law denominator \u2014 the term 1 + K_eq*[H+] saturates the acid-catalysed rate at high acidity. Upstream MTK `@constants` value 13.0/1000.0 = 0.013 \u2014 the literature constant 13 M^-1 converted to SI. Mirrors h2o2.esm."
                },
                "H_plus": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.1,
                  "description": "Hydrogen-ion concentration [H+] of the cloud droplet. Driven by SulfateFormation.h2o2_ox.H_plus ~ H_plus; re-typed parameter -> state. Default 0.1 mol/m^3 (1e-4 M, pH 4)."
                },
                "H2O2_aq": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.0001,
                  "description": "Aqueous-phase hydrogen-peroxide concentration [H2O2(aq)] in the cloud droplet. Driven by SulfateFormation.h2o2_ox.H2O2_aq ~ H2O2_aq; re-typed parameter -> state. Default 1.0e-4 mol/m^3."
                },
                "HSO3_minus": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Bisulfite-ion concentration [HSO3-] \u2014 the limiting reactant for this pathway. Driven by SulfateFormation.h2o2_ox.HSO3_minus ~ HSO3_minus; re-typed parameter -> state. Default 1.0e-3 mol/m^3. Shares the top-level HSO3_minus input with the o3_ox subsystem."
                },
                "R_H2O2": {
                  "type": "state",
                  "units": "mol/m^3/s",
                  "description": "S(IV)->S(VI) oxidation rate by the H2O2 pathway (Eq. 7.84): R_H2O2 = k*[H+]*[H2O2]*[HSO3-]/(1+K_eq*[H+]). The dominant aqueous sulfate-formation pathway at low pH, where the competing O3 pathway is slow."
                }
              },
              "equations": [
                {
                  "_comment": "Eq. 7.84 \u2014 aqueous S(IV)+H2O2 oxidation rate. Inlined from h2o2.esm (SulfateFormationH2O2).",
                  "lhs": "R_H2O2",
                  "rhs": {
                    "op": "/",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          "k",
                          "H_plus",
                          "H2O2_aq",
                          "HSO3_minus"
                        ]
                      },
                      {
                        "op": "+",
                        "args": [
                          1,
                          {
                            "op": "*",
                            "args": [
                              "K_eq",
                              "H_plus"
                            ]
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            "fe_ox": {
              "variables": {
                "k_low_pH": {
                  "type": "parameter",
                  "units": "s^-1",
                  "default": 6.0,
                  "description": "Rate constant for the Fe(III)-catalyzed S(IV) oxidation in the low-pH regime (pH 0-3.6), Eq. 7.92. Upstream MTK `@constants` value 6.0 s^-1. Mirrors fe.esm."
                },
                "H_plus": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.1,
                  "description": "Hydrogen-ion concentration [H+] of the cloud droplet. Driven by SulfateFormation.fe_ox.H_plus ~ H_plus; re-typed parameter -> state. Default 0.1 mol/m^3."
                },
                "Fe_III": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Dissolved Fe(III) concentration \u2014 the catalyst of this oxidation pathway. Driven by SulfateFormation.fe_ox.Fe_III ~ Fe_III; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "S_IV_total": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Total dissolved S(IV) concentration \u2014 the substrate oxidized to S(VI). Driven by SulfateFormation.fe_ox.S_IV_total ~ S_IV_total; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "R_Fe": {
                  "type": "state",
                  "units": "mol/m^3/s",
                  "description": "S(IV)->S(VI) oxidation rate by Fe(III)-catalyzed dissolved O2 (Eq. 7.92, low-pH regime): R_Fe = k_low_pH*[Fe(III)]*[S(IV)]/[H+]. NOTE: this standalone Fe-only rate is NOT summed into the model's R_total \u2014 the femn_ox subsystem already carries an Fe-only term, and using femn_ox avoids double-counting. fe_ox is retained for diagnostic comparison. Migrated equations-form (type: state + equation), not the observed-form used by the standalone fe.esm, because a composed model carries its relations as equations."
                }
              },
              "equations": [
                {
                  "_comment": "Eq. 7.92 \u2014 Fe(III)-catalyzed S(IV) oxidation rate (low-pH regime). Inlined from fe.esm (SulfateFormationFe), with the output re-expressed in equations-form.",
                  "lhs": "R_Fe",
                  "rhs": {
                    "op": "/",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          "k_low_pH",
                          "Fe_III",
                          "S_IV_total"
                        ]
                      },
                      "H_plus"
                    ]
                  }
                }
              ]
            },
            "mn_ox": {
              "variables": {
                "k0": {
                  "type": "parameter",
                  "units": "m^3/mol/s",
                  "default": 1.0,
                  "description": "Rate constant for the low-S(IV)-regime Mn(II)-catalyzed S(IV) oxidation (Eq. 7.101). Upstream MTK `@constants` value 1000.0/1000.0 = 1.0 \u2014 the literature value 1000 M^-1 s^-1 converted to SI. Mirrors mn.esm."
                },
                "Mn_II": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Dissolved Mn(II) concentration \u2014 the transition-metal catalyst. Driven by SulfateFormation.mn_ox.Mn_II ~ Mn_II; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "S_IV_total": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Total dissolved S(IV) concentration. Driven by SulfateFormation.mn_ox.S_IV_total ~ S_IV_total; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "R_Mn": {
                  "type": "state",
                  "units": "mol/m^3/s",
                  "description": "S(IV)->S(VI) oxidation rate by the Mn(II)-catalyzed O2 pathway (Eq. 7.101): R_Mn = k0*[Mn(II)]*[S(IV)]. NOTE: this standalone Mn-only rate is NOT summed into R_total \u2014 femn_ox already carries an Mn-only term. mn_ox is retained for diagnostic comparison. Migrated equations-form (type: state + equation), not the observed-form used by the standalone mn.esm."
                }
              },
              "equations": [
                {
                  "_comment": "Eq. 7.101 \u2014 Mn(II)-catalyzed S(IV) oxidation rate (low-S(IV) regime). Inlined from mn.esm (SulfateFormationMn), with the output re-expressed in equations-form.",
                  "lhs": "R_Mn",
                  "rhs": {
                    "op": "*",
                    "args": [
                      "k0",
                      "Mn_II",
                      "S_IV_total"
                    ]
                  }
                }
              ]
            },
            "femn_ox": {
              "variables": {
                "k_Mn": {
                  "type": "parameter",
                  "units": "m^3/mol/s",
                  "default": 0.75,
                  "description": "Rate constant for the Mn-only term of the Fe/Mn synergism rate law (Eq. 7.102). Upstream MTK `@constants` value 750.0/1000.0 = 0.75 \u2014 the literature value 750 M^-1 s^-1 converted to SI."
                },
                "k_Fe": {
                  "type": "parameter",
                  "units": "m^3/mol/s",
                  "default": 2.6,
                  "description": "Rate constant for the Fe-only term of the Fe/Mn synergism rate law (Eq. 7.102). Upstream MTK `@constants` value 2600.0/1000.0 = 2.6 \u2014 the literature value 2600 M^-1 s^-1 converted to SI."
                },
                "k_FeMn": {
                  "type": "parameter",
                  "units": "m^6/mol^2/s",
                  "default": 10000.0,
                  "description": "Rate constant for the synergistic Fe.Mn term of the Fe/Mn synergism rate law (Eq. 7.102). Upstream MTK `@constants` value 1.0e10/1.0e6 = 10000.0 \u2014 the literature value 1.0e10 M^-2 s^-1 converted to SI (1 M^-2 = 1e-6 (mol/m^3)^-2). The large coefficient represents the greatly enhanced oxidation when both Fe(III) and Mn(II) are present."
                },
                "Mn_II": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Dissolved Mn(II) concentration. Driven by SulfateFormation.femn_ox.Mn_II ~ Mn_II; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "Fe_III": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Dissolved Fe(III) concentration. Driven by SulfateFormation.femn_ox.Fe_III ~ Fe_III; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "S_IV_total": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Total dissolved S(IV) concentration. Driven by SulfateFormation.femn_ox.S_IV_total ~ S_IV_total; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "R_Mn_term": {
                  "type": "state",
                  "units": "mol/m^3/s",
                  "description": "Mn-only contribution to the Fe/Mn synergism rate (Eq. 7.102): k_Mn*[Mn(II)]*[S(IV)]."
                },
                "R_Fe_term": {
                  "type": "state",
                  "units": "mol/m^3/s",
                  "description": "Fe-only contribution to the Fe/Mn synergism rate (Eq. 7.102): k_Fe*[Fe(III)]*[S(IV)]."
                },
                "R_synergy_term": {
                  "type": "state",
                  "units": "mol/m^3/s",
                  "description": "Synergistic contribution to the Fe/Mn rate (Eq. 7.102): k_FeMn*[Mn(II)]*[Fe(III)]*[S(IV)]. The greatly enhanced channel that operates only when both transition metals are present; typically the largest of the three terms."
                },
                "R_FeMn": {
                  "type": "state",
                  "units": "mol/m^3/s",
                  "description": "Total S(IV)->S(VI) oxidation rate with Fe/Mn synergism (Eq. 7.102): the sum of the Mn-only, Fe-only and synergistic terms. This is the Fe/Mn term used in the model's R_total (replacing the standalone fe_ox/mn_ox rates to avoid double-counting)."
                }
              },
              "equations": [
                {
                  "_comment": "Eq. 7.102 \u2014 Mn-only term of the Fe/Mn synergism rate law.",
                  "lhs": "R_Mn_term",
                  "rhs": {
                    "op": "*",
                    "args": [
                      "k_Mn",
                      "Mn_II",
                      "S_IV_total"
                    ]
                  }
                },
                {
                  "_comment": "Eq. 7.102 \u2014 Fe-only term of the Fe/Mn synergism rate law.",
                  "lhs": "R_Fe_term",
                  "rhs": {
                    "op": "*",
                    "args": [
                      "k_Fe",
                      "Fe_III",
                      "S_IV_total"
                    ]
                  }
                },
                {
                  "_comment": "Eq. 7.102 \u2014 synergistic Fe.Mn term of the Fe/Mn synergism rate law.",
                  "lhs": "R_synergy_term",
                  "rhs": {
                    "op": "*",
                    "args": [
                      "k_FeMn",
                      "Mn_II",
                      "Fe_III",
                      "S_IV_total"
                    ]
                  }
                },
                {
                  "_comment": "Eq. 7.102 \u2014 total Fe/Mn-synergism oxidation rate (sum of the three terms).",
                  "lhs": "R_FeMn",
                  "rhs": {
                    "op": "+",
                    "args": [
                      "R_Mn_term",
                      "R_Fe_term",
                      "R_synergy_term"
                    ]
                  }
                }
              ]
            }
          },
          "equations": [
            {
              "_comment": "Coupling equation \u2014 feed the top-level input SO2_aq into the o3_ox subsystem.",
              "lhs": "CloudChemistryFixedpH.sulfate.o3_ox.SO2_aq",
              "rhs": "SO2_aq"
            },
            {
              "_comment": "Coupling equation \u2014 feed the top-level input HSO3_minus into the o3_ox subsystem.",
              "lhs": "CloudChemistryFixedpH.sulfate.o3_ox.HSO3_minus",
              "rhs": "HSO3_minus"
            },
            {
              "_comment": "Coupling equation \u2014 feed the top-level input SO3_2minus into the o3_ox subsystem.",
