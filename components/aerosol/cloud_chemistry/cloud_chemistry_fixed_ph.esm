              "lhs": "K_c2",
              "rhs": {
                "op": "*",
                "args": [
                  "K_c2_298",
                  {
                    "op": "exp",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          -1,
                          {
                            "op": "/",
                            "args": [
                              "dH_Kc2",
                              "R_gas"
                            ]
                          },
                          {
                            "op": "+",
                            "args": [
                              {
                                "op": "/",
                                "args": [
