      "tests": [
        {
          "id": "ph_to_hplus_conversion",
          "description": "Verifies the core equation H_plus = C_ref * 10^(-pH_input) at two pH values. pH 4.0 \u2192 H_plus = 0.1 mol/m\u00b3 (acidic, typical polluted cloud); pH 7.0 \u2192 H_plus = 1e-4 mol/m\u00b3 (neutral). The 1000\u00d7 C_ref factor converts from molarity to mol/m\u00b3.",
          "parameter_overrides": {
            "pH_input": 4.0,
            "T": 298.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "CloudChemistryFixedpH.H_plus",
              "time": 0.0,
              "expected": 0.1
            }
          ]
        },
        {
          "id": "ph_neutral_hplus",
          "description": "pH 7.0 (neutral water): H_plus = 1000 * 10^-7 = 1e-4 mol/m\u00b3.",
          "parameter_overrides": {
            "pH_input": 7.0,
            "T": 298.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "CloudChemistryFixedpH.H_plus",
              "time": 0.0,
              "expected": 0.0001
            }
          ]
        },
        {
          "id": "water_equilibrium_acidic_298K",
          "description": "WaterEquilibrium at T = T_ref = 298.0 K (van't Hoff factor = 1): K_w = K_w_298 = 1e-8 mol\u00b2/m\u2076. At pH 4 (H_plus = 0.1 mol/m\u00b3): OH_minus = K_w / H_plus = 1e-8 / 0.1 = 1e-7 mol/m\u00b3. Also checks the subsystem K_w variable via the dotted path.",
          "parameter_overrides": {
            "pH_input": 4.0,
            "T": 298.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "CloudChemistryFixedpH.H_plus",
              "time": 0.0,
              "expected": 0.1
            },
            {
              "variable": "CloudChemistryFixedpH.water_eq.K_w",
              "time": 0.0,
              "expected": 1e-08
            },
            {
              "variable": "CloudChemistryFixedpH.OH_minus",
              "time": 0.0,
              "expected": 1e-07
            }
          ]
        },
        {
          "id": "so2_equilibrium_pH4_298K",
