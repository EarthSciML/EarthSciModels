                              "SO2_aq"
                            ]
                          },
                          {
                            "op": "*",
                            "args": [
                              "k1",
                              "HSO3_minus"
                            ]
                          },
                          {
                            "op": "*",
                            "args": [
                              "k2",
                              "SO3_2minus"
                            ]
                          }
                        ]
                      },
                      "O3_aq"
