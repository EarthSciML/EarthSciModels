                },
                "Mn_II": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Dissolved Mn(II) concentration — the transition-metal catalyst. Driven by SulfateFormation.mn_ox.Mn_II ~ Mn_II; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "S_IV_total": {
                  "type": "state",
                  "units": "mol/m^3",
