                },
                {
                  "_comment": "Eq. 7.102 — Fe-only term of the Fe/Mn synergism rate law.",
                  "lhs": "R_Fe_term",
                  "rhs": {
                    "op": "*",
                    "args": [
                      "k_Fe",
                      "Fe_III",
                      "S_IV_total"
                    ]
                  }
                },
                {
                  "_comment": "Eq. 7.102 — synergistic Fe.Mn term of the Fe/Mn synergism rate law.",
                  "lhs": "R_synergy_term",
                  "rhs": {
                    "op": "*",
                    "args": [
                      "k_FeMn",
                      "Mn_II",
                      "Fe_III",
                      "S_IV_total"
                    ]
                  }
                },
                {
                  "_comment": "Eq. 7.102 — total Fe/Mn-synergism oxidation rate (sum of the three terms).",
                  "lhs": "R_FeMn",
                  "rhs": {
                    "op": "+",
                    "args": [
                      "R_Mn_term",
                      "R_Fe_term",
                      "R_synergy_term"
                    ]
                  }
                }
              ]
            }
          },
          "equations": [
            {
              "_comment": "Coupling equation — feed the top-level input SO2_aq into the o3_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.o3_ox.SO2_aq",
              "rhs": "SO2_aq"
            },
            {
              "_comment": "Coupling equation — feed the top-level input HSO3_minus into the o3_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.o3_ox.HSO3_minus",
              "rhs": "HSO3_minus"
            },
            {
              "_comment": "Coupling equation — feed the top-level input SO3_2minus into the o3_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.o3_ox.SO3_2minus",
              "rhs": "SO3_2minus"
            },
            {
              "_comment": "Coupling equation — feed the top-level input O3_aq into the o3_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.o3_ox.O3_aq",
              "rhs": "O3_aq"
            },
            {
              "_comment": "Coupling equation — feed the top-level input H_plus into the h2o2_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.h2o2_ox.H_plus",
              "rhs": "H_plus"
            },
            {
              "_comment": "Coupling equation — feed the top-level input H2O2_aq into the h2o2_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.h2o2_ox.H2O2_aq",
              "rhs": "H2O2_aq"
            },
            {
              "_comment": "Coupling equation — feed the top-level input HSO3_minus into the h2o2_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.h2o2_ox.HSO3_minus",
              "rhs": "HSO3_minus"
            },
            {
              "_comment": "Coupling equation — feed the top-level input H_plus into the fe_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.fe_ox.H_plus",
              "rhs": "H_plus"
            },
            {
              "_comment": "Coupling equation — feed the top-level input Fe_III into the fe_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.fe_ox.Fe_III",
              "rhs": "Fe_III"
            },
            {
              "_comment": "Coupling equation — feed the top-level input S_IV_total into the fe_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.fe_ox.S_IV_total",
              "rhs": "S_IV_total"
            },
            {
              "_comment": "Coupling equation — feed the top-level input Mn_II into the mn_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.mn_ox.Mn_II",
              "rhs": "Mn_II"
            },
            {
              "_comment": "Coupling equation — feed the top-level input S_IV_total into the mn_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.mn_ox.S_IV_total",
              "rhs": "S_IV_total"
            },
            {
              "_comment": "Coupling equation — feed the top-level input Mn_II into the femn_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.femn_ox.Mn_II",
              "rhs": "Mn_II"
            },
            {
              "_comment": "Coupling equation — feed the top-level input Fe_III into the femn_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.femn_ox.Fe_III",
              "rhs": "Fe_III"
            },
            {
              "_comment": "Coupling equation — feed the top-level input S_IV_total into the femn_ox subsystem.",
              "lhs": "CloudChemistry.sulfate.femn_ox.S_IV_total",
              "rhs": "S_IV_total"
            },
            {
              "_comment": "Total S(IV) oxidation rate — sum of the O3, H2O2 and Fe/Mn-synergism pathway rates. The fe_ox and mn_ox standalone rates are excluded: femn_ox already includes Fe-only and Mn-only terms, so using it avoids double-counting (upstream comment).",
              "lhs": "R_total",
              "rhs": {
                "op": "+",
                "args": [
                  "CloudChemistry.sulfate.o3_ox.R_O3",
                  "CloudChemistry.sulfate.h2o2_ox.R_H2O2",
                  "CloudChemistry.sulfate.femn_ox.R_FeMn"
                ]
              }
            },
            {
              "_comment": "Sulfate production equals the S(IV) oxidation rate.",
              "lhs": "S_VI_production",
              "rhs": "R_total"
            },
            {
              "_comment": "Liquid water volume ratio (dimensionless): w_L = rho_w_inv * L.",
              "lhs": "w_L",
              "rhs": {
                "op": "*",
                "args": [
                  "rho_w_inv",
                  "L"
                ]
              }
            },
            {
              "_comment": "Eq. 7.75 — rate conversion to ppb/hr: R_ppb_hr = ppb_factor * s_per_hr * w_L * R_gas * T * R_total / p_total.",
              "lhs": "R_ppb_hr",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "ppb_factor",
                      "s_per_hr",
                      "w_L",
                      "R_gas",
                      "T",
                      "R_total"
                    ]
                  },
                  "p_total"
                ]
              }
            },
            {
              "_comment": "Eq. 7.76 — rate conversion to %/hr: R_percent_hr = pct_factor * s_per_hr * R_total * w_L * R_gas * T / (p_total * xi_SO2).",
              "lhs": "R_percent_hr",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "pct_factor",
                      "s_per_hr",
                      "R_total",
                      "w_L",
                      "R_gas",
                      "T"
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "p_total",
                      "xi_SO2"
                    ]
                  }
                ]
              }
            },
            {
              "_comment": "Eq. 7.78 — SO2 lifetime: tau_SO2 = xi_SO2 * p_total / (w_L * R_gas * T * R_total).",
              "lhs": "tau_SO2",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "xi_SO2",
                      "p_total"
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "w_L",
                      "R_gas",
                      "T",
                      "R_total"
                    ]
                  }
                ]
              }
            }
          ]
        }
      },
      "equations": [
        {
          "_comment": "Temperature couples into the AqueousEquilibria subsystem for van't Hoff corrections.",
          "lhs": "CloudChemistry.aq_eq.T",
          "rhs": "T"
        },
        {
          "_comment": "CO2 partial pressure drives CO2 dissolution and CO2/carbonate equilibria.",
          "lhs": "CloudChemistry.aq_eq.p_CO2",
          "rhs": "p_CO2"
        },
        {
          "_comment": "SO2 partial pressure drives SO2 dissolution and S(IV) speciation.",
          "lhs": "CloudChemistry.aq_eq.p_SO2",
          "rhs": "p_SO2"
        },
        {
          "_comment": "NH3 partial pressure drives NH3 dissolution and NH4+ formation (pH buffer).",
          "lhs": "CloudChemistry.aq_eq.p_NH3",
          "rhs": "p_NH3"
        },
        {
          "_comment": "HNO3 partial pressure drives HNO3 dissolution and NO3- formation (acidifying).",
          "lhs": "CloudChemistry.aq_eq.p_HNO3",
          "rhs": "p_HNO3"
        },
        {
          "_comment": "H2O2 partial pressure drives H2O2 dissolution (oxidant and HO2- contributor).",
          "lhs": "CloudChemistry.aq_eq.p_H2O2",
          "rhs": "p_H2O2"
        },
        {
          "_comment": "O3 partial pressure drives O3 dissolution (sparingly soluble oxidant).",
          "lhs": "CloudChemistry.aq_eq.p_O3",
          "rhs": "p_O3"
        },
        {
          "_comment": "H+ concentration aliased from aq_eq — computed by the quadratic charge-balance from all dissolved ions.",
          "lhs": "H_plus",
          "rhs": "CloudChemistry.aq_eq.H_plus"
        },
        {
          "_comment": "OH- aliased from aq_eq.OH_minus = K_w(T) / H_plus.",
          "lhs": "OH_minus",
          "rhs": "CloudChemistry.aq_eq.OH_minus"
        },
        {
          "_comment": "pH aliased from aq_eq.pH = -log10(H_plus / C_ref).",
          "lhs": "pH",
          "rhs": "CloudChemistry.aq_eq.pH"
        },
        {
          "_comment": "Aqueous SO2 ([SO2·H2O]) aliased from aq_eq.SO2_aq = H_SO2(T) × p_SO2.",
          "lhs": "SO2_aq",
          "rhs": "CloudChemistry.aq_eq.SO2_aq"
        },
        {
          "_comment": "Bisulfite [HSO3-] aliased from aq_eq.HSO3_minus.",
          "lhs": "HSO3_minus",
          "rhs": "CloudChemistry.aq_eq.HSO3_minus"
        },
        {
          "_comment": "Sulfite [SO3²-] aliased from aq_eq.SO3_2minus.",
          "lhs": "SO3_2minus",
          "rhs": "CloudChemistry.aq_eq.SO3_2minus"
        },
        {
          "_comment": "Aqueous H2O2 aliased from aq_eq.H2O2_aq = H_H2O2(T) × p_H2O2.",
          "lhs": "H2O2_aq",
          "rhs": "CloudChemistry.aq_eq.H2O2_aq"
        },
        {
          "_comment": "Aqueous O3 aliased from aq_eq.O3_aq = H_O3(T) × p_O3.",
          "lhs": "O3_aq",
          "rhs": "CloudChemistry.aq_eq.O3_aq"
        },
        {
          "_comment": "Total S(IV) (SO2_aq + HSO3_minus + SO3_2minus) aliased from aq_eq.S_IV_total.",
          "lhs": "S_IV_total",
          "rhs": "CloudChemistry.aq_eq.S_IV_total"
        },
        {
          "_comment": "Temperature couples into SulfateFormation for the rate conversion equations.",
          "lhs": "CloudChemistry.sulfate.T",
          "rhs": "T"
        },
        {
          "_comment": "H+ from charge-balance couples into SulfateFormation (drives H2O2 pathway rate).",
          "lhs": "CloudChemistry.sulfate.H_plus",
          "rhs": "H_plus"
        },
        {
          "_comment": "Aqueous SO2 couples into SulfateFormation's O3 oxidation pathway.",
          "lhs": "CloudChemistry.sulfate.SO2_aq",
          "rhs": "SO2_aq"
        },
        {
          "_comment": "Bisulfite couples into SulfateFormation (O3 and H2O2 pathway reactant).",
          "lhs": "CloudChemistry.sulfate.HSO3_minus",
          "rhs": "HSO3_minus"
        },
        {
          "_comment": "Sulfite couples into SulfateFormation (O3 pathway reactant, large k2).",
          "lhs": "CloudChemistry.sulfate.SO3_2minus",
          "rhs": "SO3_2minus"
        },
        {
          "_comment": "Total S(IV) couples into SulfateFormation (Fe/Mn pathway reactant).",
          "lhs": "CloudChemistry.sulfate.S_IV_total",
          "rhs": "S_IV_total"
        },
        {
          "_comment": "Aqueous O3 couples into SulfateFormation's O3 oxidation pathway.",
          "lhs": "CloudChemistry.sulfate.O3_aq",
          "rhs": "O3_aq"
        },
        {
          "_comment": "Aqueous H2O2 couples into SulfateFormation's H2O2 oxidation pathway.",
          "lhs": "CloudChemistry.sulfate.H2O2_aq",
          "rhs": "H2O2_aq"
        },
        {
          "_comment": "Fe(III) catalyst couples into SulfateFormation for the Fe/Mn synergism pathway.",
          "lhs": "CloudChemistry.sulfate.Fe_III",
          "rhs": "Fe_III"
        },
        {
          "_comment": "Mn(II) catalyst couples into SulfateFormation for the Fe/Mn synergism pathway.",
          "lhs": "CloudChemistry.sulfate.Mn_II",
          "rhs": "Mn_II"
        },
        {
          "_comment": "Cloud LWC couples into SulfateFormation for rate conversion (Eq. 7.75-7.78).",
          "lhs": "CloudChemistry.sulfate.L",
          "rhs": "L"
        },
        {
          "_comment": "SO2 mixing ratio couples into SulfateFormation for %/hr rate and SO2 lifetime.",
          "lhs": "CloudChemistry.sulfate.xi_SO2",
          "rhs": "xi_SO2"
        },
        {
          "_comment": "Total S(IV) oxidation rate aliased from sulfate.R_total = O3 + H2O2 + FeMn pathways.",
          "lhs": "R_total",
          "rhs": "CloudChemistry.sulfate.R_total"
        },
        {
          "_comment": "O3 pathway rate aliased from sulfate.o3_ox.R_O3 (Eq. 7.79).",
          "lhs": "R_O3",
          "rhs": "CloudChemistry.sulfate.o3_ox.R_O3"
        },
        {
          "_comment": "H2O2 pathway rate aliased from sulfate.h2o2_ox.R_H2O2 (Eq. 7.84).",
          "lhs": "R_H2O2",
          "rhs": "CloudChemistry.sulfate.h2o2_ox.R_H2O2"
        },
        {
