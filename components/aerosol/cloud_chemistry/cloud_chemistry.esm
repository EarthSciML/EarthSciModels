        {
          "id": "full_system_default",
          "description": "Full CloudChemistry system at default parameters (T=298.15 K, p_CO2=38.5 Pa, p_SO2=1 ppb, p_NH3=1 ppb, p_HNO3=0, p_H2O2=1 ppb, p_O3=50 ppb, Fe_III=Mn_II=1e-3 mol/m³). All three oxidation pathways (O3, H2O2, FeMn) are active. NH3 buffers the SO2 acidity, giving pH≈6.35. The O3 pathway dominates at this pH.",
          "parameter_overrides": {
            "T": 298.15
          },
          "time_span": {
            "start": 0.0,
