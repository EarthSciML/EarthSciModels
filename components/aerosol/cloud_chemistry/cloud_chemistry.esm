          "lhs": "R_FeMn",
          "rhs": "CloudChemistry.sulfate.femn_ox.R_FeMn"
        }
      ],
      "tests": [
        {
          "id": "charge_balance_co2_so2_298K",
          "description": "CO2+SO2 charge balance at 298 K. With p_CO2=40 Pa (≈400 ppm) and p_SO2=0.001 Pa, the AqueousEquilibria quadratic charge-balance gives H⁺ = √((K_w + K_s1·SO2_aq)/1) ≈ 0.01279 mol/m³ (pH≈4.89), NOT the 0.1 mol/m³ (pH 4) that CloudChemistryFixedpH would use with pH_input=4.0. The higher pH gives larger HSO3⁻ and S_IV_total concentrations. Fe_III and Mn_II active; R_total = R_FeMn (no H2O2 or O3 oxidants present).",
          "parameter_overrides": {
            "T": 298.0,
            "p_CO2": 40.0,
            "p_SO2": 0.001,
            "p_NH3": 0.0,
            "p_HNO3": 0.0,
            "p_H2O2": 0.0,
            "p_O3": 0.0,
            "Fe_III": 0.001,
            "Mn_II": 0.001
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "CloudChemistry.H_plus",
              "time": 0.0,
              "expected": 0.012790252,
              "tolerance": {
                "rel": 0.0001
              }
            },
            {
              "variable": "CloudChemistry.pH",
              "time": 0.0,
              "expected": 4.8931209,
              "tolerance": {
                "rel": 0.0001
              }
            },
            {
              "variable": "CloudChemistry.SO2_aq",
              "time": 0.0,
              "expected": 1.2139156e-05,
              "tolerance": {
                "rel": 0.0001
              }
            },
            {
              "variable": "CloudChemistry.HSO3_minus",
              "time": 0.0,
              "expected": 0.012338226,
              "tolerance": {
                "rel": 0.0001
              }
            },
            {
              "variable": "CloudChemistry.SO3_2minus",
              "time": 0.0,
              "expected": 6.3667464e-05,
              "tolerance": {
                "rel": 0.0001
              }
            },
            {
              "variable": "CloudChemistry.S_IV_total",
              "time": 0.0,
              "expected": 0.012414033,
              "tolerance": {
                "rel": 0.0001
              }
            },
            {
              "variable": "CloudChemistry.R_FeMn",
              "time": 0.0,
              "expected": 0.00016572734,
              "tolerance": {
                "rel": 0.001
              }
            },
            {
              "variable": "CloudChemistry.R_total",
              "time": 0.0,
              "expected": 0.00016572734,
              "tolerance": {
                "rel": 0.001
              }
            }
          ]
        },
        {
          "id": "nh3_buffers_acidity_298K",
          "description": "NH3 buffering at 298 K (p_CO2=40 Pa, p_SO2=0.001 Pa, p_NH3=0.001 Pa). NH3 dissolves and forms NH4⁺ (a base), raising pH from ~4.89 (CO2+SO2 only) to 6.40. At the higher pH, SO2 speciation shifts dramatically: HSO3⁻ rises from 0.012 to 0.398 mol/m³ and SO3²⁻ from 6.4e-5 to 0.066 mol/m³. The Fe/Mn oxidation rate also increases due to the larger S_IV_total (0.464 mol/m³).",
          "parameter_overrides": {
            "T": 298.0,
            "p_CO2": 40.0,
            "p_SO2": 0.001,
            "p_NH3": 0.001,
            "p_HNO3": 0.0,
            "p_H2O2": 0.0,
            "p_O3": 0.0,
            "Fe_III": 0.001,
            "Mn_II": 0.001
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "CloudChemistry.H_plus",
              "time": 0.0,
              "expected": 0.00039637702,
              "tolerance": {
                "rel": 0.001
              }
            },
            {
              "variable": "CloudChemistry.pH",
              "time": 0.0,
              "expected": 6.4018915,
