                },
                "k_Fe": {
                  "type": "parameter",
                  "units": "m^3/mol/s",
                  "default": 2.6,
                  "description": "Rate constant for the Fe-only term of the Fe/Mn synergism rate law (Eq. 7.102). Upstream MTK `@constants` value 2600.0/1000.0 = 2.6 — the literature value 2600 M^-1 s^-1 converted to SI."
                },
                "k_FeMn": {
                  "type": "parameter",
                  "units": "m^6/mol^2/s",
                  "default": 10000.0,
                  "description": "Rate constant for the synergistic Fe.Mn term of the Fe/Mn synergism rate law (Eq. 7.102). Upstream MTK `@constants` value 1.0e10/1.0e6 = 10000.0 — the literature value 1.0e10 M^-2 s^-1 converted to SI (1 M^-2 = 1e-6 (mol/m^3)^-2). The large coefficient represents the greatly enhanced oxidation when both Fe(III) and Mn(II) are present."
                },
                "Mn_II": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
                  "description": "Dissolved Mn(II) concentration. Driven by SulfateFormation.femn_ox.Mn_II ~ Mn_II; re-typed parameter -> state. Default 1.0e-3 mol/m^3."
                },
                "Fe_III": {
                  "type": "state",
                  "units": "mol/m^3",
                  "default": 0.001,
