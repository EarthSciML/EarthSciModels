            ],
            "tests": [
                {
                    "id": "canonical_lognormal_day",
                    "description": "Upstream TOMAS.jl base case: a normal-distribution-weighted initial number spectrum (N_k proportional to pdf(Normal(15,5), k)) integrated over a full day. Brownian coagulation collapses the number concentration in every bin by 3-7 orders of magnitude over 86400 s. The N1 assertion at t=0 verifies initial-condition handling; N_k at 1 h and 24 h are the primary behavioral gate; the mass bins M3-M5 are checked at 5 min and M5 (slowest-decaying mass bin) again at 24 h.",
                    "initial_conditions": {
