                },
                "M3": {
                    "type": "state",
                    "units": "g/cm^3",
                    "default": 2.687343635381148e-10,
                    "description": "Mass concentration of aerosol particles in mass-doubling size bin 3 (of 5)."
                },
                "M4": {
                    "type": "state",
                    "units": "g/cm^3",
                    "default": 8.513902283095546e-10,
                    "description": "Mass concentration of aerosol particles in mass-doubling size bin 4 (of 5)."
                },
                "M5": {
                    "type": "state",
                    "units": "g/cm^3",
                    "default": 2.5915663926330265e-09,
                    "description": "Mass concentration of aerosol particles in mass-doubling size bin 5 (of 5)."
                },
                "f1": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient f for size bin 1; evaluated algebraically as 2*N1/m_lower*(2 - m_k/m_lower). Equals psi1 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "f2": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient f for size bin 2; evaluated algebraically as 2*N2/m_lower*(2 - m_k/m_lower). Equals psi2 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "f3": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient f for size bin 3; evaluated algebraically as 2*N3/m_lower*(2 - m_k/m_lower). Equals psi3 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "f4": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient f for size bin 4; evaluated algebraically as 2*N4/m_lower*(2 - m_k/m_lower). Equals psi4 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "f5": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient f for size bin 5; evaluated algebraically as 2*N5/m_lower*(2 - m_k/m_lower). Equals psi5 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "psi1": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient psi for size bin 1; evaluated algebraically as 2*N1/m_lower*(m_k/m_lower - 1). Equals f1 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "psi2": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient psi for size bin 2; evaluated algebraically as 2*N2/m_lower*(m_k/m_lower - 1). Equals f2 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "psi3": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient psi for size bin 3; evaluated algebraically as 2*N3/m_lower*(m_k/m_lower - 1). Equals f3 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "psi4": {
                    "type": "state",
                    "units": "cm^-3/g",
                    "description": "Within-bin linear number-distribution reconstruction coefficient psi for size bin 4; evaluated algebraically as 2*N4/m_lower*(m_k/m_lower - 1). Equals f4 on the mass-doubling grid (m_k/m_lower = 1.5)."
                },
                "psi5": {
