                                                    {
                                                        "op": "sqrt",
                                                        "args": [
                                                            {
                                                                "op": "*",
                                                                "args": [
                                                                    2,
                                                                    "π_c"
                                                                ]
                                                            }
                                                        ]
                                                    },
                                                    "logσ_1"
                                                ]
                                            }
                                        ]
                                    },
