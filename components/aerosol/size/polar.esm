            "examples": [
                {
                    "id": "aerosol_size_distribution_curves",
                    "description": "The Seinfeld & Pandis Chapter 8 size-distribution figure for the Polar aerosol (Table 8.3). Sweeps the evaluation diameter D_p logarithmically from 1 nm to 100 um — the upper bound is extended past the usual 10 um so the coarse mode at D_g = 8.6 um and the tail of its volume distribution are captured — and plots the number (n_N_o, Eq. 8.54), surface-area (n_S_o, Eq. 8.49/8.50) and volume (n_V_o, Eq. 8.52/8.53) distribution densities. The polar aerosol is extremely dilute; the characteristic shift of the distribution peak toward larger diameters going from number to surface to volume is the headline result.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "D_p",
                                "range": {
                                    "start": 1e-09,
                                    "stop": 0.0001,
                                    "count": 100,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "number_distribution",
                            "type": "line",
                            "description": "Number distribution density dN/d(log D_p) versus particle diameter on a logarithmic D_p axis — the Polar multi-modal lognormal of Eq. 8.54.",
                            "x": {
                                "variable": "D_p",
                                "label": "particle diameter D_p (m)"
                            },
                            "y": {
                                "variable": "n_N_o",
                                "label": "number distribution dN/d(log D_p) (m^-3)"
                            }
                        },
                        {
                            "id": "surface_distribution",
                            "type": "line",
                            "description": "Surface-area distribution density dS/d(log D_p) versus particle diameter (Eq. 8.49/8.50) — the peak sits at a larger D_p than the number distribution.",
                            "x": {
                                "variable": "D_p",
                                "label": "particle diameter D_p (m)"
                            },
                            "y": {
                                "variable": "n_S_o",
                                "label": "surface distribution dS/d(log D_p) (m^-1)"
                            }
                        },
                        {
                            "id": "volume_distribution",
                            "type": "line",
                            "description": "Volume distribution density dV/d(log D_p) versus particle diameter (Eq. 8.52/8.53) — the peak sits at the largest D_p of the three moments.",
                            "x": {
                                "variable": "D_p",
                                "label": "particle diameter D_p (m)"
                            },
                            "y": {
                                "variable": "n_V_o",
                                "label": "volume distribution dV/d(log D_p) (-)"
                            }
                        }
                    ]
                },
                {
                    "id": "vertical_mass_profile",
                    "description": "Vertical aerosol mass profile of Seinfeld & Pandis Eq. 8.55. Sweeps altitude z from the surface to 5 km and plots the mass concentration ratio M_z = M(z)/M(0) = exp(-z/H_p) with the default scale height H_p = 1000 m. The profile decays exponentially, reaching 1/e of the surface value at z = H_p.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "z",
                                "range": {
                                    "start": 0.0,
                                    "stop": 5000.0,
                                    "count": 51,
                                    "scale": "linear"
                                }
                            }
