            "equations": [],
            "tests": [
                {
                    "id": "urban_default_distribution",
                    "description": "All parameters at their declared defaults — the Urban size distribution of Seinfeld & Pandis (2006) Table 8.3 (three lognormal modes), evaluated at D_p = 1.0e-7 m (0.1 um). Pins every one of the ten outputs: the number/surface/volume distribution densities n_N_o/n_S_o/n_V_o (Eq. 8.54/8.49/8.52), the total concentrations N_t/S_t/V_t, the mode-1 Hatch-Choate diameters D_s/D_v/D_bar, and the surface vertical mass ratio M_z. N_t = N_1+N_2+N_3 = 1.3681e11 m^-3; M_z = exp(-z/H_p) = 1 at the surface (z = 0). All outputs are algebraic and time-independent, so N_t and M_z are also asserted at t = 1 to confirm time-invariance.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "n_N_o",
                            "time": 0.0,
                            "expected": 29440391703.87598
                        },
                        {
                            "variable": "n_S_o",
                            "time": 0.0,
                            "expected": 0.004055695331493581
                        },
                        {
