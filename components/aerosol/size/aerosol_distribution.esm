                            "time": 0.0,
                            "expected": 136810000000.0
                        },
                        {
                            "variable": "S_t",
                            "time": 0.0,
                            "expected": 0.001128262200385865
                        },
                        {
                            "variable": "V_t",
                            "time": 0.0,
                            "expected": 9.917187382842179e-11
                        },
                        {
