                            {
                                "op": "*",
                                "args": [
                                    0.02650648471,
                                    {
                                        "op": "^",
                                        "args": [
                                            "T_C",
                                            3
                                        ]
                                    }
                                ]
                            },
                            {
                                "op": "*",
                                "args": [
                                    0.0003031240396,
                                    {
                                        "op": "^",
                                        "args": [
                                            "T_C",
                                            4
                                        ]
                                    }
                                ]
