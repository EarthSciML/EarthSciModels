                        {"variable": "h_LCL",      "time":   0.0, "expected": 292.22938809413193},
                        {"variable": "h_LCL",      "time": 600.0, "expected": 292.22938809413193},
                        {"variable": "Γ_d",        "time":   0.0, "expected": 0.009761194029850746},
                        {"variable": "IN",         "time":   0.0, "expected": 2.265408914814352},
                        {"variable": "kelvin_ice", "time":   0.0, "expected": 1.0038145595610195}
                    ]
                },
                {
                    "id": "scavenging_defaults",
                    "description": "Spot-check AerosolScavenging at default parameters and at a complete-scavenging boundary (C_int=0, N_int=0). Confirms F_mass=F_number=1 at the upper bound and verifies Λ=N_d*K_coll=1e-4 s^-1 at defaults. Sourced from aerosol_scavenging.esm tests.",
