                    ]
                },
                {
                    "id": "rain_saturation_rh",
                    "description": "CloudDynamics at RH=1.0 (100% humidity): dew point equals air temperature so h_LCL=0 (parcel already at saturation). RainFormation outputs unchanged. Sourced from cloud_dynamics.esm 'saturation_rh_100' test.",
