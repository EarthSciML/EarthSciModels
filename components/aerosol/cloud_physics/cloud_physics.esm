            ],
            "examples": [
                {
                    "id": "lcl_height_vs_relative_humidity",
                    "description": "LCL height h_LCL as a function of relative humidity RH at T_0=293.15 K. As RH decreases the dew-point depression increases and cloud base rises (S&P Eq. 17.49). Reproduces CloudDynamics example.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "RH",
                                "range": {"start": 0.2, "stop": 1.0, "count": 50, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "h_LCL_vs_RH",
                            "type": "line",
                            "description": "LCL height h_LCL vs relative humidity (S&P Eq. 17.49).",
                            "x": {"variable": "RH",   "label": "Relative humidity RH"},
                            "y": {"variable": "h_LCL", "label": "h_LCL (m)"}
                        }
                    ]
                },
                {
                    "id": "ice_nuclei_temperature_sweep",
                    "description": "Ice nuclei concentration IN vs temperature T (233–273 K) at fixed IN_ref=1000 m^-3 and IN_coeff=0.6 K^-1. Spans ~7 orders of magnitude over 40 K (S&P Eq. 17.103). Reproduces IcePhysics example.",
                    "time_span": {"start": 0.0, "end": 60.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T",
                                "range": {"start": 233.15, "stop": 273.15, "count": 21, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "IN_vs_T",
