                        {"variable": "IN",    "time": 600.0, "expected": 368706.1554093557},
                        {"variable": "Γ_d",   "time":   0.0, "expected": 0.009761194029850746},
                        {"variable": "p_sat", "time":   0.0, "expected": 2333.4406230993577},
                        {"variable": "h_LCL", "time":   0.0, "expected": 362.65772849528986}
                    ]
                },
                {
                    "id": "cloud_dynamics_cold_independent_of_ice",
                    "description": "T_0=263.15 K (cold parcel). CloudDynamics outputs change (lower p_sat, lower h_LCL). IcePhysics outputs must remain unchanged because they depend on T not T_0. Also confirms Γ_d = g/c_p_air is constant (does not depend on temperature).\n\np_sat and h_LCL expected from cloud_dynamics.esm 'cold_temperature_T0_263' test.",
                    "parameter_overrides": {"T_0": 263.15},
                    "time_span": {"start": 0.0, "end": 600.0},
