                            "y": {"variable": "IN", "label": "IN (m^-3)"}
                        }
                    ]
                },
                {
                    "id": "marshall_palmer_raindrop_spectrum",
                    "description": "Marshall-Palmer number density n_MP vs collector drop diameter D_p_rain (0.5–5 mm). Exponential decay n = n_0 * exp(-ψ D) (S&P Eq. 17.108). Reproduces RainFormation example.",
                    "time_span": {"start": 0.0, "end": 60.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "D_p_rain",
                                "range": {"start": 5.0e-4, "stop": 5.0e-3, "count": 19, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "n_MP_vs_D_p_rain",
