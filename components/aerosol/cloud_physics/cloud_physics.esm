                            "x": {"variable": "D_p_rain", "label": "D_p_rain (m)"},
                            "y": {"variable": "n_MP",     "label": "n_MP (m^-4)"}
                        }
                    ]
                },
                {
                    "id": "scavenging_coefficient_vs_droplet_density",
                    "description": "Scavenging coefficient Λ = N_d K_coll vs cloud-droplet number density N_d across four orders of magnitude (1e6–1e10 m^-3). Covers timescales from ~1 second (heavy cumulus) to ~12 days (thin cirrus) (S&P Eq. 17.92). Reproduces AerosolScavenging example.",
                    "time_span": {"start": 0.0, "end": 60.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "N_d",
                                "range": {"start": 1.0e6, "stop": 1.0e10, "count": 21, "scale": "log"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "lambda_vs_Nd",
                            "type": "line",
                            "description": "Scavenging coefficient Λ vs cloud-droplet number density.",
                            "x": {"variable": "N_d", "label": "N_d (m^-3)"},
                            "y": {"variable": "Λ",   "label": "Λ (1/s)"}
                        }
                    ]
