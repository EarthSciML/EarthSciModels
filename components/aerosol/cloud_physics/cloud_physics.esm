                    ]
                },
                {
                    "id": "D_p_rain_independent_of_D_p_ice",
                    "description": "D_p_rain=2e-3 m (2 mm collector drop, 2× default). Verifies n_MP drops per the Marshall-Palmer exponential while kelvin_ice and all IcePhysics outputs remain at default values, confirming D_p_rain and D_p_ice are independent parameters.\n\nn_MP expected from rain_formation.esm 'marshall_palmer_decreasing' test.",
                    "parameter_overrides": {"D_p_rain": 2.0e-3},
