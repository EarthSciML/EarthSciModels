                        {"variable": "kelvin_ice", "time":   0.0, "expected": 1.0038145595610195},
                        {"variable": "kelvin_ice", "time": 600.0, "expected": 1.0038145595610195},
                        {"variable": "IN",         "time":   0.0, "expected": 2.265408914814352},
                        {"variable": "IN",         "time": 600.0, "expected": 2.265408914814352}
                    ]
                },
                {
                    "id": "ice_temperature_independent_of_cloud_dynamics",
                    "description": "T=243.15 K (cold surge, 10 K below T_IN_ref=253 K). Ice nuclei concentration IN spikes per the exponential parameterization (Eq. 17.103). CloudDynamics outputs (Γ_d, p_sat, etc.) must remain unchanged because they depend on T_0 not T, confirming the two temperature parameters are independent.\n\nIN expected from ice_physics.esm 'ice_nuclei_cold_surge' test.",
                    "parameter_overrides": {"T": 243.15},
                    "time_span": {"start": 0.0, "end": 600.0},
