                                    {
                                        "args": [
                                            {
                                                "args": [
                                                    2,
                                                    {
                                                        "args": [
                                                            {
                                                                "args": [
                                                                    {
                                                                        "args": [
                                                                            2,
                                                                            "M_a",
                                                                            "π_val"
                                                                        ],
                                                                        "op": "*"
                                                                    },
                                                                    {
                                                                        "args": [
                                                                            "T",
                                                                            "R"
                                                                        ],
                                                                        "op": "*"
                                                                    }
                                                                ],
                                                                "op": "/"
                                                            }
                                                        ],
                                                        "op": "sqrt"
                                                    },
                                                    "k_a"
                                                ],
                                                "op": "*"
                                            },
                                            {
                                                "args": [
                                                    "c_p_air",
                                                    "α_T",
                                                    "D_p",
                                                    "ρ_air"
                                                ],
                                                "op": "*"
                                            }
                                        ],
                                        "op": "/"
                                    }
                                ],
                                "op": "+"
                            }
                        ],
                        "op": "/"
                    },
