                                                                "op": "*"
                                                            }
                                                        ],
                                                        "op": "+"
                                                    },
                                                    "magnus_a"
                                                ],
                                                "op": "*"
                                            },
                                            {
                                                "args": [
                                                    "T",
                                                    {
                                                        "args": [
                                                            -1,
                                                            "T_magnus_offset"
                                                        ],
                                                        "op": "*"
                                                    },
                                                    "magnus_b"
