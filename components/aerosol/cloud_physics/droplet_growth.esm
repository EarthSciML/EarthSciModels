                                                                            "π_val"
                                                                        ],
                                                                        "op": "*"
                                                                    },
                                                                    {
                                                                        "args": [
                                                                            "T",
                                                                            "R"
                                                                        ],
                                                                        "op": "*"
                                                                    }
                                                                ],
                                                                "op": "/"
                                                            }
                                                        ],
                                                        "op": "sqrt"
                                                    },
                                                    "D_v"
                                                ],
                                                "op": "*"
                                            },
                                            {
                                                "args": [
                                                    "D_p",
                                                    "α_c"
                                                ],
                                                "op": "*"
                                            }
                                        ],
                                        "op": "/"
                                    }
                                ],
                                "op": "+"
                            }
                        ],
                        "op": "/"
                    },
                    "lhs": "D_v_prime"
                },
                {
                    "rhs": {
                        "args": [
                            {
                                "args": [
                                    "T",
                                    "ka_c1"
                                ],
                                "op": "*"
                            },
                            "ka_c0"
                        ],
                        "op": "+"
                    },
                    "lhs": "k_a"
                },
                {
                    "rhs": {
                        "args": [
                            {
                                "args": [
                                    "M_a",
                                    "p_a"
                                ],
                                "op": "*"
                            },
                            {
                                "args": [
                                    "T",
                                    "R"
                                ],
                                "op": "*"
                            }
                        ],
                        "op": "/"
                    },
                    "lhs": "ρ_air"
                },
                {
                    "rhs": {
                        "args": [
                            "k_a",
                            {
