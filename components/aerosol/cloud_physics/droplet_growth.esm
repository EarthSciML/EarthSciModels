                                                    "T",
                                                    "Hv_exp_coeff"
                                                ],
                                                "op": "*"
                                            }
                                        ],
                                        "op": "+"
                                    }
                                ],
                                "op": "^"
                            }
                        ],
                        "op": "*"
                    },
                    "lhs": "ΔH_v"
                },
                {
                    "rhs": {
                        "args": [
                            {
                                "args": [
                                    {
                                        "args": [
                                            {
                                                "args": [
                                                    4,
                                                    "M_w",
                                                    "σ_w"
                                                ],
                                                "op": "*"
                                            },
                                            {
                                                "args": [
                                                    "T",
                                                    "R",
                                                    "D_p",
                                                    "ρ_w"
                                                ],
                                                "op": "*"
