{
    "esm": "0.1.0",
    "models": {
        "ERCTimeSeries": {
            "variables": {
                "a_prev": {
                    "type": "parameter",
                    "description": "White noise value at previous time step (dimensionless)"
                },
                "var_a": {
                    "type": "state",
                    "description": "Variance of white noise process (dimensionless)"
                },
                "ERC_hat": {
                    "type": "state",
                    "description": "Simulated daily ERC value (dimensionless)"
                },
                "σ²_daily": {
                    "type": "state",
                    "description": "Daily variance of ERC around seasonal trend (dimensionless)"
                },
                "ρ₁": {
                    "type": "parameter",
                    "description": "First-order autocorrelation (dimensionless)"
                },
                "φ₁": {
                    "type": "parameter",
                    "description": "First-order autoregressive coefficient (dimensionless)"
                },
                "a_current": {
                    "type": "parameter",
                    "description": "White noise value at current time step (dimensionless)"
                },
                "f_t": {
                    "type": "parameter",
                    "description": "Seasonal trend value at current time step (dimensionless)"
                },
                "one": {
                    "default": 1,
                    "type": "parameter",
                    "description": "Dimensionless unity (dimensionless)"
                },
                "s²": {
                    "type": "parameter",
                    "description": "Observed daily variance of ERC (dimensionless)"
                }
            },
            "examples": [
            ],
            "reference": {
                "notes": "Energy Release Component (ERC) time series model - first-order autoregressive simulation"
            },
            "equations": [
                {
                    "rhs": {
                        "args": [
                            {
                                "args": [
                                    "φ₁",
                                    "a_prev"
                                ],
                                "op": "*"
                            },
                            "a_current",
                            "f_t"
                        ],
                        "op": "+"
                    },
                    "lhs": "ERC_hat"
                },
                {
                    "rhs": {
                        "args": [
                            "s²",
                            {
                                "args": [
                                    {
                                        "args": [
                                            -1,
                                            "ρ₁",
                                            "φ₁"
                                        ],
                                        "op": "*"
                                    },
                                    "one"
                                ],
                                "op": "+"
                            }
                        ],
                        "op": "*"
                    },
                    "lhs": "var_a"
                },
                {
                    "rhs": {
                        "args": [
                            "var_a",
                            {
                                "args": [
                                    {
                                        "args": [
                                            -1,
                                            "ρ₁",
                                            "φ₁"
                                        ],
                                        "op": "*"
                                    },
                                    "one"
                                ],
                                "op": "+"
                            }
                        ],
                        "op": "/"
                    },
                    "lhs": "σ²_daily"
                }
            ],
            "tests": [
            ]
        }
    },
    "metadata": {
        "name": "ERCTimeSeries",
        "tags": [
            "wildfire",
            "erc",
            "time-series",
            "fsim"
        ],
        "description": "Energy Release Component (ERC) time series model - first-order autoregressive simulation"
    }
}