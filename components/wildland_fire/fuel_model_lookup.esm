            "equations": [],
            "tests": [
                {
                    "id": "code_1_short_grass_all_properties",
                    "description": "Anderson fuel model 1 (short grass): code=1 → verify all six Rothermel fuel properties. This is the lowest-numbered Anderson model and the default for out-of-range codes (except h).",
                    "parameter_overrides": {"code": 1.0},
                    "time_span": {"start": 0.0, "end": 1.0},
                    "assertions": [
                        {"variable": "sigma", "time": 0.0, "expected": 11482.939632545931, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "w_0",   "time": 0.0, "expected": 0.16600253963702372, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "delta", "time": 0.0, "expected": 0.3048, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "M_x",   "time": 0.0, "expected": 0.12, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "h",     "time": 0.0, "expected": 18608000.0, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "T_f",   "time": 0.0, "expected": 8.221752407798919, "tolerance": {"abs": 0.0, "rel": 0.0}}
                    ]
                },
                {
                    "id": "code_2_timber_grass",
                    "description": "Anderson fuel model 2 (timber/grass/shrub understory): code=2 → verify σ and T_f (same T_f as model 1 but different σ and w₀).",
                    "parameter_overrides": {"code": 2.0},
                    "time_span": {"start": 0.0, "end": 1.0},
                    "assertions": [
                        {"variable": "sigma", "time": 0.0, "expected": 9842.51968503937, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "w_0",   "time": 0.0, "expected": 0.4491833425472406, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "M_x",   "time": 0.0, "expected": 0.15, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "T_f",   "time": 0.0, "expected": 8.221752407798919, "tolerance": {"abs": 0.0, "rel": 0.0}}
                    ]
                },
                {
                    "id": "code_4_chaparral_all_properties",
                    "description": "Anderson fuel model 4 (chaparral): code=4 → verify all six properties. Model 4 has the deepest fuel bed (1.8288 m) and the longest residence time (≈211.4 s) of the shrub/brush group.",
                    "parameter_overrides": {"code": 4.0},
                    "time_span": {"start": 0.0, "end": 1.0},
                    "assertions": [
                        {"variable": "sigma", "time": 0.0, "expected": 5705.380577427822, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "w_0",   "time": 0.0, "expected": 1.1229583563681016, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "delta", "time": 0.0, "expected": 1.8288, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "M_x",   "time": 0.0, "expected": 0.20, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "h",     "time": 0.0, "expected": 18608000.0, "tolerance": {"abs": 0.0, "rel": 0.0}},
                        {"variable": "T_f",   "time": 0.0, "expected": 211.4164904862579, "tolerance": {"abs": 0.0, "rel": 0.0}}
                    ]
                },
                {
