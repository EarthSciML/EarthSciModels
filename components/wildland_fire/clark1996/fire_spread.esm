                        {"variable": "S_f", "time": 0.0, "expected": 0.4179479281204271},
                        {"variable": "ground_burn_rate", "time": 0.0, "expected": 0.043433857760968},
                        {"variable": "F_s", "time": 0.0, "expected": 716224.3144783623},
                        {"variable": "F_l", "time": 0.0, "expected": 82958.66832344889}
                    ]
