                        {"variable": "canopy_burning", "time": 0.0, "expected": 0.0, "tolerance": {"abs": 1.0e-15}},
                        {"variable": "ground_burn_rate", "time": 0.0, "expected": 0.037040518354904265},
                        {"variable": "total_burn_rate", "time": 0.0, "expected": 0.037040518354904265},
                        {"variable": "F_s", "time": 0.0, "expected": 610798.1476723714},
                        {"variable": "F_l", "time": 0.0, "expected": 70747.39005786716}
