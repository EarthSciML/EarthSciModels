                            "description": "Normal direction ψ (rad) vs. γ (rad) — relationship between the direction from ignition and the normal to the perimeter.",
                            "x": {
                                "variable": "γ",
                                "label": "γ (rad)"
                            },
                            "y": {
                                "variable": "ψ",
                                "label": "ψ (rad)"
                            }
                        }
                    ]
                },
                {
                    "id": "perimeter_sweep_ellipse_aspect",
                    "description": "Sensitivity of R_ψ to the ellipse aspect ratio (h/f) at fixed f=100 m, g=50 m, across three sample directions γ ∈ {0, π/4, π/2}. Surfaces how the ellipse shape modulates the perimeter spread rate.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "h",
                                "range": {
                                    "start": 10.0,
                                    "stop": 100.0,
                                    "count": 10,
                                    "scale": "linear"
                                }
                            },
                            {
                                "parameter": "γ",
                                "range": {
                                    "start": 0.0,
                                    "stop": 1.5707963267948966,
                                    "count": 3,
                                    "scale": "linear"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "R_psi_surface",
                            "type": "heatmap",
                            "description": "R_ψ over the (h, γ) plane — full 2D surface of perimeter spread rate sensitivity to ellipse aspect and direction.",
                            "x": {
                                "variable": "h",
                                "label": "h (m)"
                            },
                            "y": {
                                "variable": "γ",
                                "label": "γ (rad)"
                            },
                            "value": {
