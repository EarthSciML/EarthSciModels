      "tests": [
        {
          "id": "cgrate_lal_low",
          "description": "LAL = 1.0 (< 1.5): CGRATE = 0 (no lightning activity at very low LAL).",
          "parameter_overrides": {
            "LAL": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 0.0
          },
          "assertions": [
            {
              "variable": "CGRATE",
              "time": 0.0,
              "expected": 0.0
            }
          ]
        },
        {
          "id": "cgrate_lal_mid",
          "description": "LAL = 3.0 (in [2.5, 3.5)): CGRATE = 12.5 (moderate lightning activity).",
          "parameter_overrides": {
