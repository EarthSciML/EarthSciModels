{
    "esm": "0.4.0",
    "models": {
        "BurningIndex": {
            "variables": {
                "ms_to_fpm": {
                    "units": "1",
                    "default": 196.8504,
                    "type": "parameter",
                    "description": "Numerical conversion: m/s to ft/min (dimensionless)"
                },
                "fuels_wet": {
                    "units": "1",
                    "default": 0,
                    "type": "parameter",
                    "description": "Flag: 1 if fuels wet or snow-covered (dimensionless)"
                },
                "ERC": {
                    "units": "1",
                    "type": "parameter",
                    "description": "Energy release component (dimensionless)"
                },
                "SC": {
                    "units": "m/s",
                    "type": "parameter",
                    "description": "Spread component"
                },
                "V_ref": {
                    "units": "m/s",
                    "default": 1,
                    "type": "parameter",
                    "description": "Reference velocity for non-dimensionalization"
                },
                "BI": {
                    "units": "1",
                    "type": "state",
                    "description": "Burning index (dimensionless)"
                }
            },
            "reference": {
                "notes": "source_ref: WildlandFire.jl@126976f2508ceacca6c486b21ae6da5b168c6f46:src/nfdrs.jl:1231\nThe Burning Index (BI) is calculated as BI = 3.01 × (SC × ERC)^0.46, where SC (spread component) is converted from m/s to ft/min for the calculation. The max(0.0, ...) ensures non-negative input to the power function. When fuels_wet > 0.5, BI is set to 0.0."
            },
            "equations": [
                {
                    "rhs": {
                        "args": [
                            {
                                "args": [
                                    0.5,
                                    "fuels_wet"
                                ],
                                "op": "<"
                            },
                            0,
                            {
                                "args": [
                                    3.01,
                                    {
                                        "args": [
                                            {
                                                "args": [
                                                    {
                                                        "args": [
                                                            {
                                                                "args": [
                                                                    {
                                                                        "args": [
                                                                            {
                                                                                "args": [
                                                                                    "ms_to_fpm",
                                                                                    "ERC",
                                                                                    "SC"
                                                                                ],
                                                                                "op": "*"
                                                                            },
                                                                            "V_ref"
                                                                        ],
                                                                        "op": "/"
                                                                    },
                                                                    0.46
                                                                ],
                                                                "op": "*"
                                                            },
                                                            0
                                                        ],
                                                        "op": ">"
                                                    },
                                                    {
                                                        "args": [
                                                            {
                                                                "args": [
                                                                    {
                                                                        "args": [
                                                                            "ms_to_fpm",
                                                                            "ERC",
                                                                            "SC"
                                                                        ],
                                                                        "op": "*"
                                                                    },
                                                                    "V_ref"
                                                                ],
                                                                "op": "/"
                                                            },
                                                            0.46
                                                        ],
                                                        "op": "*"
                                                    },
                                                    0
                                                ],
                                                "op": "ifelse"
                                            }
                                        ],
                                        "op": "^"
                                    }
                                ],
                                "op": "*"
                            }
                        ],
                        "op": "ifelse"
                    },
                    "lhs": "BI"
                }
            ],
            "tolerance": {
                "rel": 1.0e-6
            }
        }
    },
    "metadata": {
        "name": "BurningIndex",
        "references": [
            {
                "citation": "Cohen, J. D., & Deeming, J. E. (1985). The National Fire-Danger Rating System: basic equations. Gen. Tech. Rep. PSW-82. Berkeley, CA: USDA Forest Service, Pacific Southwest Forest and Range Experiment Station. Page 12 (Burning Index)."
            }
