            "tests": [
                {
                    "id": "green_stage_high_moisture",
                    "description": "Green stage (MCHRBP > 1.2): is_cured=0, is_greenup=0, is_annual=0 (perennial), CLIMAT=2. X1000=0.03 ⇒ MCHRBP = (-100 + 14*3)/100 = 0.42. Since MCHRBP ≤ 1.2, uses transition equation for perennials: max(0.3, min(1.5, (11.2 + 7.4*3)/100)) = max(0.3, min(1.5, 0.334)) = 0.334.",
                    "parameter_overrides": {
                        "X1000": 0.03,
                        "MC1": 0.1,
                        "CLIMAT": 2.0,
                        "is_annual": 0.0,
                        "GRNDAY": 0.0,
                        "is_greenup": 0.0,
                        "is_cured": 0.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "MCHERB", "time": 0.0, "expected": 0.334 }
                    ]
                },
                {
                    "id": "greenup_stage",
                    "description": "Greenup stage: is_cured=0, is_greenup=1, CLIMAT=2, X1000=0.02, GRNDAY=14. GREN = min(1, 14/(7*2)) = 1. MCHRBP = (-100 + 14*2)/100 = 0.28. MCHERB = 0.3 + (max(0.3, 0.28) - 0.3) * 1 = 0.3.",
                    "parameter_overrides": {
                        "X1000": 0.02,
                        "MC1": 0.1,
                        "CLIMAT": 2.0,
