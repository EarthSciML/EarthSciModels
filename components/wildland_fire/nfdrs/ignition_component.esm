            ],
            "tests": [
                {
                    "name": "high_temperature_low_moisture",
                    "description": "High temperature (40°C) and low fuel moisture (5%) should produce high IC",
                    "initial_state": {
                        "TMPPRM": 313.15,
                        "MC1": 0.05,
                        "SC": 0.01,
                        "SCM": 0.005
                    },
                    "time_span": {"start": 0.0, "end": 1.0},
                    "assertions": [
                        {
                            "variable": "IC",
                            "operator": ">",
                            "value": 0,
                            "description": "IC should be positive under high risk conditions"
                        },
                        {
                            "variable": "PI",
                            "operator": ">",
                            "value": 0,
                            "description": "Probability of ignition should be positive"
                        }
                    ]
                },
                {
                    "name": "low_temperature_high_moisture",
                    "description": "Low temperature (10°C) and high fuel moisture (20%) should produce low IC",
                    "initial_state": {
                        "TMPPRM": 283.15,
                        "MC1": 0.20,
                        "SC": 0.001,
                        "SCM": 0.005
                    },
                    "time_span": {"start": 0.0, "end": 1.0},
                    "assertions": [
                        {
                            "variable": "IC",
                            "operator": ">=",
                            "value": 0,
                            "description": "IC should be non-negative"
                        },
                        {
                            "variable": "IC",
                            "operator": "<=",
                            "value": 100,
                            "description": "IC should be at most 100"
                        }
                    ]
                },
                {
                    "name": "moderate_conditions",
                    "description": "Moderate temperature (25°C) and moderate fuel moisture (10%)",
                    "initial_state": {
                        "TMPPRM": 298.15,
                        "MC1": 0.10,
                        "SC": 0.005,
                        "SCM": 0.005
                    },
                    "time_span": {"start": 0.0, "end": 1.0},
                    "assertions": [
                        {
                            "variable": "IC",
                            "operator": ">=",
                            "value": 0,
                            "description": "IC should be non-negative"
                        },
                        {
                            "variable": "QIGN",
                            "operator": "<",
                            "value": 144.5,
                            "description": "QIGN should be less than maximum (144.5)"
                        }
                    ]
                },
                {
                    "name": "boundary_ic_range",
                    "description": "Verify IC stays within 0-100 range across conditions",
                    "initial_state": {
                        "TMPPRM": 303.15,
                        "MC1": 0.08,
                        "SC": 0.015,
                        "SCM": 0.005
                    },
                    "time_span": {"start": 0.0, "end": 1.0},
                    "assertions": [
                        {
                            "variable": "IC",
                            "operator": ">=",
                            "value": 0,
                            "description": "IC lower bound"
                        },
                        {
                            "variable": "IC",
                            "operator": "<=",
                            "value": 100,
                            "description": "IC upper bound"
                        },
                        {
                            "variable": "PI",
                            "operator": ">=",
                            "value": 0,
                            "description": "PI lower bound"
                        },
                        {
                            "variable": "PI",
                            "operator": "<=",
                            "value": 100,
                            "description": "PI upper bound"
                        }
                    ]
                }
            ]
        }
    },
    "metadata": {
        "name": "IgnitionComponent",
        "tags": [
            "wildland-fire",
            "nfdrs",
            "ignition"
        ],
        "description": "NFDRS Ignition Component (IC) - calculates probability of ignition and reportable fire",
        "authors": [
            "Cohen & Deeming (1985)",
            "EarthSciML Authors"
        ]
    }
}
