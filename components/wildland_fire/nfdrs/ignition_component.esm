{
    "esm": "0.1.0",
    "models": {
        "IgnitionComponent": {
            "variables": {
                "QIGN": {
                    "type": "state",
                    "description": "Heat of ignition (dimensionless)"
                },
                "CHI": {
                    "type": "state",
                    "description": "Intermediate variable (dimensionless)"
                },
                "MC1": {
                    "type": "parameter",
                    "description": "1-hour fuel moisture content (dimensionless)"
                },
                "TMPPRM": {
                    "type": "parameter",
                    "description": "Temperature at fuel-atmosphere interface"
                },
                "SC": {
                    "type": "parameter",
                    "description": "Spread component"
                },
                "PI": {
                    "type": "state",
                    "description": "Probability of ignition 0-100 (dimensionless)"
                },
                "PFI": {
                    "type": "state",
                    "description": "Probability of reportable fire given ignition (dimensionless)"
                },
                "V_ref": {
                    "default": 1,
                    "type": "parameter",
                    "description": "Reference velocity for non-dimensionalization"
                },
                "K_ref": {
                    "default": 1,
                    "type": "parameter",
                    "description": "Reference temperature for non-dimensionalization"
                },
                "SCM": {
                    "type": "parameter",
                    "description": "Spread component threshold for reportable fires"
                },
                "IC": {
                    "type": "state",
                    "description": "Ignition component 0-100 (dimensionless)"
                },
                "SCN": {
                    "type": "state",
                    "description": "Normalized spread component (dimensionless)"
                },
                "PNORM3": {
                    "default": 1.85e-5,
                    "type": "parameter",
                    "description": "P(I) scaling factor 3 (dimensionless)"
                },
                "PNORM1": {
                    "default": 0.00232,
                    "type": "parameter",
                    "description": "P(I) scaling factor 1 (dimensionless)"
                },
                "PNORM2": {
                    "default": 0.99767,
                    "type": "parameter",
                    "description": "P(I) scaling factor 2 (dimensionless)"
                },
                "K_to_C": {
                    "default": 273.15,
                    "type": "parameter",
                    "description": "Kelvin to Celsius offset (dimensionless)"
                }
            },
            "examples": [
                {
                    "id": "typical_summer_conditions",
                    "description": "Typical summer conditions with moderate temperature and fuel moisture",
                    "initial_state": {
                        "TMPPRM": 298.15,
                        "MC1": 0.10,
                        "SC": 0.01,
                        "SCM": 0.005
                    },
                    "time_span": {"start": 0.0, "end": 1.0}
                },
                {
                    "id": "high_risk_conditions",
                    "description": "High fire risk with high temperature and low fuel moisture",
                    "initial_state": {
                        "TMPPRM": 313.15,
                        "MC1": 0.05,
                        "SC": 0.02,
                        "SCM": 0.005
                    },
                    "time_span": {"start": 0.0, "end": 1.0}
                },
                {
                    "id": "low_risk_conditions",
                    "description": "Low fire risk with low temperature and high fuel moisture",
                    "initial_state": {
                        "TMPPRM": 283.15,
                        "MC1": 0.20,
                        "SC": 0.001,
                        "SCM": 0.005
                    },
                    "time_span": {"start": 0.0, "end": 1.0}
                }
            ],
            "reference": {
                "notes": "source_ref: WildlandFire.jl/src/nfdrs.jl:1291\nNFDRS Ignition Component (IC) - calculates probability of ignition and reportable fire\n\nFrom Cohen & Deeming (1985), pages 12-13:\n- IC = 0.10 × P(I) × P(F/I)\n- QIGN equation from page 13\n\nTODO_GAP: gt-p3ep - registered function needed for 'max' operator\nTODO_GAP: gt-p3ep - registered function needed for 'min' operator",
                "source": "Cohen, J.D., and Deeming, J.E. (1985). The National Fire-Danger Rating System: The Ignition Component. General Technical Report INT-188. Ogden, UT: U.S. Department of Agriculture, Forest Service, Intermountain Forest and Range Experiment Station. 26 p."
            },
