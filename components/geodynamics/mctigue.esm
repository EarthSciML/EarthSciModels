            "tests": [
                {
                    "id": "table1_correctness",
                    "description": "Primary numerical correctness test using Table 1 parameters from Taylor et al. (2021): G=4 GPa, ν=0.25, ΔP=2 MPa, a=1 km, d=4 km, evaluated at x=5 km. Verifies all three state variables (R, Ur, Uz) against precomputed reference values from Eqs. 3–4: R = sqrt(5000²+4000²) = 6403.124..., McTigue correction C ≈ 1.005261, Ur = Mogi_Ur × C ≈ 7.1797e-3 m, Uz = Mogi_Uz × C ≈ 5.7437e-3 m. Reference values from upstream 'McTigue Equation Correctness' test (test/mogi_mctigue_test.jl:116).",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_overrides": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": 2.0e6,
                        "a": 1000.0,
                        "d": 4000.0,
                        "x": 5000.0
                    },
                    "assertions": [
                        {"variable": "R",  "time": 0.0, "expected": 6403.1242374328485,    "tolerance": {"rel": 1.0e-10}},
                        {"variable": "Ur", "time": 0.0, "expected": 0.007179665914415501,  "tolerance": {"rel": 1.0e-10}},
                        {"variable": "Uz", "time": 0.0, "expected": 0.005743732731532400,  "tolerance": {"rel": 1.0e-10}}
                    ]
                },
                {
                    "id": "kilauea_deflation_event",
                    "description": "Kīlauea June 2007 deflation event (Table 3, Taylor et al. 2021): G=4 GPa, ν=0.25, ΔP=−3.73 MPa (deflation), a=800 m, d=2000 m, x=3000 m. ε=a/d=0.4, McTigue correction C≈1.01552. Negative overpressure (deflation) produces negative radial displacement (inward) and negative vertical displacement (subsidence). McTigue magnitudes are slightly larger than Mogi because C > 1 for ε=0.4. Reference values precomputed from Eqs. 3–4 with Table 3 parameters.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_overrides": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": -3.73e6,
                        "a": 800.0,
                        "d": 2000.0,
                        "x": 3000.0
                    },
                    "assertions": [
                        {"variable": "Ur", "time": 0.0, "expected": -0.023274163748791293, "tolerance": {"rel": 1.0e-10}},
                        {"variable": "Uz", "time": 0.0, "expected": -0.015516109165860862, "tolerance": {"rel": 1.0e-10}}
                    ]
                },
                {
                    "id": "reduces_to_mogi_small_epsilon",
                    "description": "When ε = a/d → 0, the McTigue correction → 1 and results should match the Mogi model. Tested with a very small source radius relative to depth: a=10 m, d=10 km → ε=0.001, ε³=1e-9. The correction term is ~8e-10 (negligible at rtol=1e-6). Reference values precomputed from Eqs. 3–4; they are numerically indistinguishable from the Mogi Eqs. 1–2 values at float64 precision. This test reproduces the upstream 'McTigue Reduces to Mogi for Small ε' testitem (test/mogi_mctigue_test.jl:153).",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_overrides": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": 2.0e6,
                        "a": 10.0,
                        "d": 10000.0,
                        "x": 5000.0
                    },
                    "assertions": [
                        {"variable": "Ur", "time": 0.0, "expected": 1.341640787579020e-9, "tolerance": {"rel": 1.0e-6}},
                        {"variable": "Uz", "time": 0.0, "expected": 2.683281575158040e-9, "tolerance": {"rel": 1.0e-6}}
                    ]
                },
                {
                    "id": "large_epsilon_correction_visible",
                    "description": "At ε=a/d=0.5 (a=2000 m, d=4000 m), the McTigue correction C≈1.0421 (4.2% larger than Mogi). Verifies that the finite-sphere correction becomes significant at larger source radii. Reference values precomputed from Eqs. 3–4; correction factor C = 1.0420864262990457 as computed from the formula at ν=0.25, ε=0.5, x=5000 m.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_overrides": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": 2.0e6,
                        "a": 2000.0,
                        "d": 4000.0,
                        "x": 5000.0
                    },
                    "assertions": [
                        {"variable": "Ur", "time": 0.0, "expected": 0.05954142344201548, "tolerance": {"rel": 1.0e-10}},
                        {"variable": "Uz", "time": 0.0, "expected": 0.04763313875361238, "tolerance": {"rel": 1.0e-10}}
                    ]
                },
                {
                    "id": "sign_convention_positive_dp",
                    "description": "Sign convention for positive overpressure (inflation): ΔP > 0 produces positive radial displacement (Ur > 0, outward) at positive x, and positive vertical displacement (Uz > 0, uplift). Same sign convention as Mogi — the McTigue correction is always positive for ν=0.25. Default Table 1 parameters (ΔP=2 MPa, x=5 km). Reference values same as table1_correctness.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_overrides": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": 2.0e6,
                        "a": 1000.0,
                        "d": 4000.0,
                        "x": 5000.0
                    },
                    "assertions": [
                        {"variable": "Ur", "time": 0.0, "expected": 0.007179665914415501, "tolerance": {"rel": 1.0e-10}},
                        {"variable": "Uz", "time": 0.0, "expected": 0.005743732731532400, "tolerance": {"rel": 1.0e-10}}
                    ]
                },
                {
                    "id": "displacement_linear_in_dp",
                    "description": "Displacements scale linearly with overpressure ΔP — the McTigue correction C does not depend on ΔP, so the linearity is inherited from the Mogi pre-factor. Doubling ΔP from 2 MPa to 4 MPa doubles both Ur and Uz exactly. Table 1 geometry (a=1000, d=4000, x=5000).",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_overrides": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": 4.0e6,
                        "a": 1000.0,
                        "d": 4000.0,
                        "x": 5000.0
                    },
                    "assertions": [
                        {"variable": "Ur", "time": 0.0, "expected": 0.014359331828831002, "tolerance": {"rel": 1.0e-10}},
                        {"variable": "Uz", "time": 0.0, "expected": 0.011487465463064801, "tolerance": {"rel": 1.0e-10}}
                    ]
                },
                {
                    "id": "uz_maximum_near_origin",
                    "description": "Uz is maximized directly above the source (x→0). At x≈0, the McTigue correction C→1+ε³×[(1+ν)/(2(−7+5ν))+15d²(−2+ν)/(4d²(−7+5ν))] = 1+ε³×(1+ν)(−2+ν)×... Evaluated at x=0.001 m (near-zero). Reference value Uz≈0.023816 m (≈Mogi value 0.023438 m × correction C≈1.01606 at x≈0). rtol=1e-6 since x=0.001 introduces a negligible deviation from the true x=0 maximum.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_overrides": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": 2.0e6,
                        "a": 1000.0,
                        "d": 4000.0,
                        "x": 0.001
                    },
                    "assertions": [
                        {"variable": "Uz", "time": 0.0, "expected": 0.023815652598503174, "tolerance": {"rel": 1.0e-6}}
                    ]
                }
            ],
            "examples": [
                {
                    "id": "displacement_profile_vs_distance",
                    "description": "Horizontal-radial (Ur) and vertical (Uz) surface displacement profiles as a function of horizontal distance x from the source, using Table 1 parameters (G=4 GPa, ν=0.25, ΔP=2 MPa, a=1 km, d=4 km). The McTigue correction shifts the Ur peak slightly inward relative to the Mogi x_crit = d/sqrt(2) ≈ 2.83 km. Both displacements decay to near-zero beyond ~20 km from the source.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameters": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": 2.0e6,
                        "a": 1000.0,
                        "d": 4000.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "x",
                                "range": {"start": 200.0, "stop": 20000.0, "count": 100, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "Ur_vs_x",
                            "type": "line",
                            "description": "Horizontal-radial displacement Ur (m) vs horizontal distance x (m) from the McTigue model. Peak is slightly inward from the Mogi x_crit = d/sqrt(2) due to the finite-sphere correction.",
                            "x": {"variable": "x", "label": "Horizontal distance x (m)"},
                            "y": {"variable": "Ur", "label": "Horizontal-radial displacement Ur (m)"}
                        },
                        {
                            "id": "Uz_vs_x",
                            "type": "line",
                            "description": "Vertical displacement Uz (m) vs horizontal distance x (m) from the McTigue model. Maximum directly above the source (x=0), decays monotonically.",
                            "x": {"variable": "x", "label": "Horizontal distance x (m)"},
                            "y": {"variable": "Uz", "label": "Vertical displacement Uz (m)"}
                        }
                    ]
                },
                {
                    "id": "correction_growth_with_epsilon",
                    "description": "Effect of increasing source radius a (and hence ε = a/d) on the McTigue vertical displacement Uz at the point directly above the source (x=1 m, approximating x=0). As a increases from 500 m to 2500 m (ε from 0.125 to 0.625), the finite-sphere correction amplifies the displacement relative to the Mogi point-source limit. Depth d=4 km, Table 1 elastic parameters.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameters": {
                        "G": 4.0e9,
                        "ν": 0.25,
                        "ΔP": 2.0e6,
                        "d": 4000.0,
                        "x": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "a",
                                "range": {"start": 500.0, "stop": 2500.0, "count": 50, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "Uz_vs_a",
                            "type": "line",
                            "description": "Vertical displacement Uz (m) vs source radius a (m), evaluated near x=0 to capture the peak Uz above the source. The super-cubic growth (a^3 × increasing correction C(ε)) is visible.",
                            "x": {"variable": "a", "label": "Source radius a (m)"},
                            "y": {"variable": "Uz", "label": "Vertical displacement Uz (m)"}
                        }
                    ]
                }
            ]
        }
    }
}
