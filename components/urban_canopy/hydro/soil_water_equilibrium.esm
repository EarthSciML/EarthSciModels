            "examples": [
                {
                    "id": "theta_E_and_psi_E_vs_z_v",
                    "description": "Drying curves: θ_E and ψ_E vs. water table depth z_v for the standard sandy-loam layer (z_h_upper = 0.05 m, z_h_lower = 0.25 m). Sweep covers z_v ∈ [0.3, 10] m, staying in the real-valued domain of Eq. 5.101 (z_v > z_h_lower − |ψ_sat| ≈ 0.214 m). The saturated plateau (θ_E = θ_sat, z_v < z_h_upper) is not shown because the plot renderer uses eager evaluation of the ifelse else-branch which produces complex-valued intermediate results for z_v < z_h_lower − |ψ_sat|.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "θ_sat": 0.434,
                        "ψ_sat": -0.036,
                        "B": 4.05,
                        "z_h_upper": 0.05,
                        "z_h_lower": 0.25,
                        "ψ_min": -100000.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "z_v",
                                "range": { "start": 0.3, "stop": 10.0, "count": 50, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "theta_E_vs_z_v_line",
                            "type": "line",
                            "description": "θ_E vs z_v unsaturated drying curve — power-law decay as the water table deepens.",
                            "x": { "variable": "z_v", "label": "z_v (m, water table depth)" },
                            "y": { "variable": "θ_E", "label": "θ_E (m³/m³)" }
                        },
                        {
                            "id": "psi_E_vs_z_v_line",
                            "type": "line",
                            "description": "ψ_E vs z_v — equilibrium matric potential deepening as the water table drops.",
                            "x": { "variable": "z_v",  "label": "z_v (m, water table depth)" },
                            "y": { "variable": "ψ_E", "label": "ψ_E (m)" }
                        }
                    ]
                },
                {
                    "id": "theta_E_soil_type_heatmap",
                    "description": "θ_E as a joint function of water table depth z_v and Clapp-Hornberger exponent B, sweeping z_v ∈ [0.3, 10.0] m and B ∈ [3.0, 12.0] (sand to clay range). The heatmap surfaces the strong interaction: at any given z_v, clay soils (high B) retain far more water than sandy soils (low B), while at any given B, θ_E decays monotonically with z_v. Sweep starts at z_v = 0.3 m (real-valued domain for Eq. 5.101; z_v < 0.25 − |ψ_sat| is the complex boundary).",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "θ_sat": 0.434,
                        "ψ_sat": -0.036,
                        "z_h_upper": 0.05,
                        "z_h_lower": 0.25,
                        "ψ_min": -100000.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "z_v",
                                "range": { "start": 0.3, "stop": 10.0, "count": 20, "scale": "linear" }
                            },
                            {
                                "parameter": "B",
                                "range": { "start": 3.0, "stop": 12.0, "count": 15, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "theta_E_heatmap",
                            "type": "heatmap",
                            "description": "θ_E as a function of (z_v, B) — shows the strong soil-texture control on equilibrium water content.",
                            "x": { "variable": "z_v", "label": "z_v (m, water table depth)" },
                            "y": { "variable": "B",   "label": "B (Clapp-Hornberger exponent)" },
                            "value": { "variable": "θ_E", "reduce": "final" }
                        }
                    ]
                }
            ]
        }
    }
}
