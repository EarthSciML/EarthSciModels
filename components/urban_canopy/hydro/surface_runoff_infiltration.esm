                        { "variable": "v",          "time": 0.0, "expected": -25.0 },
                        { "variable": "q_infl_max", "time": 0.0, "expected": 0.26 },
                        { "variable": "q_over",     "time": 0.0, "expected": 2.0e-4 },
                        { "variable": "q_infl",     "time": 0.0, "expected": 0.0, "tolerance": { "abs": 1.0e-15 } }
                    ]
