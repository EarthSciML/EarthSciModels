                }
            ],
            "examples": [
                {
                    "id": "vapor_pressure_vs_specific_humidity_sweep",
                    "description": "Sweep q_atm from 0 to 0.05 kg/kg at fixed P_atm = 101325 Pa, T_atm = 293.15 K to surface the vapor-pressure inversion (Eq. 1): e_atm = q_atm * P_atm / (epsilon + (1-epsilon) * q_atm). The curve passes through the origin (q = 0 → e = 0) and grows nearly linearly at small q with slope P_atm / epsilon ≈ 162900 Pa per (kg/kg), bending sublinearly as the denominator (1-epsilon)*q_atm starts to compete with epsilon. The accompanying rho_atm curve drops as q_atm rises, mirroring the (1-epsilon)*e_atm humidity correction in Eq. 2.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "P_atm": 101325.0,
                        "T_atm": 293.15,
                        "z_prime_atm": 30.0,
                        "z_0": 1.0,
                        "z_d": 5.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "q_atm",
                                "range": { "start": 0.0, "stop": 0.05, "count": 21, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "e_atm_vs_q",
                            "type": "line",
                            "description": "Vapor pressure vs specific humidity at standard P, T: through-origin curve that bends sublinearly as q rises, per Eq. 1.",
                            "x": { "variable": "q_atm", "label": "q_atm (kg/kg)" },
                            "y": { "variable": "e_atm", "label": "e_atm (Pa)" }
                        },
                        {
                            "id": "rho_atm_vs_q",
                            "type": "line",
                            "description": "Air density vs specific humidity at standard P, T: monotonic decline as moist-air correction in Eq. 2 subtracts (1-epsilon)*e_atm from P_atm.",
                            "x": { "variable": "q_atm",   "label": "q_atm (kg/kg)" },
                            "y": { "variable": "rho_atm", "label": "rho_atm (kg/m^3)" }
                        }
                    ]
                },
                {
                    "id": "air_density_temperature_sweep",
                    "description": "Sweep T_atm from 250 to 320 K at fixed P_atm = 101325 Pa, q_atm = 0.01 kg/kg, surfacing the 1/T scaling of the ideal-gas law (Eq. 2). e_atm is T-independent (Eq. 1 has no T term) so it stays flat at 1619.25 Pa across the sweep; rho_atm drops smoothly from 1.412 kg/m^3 at 250 K to 1.097 kg/m^3 at 320 K, exhibiting the strong negative dependence on temperature that drives buoyancy in convective boundary layers.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "q_atm": 0.01,
                        "P_atm": 101325.0,
                        "z_prime_atm": 30.0,
                        "z_0": 1.0,
                        "z_d": 5.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T_atm",
                                "range": { "start": 250.0, "stop": 320.0, "count": 15, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "rho_atm_vs_T",
                            "type": "line",
                            "description": "Air density vs temperature at standard P and q: 1/T-shaped decay, per Eq. 2.",
                            "x": { "variable": "T_atm",   "label": "T_atm (K)" },
                            "y": { "variable": "rho_atm", "label": "rho_atm (kg/m^3)" }
                        }
                    ]
                },
                {
                    "id": "air_density_pressure_temperature_heatmap",
                    "description": "Joint sweep over (T_atm, P_atm) at fixed q_atm = 0.01 kg/kg, showing the bilinear-reciprocal structure of Eq. 2: rho_atm grows linearly with P_atm at fixed T and decays as 1/T at fixed P. Iso-rho contours follow curves of constant P/T (isentropes for an ideal gas), useful for visualizing the parameter regime of typical urban boundary-layer states (P in [95, 105] kPa, T in [260, 310] K spanning winter to summer).",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "q_atm": 0.01,
                        "z_prime_atm": 30.0,
                        "z_0": 1.0,
                        "z_d": 5.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T_atm",
                                "range": { "start": 260.0, "stop": 310.0, "count": 11, "scale": "linear" }
                            },
                            {
                                "parameter": "P_atm",
                                "range": { "start": 95000.0, "stop": 105000.0, "count": 11, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "rho_atm_T_P_heatmap",
                            "type": "heatmap",
                            "description": "rho_atm in (T_atm, P_atm) space at q_atm = 0.01: bilinear-reciprocal surface with iso-rho contours along P/T = const.",
                            "x": { "variable": "T_atm", "label": "T_atm (K)" },
                            "y": { "variable": "P_atm", "label": "P_atm (Pa)" },
                            "value": { "variable": "rho_atm", "reduce": "final" }
                        }
                    ]
                }
            ]
        }
    }
