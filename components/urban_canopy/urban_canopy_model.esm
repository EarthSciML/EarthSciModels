            }
          ]
        },
        "atmos": {
          "variables": {
            "kappa_boltz": {
              "type": "parameter",
              "units": "J/K",
              "default": 1.38065e-23,
              "description": "Boltzmann constant (Oleson Table 1.4) \u2014 upstream `@constants` \u03ba_boltz; the per-particle gas constant for Avogadro-scaling the universal gas constant"
            },
            "N_A": {
              "type": "parameter",
              "units": "mol^-1",
              "default": 6.02214e+23,
              "description": "Avogadro's number (Oleson Table 1.4) \u2014 upstream `@constants` N_A; the conversion factor from per-mole to per-particle (Oleson uses kmol in the table; this value is converted to SI mol)"
            },
            "MW_da": {
              "type": "parameter",
              "units": "kg/mol",
              "default": 0.028966,
              "description": "Molecular weight of dry air (Oleson Table 1.4) \u2014 upstream `@constants` MW_da; standard atmospheric mean (Oleson reports 28.966 kg/kmol; here in SI kg/mol)"
            },
            "MW_wv": {
              "type": "parameter",
              "units": "kg/mol",
              "default": 0.018016,
              "description": "Molecular weight of water vapor (Oleson Table 1.4) \u2014 upstream `@constants` MW_wv; standard H2O molecular weight (Oleson reports 18.016 kg/kmol; here in SI kg/mol)"
            },
            "R_gas": {
              "type": "parameter",
              "units": "J/(K*mol)",
              "default": 8.314467591,
              "description": "Universal gas constant R_gas = N_A * kappa_boltz (Oleson Table 1.4) \u2014 upstream `@constants` R_gas; the IEEE-754 double-precision product of the upstream Avogadro and Boltzmann defaults (matches Julia bit-for-bit). Not used in this component's equations but preserved as part of the upstream component's public constant interface"
            },
            "R_da": {
              "type": "parameter",
              "units": "J/(K*kg)",
              "default": 287.0423113650487,
              "description": "Specific gas constant for dry air R_da = R_gas / MW_da (Oleson Table 1.4) \u2014 upstream `@constants` R_da; appears as the denominator scale of the ideal-gas law in Eq. 2 of this component. The IEEE-754 double-precision quotient of the upstream R_gas / MW_da defaults (matches Julia bit-for-bit, slightly tighter than the rounded 287.042 used in the upstream test docstring)"
            },
            "epsilon_ratio": {
              "type": "parameter",
              "units": "1",
              "default": 0.6219705862045157,
              "description": "Ratio of molecular weights epsilon = MW_wv / MW_da (Oleson Table 1.4) \u2014 upstream `@constants` \u03b5_ratio; appears in the denominator of the vapor-pressure inversion (Eq. 1). The IEEE-754 double-precision quotient of MW_wv / MW_da (matches Julia bit-for-bit; commonly rounded to 0.622 in textbook references)"
            },
            "one_minus_epsilon": {
              "type": "parameter",
              "units": "1",
              "default": 0.37802941379548427,
              "description": "Complement 1 - epsilon = 1 - MW_wv / MW_da (Oleson Table 1.4) \u2014 upstream `@constants` one_minus_\u03b5; appears as the coefficient of q_atm in the vapor-pressure denominator (Eq. 1) and as the coefficient of e_atm in the air-density numerator (Eq. 2). The IEEE-754 double-precision 1.0 - epsilon_ratio (commonly rounded to 0.378)"
            },
            "z_prime_atm": {
              "type": "state",
              "units": "m",
              "default": 30.0,
              "description": "Atmospheric reference height from the driving atmospheric model (Oleson Table 1.1) \u2014 z'_atm, the height above the zero datum at which the atmospheric forcing variables are reported. Combined with z_0 and z_d in Eq. 3 to produce the effective z_atm used by the urban-canopy flux computations"
            },
            "u_atm": {
              "type": "parameter",
              "units": "m/s",
              "default": 0.0,
              "description": "Zonal wind at the atmospheric reference height (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy momentum-flux components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "v_atm": {
              "type": "parameter",
              "units": "m/s",
              "default": 0.0,
              "description": "Meridional wind at the atmospheric reference height (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy momentum-flux components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "theta_atm": {
              "type": "parameter",
              "units": "K",
              "default": 293.15,
              "description": "Atmospheric potential temperature at the reference height (Oleson Table 1.1) \u2014 upstream `@parameters` \u03b8_atm; passthrough atmospheric forcing input consumed by downstream urban-canopy sensible-heat-flux components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "q_atm": {
              "type": "state",
              "units": "kg/kg",
              "default": 0.01,
              "description": "Specific humidity at the atmospheric reference height (Oleson Table 1.1) \u2014 input to the vapor-pressure inversion (Eq. 1) and indirectly the air-density correction (Eq. 2). Mass of water vapor per mass of moist air; typical mid-latitude values 0.001-0.02 kg/kg"
            },
            "P_atm": {
              "type": "state",
              "units": "Pa",
              "default": 101325.0,
              "description": "Atmospheric pressure at the reference height (Oleson Table 1.1) \u2014 total pressure, input to both Eq. 1 (numerator of vapor-pressure inversion) and Eq. 2 (numerator of ideal-gas law). Default is the standard sea-level atmosphere (101325 Pa)"
            },
            "T_atm": {
              "type": "state",
              "units": "K",
              "default": 293.15,
              "description": "Atmospheric temperature at the reference height (Oleson Table 1.1) \u2014 input to the ideal-gas air-density equation (Eq. 2). Default is the standard sea-level temperature (293.15 K = 20 degC)"
            },
            "L_atm_down": {
              "type": "parameter",
              "units": "W/m^2",
              "default": 0.0,
              "description": "Incident downward longwave radiation at the reference height (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy longwave-flux components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "q_rain": {
              "type": "parameter",
              "units": "kg/(m^2*s)",
              "default": 0.0,
              "description": "Liquid precipitation rate (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy hydrology components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "q_sno": {
              "type": "parameter",
              "units": "kg/(m^2*s)",
              "default": 0.0,
              "description": "Solid precipitation rate (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy snow components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "S_atm_dir_vis": {
              "type": "parameter",
              "units": "W/m^2",
              "default": 0.0,
              "description": "Incident direct-beam visible solar radiation (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy shortwave-radiation components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "S_atm_dir_nir": {
              "type": "parameter",
              "units": "W/m^2",
              "default": 0.0,
              "description": "Incident direct-beam near-infrared solar radiation (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy shortwave-radiation components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "S_atm_dif_vis": {
              "type": "parameter",
              "units": "W/m^2",
              "default": 0.0,
              "description": "Incident diffuse visible solar radiation (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy shortwave-radiation components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "S_atm_dif_nir": {
              "type": "parameter",
              "units": "W/m^2",
              "default": 0.0,
              "description": "Incident diffuse near-infrared solar radiation (Oleson Table 1.1) \u2014 passthrough atmospheric forcing input consumed by downstream urban-canopy shortwave-radiation components; declared by the upstream interface component but not used in the three diagnostic equations of CLMUAtmosphere itself"
            },
            "z_0": {
              "type": "state",
              "units": "m",
              "default": 1.0,
              "description": "Roughness length (Oleson Table 1.3, Footnote 1 p.16) \u2014 characteristic length scale of the surface drag for the log-law wind profile. Typical urban values 0.5-3 m. Input to Eq. 3 (effective reference height)"
            },
            "z_d": {
              "type": "state",
              "units": "m",
              "default": 5.0,
              "description": "Displacement height (Oleson Table 1.3, Footnote 1 p.16) \u2014 vertical offset of the log-law wind profile, representing the effective height of the canopy bulk drag center. Typical urban values 1-15 m (a fraction of building height H). Input to Eq. 3 (effective reference height)"
            },
            "e_atm": {
              "type": "state",
              "units": "Pa",
              "description": "Atmospheric vapor pressure (Oleson Ch. 1 p.17, Eq. 1): e_atm = q_atm * P_atm / (epsilon + (1-epsilon) * q_atm). Bolton-style inversion of specific humidity to vapor pressure for the moist-air state used by downstream flux components. At q_atm = 0 gives e_atm = 0; bounded above by P_atm at q_atm = 1"
            },
            "rho_atm": {
              "type": "state",
              "units": "kg/m^3",
              "description": "Atmospheric air density (Oleson Ch. 1 p.17, Eq. 2): rho_atm = (P_atm - (1-epsilon) * e_atm) / (R_da * T_atm). Ideal-gas density of moist air, with the (1-epsilon)*e_atm correction subtracted from P_atm to give the dry-air partial pressure (which then divides by R_da*T_atm). The humidity correction makes moist air slightly less dense than dry air at the same P and T"
            },
            "z_atm": {
              "type": "state",
              "units": "m",
              "description": "Effective atmospheric reference height for flux computations (Oleson Ch. 1 Footnote 1 p.16, Eq. 3): z_atm = z_prime_atm + z_0 + z_d. Linear sum of the model-reported height and the surface drag-profile parameters; used by downstream urban-canopy momentum and turbulent-flux subcomponents as the height at which the atmospheric forcings are evaluated"
            }
          },
          "equations": [
            {
              "lhs": "e_atm",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "q_atm",
                      "P_atm"
                    ]
                  },
                  {
                    "op": "+",
                    "args": [
                      "epsilon_ratio",
                      {
                        "op": "*",
                        "args": [
                          "one_minus_epsilon",
                          "q_atm"
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "rho_atm",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "P_atm",
                      {
                        "op": "*",
                        "args": [
                          "one_minus_epsilon",
                          "e_atm"
                        ]
                      }
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "R_da",
                      "T_atm"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "z_atm",
              "rhs": {
                "op": "+",
                "args": [
                  {
                    "op": "+",
                    "args": [
                      "z_prime_atm",
                      "z_0"
                    ]
                  },
                  "z_d"
                ]
              }
            }
          ]
        },
        "rad": {
          "variables": {
            "\u03c3_SB": {
              "type": "parameter",
              "units": "W/(m^2*K^4)",
              "default": 5.67e-08,
              "description": "Stefan-Boltzmann constant (Oleson Table 1.4) \u2014 upstream `@constants` \u03c3_SB; the coefficient of T^4 in the Stefan-Boltzmann law for upward longwave emission used in Eqs. 2.102, 2.111-2.113"
            },
            "\u03c0_val": {
              "type": "parameter",
              "units": "1",
              "default": 3.141592653589793,
              "description": "Pi (dimensionless) \u2014 upstream `@constants` \u03c0_val = Float64(\u03c0); appears in the direct-beam canyon-orientation factors of Eqs. 2.16-2.17"
            },
            "one_rad": {
              "type": "parameter",
              "units": "rad",
              "default": 1.0,
              "description": "Unit-angle reference (1 rad) \u2014 upstream `@constants` one_rad; used in `\u03bc_zen / one_rad` to make the argument of `tan` dimensionless and in `asin(...) * one_rad` to restore rad dimension on \u03b8_0 (Eq. 2.11). Value is exactly 1.0 by construction; numerically a no-op."
            },
            "one_wm2": {
              "type": "parameter",
              "units": "W/m^2",
              "default": 1.0,
              "description": "Unit radiative flux (1 W/m\u00b2) \u2014 upstream `@constants` one_wm2; declared by the upstream component but unused in the equation block (kept here for 1:1 parameter-count fidelity with upstream `length(parameters(sys)) == 31`). The unit-balancing role of one_wm2 is taken by `zero_wm2` in the canyon-albedo guard."
            },
            "zero_wm2": {
              "type": "parameter",
              "units": "W/m^2",
              "default": 0.0,
              "description": "Zero radiative flux (0 W/m\u00b2) \u2014 upstream `@constants` zero_wm2; used as the comparison RHS in the canyon-albedo guard `ifelse(incident > zero_wm2, refl/incident, 0.0)` to keep the `>` comparison unit-consistent with the W/m\u00b2 LHS"
            },
            "H_W": {
              "type": "state",
              "units": "1",
              "default": 1.0,
              "description": "Canyon height-to-width ratio H/W (dimensionless) \u2014 controls all view factor geometry (Eqs. 2.22-2.28); typical urban values 0.5-3, but the implementation is valid for 0 (flat) to large (deep canyon)"
            },
            "W_roof": {
              "type": "state",
              "units": "1",
              "default": 0.25,
              "description": "Roof fraction of urban surface (dimensionless) \u2014 controls the area-weighted combination of roof and canyon contributions to total net radiation in Eqs. 2.95 and 2.175"
            },
            "S_atm_dir_vis": {
              "type": "state",
              "units": "W/m^2",
              "default": 200.0,
              "description": "Incident direct beam visible solar radiation from the atmosphere (upstream `@parameters` S_atm_dir_vis)"
            },
            "S_atm_dir_nir": {
              "type": "state",
              "units": "W/m^2",
              "default": 150.0,
              "description": "Incident direct beam NIR solar radiation from the atmosphere"
            },
            "S_atm_dif_vis": {
              "type": "state",
              "units": "W/m^2",
              "default": 80.0,
              "description": "Incident diffuse visible solar radiation from the atmosphere"
            },
            "S_atm_dif_nir": {
              "type": "state",
              "units": "W/m^2",
              "default": 60.0,
              "description": "Incident diffuse NIR solar radiation from the atmosphere"
            },
            "L_atm_down": {
              "type": "state",
              "units": "W/m^2",
              "default": 350.0,
              "description": "Incident longwave radiation from the atmosphere (downwelling)"
            },
            "\u03bc_zen": {
              "type": "state",
              "units": "rad",
              "default": 0.5236,
              "description": "Solar zenith angle (rad) \u2014 appears in `tan(\u03bc_zen)` in the direct-beam factor of Eq. 2.16-2.17. Default 0.5236 rad \u2248 30 degrees."
            },
            "\u03b1_roof_dir_vis": {
              "type": "state",
              "units": "1",
              "default": 0.2,
              "description": "Roof albedo, direct beam, visible (dimensionless) \u2014 surface optical property; appears in Eq. 2.34-2.35 for absorbed solar by the roof"
            },
            "\u03b1_roof_dir_nir": {
              "type": "state",
              "units": "1",
              "default": 0.2,
              "description": "Roof albedo, direct beam, NIR (dimensionless)"
            },
            "\u03b1_roof_dif_vis": {
              "type": "state",
              "units": "1",
              "default": 0.2,
              "description": "Roof albedo, diffuse, visible (dimensionless)"
            },
            "\u03b1_roof_dif_nir": {
              "type": "state",
              "units": "1",
              "default": 0.2,
              "description": "Roof albedo, diffuse, NIR (dimensionless)"
            },
            "\u03b1_road_dir_vis": {
              "type": "state",
              "units": "1",
              "default": 0.08,
              "description": "Effective road albedo, direct beam, visible (dimensionless) \u2014 weighted average over pervious/impervious road fraction, computed upstream"
            },
            "\u03b1_road_dir_nir": {
              "type": "state",
              "units": "1",
              "default": 0.08,
              "description": "Effective road albedo, direct beam, NIR (dimensionless)"
            },
            "\u03b1_road_dif_vis": {
              "type": "state",
              "units": "1",
              "default": 0.08,
              "description": "Effective road albedo, diffuse, visible (dimensionless)"
            },
            "\u03b1_road_dif_nir": {
              "type": "state",
              "units": "1",
              "default": 0.08,
              "description": "Effective road albedo, diffuse, NIR (dimensionless)"
            },
            "\u03b1_wall_dir_vis": {
              "type": "state",
              "units": "1",
              "default": 0.25,
              "description": "Wall albedo, direct beam, visible (dimensionless)"
            },
            "\u03b1_wall_dir_nir": {
              "type": "state",
              "units": "1",
              "default": 0.25,
              "description": "Wall albedo, direct beam, NIR (dimensionless)"
            },
            "\u03b1_wall_dif_vis": {
              "type": "state",
              "units": "1",
              "default": 0.25,
              "description": "Wall albedo, diffuse, visible (dimensionless)"
            },
            "\u03b1_wall_dif_nir": {
              "type": "state",
              "units": "1",
              "default": 0.25,
              "description": "Wall albedo, diffuse, NIR (dimensionless)"
            },
            "\u03b5_roof": {
              "type": "state",
              "units": "1",
              "default": 0.9,
              "description": "Roof longwave emissivity (dimensionless) \u2014 Stefan-Boltzmann pre-factor in upward LW emission (Eq. 2.102); typical urban roof values 0.85-0.95"
            },
            "\u03b5_road": {
              "type": "state",
              "units": "1",
              "default": 0.95,
              "description": "Effective road longwave emissivity (dimensionless) \u2014 weighted average over pervious/impervious road fraction"
            },
            "\u03b5_wall": {
              "type": "state",
              "units": "1",
              "default": 0.85,
              "description": "Wall longwave emissivity (dimensionless)"
            },
            "T_roof": {
              "type": "state",
              "units": "K",
              "default": 305.0,
              "description": "Roof surface temperature \u2014 appears as T^4 in the Stefan-Boltzmann upward emission (Eq. 2.102)"
            },
            "T_road": {
              "type": "state",
              "units": "K",
              "default": 310.0,
              "description": "Road surface temperature \u2014 appears as T^4 in the road LW emission (Eq. 2.111)"
            },
            "T_sunwall": {
              "type": "state",
              "units": "K",
              "default": 315.0,
              "description": "Sunlit wall surface temperature \u2014 appears as T^4 in the sunlit-wall LW emission (Eq. 2.112)"
            },
            "T_shdwall": {
              "type": "state",
              "units": "K",
              "default": 300.0,
              "description": "Shaded wall surface temperature \u2014 appears as T^4 in the shaded-wall LW emission (Eq. 2.113)"
            },
            "\u03a8_wall_sky": {
              "type": "state",
              "units": "1",
              "description": "View factor: wall to sky (Oleson Eq. 2.24) \u2014 fraction of radiation leaving a wall that reaches the sky"
            },
            "\u03a8_wall_road": {
              "type": "state",
              "units": "1",
              "description": "View factor: wall to road (Oleson Eq. 2.26) \u2014 equal to \u03a8_wall_sky by reciprocity"
            },
            "\u03a8_wall_wall": {
              "type": "state",
              "units": "1",
              "description": "View factor: wall to opposite wall (Oleson Eq. 2.28) \u2014 closure of the row-sum 1 = \u03a8_wall_sky + \u03a8_wall_road + \u03a8_wall_wall"
            },
            "\u03a8_road_sky": {
              "type": "state",
              "units": "1",
              "description": "View factor: road to sky (Oleson Eq. 2.25) \u2014 fraction of radiation leaving the road that reaches the sky; decreases with H/W"
            },
            "\u03a8_road_wall": {
              "type": "state",
              "units": "1",
              "description": "View factor: road to wall (Oleson Eq. 2.27) \u2014 fraction of radiation leaving the road that reaches one wall; two walls so 2*\u03a8_road_wall = 1 - \u03a8_road_sky"
            },
            "\u03a8_sky_road": {
              "type": "state",
              "units": "1",
              "description": "View factor: sky to road (Oleson Eq. 2.25) \u2014 equal to \u03a8_road_sky by reciprocity"
            },
            "\u03a8_sky_wall": {
              "type": "state",
              "units": "1",
              "description": "View factor: sky to wall, per unit wall area (Oleson Eq. 2.24) \u2014 equal to \u03a8_wall_sky by reciprocity"
            },
            "\u03b8_0": {
              "type": "state",
              "units": "rad",
              "description": "Critical canyon orientation angle (Oleson Eq. 2.11) \u2014 the canyon-orientation azimuth threshold separating sunlit-wall from shadowed-wall geometries integrated to derive the canyon-averaged direct-beam radiation factors"
            },
            "S_sunwall_factor": {
              "type": "state",
              "units": "1",
              "description": "Sunlit wall direct beam factor (Oleson Eq. 2.16) \u2014 dimensionless fraction of atmospheric direct-beam radiation that lands on the sunlit wall per unit wall area, integrated over canyon orientation"
            },
            "S_road_factor": {
              "type": "state",
              "units": "1",
              "description": "Road direct beam factor (Oleson Eq. 2.17) \u2014 dimensionless fraction of atmospheric direct-beam radiation that lands on the road per unit ground area; conservation Eq. 2.18 requires S_road_factor + H/W * S_sunwall_factor = 1"
            },
            "S_road_dir_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Direct beam VIS incident on road (Oleson Eq. 2.17): S_road_factor * S_atm_dir_vis"
            },
            "S_road_dir_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Direct beam NIR incident on road: S_road_factor * S_atm_dir_nir"
            },
            "S_sunwall_dir_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Direct beam VIS incident on sunlit wall (Oleson Eq. 2.16): S_sunwall_factor * S_atm_dir_vis"
            },
            "S_sunwall_dir_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Direct beam NIR incident on sunlit wall: S_sunwall_factor * S_atm_dir_nir"
            },
            "S_road_dif_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Diffuse VIS incident on road (Oleson Eq. 2.30): S_atm_dif_vis * \u03a8_sky_road"
            },
            "S_road_dif_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Diffuse NIR incident on road: S_atm_dif_nir * \u03a8_sky_road"
            },
            "S_wall_dif_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Diffuse VIS incident on each wall (Oleson Eqs. 2.31-2.32): S_atm_dif_vis * \u03a8_sky_wall \u2014 same on sunlit and shaded walls for diffuse radiation"
            },
            "S_wall_dif_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Diffuse NIR incident on each wall: S_atm_dif_nir * \u03a8_sky_wall"
            },
            "T_rw": {
              "type": "state",
              "units": "1",
              "description": "Transport matrix element: wall to road (Oleson Section 2.5, p. 42-43) = H/W * \u03a8_wall_road \u2014 accounts for the wall-to-road area ratio in the multi-reflection transport matrix T"
            },
            "T_wr": {
              "type": "state",
              "units": "1",
              "description": "Transport matrix element: road to wall = \u03a8_road_wall / (H/W) \u2014 accounts for the road-to-wall area ratio (per unit wall area)"
            },
            "T_ww": {
              "type": "state",
              "units": "1",
              "description": "Transport matrix element: wall to opposite wall = \u03a8_wall_wall \u2014 the off-diagonal that couples the sunlit and shaded walls in the canyon-reflection geometric series"
            },
            "det_dir_vis": {
              "type": "state",
              "units": "1",
              "description": "Determinant of (I - T*A) for direct VIS waveband: (1 - d\u00b2) - 2bc(1 + d), where b = a_w*T_rw, c = a_r*T_wr, d = a_w*T_ww \u2014 denominator of the closed-form multi-reflection solution"
            },
            "det_dir_nir": {
              "type": "state",
              "units": "1",
              "description": "Determinant of (I - T*A) for direct NIR waveband"
            },
            "det_dif_vis": {
              "type": "state",
              "units": "1",
              "description": "Determinant of (I - T*A) for diffuse VIS waveband"
            },
            "det_dif_nir": {
              "type": "state",
              "units": "1",
              "description": "Determinant of (I - T*A) for diffuse NIR waveband"
            },
            "S_net_roof": {
              "type": "state",
              "units": "W/m^2",
              "description": "Net absorbed solar by roof (Oleson Eqs. 2.34-2.35): \u03a3 S_atm_*_*(1 - \u03b1_roof_*_*) summed over all four wavebands"
            },
            "S_net_road_dir_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by road, direct VIS waveband: (1 - \u03b1_road_dir_vis) * Q_road_dir_vis where Q_road_dir_vis is the per-waveband closed-form M\u207b\u00b9*S_0 multi-reflection result"
            },
            "S_net_road_dir_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by road, direct NIR waveband"
            },
            "S_net_road_dif_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by road, diffuse VIS waveband"
            },
            "S_net_road_dif_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by road, diffuse NIR waveband"
            },
            "S_net_sunwall_dir_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by sunlit wall, direct VIS waveband (per unit wall area)"
            },
            "S_net_sunwall_dir_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by sunlit wall, direct NIR waveband"
            },
            "S_net_sunwall_dif_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by sunlit wall, diffuse VIS waveband"
            },
            "S_net_sunwall_dif_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by sunlit wall, diffuse NIR waveband"
            },
            "S_net_shdwall_dir_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by shaded wall, direct VIS waveband \u2014 non-zero only via multi-reflection from road and sunlit wall (no direct beam reaches the shaded wall)"
            },
            "S_net_shdwall_dir_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by shaded wall, direct NIR waveband"
            },
            "S_net_shdwall_dif_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by shaded wall, diffuse VIS waveband \u2014 equal to sunwall diffuse VIS by symmetry"
            },
            "S_net_shdwall_dif_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Absorbed solar by shaded wall, diffuse NIR waveband"
            },
            "S_net_road": {
              "type": "state",
              "units": "W/m^2",
              "description": "Total net absorbed solar by road: sum of S_net_road_* over the four wavebands"
            },
            "S_net_sunwall": {
              "type": "state",
              "units": "W/m^2",
              "description": "Total net absorbed solar by sunlit wall per unit wall area: sum of S_net_sunwall_* over the four wavebands"
            },
            "S_net_shdwall": {
              "type": "state",
              "units": "W/m^2",
              "description": "Total net absorbed solar by shaded wall per unit wall area: sum of S_net_shdwall_* over the four wavebands"
            },
            "S_net_uc": {
              "type": "state",
              "units": "W/m^2",
              "description": "Net absorbed solar by the urban canyon per unit ground area: S_net_road + (S_net_sunwall + S_net_shdwall) * H/W"
            },
            "S_net_total": {
              "type": "state",
              "units": "W/m^2",
              "description": "Total net absorbed solar (Oleson Eq. 2.95): W_roof * S_net_roof + (1 - W_roof) * S_net_uc \u2014 area-weighted total over roof and canyon"
            },
            "S_refl_sky_dir_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Solar reflected back to sky from the canyon, direct VIS waveband \u2014 energy-balance closure: incident_canyon - absorbed_canyon (per unit ground area)"
            },
            "S_refl_sky_dir_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Solar reflected back to sky from the canyon, direct NIR waveband"
            },
            "S_refl_sky_dif_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Solar reflected back to sky from the canyon, diffuse VIS waveband"
            },
            "S_refl_sky_dif_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Solar reflected back to sky from the canyon, diffuse NIR waveband"
            },
            "\u03b1_uc_dir_vis": {
              "type": "state",
              "units": "1",
              "description": "Canyon direct beam albedo, VIS (Oleson Eq. 2.93): S_refl_sky_dir_vis / incident_canyon \u2014 the ratio of reflected to incident summed over the canyon (excluding the roof). Guarded against divide-by-zero when there is no incident radiation in this waveband."
            },
            "\u03b1_uc_dir_nir": {
              "type": "state",
              "units": "1",
              "description": "Canyon direct beam albedo, NIR"
            },
            "\u03b1_uc_dif_vis": {
              "type": "state",
              "units": "1",
              "description": "Canyon diffuse albedo, VIS (Oleson Eq. 2.94)"
            },
            "\u03b1_uc_dif_nir": {
              "type": "state",
              "units": "1",
              "description": "Canyon diffuse albedo, NIR"
            },
            "L_up_roof": {
              "type": "state",
              "units": "W/m^2",
              "description": "Upward longwave radiation from roof (Oleson Eq. 2.102): \u03b5_roof * \u03c3_SB * T_roof^4 + (1 - \u03b5_roof) * L_atm_down \u2014 Stefan-Boltzmann emission plus reflection of the downwelling atmospheric LW"
            },
            "L_net_roof": {
              "type": "state",
              "units": "W/m^2",
              "description": "Net longwave for roof (Oleson Eq. 2.101): L_up_roof - L_atm_down \u2014 positive when the roof is losing more LW than it absorbs"
            },
            "L_emit_road": {
              "type": "state",
              "units": "W/m^2",
              "description": "Emitted longwave from road (Oleson Eq. 2.111): \u03b5_road * \u03c3_SB * T_road^4 \u2014 Stefan-Boltzmann emission only, before multi-reflection"
            },
            "L_emit_sunwall": {
              "type": "state",
              "units": "W/m^2",
              "description": "Emitted longwave from sunlit wall (Oleson Eq. 2.112): \u03b5_wall * \u03c3_SB * T_sunwall^4"
            },
            "L_emit_shdwall": {
              "type": "state",
              "units": "W/m^2",
              "description": "Emitted longwave from shaded wall (Oleson Eq. 2.113): \u03b5_wall * \u03c3_SB * T_shdwall^4"
            },
            "det_lw": {
              "type": "state",
              "units": "1",
              "description": "Determinant of (I - T*A) for longwave: (1 - d_lw\u00b2) - 2*b_lw*c_lw*(1 + d_lw), where b_lw = (1-\u03b5_wall)*T_rw, c_lw = (1-\u03b5_road)*T_wr, d_lw = (1-\u03b5_wall)*T_ww \u2014 structurally identical to the solar determinant but with reflectivity (1 - \u03b5) in place of albedo \u03b1"
            },
            "L_net_road": {
              "type": "state",
              "units": "W/m^2",
              "description": "Net longwave for road: L_emit_road - \u03b5_road * Q_road_lw, where Q_road_lw is the canyon-trapped incoming LW from atmosphere and wall emission via the multi-reflection M\u207b\u00b9*S_0_lw solution. Positive when the road loses more LW than it absorbs."
            },
            "L_net_sunwall": {
              "type": "state",
              "units": "W/m^2",
              "description": "Net longwave for sunlit wall per unit wall area: L_emit_sunwall - \u03b5_wall * Q_sw_lw"
            },
            "L_net_shdwall": {
              "type": "state",
              "units": "W/m^2",
              "description": "Net longwave for shaded wall per unit wall area: L_emit_shdwall - \u03b5_wall * Q_sh_lw"
            },
            "L_net_uc": {
              "type": "state",
              "units": "W/m^2",
              "description": "Net longwave for urban canyon per unit ground area (Oleson Eq. 2.172): L_net_road + (L_net_sunwall + L_net_shdwall) * H/W"
            },
            "L_net_total": {
              "type": "state",
              "units": "W/m^2",
              "description": "Total net longwave (Oleson Eq. 2.175): W_roof * L_net_roof + (1 - W_roof) * L_net_uc \u2014 area-weighted total over roof and canyon"
            }
          },
          "equations": [
            {
              "lhs": "\u03a8_sky_wall",
              "rhs": {
                "op": "/",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      {
                        "op": "+",
                        "args": [
                          "H_W",
                          1.0
                        ]
                      },
                      {
                        "op": "sqrt",
                        "args": [
                          {
                            "op": "+",
                            "args": [
                              1.0,
                              {
                                "op": "^",
                                "args": [
                                  "H_W",
                                  2.0
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      2.0,
                      "H_W"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "\u03a8_wall_sky",
              "rhs": "\u03a8_sky_wall"
            },
            {
              "lhs": "\u03a8_road_sky",
              "rhs": {
                "op": "-",
                "args": [
                  {
                    "op": "sqrt",
                    "args": [
                      {
                        "op": "+",
                        "args": [
                          1.0,
                          {
                            "op": "^",
                            "args": [
                              "H_W",
                              2.0
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  "H_W"
                ]
              }
            },
            {
              "lhs": "\u03a8_sky_road",
              "rhs": "\u03a8_road_sky"
