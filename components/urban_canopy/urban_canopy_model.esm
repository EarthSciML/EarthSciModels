                      "S_atm"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "S_atm_dif_vis",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "one_dimless",
                      "R_vis"
                    ]
