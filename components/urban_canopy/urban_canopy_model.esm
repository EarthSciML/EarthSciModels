          "default": 0.2,
          "description": "Roof albedo, direct, vis"
        },
        "\u03b1_roof_dir_nir": {
          "type": "parameter",
          "units": "1",
          "default": 0.25,
          "description": "Roof albedo, direct, NIR"
        },
        "\u03b1_roof_dif_vis": {
          "type": "parameter",
          "units": "1",
          "default": 0.2,
          "description": "Roof albedo, diffuse, vis"
        },
        "\u03b1_roof_dif_nir": {
          "type": "parameter",
          "units": "1",
          "default": 0.25,
          "description": "Roof albedo, diffuse, NIR"
        },
        "\u03b1_road_dir_vis": {
          "type": "parameter",
          "units": "1",
          "default": 0.1,
          "description": "Road albedo, direct, vis"
        },
        "\u03b1_road_dir_nir": {
          "type": "parameter",
          "units": "1",
          "default": 0.15,
          "description": "Road albedo, direct, NIR"
        },
        "\u03b1_road_dif_vis": {
          "type": "parameter",
          "units": "1",
          "default": 0.1,
          "description": "Road albedo, diffuse, vis"
        },
        "\u03b1_road_dif_nir": {
          "type": "parameter",
          "units": "1",
          "default": 0.15,
          "description": "Road albedo, diffuse, NIR"
        },
        "\u03b1_wall_dir_vis": {
          "type": "parameter",
          "units": "1",
          "default": 0.3,
          "description": "Wall albedo, direct, vis"
        },
        "\u03b1_wall_dir_nir": {
          "type": "parameter",
          "units": "1",
          "default": 0.35,
