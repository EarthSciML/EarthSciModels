                  {
                    "op": "*",
                    "args": [
                      "alpha_vis",
                      "S_atm"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "S_atm_dif_nir",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "-",
