          "units": "1",
          "default": 0.1,
          "description": "Wetted fraction of impervious road"
        },
        "zeta_in": {
          "type": "parameter",
          "units": "1",
          "default": -0.1,
          "description": "Monin-Obukhov stability parameter \u03b6 (external input; negative=unstable)"
        }
      },
      "subsystems": {
        "offline": {
          "variables": {
            "sigma_SB": {
              "type": "parameter",
              "units": "W/(m^2*K^4)",
              "default": 5.67e-08,
              "description": "Stefan-Boltzmann constant (Oleson Table 1.4) \u2014 upstream `@constants` \u03c3_SB; coefficient on the T_atm^4 upward emission term in Eq. 6.9"
            },
            "T_f": {
              "type": "parameter",
              "units": "K",
              "default": 273.15,
              "description": "Freezing temperature of water (Oleson Table 1.4) \u2014 reference temperature for the rain/snow partition (Eq. 6.13): below T_f the slope-0.5 ramp goes negative and clamps to 0 (all snow); above T_f + 2 K it goes above 1 and clamps (all rain)"
            },
            "MW_da": {
              "type": "parameter",
              "units": "kg/mol",
              "default": 0.028966,
              "description": "Molecular weight of dry air (Oleson Table 1.4) \u2014 upstream `@constants`; used to derive the \u03b5_ratio and one_minus_\u03b5 constants below. The derivation is evaluated at the upstream defaults and the resulting ratios are frozen in as their own parameters; this MW_da default is exposed for cross-reference"
            },
            "MW_wv": {
              "type": "parameter",
              "units": "kg/mol",
              "default": 0.018016,
              "description": "Molecular weight of water vapor (Oleson Table 1.4) \u2014 upstream `@constants`; used to derive the \u03b5_ratio and one_minus_\u03b5 constants below"
            },
            "epsilon_ratio": {
              "type": "parameter",
              "units": "1",
              "default": 0.6219705862045157,
              "description": "Ratio of molecular weights MW_wv/MW_da \u2248 0.622 (Oleson Table 1.4, p. 12) \u2014 upstream `@constants` \u03b5_ratio = MW_wv/MW_da, frozen at the upstream-default IEEE-754 value `0.018016 / 0.028966`. Appears in Eq. 6.10 as the constant term in the denominator: e_atm = P_atm * q_atm / (epsilon_ratio + one_minus_epsilon * q_atm)"
            },
            "one_minus_epsilon": {
              "type": "parameter",
              "units": "1",
              "default": 0.37802941379548427,
              "description": "One minus MW_wv/MW_da \u2248 0.378 \u2014 upstream `@constants` one_minus_\u03b5 = 1.0 - MW_wv/MW_da, frozen at the upstream-default IEEE-754 value. Appears in Eq. 6.10 as the coefficient of q_atm in the denominator. Note: epsilon_ratio + one_minus_epsilon is exactly 1.0 by construction at the upstream defaults"
            },
            "alpha_vis": {
              "type": "parameter",
              "units": "1",
              "default": 0.5,
              "description": "Ratio of visible to total incident solar radiation (Oleson Eq. 6.6) \u2014 upstream `@constants` \u03b1_vis = 0.5. Within the canonical S_atm = 500 W/m^2 fixture, alpha_vis * S_atm = 250 W/m^2 in visible and (1 - alpha_vis) * S_atm = 250 W/m^2 in NIR. The 50/50 split is a standard solar-band partition for clear-sky surface conditions in CLM"
            },
            "a_0": {
              "type": "parameter",
              "units": "1",
              "default": 0.17639,
              "description": "Visible direct-fraction polynomial coefficient a_0 (Oleson Eq. 6.7, dimensionless) \u2014 at zero visible flux R_vis_raw = a_0 = 0.17639 (the y-intercept of the cubic)"
            },
            "a_1": {
              "type": "parameter",
              "units": "m^2/W",
              "default": 0.0038,
              "description": "Visible direct-fraction polynomial coefficient a_1 (Oleson Eq. 6.7) \u2014 linear term in (alpha_vis * S_atm)"
            },
            "a_2": {
              "type": "parameter",
              "units": "m^4/W^2",
              "default": -9.0039e-06,
              "description": "Visible direct-fraction polynomial coefficient a_2 (Oleson Eq. 6.7) \u2014 quadratic term in (alpha_vis * S_atm); negative, bending the cubic downward at mid-range fluxes"
            },
            "a_3": {
              "type": "parameter",
              "units": "m^6/W^3",
              "default": 8.1351e-09,
              "description": "Visible direct-fraction polynomial coefficient a_3 (Oleson Eq. 6.7) \u2014 cubic term in (alpha_vis * S_atm); positive, bending the cubic back upward at high fluxes"
            },
            "b_0": {
              "type": "parameter",
              "units": "1",
              "default": 0.29548,
              "description": "NIR direct-fraction polynomial coefficient b_0 (Oleson Eq. 6.8, dimensionless) \u2014 at zero NIR flux R_nir_raw = b_0 = 0.29548"
            },
            "b_1": {
              "type": "parameter",
              "units": "m^2/W",
              "default": 0.00504,
              "description": "NIR direct-fraction polynomial coefficient b_1 (Oleson Eq. 6.8) \u2014 linear term in ((1 - alpha_vis) * S_atm)"
            },
            "b_2": {
              "type": "parameter",
              "units": "m^4/W^2",
              "default": -1.4957e-05,
              "description": "NIR direct-fraction polynomial coefficient b_2 (Oleson Eq. 6.8) \u2014 quadratic term in ((1 - alpha_vis) * S_atm); negative"
            },
            "b_3": {
              "type": "parameter",
              "units": "m^6/W^3",
              "default": 1.4881e-08,
              "description": "NIR direct-fraction polynomial coefficient b_3 (Oleson Eq. 6.8) \u2014 cubic term in ((1 - alpha_vis) * S_atm); positive"
            },
            "idso_base": {
              "type": "parameter",
              "units": "1",
              "default": 0.7,
              "description": "Idso (1981) base emissivity factor (Oleson Eq. 6.9, dimensionless) \u2014 the additive constant in the bracketed emissivity factor `[0.70 + idso_coeff * e_atm * exp(idso_T_ref / T_atm)]`. Represents the dry-air contribution to clear-sky atmospheric emissivity"
            },
            "idso_coeff": {
              "type": "parameter",
              "units": "Pa^-1",
              "default": 5.95e-07,
              "description": "Idso (1981) vapor-pressure coefficient (Oleson Eq. 6.9) \u2014 encodes the upstream pre-multiplied form `5.95e-5 * 0.01 = 5.95e-7` Pa^-1 from the upstream comment, so the equation reads `idso_base + idso_coeff * e_atm * exp(idso_T_ref / T_atm)` without an inline literal 0.01 factor. The 0.01 factor converts e_atm from Pa to a 100-Pa unit equivalent (a hectopascal) so that the dimensionless product idso_coeff * e_atm is at unit order ~0.1 for moist atmospheres"
            },
            "idso_T_ref": {
              "type": "parameter",
              "units": "K",
              "default": 1500.0,
              "description": "Idso (1981) temperature reference (Oleson Eq. 6.9) \u2014 argument of the exp() factor: exp(1500/T_atm). At T_atm = 273.15 K the factor is exp(5.49) \u2248 242; at T_atm = 293.15 K it is exp(5.12) \u2248 167. Captures the strong moisture-temperature coupling of clear-sky downwelling longwave"
            },
            "f_P_slope": {
              "type": "parameter",
              "units": "K^-1",
              "default": 0.5,
              "description": "Rain-fraction slope (Oleson Eq. 6.13) \u2014 coefficient of (T_atm - T_f) in the linear rain-fraction ramp. With slope 0.5 K^-1, f_P_raw crosses 0 at T_atm = T_f and crosses 1 at T_atm = T_f + 2 K, giving a 2-K-wide transition zone for the rain/snow partition"
            },
            "R_min": {
              "type": "parameter",
              "units": "1",
              "default": 0.01,
              "description": "Minimum direct fraction (Oleson Eqs. 6.7-6.8, dimensionless) \u2014 lower bound of the [R_min, R_max] clamp on R_vis_raw and R_nir_raw; prevents the polynomial fit from producing implausibly small direct fractions at the polynomial's roots / sign changes"
            },
            "R_max": {
              "type": "parameter",
              "units": "1",
              "default": 0.99,
              "description": "Maximum direct fraction (Oleson Eqs. 6.7-6.8, dimensionless) \u2014 upper bound of the [R_min, R_max] clamp; prevents the polynomial fit from producing a direct fraction > 1 at high S_atm (where the polynomial extrapolates outside its calibration range)"
            },
            "zero_dimless": {
              "type": "parameter",
              "units": "1",
              "default": 0.0,
              "description": "Zero (dimensionless) \u2014 upstream `@constants` zero_dimless used as the lower clamp on f_P (Eq. 6.13). Identically 0.0; the parameter form preserves the upstream contract that all clamp bounds are declared `@constants` rather than inline literals"
            },
            "one_dimless": {
              "type": "parameter",
              "units": "1",
              "default": 1.0,
              "description": "One (dimensionless) \u2014 upstream `@constants` one_dimless used (a) as the upper clamp on f_P (Eq. 6.13), (b) as the multiplicand in `(1 - alpha_vis)` for NIR weighting, (c) as the multiplicand in `(1 - R_vis)` and `(1 - R_nir)` for diffuse-fraction extraction, and (d) as the multiplicand in `(1 - f_P)` for the snow-fraction extraction. Identically 1.0"
            },
            "sqrt2_inv": {
              "type": "parameter",
              "units": "1",
              "default": 0.7071067811865475,
              "description": "1/\u221a2 (dimensionless) \u2014 upstream `@constants` sqrt2_inv = 1.0 / sqrt(2.0), frozen at the IEEE-754 double value. Used in the wind decomposition u_atm = v_atm = sqrt2_inv * W_atm so that u_atm^2 + v_atm^2 = W_atm^2 exactly (anchored by the wind_decomposition_pythagorean test). The decomposition assumes the wind is equally split between zonal and meridional components in offline mode \u2014 a default that downstream CLMU surface-layer routines can override if a wind-direction observation is available"
            },
            "z_prime_atm_val": {
              "type": "parameter",
              "units": "m",
              "default": 30.0,
              "description": "Atmospheric reference height (Oleson CLMU Tech Note p. 149) \u2014 upstream `@constants`. The reference height at which the atmospheric forcing inputs (T_atm, q_atm, W_atm) are measured; CLMU's surface-layer turbulence parameterizations use this to compute the Monin-Obukhov stability profile. 30 m is the standard CLMU default; downstream consumers can rebind this parameter for site-specific tower heights"
            },
            "S_atm": {
              "type": "state",
              "units": "W/m^2",
              "default": 500.0,
              "description": "Total incident solar radiation at the model time step (Oleson Eq. 6.1 output) \u2014 upstream `@parameters`. The single solar-radiation input to the four-way partition (Eqs. 6.2-6.5); already at the model time step (Eq. 6.1 temporal-downscaling is an upstream preprocessing step). Default 500 W/m^2 mirrors the upstream-test canonical fixture"
            },
            "T_atm": {
              "type": "state",
              "units": "K",
              "default": 293.15,
              "description": "Atmospheric temperature at z_prime_atm_val (Oleson CLMU Ch. 6) \u2014 upstream `@parameters`. Used in the Idso longwave formula (Eq. 6.9), the rain/snow partition (Eq. 6.13), and assigned to theta_atm directly (p. 149). Default 293.15 K (20\u00b0C) mirrors the upstream canonical fixture"
            },
            "P_atm": {
              "type": "state",
              "units": "Pa",
              "default": 101325.0,
              "description": "Atmospheric pressure at z_prime_atm_val \u2014 upstream `@parameters`. Multiplies q_atm in the vapor-pressure formula (Eq. 6.10) \u2014 at standard pressure 101325 Pa and q_atm = 0.01 the vapor pressure e_atm \u2248 1619 Pa (about 16 hPa)"
            },
            "q_atm": {
              "type": "state",
              "units": "kg/kg",
              "default": 0.01,
              "description": "Atmospheric specific humidity at z_prime_atm_val \u2014 upstream `@parameters`. The single moisture input to the Idso longwave formula (via e_atm in Eq. 6.10). Default 0.01 kg/kg (10 g of water per kg of moist air) is representative of mid-latitude summer surface conditions"
            },
            "W_atm": {
              "type": "state",
              "units": "m/s",
              "default": 5.0,
              "description": "Atmospheric wind speed at z_prime_atm_val \u2014 upstream `@parameters`. Split equally between zonal and meridional via the sqrt2_inv decomposition (p. 149). Default 5 m/s is a moderate breeze"
            },
            "P_precip": {
              "type": "state",
              "units": "kg/(m^2*s)",
              "default": 0.0,
              "description": "Total precipitation rate (rain + snow) \u2014 upstream `@parameters`. Partitioned into q_rain and q_snow via the temperature-dependent f_P ramp (Eqs. 6.11-6.13). Default 0 (dry conditions) so non-precipitation tests do not need to override this parameter"
            },
            "R_vis_raw": {
              "type": "state",
              "units": "1",
              "description": "Unclamped visible direct fraction (Oleson Eq. 6.7) \u2014 the raw polynomial output `a_0 + a_1*(alpha_vis*S_atm) + a_2*(alpha_vis*S_atm)^2 + a_3*(alpha_vis*S_atm)^3` before the [R_min, R_max] clamp. Exposed so downstream consumers can detect when the clamp activates (the polynomial may exceed 0.99 or fall below 0.01 at extreme S_atm)"
            },
            "R_nir_raw": {
              "type": "state",
              "units": "1",
              "description": "Unclamped NIR direct fraction (Oleson Eq. 6.8) \u2014 the raw polynomial output `b_0 + b_1*((1-alpha_vis)*S_atm) + b_2*((1-alpha_vis)*S_atm)^2 + b_3*((1-alpha_vis)*S_atm)^3` before the [R_min, R_max] clamp"
            },
            "R_vis": {
              "type": "state",
              "units": "1",
              "description": "Visible direct fraction clamped to [R_min, R_max] (Oleson Eq. 6.7): max(R_min, min(R_max, R_vis_raw)). The fraction of the visible incident flux that is direct beam (rest is diffuse)"
            },
            "R_nir": {
              "type": "state",
              "units": "1",
              "description": "NIR direct fraction clamped to [R_min, R_max] (Oleson Eq. 6.8): max(R_min, min(R_max, R_nir_raw))"
            },
            "S_atm_dir_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Direct-beam visible solar radiation at the surface (Oleson Eq. 6.2): R_vis * (alpha_vis * S_atm). The shortwave-vis component that hits a horizontal surface from the direct solar beam"
            },
            "S_atm_dir_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Direct-beam NIR solar radiation at the surface (Oleson Eq. 6.3): R_nir * ((1 - alpha_vis) * S_atm)"
            },
            "S_atm_dif_vis": {
              "type": "state",
              "units": "W/m^2",
              "description": "Diffuse visible solar radiation at the surface (Oleson Eq. 6.4): (1 - R_vis) * (alpha_vis * S_atm)"
            },
            "S_atm_dif_nir": {
              "type": "state",
              "units": "W/m^2",
              "description": "Diffuse NIR solar radiation at the surface (Oleson Eq. 6.5): (1 - R_nir) * ((1 - alpha_vis) * S_atm)"
            },
            "e_atm": {
              "type": "state",
              "units": "Pa",
              "description": "Atmospheric vapor pressure (Oleson Eq. 6.10): P_atm * q_atm / (epsilon_ratio + one_minus_epsilon * q_atm). The partial pressure of water vapor in the atmosphere derived from specific humidity using the molecular-weight-ratio formula. Zero at q_atm = 0; bounded above by P_atm * q_atm / epsilon_ratio at small q_atm"
            },
            "L_atm_down": {
              "type": "state",
              "units": "W/m^2",
              "description": "Atmospheric downwelling longwave radiation at the surface (Oleson Eq. 6.9, after Idso 1981): (idso_base + idso_coeff * e_atm * exp(idso_T_ref / T_atm)) * sigma_SB * T_atm^4. Sum of a clear-sky dry-air contribution and a moisture-amplification term \u2014 increases monotonically with both T_atm (Stefan-Boltzmann ^4) and q_atm (through e_atm)"
            },
            "f_P_raw": {
              "type": "state",
              "units": "1",
              "description": "Unclamped rain fraction (Oleson Eq. 6.13): f_P_slope * (T_atm - T_f). The linear T_atm - T_f ramp before the [0, 1] clamp. Negative below freezing, > 1 above T_f + 2 K"
            },
            "f_P": {
              "type": "state",
              "units": "1",
              "description": "Rain fraction clamped to [zero_dimless, one_dimless] (Oleson Eq. 6.13): max(zero_dimless, min(one_dimless, f_P_raw)). The fraction of total precipitation that falls as rain; complement (1 - f_P) falls as snow"
            },
            "q_rain": {
              "type": "state",
              "units": "kg/(m^2*s)",
              "description": "Rain (liquid precipitation) rate (Oleson Eq. 6.11): P_precip * f_P. Zero below T_f; equals P_precip above T_f + 2 K"
            },
            "q_snow": {
              "type": "state",
              "units": "kg/(m^2*s)",
              "description": "Snow (solid precipitation) rate (Oleson Eq. 6.12): P_precip * (one_dimless - f_P). Equals P_precip below T_f; zero above T_f + 2 K. By construction q_rain + q_snow = P_precip for all T_atm"
            },
            "u_atm": {
              "type": "state",
              "units": "m/s",
              "description": "Zonal (east-west) wind component (Oleson CLMU p. 149): sqrt2_inv * W_atm. Equal-split assumption \u2014 offline mode lacks wind-direction information, so the wind is decomposed isotropically. By construction u_atm^2 + v_atm^2 = W_atm^2"
            },
            "v_atm": {
              "type": "state",
              "units": "m/s",
              "description": "Meridional (north-south) wind component (Oleson CLMU p. 149): sqrt2_inv * W_atm. Equal-split assumption, see u_atm"
            },
            "theta_atm": {
              "type": "state",
              "units": "K",
              "description": "Atmospheric potential temperature (Oleson CLMU p. 149) \u2014 upstream `\u03b8_atm`; identified with T_atm in offline mode (no atmospheric layer above z_prime_atm_val, so the potential-temperature reference is the surface). Used by CLMU's Monin-Obukhov surface-layer routine"
            },
            "z_prime_atm": {
              "type": "state",
              "units": "m",
              "description": "Atmospheric reference height (Oleson CLMU p. 149) \u2014 assigned to z_prime_atm_val (default 30 m). Exposed as a state output so a coupled CLMU build can wire it to the surface-layer routine via observed-equation forwarding"
            }
          },
          "equations": [
            {
              "lhs": "R_vis_raw",
              "rhs": {
                "op": "+",
                "args": [
