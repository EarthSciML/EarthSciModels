      ],
      "tests": [
        {
          "description": "Model loads and all subsystems initialize without error",
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "time": 0.0,
              "variable": "UrbanCanopyModel.flux.T_ac",
              "expected": 296.0,
              "tolerance": {
                "rel": 0.05
              }
            },
            {
              "time": 0.0,
              "variable": "UrbanCanopyModel.flux.H_total",
              "expected": 98.38416414890685,
              "tolerance": {
                "rel": 1e-05
              }
            },
            {
              "time": 0.0,
              "variable": "UrbanCanopyModel.rad.S_net_total",
              "expected": 422.7339093856878,
              "tolerance": {
                "rel": 1e-05
              }
            }
          ],
          "id": "structural_load"
        },
        {
          "description": "CLMUAtmosphere reproduces canonical air density at default conditions (q=0.01, P=101325, T=293.15)",
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "time": 0.0,
              "variable": "UrbanCanopyModel.atmos.rho_atm",
              "expected": 1.1968760398898206,
              "tolerance": {
                "rel": 1e-08
              }
            }
          ],
          "id": "atmos_rho_canonical"
        },
        {
          "description": "UCL air temperature is bounded between atmospheric and surface temperatures",
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "time": 0.0,
              "variable": "UrbanCanopyModel.flux.T_ac",
              "expected": 296.0,
              "tolerance": {
                "rel": 0.05
              }
            }
          ],
          "id": "flux_T_ac_bounds"
        },
        {
          "description": "Total evaporation E_total is positive (drying: surface drier than air)",
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "time": 0.0,
              "variable": "UrbanCanopyModel.flux.E_total",
              "expected": 1e-05,
              "tolerance": {
                "rel": 100.0
              }
            }
          ],
          "id": "flux_E_total_sign"
        },
        {
          "description": "Net longwave is positive (net upward emission from warm surfaces)",
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "time": 0.0,
              "variable": "UrbanCanopyModel.rad.L_net_total",
              "expected": 78.83055675488629,
              "tolerance": {
                "rel": 1e-05
              }
            }
          ],
          "id": "rad_L_net_total_sign"
        }
      ],
