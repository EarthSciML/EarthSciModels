                            "op": "-",
                            "args": [
                              "one_dimless",
                              "alpha_vis"
                            ]
                          },
                          "S_atm"
                        ]
                      }
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "b_2",
                      {
                        "op": "^",
                        "args": [
                          {
                            "op": "*",
                            "args": [
                              {
                                "op": "-",
                                "args": [
                                  "one_dimless",
                                  "alpha_vis"
                                ]
                              },
                              "S_atm"
                            ]
                          },
                          2.0
                        ]
                      }
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "b_3",
                      {
                        "op": "^",
                        "args": [
                          {
                            "op": "*",
                            "args": [
                              {
                                "op": "-",
                                "args": [
                                  "one_dimless",
                                  "alpha_vis"
                                ]
                              },
                              "S_atm"
                            ]
                          },
                          3.0
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "R_vis",
              "rhs": {
                "op": "max",
                "args": [
                  "R_min",
                  {
                    "op": "min",
                    "args": [
                      "R_max",
                      "R_vis_raw"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "R_nir",
              "rhs": {
                "op": "max",
                "args": [
                  "R_min",
                  {
                    "op": "min",
                    "args": [
                      "R_max",
                      "R_nir_raw"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "S_atm_dir_vis",
              "rhs": {
                "op": "*",
                "args": [
                  "R_vis",
                  {
                    "op": "*",
                    "args": [
                      "alpha_vis",
                      "S_atm"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "S_atm_dir_nir",
              "rhs": {
