                        "dh_dT": -10.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "H_i",
                                "range": { "start": -1000.0, "stop": 1000.0, "count": 81, "scale": "linear" }
                            },
                            {
                                "parameter": "is_top",
                                "values": [0.0, 1.0]
