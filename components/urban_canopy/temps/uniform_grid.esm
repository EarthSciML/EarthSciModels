            ],
            "tests": [
                {
                    "id": "z_node_full_column",
                    "description": "Verifies Oleson Eq. 4.5 across all 15 grid layers: z_i = (i - 0.5) * (dz_total / N) with dz_total = 0.3 m and N = 15. Reference values computed directly from the closed-form expression and matched to the upstream Julia component which integrates the same equation symbolically (`roof_wall_road_snow_temperatures_test.jl:935-939` Equation Verification). This anchors the layer-node depth profile that drives the roof/wall thermal grid in CLMU.",
                    "parameter_overrides": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "z_node_1",
                            "time": 0.0,
                            "expected": 0.01
                        },
                        {
                            "variable": "z_node_2",
                            "time": 0.0,
                            "expected": 0.03
                        },
                        {
                            "variable": "z_node_3",
                            "time": 0.0,
                            "expected": 0.05
                        },
