                            "time": 0.0,
                            "expected": 0.19
                        },
                        {
                            "variable": "z_node_11",
                            "time": 0.0,
                            "expected": 0.21
                        },
                        {
                            "variable": "z_node_12",
                            "time": 0.0,
                            "expected": 0.23
                        },
                        {
                            "variable": "z_node_13",
                            "time": 0.0,
                            "expected": 0.25
                        },
                        {
                            "variable": "z_node_14",
                            "time": 0.0,
                            "expected": 0.27
                        },
                        {
                            "variable": "z_node_15",
                            "time": 0.0,
                            "expected": 0.29
                        }
                    ]
                },
                {
                    "id": "z_interface_surface_boundary",
                    "description": "Verifies the surface boundary condition: z_interface_1 = z_{h,0} = 0 m exactly (Oleson Eq. 4.7, paper index i=0; matches upstream `roof_wall_road_snow_temperatures_test.jl:948`). Tightened absolute tolerance to catch any stuck-at-nonzero regression in the boundary equation.",
                    "parameter_overrides": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "z_interface_1",
                            "time": 0.0,
                            "expected": 0.0,
                            "tolerance": {
                                "abs": 1e-12
                            }
                        }
                    ]
                },
                {
                    "id": "dz_layer_full_column",
                    "description": "Verifies Oleson Eq. 4.6 layer-thickness recurrence across all 15 layers: top dz_layer_1 = 0.5 * (z_node_1 + z_node_2), interior dz_layer_i = 0.5 * (z_node_{i+1} - z_node_{i-1}), bottom dz_layer_15 = z_node_15 - z_node_14. For a uniform grid all layer thicknesses collapse to dz_total / N = 0.02 m algebraically (matches upstream `roof_wall_road_snow_temperatures_test.jl:942-945` Equation Verification). Pinned values include ULP-level deviations from 0.02 (e.g. dz_layer_3 = 0.020000000000000004) reflecting the order-of-evaluation in the upstream IEEE-754 expression; the rel=1e-9 tolerance accommodates these.",
                    "parameter_overrides": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "dz_layer_1",
                            "time": 0.0,
                            "expected": 0.02
                        },
                        {
                            "variable": "dz_layer_2",
                            "time": 0.0,
                            "expected": 0.02
                        },
                        {
                            "variable": "dz_layer_3",
                            "time": 0.0,
                            "expected": 0.020000000000000004
                        },
