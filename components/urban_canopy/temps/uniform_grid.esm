                            "expected": 0.24
                        },
                        {
                            "variable": "z_interface_14",
                            "time": 0.0,
                            "expected": 0.26
                        },
                        {
                            "variable": "z_interface_15",
                            "time": 0.0,
                            "expected": 0.28
                        },
                        {
                            "variable": "z_interface_16",
                            "time": 0.0,
                            "expected": 0.29999999999999993
                        }
                    ]
                },
                {
                    "id": "monotonic_increasing_depths",
                    "description": "Spot-checks the monotonic-increasing-with-depth invariant of the uniform grid: z_node_1 < z_node_7 < z_node_15 and z_interface_1 < z_interface_8 < z_interface_16. The full-column tests above already pin every layer; this test documents the monotonicity contract for downstream consumers and matches the structural-invariant style of the sibling ExponentialGrid Increasing Depth test (`roof_wall_road_snow_temperatures_test.jl:1016`).",
                    "parameter_overrides": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "z_node_1",
                            "time": 0.0,
                            "expected": 0.01
                        },
                        {
                            "variable": "z_node_7",
                            "time": 0.0,
                            "expected": 0.13
                        },
                        {
                            "variable": "z_node_15",
                            "time": 0.0,
                            "expected": 0.29
                        },
                        {
                            "variable": "z_interface_1",
                            "time": 0.0,
                            "expected": 0.0,
                            "tolerance": {
                                "abs": 1e-12
                            }
                        },
                        {
                            "variable": "z_interface_8",
                            "time": 0.0,
                            "expected": 0.14
                        },
                        {
                            "variable": "z_interface_16",
                            "time": 0.0,
                            "expected": 0.29999999999999993
                        }
                    ]
                },
                {
                    "id": "node_at_midpoint",
                    "description": "Verifies the geometric midpoint invariant: each z_node_i lies exactly midway between its surrounding interfaces, z_node_i = 0.5 * (z_interface_i + z_interface_{i+1}). This is the upstream `UniformGrid - Node at Midpoint` test (`roof_wall_road_snow_temperatures_test.jl:954-972`) reformulated as direct assertions on z_node values for layers 1, 8, and 15 (the same values asserted in z_node_full_column above — repeated here to document the invariant). For a uniform grid this is satisfied trivially by construction since both z_node and z_interface fall at multiples of dz_total/N.",
                    "parameter_overrides": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "z_node_1",
                            "time": 0.0,
                            "expected": 0.01
                        },
                        {
                            "variable": "z_node_8",
                            "time": 0.0,
                            "expected": 0.15
                        },
                        {
                            "variable": "z_node_15",
                            "time": 0.0,
                            "expected": 0.29
                        }
                    ]
                },
                {
                    "id": "dz_total_doubled_scales_linearly",
                    "description": "Verifies the linear scaling of the grid with the dz_total parameter: doubling dz_total from 0.3 m to 0.6 m doubles every z_node value, since z_i = (i - 0.5) * (dz_total / N) is linear in dz_total. Spot-checks layers 1, 8, and 15 (top, middle, and bottom). Guards against regressions that pin the column thickness or break the linear coupling — analog of the `f_s_doubled_scales_linearly` test in exponential_grid.esm.",
                    "parameter_overrides": {
                        "dz_total": 0.6
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "z_node_1",
                            "time": 0.0,
                            "expected": 0.02
                        },
                        {
                            "variable": "z_node_8",
                            "time": 0.0,
                            "expected": 0.3
                        },
                        {
                            "variable": "z_node_15",
                            "time": 0.0,
                            "expected": 0.58
                        }
                    ]
