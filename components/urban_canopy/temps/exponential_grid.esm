            "tests": [
                {
                    "id": "z_node_full_column",
                    "description": "Verifies Oleson Eq. 4.8 across all 15 grid layers: z_i = f_s * (exp(0.5*(i-0.5)) - 1) with f_s = 0.025 m. Reference values computed directly from the closed-form expression and matched to the upstream Julia component which integrates the same equation symbolically. This anchors the layer-node depth profile that drives the road-soil thermal grid in CLMU.",
                    "parameter_overrides": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
