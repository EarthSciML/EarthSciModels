                },
                "z_node_13": {
                    "type": "state",
                    "units": "m",
                    "description": "Node depth of layer 13 (Oleson Eq. 4.8): z_13 = f_s * (exp(0.5*(13 - 0.5)) - 1)"
                },
                "z_node_14": {
                    "type": "state",
                    "units": "m",
                    "description": "Node depth of layer 14 (Oleson Eq. 4.8): z_14 = f_s * (exp(0.5*(14 - 0.5)) - 1)"
                },
                "z_node_15": {
                    "type": "state",
                    "units": "m",
                    "description": "Node depth of layer 15 (Oleson Eq. 4.8): z_15 = f_s * (exp(0.5*(15 - 0.5)) - 1)"
                },
