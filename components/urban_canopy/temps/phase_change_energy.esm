                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "is_top": 1.0,
                        "c_i": 2.0e6,
                        "Δz_i": 0.01,
                        "Δt": 3600.0,
                        "h_n": 100.0,
                        "dh_dT": -10.0,
                        "F_i_n": 0.0,
                        "F_i_np1": 0.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T_i_n",
                                "range": { "start": 263.15, "stop": 283.15, "count": 41, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "H_excess_curve_top",
                            "type": "line",
                            "description": "H_excess vs T_i_n (top variant, surface forcing h_n = 100, dh_dT = -10): tilted line offset upward by h_n with slope c_i*Δz_i/Δt - dh_dT relative to the interior example.",
                            "x": { "variable": "T_i_n", "label": "T_i_n (K)" },
                            "y": { "variable": "H_excess", "label": "H_excess (W/m^2)" }
                        }
                    ]
                },
                {
                    "id": "two_d_sweep_T_F_interior",
                    "description": "Interior variant: 2-D sweep over (T_i_n, F_i_n) at fixed F_im1_n = F_i_np1 = F_im1_np1 = 0 surfacing the joint contribution of the storage term (linear in T_i_n) and the Crank-Nicholson lower-interface flux (linear in F_i_n). Iso-H_excess contours are oblique lines in (T_i_n, F_i_n) space with slope determined by the storage coefficient and α_CN. Exercises the bivariate dependence of Eq. 4.59 with the upper-interface fluxes set to zero (limit of a column with no flux at the layer-(i-1)/layer-i interface).",
                    "initial_state": {
