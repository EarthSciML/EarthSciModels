                            "id": "H_excess_T_F_heatmap",
                            "type": "heatmap",
                            "description": "H_excess in (T_i_n, F_i_n) space (interior variant). Planar surface: storage slope along T_i_n and α_CN-weighted Crank-Nicholson slope along F_i_n. Iso-H_excess lines have constant slope, with the zero contour passing through (T_f, 0).",
                            "x": { "variable": "T_i_n", "label": "T_i_n (K)" },
                            "y": { "variable": "F_i_n", "label": "F_i_n (W/m^2)" },
