                        "F_i_np1": 0.0,
                        "F_im1_n": 0.0,
                        "F_im1_np1": 0.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        {
                            "variable": "H_excess",
                            "time": 0.0,
                            "expected": 33.33333333333333,
                            "tolerance": { "rel": 1.0e-10 }
                        }
                    ]
                }
            ],
            "examples": [
                {
                    "id": "H_excess_vs_T_i_n_interior",
                    "description": "Interior variant: sweep T_i_n across the freezing point T_f = 273.15 K with all fluxes zero. With F_i_n = F_im1_n = F_i_np1 = F_im1_np1 = 0, only the storage term contributes: H_excess = -(c_i*Δz_i/Δt)*(T_f - T_i_n). At T_i_n = T_f the curve crosses zero; for T_i_n > T_f the layer has surplus energy (warm layer can melt ice if any); for T_i_n < T_f the layer has deficit (cold layer cannot reach T_f within Δt without additional energy). Linear in T_i_n with slope +(c_i*Δz_i/Δt) = 55.555 W/(m^2*K) at the default parameters. Surfaces the Eq. 4.59 storage-term sign convention directly.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
