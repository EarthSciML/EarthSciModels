                        "epsilon_g": 0.95,
                        "T_g_n": 300.0,
                        "dH_g_dT": 0.0,
                        "dlambdaE_g_dT": 0.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "h",       "time": 0.0, "expected": 115.0 },
                        {
                            "variable": "dL_g_dT",
                            "time": 0.0,
                            "expected": 5.81742,
                            "tolerance": { "rel": 1.0e-6 }
                        },
                        {
                            "variable": "dh_dT",
                            "time": 0.0,
                            "expected": -5.81742,
                            "tolerance": { "rel": 1.0e-6 }
                        }
                    ]
                }
            ],
            "examples": [
                {
                    "id": "dL_g_dT_vs_T_g_n_cube_scaling",
                    "description": "Sweep T_g_n across a realistic urban-surface temperature range (240-360 K) at fixed epsilon_g = 0.95 to surface the T^3 scaling of the longwave-derivative diagnostic (Eq. 4.29). dL_g_dT = 4*0.95*5.67e-8*T_g_n^3 grows cubically with T_g_n, from 3.0 W/(m^2*K) at 240 K to 10.0 W/(m^2*K) at 360 K. Paired with the corresponding dh_dT curve (dh_dT = -dL_g_dT - constant turbulent terms): the constant offset of -7 W/(m^2*K) (from dH_g_dT = 5 and dlambdaE_g_dT = 2) merely shifts the curve downward without changing its curvature.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "S_g": 200.0,
                        "L_g": 50.0,
                        "H_g": 30.0,
                        "lambdaE_g": 20.0,
                        "H_wasteheat_g": 10.0,
                        "H_aircond_g": 5.0,
                        "epsilon_g": 0.95,
                        "dH_g_dT": 5.0,
                        "dlambdaE_g_dT": 2.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T_g_n",
                                "range": { "start": 240.0, "stop": 360.0, "count": 31, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "dL_g_dT_curve",
                            "type": "line",
                            "description": "dL_g_dT vs T_g_n: cubic curve through (0,0) with slope 4*epsilon_g*sigma_SB*T^2 — radiative feedback grows rapidly with surface temperature.",
                            "x": { "variable": "T_g_n", "label": "T_g_n (K)" },
                            "y": { "variable": "dL_g_dT", "label": "dL_g_dT (W/(m^2*K))" }
                        },
                        {
                            "id": "dh_dT_curve",
                            "type": "line",
                            "description": "dh_dT vs T_g_n: -dL_g_dT - 7 — the same cube curve reflected across zero and shifted downward by the constant turbulent derivative offset.",
                            "x": { "variable": "T_g_n", "label": "T_g_n (K)" },
                            "y": { "variable": "dh_dT", "label": "dh_dT (W/(m^2*K))" }
                        }
                    ]
                },
                {
                    "id": "dL_g_dT_heatmap_T_epsilon",
                    "description": "Joint sweep over (T_g_n, epsilon_g) at fixed flux inputs, surfacing the bilinear-cubic structure of Eq. 4.29: dL_g_dT scales linearly with epsilon_g (vertical axis) and cubically with T_g_n (horizontal axis). Iso-dL_g_dT contours follow curves of constant epsilon_g * T_g_n^3 — at low T_g_n a wide range of emissivities give similar small feedback; at high T_g_n the contour spacing tightens, showing the strong sensitivity to T in summer urban heat-island regimes. The vertical strip at epsilon_g = 0 collapses to dL_g_dT = 0 regardless of T_g_n.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "S_g": 200.0,
                        "L_g": 50.0,
                        "H_g": 30.0,
                        "lambdaE_g": 20.0,
                        "H_wasteheat_g": 10.0,
                        "H_aircond_g": 5.0,
                        "dH_g_dT": 5.0,
                        "dlambdaE_g_dT": 2.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T_g_n",
                                "range": { "start": 240.0, "stop": 360.0, "count": 13, "scale": "linear" }
                            },
                            {
                                "parameter": "epsilon_g",
                                "range": { "start": 0.0, "stop": 1.0, "count": 11, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "dL_g_dT_T_epsilon_heatmap",
                            "type": "heatmap",
                            "description": "dL_g_dT in (T_g_n, epsilon_g) space: bilinear-cubic surface with iso-contours along constant epsilon_g * T_g_n^3.",
                            "x": { "variable": "T_g_n",     "label": "T_g_n (K)" },
                            "y": { "variable": "epsilon_g", "label": "epsilon_g (dimensionless)" },
                            "value": { "variable": "dL_g_dT", "reduce": "final" }
                        }
                    ]
                }
            ]
        }
    }
}
