            "examples": [
                {
                    "id": "preindustrial_equilibrium",
                    "description": "The preindustrial (~1850) carbon cycle at rest. With zero anthropogenic forcing the Schmitz (2002) reservoir masses (Seinfeld & Pandis Table 22.1) are very nearly stationary — over 10 model years the atmospheric and biota reservoirs drift by far less than 1%. Reproduces the steady-state box diagram of S&P Fig. 22.6 as a time series.",
                    "time_span": {"start": 0.0, "end": 315576000.0},
                    "plots": [
                        {
                            "id": "atmosphere_vs_time",
                            "type": "line",
                            "description": "Atmospheric carbon M1 over 10 years at the preindustrial state — essentially flat, confirming the near-equilibrium of the unforced cycle.",
                            "x": {"variable": "t", "label": "Time (s)"},
                            "y": {"variable": "M1", "label": "Atmospheric carbon M1 (kg)"}
                        },
                        {
                            "id": "biota_vs_time",
                            "type": "line",
                            "description": "Terrestrial biota carbon M5 over 10 years at the preindustrial state.",
                            "x": {"variable": "t", "label": "Time (s)"},
                            "y": {"variable": "M5", "label": "Terrestrial biota carbon M5 (kg)"}
                        }
                    ]
                },
                {
                    "id": "fossil_fuel_emission_trajectory",
                    "description": "Three centuries of sustained fossil fuel emission at 5 Pg C/yr (Ff = 5.0e12/31557600 kg/s). Atmospheric carbon M1 climbs steeply while the warm ocean M2 slowly absorbs a fraction of the excess CO2 and the fossil reserve M7 is drawn down linearly (D(M7) = −Ff). This is the carbon-cycle response that underlies the anthropogenic CO2 rise discussed in Seinfeld & Pandis Ch. 22.",
                    "parameters": {"Ff": 158440.43907014476},
                    "time_span": {"start": 0.0, "end": 9467280000.0},
                    "plots": [
                        {
                            "id": "atmosphere_rise",
                            "type": "line",
                            "description": "Atmospheric carbon M1 rising under 5 Pg C/yr fossil fuel emission over 300 years.",
                            "x": {"variable": "t", "label": "Time (s)"},
                            "y": {"variable": "M1", "label": "Atmospheric carbon M1 (kg)"}
                        },
                        {
                            "id": "ocean_uptake",
                            "type": "line",
                            "description": "Warm ocean surface carbon M2 increasing as the ocean takes up a fraction of the emitted CO2.",
                            "x": {"variable": "t", "label": "Time (s)"},
                            "y": {"variable": "M2", "label": "Warm ocean carbon M2 (kg)"}
                        },
                        {
                            "id": "fossil_depletion",
                            "type": "line",
                            "description": "Fossil fuel reserve M7 depleting linearly at the constant emission rate.",
                            "x": {"variable": "t", "label": "Time (s)"},
                            "y": {"variable": "M7", "label": "Fossil fuel reserve M7 (kg)"}
                        }
                    ]
                },
                {
                    "id": "fossil_fuel_rate_sweep",
                    "description": "Sensitivity of the carbon cycle to the fossil fuel emission rate. The forcing Ff is swept linearly from 0 to 10 Pg C/yr (0 to 3.1688e5 kg/s) and the system is integrated for 100 model years. Plotting the 100-year reservoir masses against Ff shows how strongly atmospheric carbon M1 responds to the emission rate and how the warm ocean M2 buffers a part of it.",
                    "time_span": {"start": 0.0, "end": 3155760000.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "Ff",
                                "range": {"start": 0.0, "stop": 316880.8781402895, "count": 21, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "atmosphere_vs_emission_rate",
                            "type": "line",
                            "description": "Atmospheric carbon M1 after 100 years as a function of the fossil fuel emission rate Ff — a near-linear rise in accumulated atmospheric carbon with emission rate.",
                            "x": {"variable": "Ff", "label": "Fossil fuel emission rate Ff (kg/s)"},
                            "y": {"variable": "M1", "label": "Atmospheric carbon M1 at 100 yr (kg)"}
                        },
                        {
                            "id": "ocean_vs_emission_rate",
                            "type": "line",
                            "description": "Warm ocean carbon M2 after 100 years versus the fossil fuel emission rate Ff — the ocean buffer's response to anthropogenic forcing.",
                            "x": {"variable": "Ff", "label": "Fossil fuel emission rate Ff (kg/s)"},
                            "y": {"variable": "M2", "label": "Warm ocean carbon M2 at 100 yr (kg)"}
                        }
                    ]
                },
                {
                    "id": "deforestation_rate_sweep",
                    "description": "Sensitivity of the terrestrial carbon pools and the land-use scaling factor to the deforestation rate. The forcing Fd is swept linearly from 0 to 4 Pg C/yr (0 to 1.2675e5 kg/s) and the system is integrated for 100 model years. Stronger deforestation draws down terrestrial biota M5, lowers the land-use scaling factor G (which further suppresses photosynthetic uptake), and raises atmospheric carbon M1.",
                    "time_span": {"start": 0.0, "end": 3155760000.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "Fd",
                                "range": {"start": 0.0, "stop": 126752.3512561158, "count": 17, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "biota_vs_deforestation",
                            "type": "line",
                            "description": "Terrestrial biota carbon M5 after 100 years versus the deforestation rate Fd — biota depletion increasing with the deforestation rate.",
                            "x": {"variable": "Fd", "label": "Deforestation rate Fd (kg/s)"},
                            "y": {"variable": "M5", "label": "Terrestrial biota carbon M5 at 100 yr (kg)"}
                        },
                        {
                            "id": "land_use_factor_vs_deforestation",
                            "type": "line",
                            "description": "Land-use scaling factor G after 100 years versus the deforestation rate Fd — the permanent-land-loss effect on biotic uptake capacity.",
                            "x": {"variable": "Fd", "label": "Deforestation rate Fd (kg/s)"},
                            "y": {"variable": "G", "label": "Land-use scaling factor G at 100 yr"}
                        },
                        {
                            "id": "atmosphere_vs_deforestation",
                            "type": "line",
                            "description": "Atmospheric carbon M1 after 100 years versus the deforestation rate Fd — atmospheric carbon rising as deforestation releases biota carbon.",
                            "x": {"variable": "Fd", "label": "Deforestation rate Fd (kg/s)"},
                            "y": {"variable": "M1", "label": "Atmospheric carbon M1 at 100 yr (kg)"}
                        }
                    ]
                }
            ]
        }
    }
