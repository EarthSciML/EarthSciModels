                    ]
                },
                {
                    "id": "momentum_flux_direction",
                    "description": "Reproduces the upstream `SurfaceFlux momentum flux direction` test (test/holtslag_boville_1993_test.jl:217-242). With both wind components positive (u₁ = 5 m/s, v₁ = 3 m/s) and neutral stratification, both momentum-flux components are negative — wu₀ < 0 and wv₀ < 0 — confirming that the surface stress (Eqs. 2.1-2.2) opposes the wind. Pins all 11 variables.",
                    "parameter_overrides": {"θᵥ₀": 300.0, "θᵥ₁": 300.0, "θ₀": 300.0, "θ₁": 300.0, "u₁": 5.0, "v₁": 3.0, "z₁": 10.0, "z₀ₘ": 0.1},
