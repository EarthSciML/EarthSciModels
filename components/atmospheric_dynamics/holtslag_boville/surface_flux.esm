            ],
            "examples": [
                {
                    "id": "stability_functions",
                    "description": "Reproduces the documented 'Surface Layer Stability Functions (Eq. 2.9-2.11)' figure from the AtmosphericDynamics.jl Holtslag & Boville (1993) page. The lowest-level virtual potential temperature θᵥ₁ is swept from 290 to 310 K with the surface value held at θᵥ₀ = 300 K, carrying the surface bulk Richardson number Ri₀ from unstable (negative) through neutral (0) to stable (positive). Plotting the momentum and heat stability functions against Ri₀ shows the asymmetric response: in unstable air (Ri₀ < 0) both functions exceed 1 and fₕ rises faster than fₘ (numerator coefficient 15 vs 10); in stable air (Ri₀ > 0) the two coincide and decay below 1. θ₁ is held at 300 K (the stability functions depend on the inputs only through Ri₀, so the curves are independent of how Ri₀ is generated).",
                    "initial_state": {"type": "per_variable", "values": {}},
                    "parameters": {"θᵥ₀": 300.0, "θ₀": 300.0, "θ₁": 300.0, "u₁": 5.0, "v₁": 0.0, "z₁": 10.0, "z₀ₘ": 0.1},
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "θᵥ₁",
                                "range": {"start": 290.0, "stop": 310.0, "count": 41, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "fm_vs_Ri",
                            "type": "line",
                            "description": "Momentum stability function fₘ as a function of the surface bulk Richardson number Ri₀ — enhanced (> 1) in unstable air, suppressed (< 1) in stable air.",
                            "x": {"variable": "Ri₀", "label": "Surface bulk Richardson number Ri₀"},
                            "y": {"variable": "fₘ", "label": "Momentum stability function fₘ"}
                        },
                        {
                            "id": "fh_vs_Ri",
                            "type": "line",
                            "description": "Heat stability function fₕ as a function of the surface bulk Richardson number Ri₀. In unstable air fₕ rises above fₘ; in stable air fₕ = fₘ.",
                            "x": {"variable": "Ri₀", "label": "Surface bulk Richardson number Ri₀"},
                            "y": {"variable": "fₕ", "label": "Heat stability function fₕ"}
                        }
                    ]
                },
                {
                    "id": "surface_fluxes_vs_wind",
                    "description": "Surface momentum and heat fluxes as a function of the lowest-level wind speed. The zonal wind u₁ is swept from 0 to 20 m/s under neutral virtual-temperature stratification (θᵥ₀ = θᵥ₁ = 300 K) with a 2 K surface-air potential-temperature contrast (θ₀ = 302 K, θ₁ = 300 K). The momentum flux wu₀ = −Cₘ·V₁·u₁ grows in magnitude roughly with the square of the wind speed, and the heat flux wθ₀ = Cₕ·V₁·(θ₀−θ₁) grows linearly with V₁ — the bulk-aerodynamic ventilation effect, stronger wind drawing more flux from the surface.",
                    "initial_state": {"type": "per_variable", "values": {}},
                    "parameters": {"θᵥ₀": 300.0, "θᵥ₁": 300.0, "θ₀": 302.0, "θ₁": 300.0, "v₁": 0.0, "z₁": 10.0, "z₀ₘ": 0.1},
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "u₁",
                                "range": {"start": 0.0, "stop": 20.0, "count": 41, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "wu0_vs_wind",
                            "type": "line",
                            "description": "Surface momentum flux wu₀ versus the lowest-level zonal wind u₁ — increasingly negative (stronger drag) as the wind strengthens.",
                            "x": {"variable": "u₁", "label": "Lowest-level zonal wind u₁ (m/s)"},
                            "y": {"variable": "wu₀", "label": "Surface momentum flux wu₀ (m^2/s^2)"}
                        },
                        {
                            "id": "wth0_vs_wind",
                            "type": "line",
                            "description": "Surface heat flux wθ₀ versus the lowest-level zonal wind u₁ — rising with wind speed through the bulk-aerodynamic ventilation factor V₁.",
                            "x": {"variable": "u₁", "label": "Lowest-level zonal wind u₁ (m/s)"},
                            "y": {"variable": "wθ₀", "label": "Surface heat flux wθ₀ (K*m/s)"}
                        }
                    ]
                },
                {
                    "id": "neutral_coefficient_vs_roughness",
                    "description": "The neutral exchange coefficient Cₙ = κ²/[ln((z₁+z₀ₘ)/z₀ₘ)]² as a function of the momentum roughness length z₀ₘ. The roughness length is swept logarithmically from 1e-5 m (very smooth, e.g. open water) to 1e-1 m (rough, e.g. tall vegetation), with the lowest model level held at z₁ = 10 m. As the surface roughens the logarithmic roughness ratio shrinks and Cₙ rises — the surface couples more strongly to the atmosphere (Eq. 2.7).",
                    "initial_state": {"type": "per_variable", "values": {}},
                    "parameters": {"z₁": 10.0},
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "z₀ₘ",
                                "range": {"start": 1.0e-5, "stop": 1.0e-1, "count": 41, "scale": "log"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "Cn_vs_z0m",
                            "type": "line",
                            "description": "Neutral exchange coefficient Cₙ as a function of the momentum roughness length z₀ₘ — monotonically increasing with surface roughness.",
                            "x": {"variable": "z₀ₘ", "label": "Momentum roughness length z₀ₘ (m)"},
                            "y": {"variable": "Cₙ", "label": "Neutral exchange coefficient Cₙ"}
                        }
                    ]
                }
            ]
        }
    }
}
