            "tests": [
                {
                    "id": "default_parameters",
                    "description": "All parameters at their declared defaults (z = 100 m, θᵥ = 300 K, ∂θᵥ/∂z = 0.003 K/m, ∂u/∂z = 0.01 1/s, ∂v/∂z = 0). Verifies the declared defaults are wired correctly and exercises all six diagnostic outputs. With ∂θᵥ/∂z > 0 the regime is weakly stable (Ri > 0, Fc < 1).",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "λc",
                            "time": 0.0,
                            "expected": 694.0928400123764
                        },
                        {
                            "variable": "lc",
                            "time": 0.0,
                            "expected": 37.8204391695565
                        },
                        {
                            "variable": "S",
                            "time": 0.0,
                            "expected": 0.010001
                        },
                        {
                            "variable": "Ri",
                            "time": 0.0,
                            "expected": 0.9808038294260766
                        },
                        {
                            "variable": "Fc",
                            "time": 0.0,
                            "expected": 0.011393916935737379
                        },
                        {
                            "variable": "Kc",
                            "time": 0.0,
                            "expected": 0.16299324698202905
                        }
                    ]
                },
                {
                    "id": "length_scale_at_1km",
                    "description": "Asymptotic and mixing length scales at z = 1000 m (Holtslag & Boville Eq. 3.6, 3.4). At z = z_ref the exponential is exp(0) = 1, so λc = 30 + 270 = 300 m (the paper's stated λc ≈ 300 m for z ≤ 1 km); the harmonic mixing length is lc = 1/(1/(κ z) + 1/λc).",
                    "parameter_overrides": {
                        "z": 1000.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "λc",
                            "time": 0.0,
                            "expected": 300.0
                        },
                        {
                            "variable": "lc",
                            "time": 0.0,
                            "expected": 171.42857142857142
                        }
                    ]
                },
                {
                    "id": "length_scale_free_atmosphere",
                    "description": "Asymptotic and mixing length scales at z = 5000 m. High above the boundary layer λc = 30 + 270 exp(1 - 5) = 30 + 270 exp(-4) ≈ 34.95 m, approaching the free-atmosphere floor λ_min = 30 m (Eq. 3.6).",
                    "parameter_overrides": {
                        "z": 5000.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "λc",
                            "time": 0.0,
                            "expected": 34.94522249995823
                        },
                        {
                            "variable": "lc",
                            "time": 0.0,
                            "expected": 34.345123508560626
                        }
                    ]
                },
                {
                    "id": "unstable_eddy_diffusivity",
                    "description": "Full eddy-diffusivity chain at z = 500 m in unstable conditions (∂θᵥ/∂z = -0.005 K/m) with two-component shear (∂u/∂z = 0.02, ∂v/∂z = 0.01 1/s). Exercises Eq. 3.3 (shear magnitude S), Eq. 3.5 (Ri < 0), Eq. 3.7 (unstable Fc = (1 - 18 Ri)^(1/2) > 1) and the Eq. 3.2 product Kc = lc^2 S Fc.",
                    "parameter_overrides": {
                        "z": 500.0,
                        "∂θᵥ_∂z": -0.005,
                        "∂u_∂z": 0.02,
                        "∂v_∂z": 0.01
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "lc",
                            "time": 0.0,
                            "expected": 140.75432275423552
                        },
                        {
                            "variable": "S",
                            "time": 0.0,
                            "expected": 0.022361679774997898
                        },
                        {
                            "variable": "Ri",
                            "time": 0.0,
                            "expected": -0.32697075419273725
                        },
                        {
                            "variable": "Fc",
                            "time": 0.0,
                            "expected": 2.6240185928208035
                        },
                        {
                            "variable": "Kc",
                            "time": 0.0,
                            "expected": 1162.504961014828
                        }
                    ]
                },
                {
                    "id": "stable_conditions",
                    "description": "Stable stratification at z = 500 m (∂θᵥ/∂z = 0.01 K/m > 0). A positive virtual-potential-temperature gradient gives Ri > 0, so the stability function takes the stable branch Eq. 2.11 Fc = 1/(1 + 10 Ri(1 + 8 Ri)) < 1 (suppressed mixing) and Kc stays positive.",
                    "parameter_overrides": {
                        "z": 500.0,
                        "∂θᵥ_∂z": 0.01,
                        "∂u_∂z": 0.01,
                        "∂v_∂z": 0.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "Ri",
                            "time": 0.0,
                            "expected": 3.269346098086922
                        },
                        {
                            "variable": "Fc",
                            "time": 0.0,
                            "expected": 0.0011251335585061304
                        },
                        {
                            "variable": "Kc",
                            "time": 0.0,
                            "expected": 0.22293126917193654
                        }
                    ]
                },
                {
                    "id": "unstable_conditions",
                    "description": "Unstable stratification at z = 500 m (∂θᵥ/∂z = -0.01 K/m < 0), the hemispheric mirror of stable_conditions. A negative gradient gives Ri < 0, so Fc takes the unstable branch Eq. 3.7 Fc = (1 - 18 Ri)^(1/2) > 1 (enhanced mixing) and Kc exceeds its stable-case value.",
                    "parameter_overrides": {
                        "z": 500.0,
                        "∂θᵥ_∂z": -0.01,
                        "∂u_∂z": 0.01,
                        "∂v_∂z": 0.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "Ri",
                            "time": 0.0,
                            "expected": -3.269346098086922
                        },
                        {
                            "variable": "Fc",
                            "time": 0.0,
                            "expected": 7.736163762845548
                        },
                        {
                            "variable": "Kc",
                            "time": 0.0,
                            "expected": 1532.824963876238
                        }
                    ]
                },
                {
                    "id": "neutral_richardson",
                    "description": "Neutral stratification at z = 500 m (∂θᵥ/∂z = 0 exactly). Eq. 3.5 gives Ri = 0, which selects the stable branch at its boundary: Fc = 1/(1 + 0) = 1. Mixing is then governed purely by the local shear, Kc = lc^2 S.",
                    "parameter_overrides": {
                        "z": 500.0,
                        "∂θᵥ_∂z": 0.0,
                        "∂u_∂z": 0.01,
                        "∂v_∂z": 0.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "S",
                            "time": 0.0,
                            "expected": 0.010001
                        },
                        {
                            "variable": "Ri",
                            "time": 0.0,
                            "expected": 0.0
                        },
                        {
                            "variable": "Fc",
                            "time": 0.0,
                            "expected": 1.0
                        },
                        {
                            "variable": "Kc",
                            "time": 0.0,
                            "expected": 198.137605519409
                        }
                    ]
                }
            ],
            "examples": [
                {
                    "id": "length_scales_vs_height",
                    "description": "Asymptotic length scale λc (Eq. 3.6) and harmonic mixing length lc (Eq. 3.4) as functions of height over 10-2000 m. λc decays from ~757 m near the surface toward the free-atmosphere floor of 30 m; lc is the harmonic blend of the surface-proportional κ z and λc, so it peaks in the mid-boundary-layer. Reproduces the length-scale behaviour behind the AtmosphericDynamics.jl 'Local Scheme Eddy Diffusivity Profile' documentation figure.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "θᵥ": 300.0,
                        "∂θᵥ_∂z": 0.003,
                        "∂u_∂z": 0.01,
                        "∂v_∂z": 0.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "z",
                                "range": {
                                    "start": 10.0,
                                    "stop": 2000.0,
                                    "count": 100,
                                    "scale": "linear"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "lambda_c_vs_z",
                            "type": "line",
                            "description": "Asymptotic length scale λc as a function of height.",
                            "x": {
                                "variable": "z",
                                "label": "Height z (m)"
                            },
                            "y": {
                                "variable": "λc",
                                "label": "Asymptotic length scale λc (m)"
                            }
                        },
                        {
                            "id": "l_c_vs_z",
                            "type": "line",
                            "description": "Harmonic mixing length lc as a function of height.",
                            "x": {
                                "variable": "z",
                                "label": "Height z (m)"
                            },
                            "y": {
                                "variable": "lc",
                                "label": "Mixing length lc (m)"
                            }
                        }
                    ]
                },
                {
                    "id": "unstable_eddy_diffusivity_profile",
                    "description": "Eddy diffusivity Kc (Eq. 3.2) versus height for unstable stratification (∂θᵥ/∂z = -0.005 K/m). Reproduces the unstable curve of the AtmosphericDynamics.jl 'Local Scheme Eddy Diffusivity Profile (Eq. 3.2)' documentation figure: enhanced mixing (Fc > 1) lifts Kc above its stable-case value.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "θᵥ": 300.0,
                        "∂θᵥ_∂z": -0.005,
                        "∂u_∂z": 0.01,
                        "∂v_∂z": 0.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "z",
                                "range": {
                                    "start": 10.0,
                                    "stop": 2000.0,
                                    "count": 100,
                                    "scale": "linear"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "Kc_vs_z",
                            "type": "line",
                            "description": "Eddy diffusivity Kc as a function of height (unstable).",
                            "x": {
                                "variable": "z",
                                "label": "Height z (m)"
                            },
                            "y": {
                                "variable": "Kc",
                                "label": "Eddy diffusivity Kc (m^2/s)"
                            }
                        }
                    ]
                },
                {
                    "id": "stable_eddy_diffusivity_profile",
                    "description": "Eddy diffusivity Kc (Eq. 3.2) versus height for stable stratification (∂θᵥ/∂z = 0.005 K/m). Reproduces the stable curve of the AtmosphericDynamics.jl 'Local Scheme Eddy Diffusivity Profile (Eq. 3.2)' documentation figure: suppressed mixing (Fc < 1) holds Kc below its unstable-case value.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "θᵥ": 300.0,
                        "∂θᵥ_∂z": 0.005,
                        "∂u_∂z": 0.01,
                        "∂v_∂z": 0.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "z",
                                "range": {
                                    "start": 10.0,
                                    "stop": 2000.0,
                                    "count": 100,
                                    "scale": "linear"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "Kc_vs_z",
                            "type": "line",
                            "description": "Eddy diffusivity Kc as a function of height (stable).",
                            "x": {
                                "variable": "z",
                                "label": "Height z (m)"
                            },
                            "y": {
                                "variable": "Kc",
                                "label": "Eddy diffusivity Kc (m^2/s)"
                            }
                        }
                    ]
                },
                {
                    "id": "stability_function_vs_richardson",
                    "description": "Local-diffusion stability function Fc as a function of the gradient Richardson number Ri, swept by varying ∂θᵥ/∂z at fixed z = 500 m and shear. Shows the two-branch behaviour: the unstable branch Eq. 3.7 Fc = (1 - 18 Ri)^(1/2) rising above 1 for Ri < 0, and the stable branch Eq. 2.11 Fc = 1/(1 + 10 Ri(1 + 8 Ri)) decaying below 1 for Ri > 0, joined continuously at Fc = 1 for neutral Ri = 0.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "θᵥ": 300.0,
                        "z": 500.0,
                        "∂u_∂z": 0.01,
                        "∂v_∂z": 0.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "∂θᵥ_∂z",
                                "range": {
                                    "start": -0.01,
