                            "w_t",
                            "z",
                            {
                                "op": "^",
                                "args": [
                                    {
                                        "op": "-",
                                        "args": [
                                            1,
                                            "η"
                                        ]
                                    },
                                    2
                                ]
                            }
                        ]
                    }
                },
                {
                    "lhs": "γc",
                    "rhs": {
                        "op": "ifelse",
                        "args": [
                            {
                                "op": ">",
                                "args": [
                                    "wθ_v0",
                                    "zero_heat_flux"
                                ]
                            },
                            {
                                "op": "/",
                                "args": [
                                    {
                                        "op": "*",
                                        "args": [
                                            "a_coeff",
                                            "w_star",
                                            "wC_0"
                                        ]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            {
                                                "op": "^",
                                                "args": [
                                                    "w_m_outer",
                                                    2
                                                ]
                                            },
                                            "h"
                                        ]
                                    }
                                ]
                            },
                            "γc_zero"
                        ]
                    }
                }
            ],
            "tests": [
                {
                    "id": "default_parameters",
                    "description": "All seven inputs at the upstream component defaults (z=100 m, h=1000 m, u_star=0.3 m/s, wθ_v0=0.05 K·m/s, wC_0=1e-5 m/s, θ_v0=300 K, L=-100 m). z/h = 0.1 lands exactly on the surface-layer/outer-layer boundary η = ε_sl, exercising the `η ≤ ε_sl` branch of w_m and w_t.",
                    "parameter_overrides": {
                        "z": 100.0,
                        "h": 1000.0,
                        "u_star": 0.3,
                        "wθ_v0": 0.05,
                        "wC_0": 1e-05,
                        "θ_v0": 300.0,
