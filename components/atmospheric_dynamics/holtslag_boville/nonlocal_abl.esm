            "examples": [
                {
                    "id": "eddy_diffusivity_profile",
                    "description": "Nonlocal-scheme eddy-diffusivity profile Kc(z) through an unstable convective boundary layer of depth h=1000 m (L=-100 m, wθ_v0=0.1 K·m/s). Reproduces the 'Eddy Diffusivity Profile (Eq. 3.9)' figure of the AtmosphericDynamics.jl holtslag_boville docs page: Kc = κ·wₜ·z·(1−z/h)² vanishes at the surface and the BL top with a maximum near z ≈ h/3.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "h": 1000.0,
                        "u_star": 0.3,
                        "wθ_v0": 0.1,
                        "wC_0": 1e-05,
                        "θ_v0": 300.0,
                        "L": -100.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "z",
                                "range": {
                                    "start": 50.0,
                                    "stop": 950.0,
                                    "count": 19,
                                    "scale": "linear"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "kc_vs_height",
                            "type": "line",
                            "description": "Eddy diffusivity Kc as a function of height z (h=1000 m, unstable).",
                            "x": {
                                "variable": "z",
                                "label": "Height z (m)"
                            },
                            "y": {
                                "variable": "Kc",
                                "label": "Eddy diffusivity Kc (m^2/s)"
                            }
                        }
                    ]
                },
                {
                    "id": "convective_velocity_scale",
                    "description": "Convective velocity scale w_star as a function of surface virtual heat flux and boundary-layer depth, w_star = ((g/θ_v0)·wθ_v0·h)^(1/3) (Eq. A12). Reproduces the 'Convective Velocity Scale Dependence (Eq. A12)' figure of the AtmosphericDynamics.jl holtslag_boville docs page as a two-dimensional sweep over (wθ_v0, h): w_star grows with both the surface heat flux and the boundary-layer depth.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "z": 500.0,
                        "u_star": 0.3,
                        "wC_0": 1e-05,
                        "θ_v0": 300.0,
                        "L": -100.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "wθ_v0",
                                "range": {
                                    "start": 0.01,
                                    "stop": 0.2,
                                    "count": 20,
                                    "scale": "linear"
                                }
                            },
                            {
                                "parameter": "h",
                                "range": {
                                    "start": 500.0,
                                    "stop": 2000.0,
                                    "count": 16,
                                    "scale": "linear"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "w_star_heatmap",
                            "type": "heatmap",
                            "description": "Convective velocity scale w_star over surface heat flux wθ_v0 and BL depth h.",
                            "x": {
                                "variable": "wθ_v0",
                                "label": "Surface virtual heat flux wθ_v0 (K*m/s)"
                            },
                            "y": {
                                "variable": "h",
                                "label": "Boundary layer height h (m)"
                            },
                            "value": {
                                "variable": "w_star",
                                "reduce": "final"
                            }
                        }
                    ]
                }
            ]
        }
