                            "variable": "Clark1977AnelasticSystem.topography.dz_s_dx",
                            "time": 0.0,
                            "expected": -0.016666666666666666
                        }
                    ]
                },
                {
                    "id": "transform_full",
                    "description": "Terrain-following coordinate transform with terrain, height and slopes all non-trivial (transform z_s=500 m, z_bar=6000 m, H=10000 m, dz_s_dx=−0.08, dz_s_dy=0.04): the Jacobian G_sqrt = 1 − z_s/H, the metric coefficients G_sqrt·G13 and G_sqrt·G23, the physical height z_phys and the ω diagnostic factor. Mirrors the standalone terrain_following.esm `full_transform` test.",
                    "parameter_overrides": {
                        "Clark1977AnelasticSystem.transform.z_s": 500.0,
                        "Clark1977AnelasticSystem.transform.z_bar": 6000.0,
                        "Clark1977AnelasticSystem.transform.H": 10000.0,
