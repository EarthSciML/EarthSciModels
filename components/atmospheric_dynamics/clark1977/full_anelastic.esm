                {
                    "id": "base_state_elevated_z1000",
                    "description": "Isentropic base state evaluated 1000 m above the surface (base_state.z = 1000 m, Θ and P_0 at defaults). The scale height H_s = c_p·Θ/g is height-independent; the temperature falls linearly (T_bar = Θ·(1 − z/H_s)) and the pressure and density fall as the (1 − z/H_s) power laws of Clark (1977) Eqs. 2.8-2.9. Expected values are the closed-form evaluation of Eqs. 2.6-2.9.",
                    "parameter_overrides": {
                        "Clark1977AnelasticSystem.base_state.z": 1000.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "Clark1977AnelasticSystem.base_state.H_s",
                            "time": 0.0,
                            "expected": 30703.363914373087
                        },
                        {
                            "variable": "Clark1977AnelasticSystem.base_state.T_bar",
                            "time": 0.0,
                            "expected": 290.22908366533864
                        },
                        {
                            "variable": "Clark1977AnelasticSystem.base_state.p_bar",
                            "time": 0.0,
                            "expected": 89062.30249029941
                        },
                        {
                            "variable": "Clark1977AnelasticSystem.base_state.ρ_bar",
                            "time": 0.0,
                            "expected": 1.0692298909033104
                        }
                    ]
                },
                {
                    "id": "topography_half_width",
                    "description": "Witch-of-Agnesi topography sampled one half-width downstream of the peak (topography.x = a = 3000 m). z_s = a^2·h/(a^2 + x^2) = h/2 = 50 m and the terrain slope dz_s/dx = −2a^2·h·x/(a^2 + x^2)^2 = −h/(2a). Mirrors the standalone witch_of_agnesi.esm `half_width` test, routed through the composition.",
                    "parameter_overrides": {
                        "Clark1977AnelasticSystem.topography.x": 3000.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
