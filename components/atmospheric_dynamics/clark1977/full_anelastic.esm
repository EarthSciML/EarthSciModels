                },
                {
                    "id": "thermodynamics_all_heat_flux",
                    "description": "Anelastic thermodynamics (Eqs. 2.14, 2.19) with non-zero potential-temperature gradients in all three directions (thermodynamics dθ_dx=1e-4, dθ_dy=5e-5, dθ_dz=3e-3 K/m): the turbulent heat-flux components H1, H2, H3 = ρ̄·K_H·∇θ. With no heat-flux-divergence inputs the divergence div_H and the first-law residual thermo_residual stay zero. Mirrors the standalone anelastic_thermo.esm `all_heat_flux_components` test.",
                    "parameter_overrides": {
                        "Clark1977AnelasticSystem.thermodynamics.dθ_dx": 0.0001,
                        "Clark1977AnelasticSystem.thermodynamics.dθ_dy": 5e-05,
                        "Clark1977AnelasticSystem.thermodynamics.dθ_dz": 0.003
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "Clark1977AnelasticSystem.thermodynamics.H1",
                            "time": 0.0,
                            "expected": 0.0024500000000000004
                        },
                        {
                            "variable": "Clark1977AnelasticSystem.thermodynamics.H2",
                            "time": 0.0,
                            "expected": 0.0012250000000000002
                        },
                        {
                            "variable": "Clark1977AnelasticSystem.thermodynamics.H3",
                            "time": 0.0,
                            "expected": 0.07350000000000001
                        },
                        {
                            "variable": "Clark1977AnelasticSystem.thermodynamics.div_H",
                            "time": 0.0,
                            "expected": 0.0
