                        }
                    ]
                },
                {
                    "id": "momentum_full_residual",
                    "description": "Anelastic momentum equations (Eqs. 2.1-2.3) with every term active — inertia, Coriolis, pressure-gradient force, Reynolds-stress divergence, buoyancy and Rayleigh friction simultaneously. Mirrors the standalone anelastic_momentum.esm `full_momentum_residual` test, routed through the composition via dot-namespaced overrides.",
                    "parameter_overrides": {
                        "Clark1977AnelasticSystem.momentum.ρ_bar": 1.0,
                        "Clark1977AnelasticSystem.momentum.ρ_prime": 0.1,
                        "Clark1977AnelasticSystem.momentum.u": 10.0,
                        "Clark1977AnelasticSystem.momentum.v": -6.0,
                        "Clark1977AnelasticSystem.momentum.w": 1.0,
                        "Clark1977AnelasticSystem.momentum.du_dt": 0.4,
                        "Clark1977AnelasticSystem.momentum.dv_dt": -0.2,
