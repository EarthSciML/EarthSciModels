                "turbulence": {
                    "variables": {
                        "k_smag": {
                            "type": "parameter",
                            "units": "1",
                            "default": 0.25,
                            "description": "Smagorinsky constant (dimensionless), Eq. 2.17. Upstream MTK `@constants`; sets the eddy viscosity through K_M = (k·Δ)²·|Def|. Clark (1977) uses k = 0.25."
                        },
                        "Def_ref": {
                            "type": "parameter",
                            "units": "1/s",
                            "default": 1.0,
                            "description": "Reference deformation rate (1 s⁻¹). Upstream MTK `@constants`; a dimensional-consistency device — the squared deformation is divided by Def_ref² before the square root in Eq. 2.18 and the result multiplied by Def_ref, so the `sqrt` acts on a dimensionless argument. Numerically the identity (Def_ref = 1), so it does not change any computed value."
                        },
                        "Δ_grid": {
                            "type": "parameter",
                            "units": "m",
                            "default": 600.0,
                            "description": "Grid resolution — the subgrid-scale filter width Δ in the Smagorinsky eddy viscosity (Eq. 2.17). K_M scales with Δ²."
                        },
                        "D11": {
                            "type": "parameter",
                            "units": "1/s",
                            "default": 0.0,
                            "description": "Deformation tensor component D₁₁ (Eq. 2.16), the normal-strain rate along x. Enters the total deformation magnitude (Eq. 2.18) through the trace term ½(D₁₁²+D₂₂²+D₃₃²)."
                        },
                        "D22": {
                            "type": "parameter",
                            "units": "1/s",
                            "default": 0.0,
                            "description": "Deformation tensor component D₂₂ (Eq. 2.16), the normal-strain rate along y. Enters the total deformation magnitude (Eq. 2.18) through the trace term ½(D₁₁²+D₂₂²+D₃₃²)."
                        },
                        "D33": {
                            "type": "parameter",
                            "units": "1/s",
                            "default": 0.0,
                            "description": "Deformation tensor component D₃₃ (Eq. 2.16), the normal-strain rate along z. Enters the total deformation magnitude (Eq. 2.18) through the trace term ½(D₁₁²+D₂₂²+D₃₃²)."
                        },
                        "D12": {
                            "type": "parameter",
                            "units": "1/s",
                            "default": 0.0,
                            "description": "Deformation tensor component D₁₂ (Eq. 2.16), the x-y shear-strain rate. Enters the total deformation magnitude (Eq. 2.18) as the full square D₁₂²."
                        },
                        "D13": {
                            "type": "parameter",
                            "units": "1/s",
                            "default": 0.0,
                            "description": "Deformation tensor component D₁₃ (Eq. 2.16), the x-z shear-strain rate. Enters the total deformation magnitude (Eq. 2.18) as the full square D₁₃²."
                        },
                        "D23": {
                            "type": "parameter",
                            "units": "1/s",
                            "default": 0.0,
                            "description": "Deformation tensor component D₂₃ (Eq. 2.16), the y-z shear-strain rate. Enters the total deformation magnitude (Eq. 2.18) as the full square D₂₃²."
                        },
                        "Def": {
                            "type": "state",
                            "units": "1/s",
                            "description": "Total deformation magnitude |Def| (Eq. 2.18): |Def| = sqrt[½(D₁₁²+D₂₂²+D₃₃²) + D₁₂²+D₁₃²+D₂₃²]. The scalar strain-rate invariant that drives the Smagorinsky eddy viscosity."
                        },
                        "K_M": {
                            "type": "state",
                            "units": "m^2/s",
                            "description": "Eddy viscosity coefficient (Eq. 2.17): K_M = (k_smag·Δ_grid)²·|Def|. The subgrid-scale turbulent momentum diffusivity; grows with the resolved deformation rate and the square of the grid filter width."
                        },
                        "K_H": {
                            "type": "state",
                            "units": "m^2/s",
                            "description": "Turbulent heat diffusivity (Eq. 2.19): K_H = K_M. Clark (1977) assumes the turbulent Prandtl number is unity, so the eddy heat diffusivity equals the eddy viscosity."
                        }
                    },
                    "equations": [
                        {
                            "_comment": "Eq. 2.18 — total deformation magnitude |Def| = Def_ref·sqrt[(½(D11²+D22²+D33²) + D12²+D13²+D23²)/Def_ref²]. The dimensionless squared deformation is the upstream Julia local `Def_sq_dimless`, inlined here. Def_ref = 1 s⁻¹ makes the /Def_ref² and ·Def_ref numerically the identity; they only keep the sqrt argument dimensionless.",
                            "lhs": "Def",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    "Def_ref",
                                    {
                                        "op": "sqrt",
                                        "args": [
                                            {
                                                "op": "/",
                                                "args": [
                                                    {
                                                        "op": "+",
                                                        "args": [
                                                            {
                                                                "op": "*",
                                                                "args": [
                                                                    0.5,
                                                                    {
                                                                        "op": "+",
                                                                        "args": [
                                                                            {
                                                                                "op": "^",
                                                                                "args": [
                                                                                    "D11",
                                                                                    2.0
                                                                                ]
                                                                            },
                                                                            {
                                                                                "op": "^",
                                                                                "args": [
                                                                                    "D22",
                                                                                    2.0
                                                                                ]
                                                                            },
                                                                            {
                                                                                "op": "^",
                                                                                "args": [
                                                                                    "D33",
                                                                                    2.0
                                                                                ]
                                                                            }
                                                                        ]
                                                                    }
                                                                ]
                                                            },
                                                            {
                                                                "op": "^",
                                                                "args": [
                                                                    "D12",
                                                                    2.0
                                                                ]
                                                            },
                                                            {
                                                                "op": "^",
                                                                "args": [
                                                                    "D13",
                                                                    2.0
                                                                ]
                                                            },
                                                            {
                                                                "op": "^",
                                                                "args": [
                                                                    "D23",
                                                                    2.0
                                                                ]
                                                            }
                                                        ]
                                                    },
                                                    {
                                                        "op": "^",
                                                        "args": [
                                                            "Def_ref",
                                                            2.0
                                                        ]
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "_comment": "Eq. 2.17 — Smagorinsky eddy viscosity coefficient K_M = (k·Δ)²·|Def|, with k the Smagorinsky constant and Δ the grid filter width.",
                            "lhs": "K_M",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    {
                                        "op": "^",
                                        "args": [
                                            {
                                                "op": "*",
                                                "args": [
                                                    "k_smag",
                                                    "Δ_grid"
                                                ]
                                            },
                                            2.0
                                        ]
                                    },
                                    "Def"
                                ]
                            }
                        },
                        {
                            "_comment": "Eq. 2.19 — turbulent heat diffusivity, set equal to the eddy viscosity (unit turbulent Prandtl number).",
                            "lhs": "K_H",
                            "rhs": "K_M"
                        }
                    ]
                },
                "momentum": {
                    "variables": {
                        "g": {
                            "type": "parameter",
                            "units": "m/s^2",
                            "default": 9.81,
                            "description": "Gravitational acceleration. Upstream MTK `@constants`; appears in the buoyancy term ρ'·g of the w-momentum equation (Eq. 2.3)."
                        },
                        "u": {
                            "type": "parameter",
                            "units": "m/s",
                            "default": 0.0,
                            "description": "x-velocity (zonal) component. Enters the Coriolis term ρ̄·u·f and the Rayleigh-friction sink ρ̄·u/τ_R of the u-momentum equation (Eq. 2.1)."
                        },
                        "v": {
                            "type": "parameter",
                            "units": "m/s",
                            "default": 0.0,
                            "description": "y-velocity (meridional) component. Enters the Coriolis term ρ̄·v·f and the Rayleigh-friction sink ρ̄·v/τ_R of the v-momentum equation (Eq. 2.2)."
                        },
                        "w": {
                            "type": "parameter",
                            "units": "m/s",
                            "default": 0.0,
                            "description": "z-velocity (vertical) component. Enters the Rayleigh-friction sink ρ̄·w/τ_R of the w-momentum equation (Eq. 2.3)."
                        },
                        "du_dt": {
                            "type": "parameter",
                            "units": "m/s^2",
                            "default": 0.0,
                            "description": "Material derivative of the x-velocity, du/dt. The inertial term ρ̄·(du/dt) of the u-momentum equation (Eq. 2.1)."
                        },
                        "dv_dt": {
                            "type": "parameter",
                            "units": "m/s^2",
                            "default": 0.0,
                            "description": "Material derivative of the y-velocity, dv/dt. The inertial term ρ̄·(dv/dt) of the v-momentum equation (Eq. 2.2)."
                        },
                        "dw_dt": {
                            "type": "parameter",
                            "units": "m/s^2",
                            "default": 0.0,
                            "description": "Material derivative of the z-velocity, dw/dt. The inertial term ρ̄·(dw/dt) of the w-momentum equation (Eq. 2.3)."
                        },
                        "dp_dx": {
                            "type": "parameter",
                            "units": "Pa/m",
                            "default": 0.0,
                            "description": "Perturbation-pressure gradient ∂p'/∂x — the x-component of the pressure-gradient force in the u-momentum equation (Eq. 2.1)."
                        },
                        "dp_dy": {
                            "type": "parameter",
                            "units": "Pa/m",
                            "default": 0.0,
                            "description": "Perturbation-pressure gradient ∂p'/∂y — the y-component of the pressure-gradient force in the v-momentum equation (Eq. 2.2)."
                        },
                        "dp_dz": {
                            "type": "parameter",
                            "units": "Pa/m",
                            "default": 0.0,
                            "description": "Perturbation-pressure gradient ∂p'/∂z — the z-component of the pressure-gradient force in the w-momentum equation (Eq. 2.3)."
                        },
                        "ρ_bar": {
                            "type": "parameter",
                            "units": "kg/m^3",
                            "default": 1.225,
                            "description": "Base-state (reference) air density ρ̄. Multiplies the inertial, Coriolis and Rayleigh-friction terms of all three momentum equations; the anelastic approximation uses the base-state density consistently."
                        },
                        "ρ_prime": {
                            "type": "parameter",
                            "units": "kg/m^3",
                            "default": 0.0,
                            "description": "Density perturbation ρ' from the base state. Drives the buoyancy term ρ'·g of the w-momentum equation (Eq. 2.3); a positive perturbation (air denser than the base state) contributes a positive residual."
                        },
                        "div_τ1": {
                            "type": "parameter",
                            "units": "Pa/m",
                            "default": 0.0,
                            "description": "Reynolds-stress divergence (∇·τ)₁ = ∂τ₁₁/∂x + ∂τ₁₂/∂y + ∂τ₁₃/∂z — the turbulent (subgrid) momentum flux entering the u-momentum equation (Eq. 2.1, stresses from Eq. 2.15)."
                        },
                        "div_τ2": {
                            "type": "parameter",
                            "units": "Pa/m",
                            "default": 0.0,
                            "description": "Reynolds-stress divergence (∇·τ)₂ = ∂τ₂₁/∂x + ∂τ₂₂/∂y + ∂τ₂₃/∂z — the turbulent (subgrid) momentum flux entering the v-momentum equation (Eq. 2.2, stresses from Eq. 2.15)."
                        },
                        "div_τ3": {
                            "type": "parameter",
                            "units": "Pa/m",
                            "default": 0.0,
                            "description": "Reynolds-stress divergence (∇·τ)₃ = ∂τ₃₁/∂x + ∂τ₃₂/∂y + ∂τ₃₃/∂z — the turbulent (subgrid) momentum flux entering the w-momentum equation (Eq. 2.3, stresses from Eq. 2.15)."
                        },
                        "f_coriolis": {
                            "type": "parameter",
                            "units": "1/s",
                            "default": 0.0,
                            "description": "Coriolis parameter f. Sets the magnitude of the Coriolis term ρ̄·V·f in the two horizontal momentum equations (Eqs. 2.1-2.2); there is no Coriolis term in the vertical."
                        },
                        "τ_R": {
                            "type": "parameter",
                            "units": "s",
                            "default": 1000.0,
                            "description": "Rayleigh-friction time scale. The momentum sink −ρ̄·V/τ_R in all three equations damps the velocity on the τ_R time scale (an absorbing-layer / large-scale-drag parameterization)."
                        },
                        "mom_u": {
                            "type": "state",
                            "units": "Pa/m",
                            "description": "u-momentum equation residual (Eq. 2.1): ρ̄·(du/dt) + ρ̄·u·f + ∂p'/∂x − (∇·τ)₁ − ρ̄·u/τ_R. Zero when the u-momentum balance is exactly satisfied."
                        },
                        "mom_v": {
                            "type": "state",
                            "units": "Pa/m",
                            "description": "v-momentum equation residual (Eq. 2.2): ρ̄·(dv/dt) + ρ̄·v·f + ∂p'/∂y − (∇·τ)₂ − ρ̄·v/τ_R. Zero when the v-momentum balance is exactly satisfied."
                        },
                        "mom_w": {
                            "type": "state",
                            "units": "Pa/m",
                            "description": "w-momentum equation residual (Eq. 2.3): ρ̄·(dw/dt) + ∂p'/∂z + ρ'·g − (∇·τ)₃ − ρ̄·w/τ_R. Zero when the w-momentum balance is exactly satisfied."
                        }
                    },
                    "equations": [
                        {
                            "_comment": "Eq. 2.1 — u-momentum equation residual: ρ̄·(du/dt) + ρ̄·u·f + ∂p'/∂x − (∇·τ)₁ − ρ̄·u/τ_R. Inertia + Coriolis + pressure-gradient force − Reynolds-stress divergence − Rayleigh friction; zero for an exact solution. The Coriolis term uses the base-state density ρ̄ consistently. Each subtraction is encoded as a term scaled by −1.0.",
                            "lhs": "mom_u",
                            "rhs": {
                                "op": "+",
                                "args": [
                                    {
                                        "op": "*",
                                        "args": [
                                            "ρ_bar",
                                            "du_dt"
                                        ]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            "ρ_bar",
                                            "u",
                                            "f_coriolis"
                                        ]
                                    },
                                    "dp_dx",
                                    {
                                        "op": "*",
                                        "args": [
                                            -1.0,
                                            "div_τ1"
                                        ]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            -1.0,
                                            {
                                                "op": "/",
                                                "args": [
                                                    {
                                                        "op": "*",
                                                        "args": [
                                                            "ρ_bar",
                                                            "u"
                                                        ]
                                                    },
                                                    "τ_R"
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "_comment": "Eq. 2.2 — v-momentum equation residual: ρ̄·(dv/dt) + ρ̄·v·f + ∂p'/∂y − (∇·τ)₂ − ρ̄·v/τ_R. Identical structure to Eq. 2.1 with the y-direction inputs.",
                            "lhs": "mom_v",
                            "rhs": {
                                "op": "+",
                                "args": [
                                    {
                                        "op": "*",
                                        "args": [
                                            "ρ_bar",
                                            "dv_dt"
                                        ]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            "ρ_bar",
                                            "v",
                                            "f_coriolis"
                                        ]
                                    },
                                    "dp_dy",
                                    {
                                        "op": "*",
                                        "args": [
                                            -1.0,
                                            "div_τ2"
                                        ]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            -1.0,
                                            {
                                                "op": "/",
                                                "args": [
                                                    {
                                                        "op": "*",
                                                        "args": [
                                                            "ρ_bar",
                                                            "v"
                                                        ]
                                                    },
                                                    "τ_R"
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "_comment": "Eq. 2.3 — w-momentum equation residual: ρ̄·(dw/dt) + ∂p'/∂z + ρ'·g − (∇·τ)₃ − ρ̄·w/τ_R. No Coriolis term in the vertical; the buoyancy term ρ'·g uses the density perturbation ρ'.",
                            "lhs": "mom_w",
                            "rhs": {
                                "op": "+",
                                "args": [
                                    {
                                        "op": "*",
                                        "args": [
                                            "ρ_bar",
                                            "dw_dt"
                                        ]
                                    },
                                    "dp_dz",
                                    {
                                        "op": "*",
                                        "args": [
                                            "ρ_prime",
                                            "g"
                                        ]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            -1.0,
                                            "div_τ3"
                                        ]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            -1.0,
                                            {
                                                "op": "/",
                                                "args": [
                                                    {
                                                        "op": "*",
                                                        "args": [
                                                            "ρ_bar",
                                                            "w"
                                                        ]
                                                    },
                                                    "τ_R"
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        }
                    ]
                },
                "mass_continuity": {
                    "variables": {
                        "ρ_bar": {
                            "type": "parameter",
                            "units": "kg/m^3",
                            "default": 1.225,
                            "description": "Base-state (reference) air density ρ̄ [kg/m^3] — the horizontally-uniform, time-independent density of the anelastic reference atmosphere against which the dynamics are linearized (Clark 1977, Sec. 2). Multiplies each velocity component to form the density-weighted velocities rho_u, rho_v, rho_w. Upstream an MTK `@parameter`; default 1.225 kg/m^3, the U.S. Standard Atmosphere sea-level air density."
                        },
                        "u": {
                            "type": "parameter",
                            "units": "m/s",
                            "default": 0.0,
                            "description": "x-velocity component u [m/s] of the air motion. An externally-supplied input of the standalone component (upstream an MTK `@parameter`); combined with the base-state density to form the density-weighted velocity rho_u = ρ̄u. Default 0 m/s (a quiescent base state)."
                        },
                        "v": {
                            "type": "parameter",
                            "units": "m/s",
                            "default": 0.0,
                            "description": "y-velocity component v [m/s] of the air motion. An externally-supplied input of the standalone component (upstream an MTK `@parameter`); combined with the base-state density to form the density-weighted velocity rho_v = ρ̄v. Default 0 m/s (a quiescent base state)."
                        },
                        "w": {
                            "type": "parameter",
                            "units": "m/s",
                            "default": 0.0,
                            "description": "z-velocity component w [m/s] of the air motion (vertical velocity). An externally-supplied input of the standalone component (upstream an MTK `@parameter`); combined with the base-state density to form the density-weighted velocity rho_w = ρ̄w. Default 0 m/s (a quiescent base state)."
                        },
                        "d_dx_rho_u": {
                            "type": "parameter",
                            "units": "kg/(m^3*s)",
                            "default": 0.0,
                            "description": "Density-weighted velocity divergence term ∂(ρ̄u)/∂x [kg/(m^3*s)] — the x-derivative of the density-weighted u-velocity. Supplied externally (upstream an MTK `@parameter`): in a coupled solve this spatial derivative is produced by the surrounding discretization / terrain-following coordinate-transform stage, so the standalone component takes it as an input. Summed with the y- and z-terms to form the anelastic mass-continuity residual (Eq. 2.4). Default 0."
                        },
                        "d_dy_rho_v": {
                            "type": "parameter",
                            "units": "kg/(m^3*s)",
                            "default": 0.0,
                            "description": "Density-weighted velocity divergence term ∂(ρ̄v)/∂y [kg/(m^3*s)] — the y-derivative of the density-weighted v-velocity. Supplied externally (upstream an MTK `@parameter`): in a coupled solve this spatial derivative is produced by the surrounding discretization / terrain-following coordinate-transform stage, so the standalone component takes it as an input. Summed with the x- and z-terms to form the anelastic mass-continuity residual (Eq. 2.4). Default 0."
                        },
                        "d_dz_rho_w": {
                            "type": "parameter",
                            "units": "kg/(m^3*s)",
                            "default": 0.0,
                            "description": "Density-weighted velocity divergence term ∂(ρ̄w)/∂z [kg/(m^3*s)] — the z-derivative of the density-weighted w-velocity. Supplied externally (upstream an MTK `@parameter`): in a coupled solve this spatial derivative is produced by the surrounding discretization / terrain-following coordinate-transform stage, so the standalone component takes it as an input. Summed with the x- and y-terms to form the anelastic mass-continuity residual (Eq. 2.4). Default 0."
                        },
                        "mass_continuity": {
                            "type": "state",
                            "units": "kg/(m^3*s)",
                            "description": "Anelastic mass continuity residual [kg/(m^3*s)] (Clark 1977, Eq. 2.4): the density-weighted velocity divergence ∂(ρ̄u)/∂x + ∂(ρ̄v)/∂y + ∂(ρ̄w)/∂z. The anelastic approximation constrains this residual to zero — a flow with mass_continuity = 0 is divergence-free in the density-weighted sense and contains no acoustic modes. An observed (algebraic) output: the LHS of exactly one purely-algebraic equation, with no time derivative and hence no initial condition."
                        },
                        "rho_u": {
                            "type": "state",
                            "units": "kg/(m^2*s)",
                            "description": "Density-weighted u-velocity ρ̄u [kg/(m^2*s)] — the base-state density times the x-velocity component, i.e. the x-component of the air mass flux. An observed (algebraic) output: the LHS of exactly one purely-algebraic equation rho_u ~ ρ_bar*u, with no time derivative and hence no initial condition. Keeps its ASCII upstream name."
                        },
                        "rho_v": {
                            "type": "state",
                            "units": "kg/(m^2*s)",
                            "description": "Density-weighted v-velocity ρ̄v [kg/(m^2*s)] — the base-state density times the y-velocity component, i.e. the y-component of the air mass flux. An observed (algebraic) output: the LHS of exactly one purely-algebraic equation rho_v ~ ρ_bar*v, with no time derivative and hence no initial condition. Keeps its ASCII upstream name."
                        },
                        "rho_w": {
                            "type": "state",
                            "units": "kg/(m^2*s)",
                            "description": "Density-weighted w-velocity ρ̄w [kg/(m^2*s)] — the base-state density times the z-velocity component, i.e. the z-component (vertical) of the air mass flux. An observed (algebraic) output: the LHS of exactly one purely-algebraic equation rho_w ~ ρ_bar*w, with no time derivative and hence no initial condition. Keeps its ASCII upstream name."
                        }
                    },
                    "equations": [
                        {
                            "lhs": "rho_u",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    "ρ_bar",
                                    "u"
                                ]
                            }
                        },
                        {
                            "lhs": "rho_v",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    "ρ_bar",
                                    "v"
                                ]
                            }
                        },
                        {
                            "lhs": "rho_w",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    "ρ_bar",
                                    "w"
                                ]
                            }
                        },
                        {
                            "lhs": "mass_continuity",
                            "rhs": {
                                "op": "+",
                                "args": [
                                    "d_dx_rho_u",
                                    "d_dy_rho_v",
                                    "d_dz_rho_w"
                                ]
                            }
                        }
                    ]
                },
                "thermodynamics": {
                    "variables": {
                        "ρ_bar": {
                            "type": "parameter",
                            "units": "kg/m^3",
                            "default": 1.225,
                            "description": "Base-state (anelastic reference) air density. Default 1.225 kg/m^3 (sea-level standard atmosphere); lower aloft. The anelastic approximation density-weights the heat fluxes and the thermodynamic tendency."
                        },
                        "dθ_dt": {
                            "type": "parameter",
                            "units": "K/s",
                            "default": 0.0,
                            "description": "Material derivative of potential temperature, dtheta/dt — the local potential-temperature tendency. Default 0 (steady state)."
                        },
                        "dθ_dx": {
                            "type": "parameter",
                            "units": "K/m",
                            "default": 0.0,
                            "description": "Potential-temperature gradient in the x (zonal) direction, ∂theta/∂x. Drives the x-component turbulent heat flux H1. Default 0."
                        },
                        "dθ_dy": {
                            "type": "parameter",
                            "units": "K/m",
                            "default": 0.0,
                            "description": "Potential-temperature gradient in the y (meridional) direction, ∂theta/∂y. Drives the y-component turbulent heat flux H2. Default 0."
                        },
                        "dθ_dz": {
                            "type": "parameter",
                            "units": "K/m",
                            "default": 0.0,
                            "description": "Potential-temperature gradient in the z (vertical) direction, ∂theta/∂z — the static-stability lapse rate (positive = stable). Drives the z-component turbulent heat flux H3. Default 0."
                        },
                        "K_H": {
                            "type": "parameter",
                            "units": "m^2/s",
                            "default": 20.0,
                            "description": "Eddy heat diffusivity from the Smagorinsky subgrid-scale closure (Clark 1977 Eq. 2.19, K_H = K_M). Default 20 m^2/s (upstream @parameter default)."
                        },
                        "dH1_dx": {
                            "type": "parameter",
                            "units": "K*kg/(m^3*s)",
                            "default": 0.0,
                            "description": "Divergence component ∂H1/∂x of the x turbulent heat flux. An externally-supplied input to the heat-flux divergence term div_H. Default 0."
                        },
                        "dH2_dy": {
                            "type": "parameter",
                            "units": "K*kg/(m^3*s)",
                            "default": 0.0,
                            "description": "Divergence component ∂H2/∂y of the y turbulent heat flux. An externally-supplied input to the heat-flux divergence term div_H. Default 0."
                        },
                        "dH3_dz": {
                            "type": "parameter",
                            "units": "K*kg/(m^3*s)",
                            "default": 0.0,
                            "description": "Divergence component ∂H3/∂z of the z turbulent heat flux. An externally-supplied input to the heat-flux divergence term div_H. Default 0."
                        },
                        "H1": {
                            "type": "state",
                            "units": "K*kg/(m^2*s)",
                            "description": "x-component turbulent heat flux, H1 = rho_bar*K_H*(∂theta/∂x) (Clark 1977 Eq. 2.19). An observed (algebraic) output — the LHS of exactly one purely-algebraic equation, with no time derivative and hence no initial condition. Downgradient: positive for a positive zonal potential-temperature gradient."
                        },
                        "H2": {
                            "type": "state",
                            "units": "K*kg/(m^2*s)",
                            "description": "y-component turbulent heat flux, H2 = rho_bar*K_H*(∂theta/∂y) (Eq. 2.19). An observed (algebraic) output; no time derivative, no initial condition."
                        },
                        "H3": {
                            "type": "state",
                            "units": "K*kg/(m^2*s)",
                            "description": "z-component turbulent heat flux, H3 = rho_bar*K_H*(∂theta/∂z) (Eq. 2.19). An observed (algebraic) output; no time derivative, no initial condition. The vertical turbulent heat flux down the static-stability gradient."
                        },
                        "div_H": {
                            "type": "state",
                            "units": "K*kg/(m^3*s)",
                            "description": "Heat-flux divergence term, div_H = -div(H) = -(∂H1/∂x + ∂H2/∂y + ∂H3/∂z) (Clark 1977 Eq. 2.14). An observed (algebraic) output; the convergence of the turbulent heat flux that heats a fluid parcel. No time derivative, no initial condition."
                        },
                        "thermo_residual": {
                            "type": "state",
                            "units": "K*kg/(m^3*s)",
                            "description": "Residual of the anelastic thermodynamic equation (Clark 1977 Eq. 2.14), thermo_residual = rho_bar*(dtheta/dt) - div_H. An observed (algebraic) output that is zero for an exact, energy-conserving solution of the first law; a nonzero value measures the imbalance between the potential-temperature tendency and the turbulent heat-flux convergence. No time derivative, no initial condition."
                        }
                    },
                    "equations": [
                        {
                            "_comment": "Clark 1977 Eq. 2.19 — x-component turbulent heat flux, H1 = rho_bar*K_H*(d(theta)/dx).",
                            "lhs": "H1",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    "ρ_bar",
                                    "K_H",
                                    "dθ_dx"
                                ]
                            }
                        },
                        {
                            "_comment": "Clark 1977 Eq. 2.19 — y-component turbulent heat flux, H2 = rho_bar*K_H*(d(theta)/dy).",
                            "lhs": "H2",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    "ρ_bar",
                                    "K_H",
                                    "dθ_dy"
                                ]
                            }
                        },
                        {
                            "_comment": "Clark 1977 Eq. 2.19 — z-component turbulent heat flux, H3 = rho_bar*K_H*(d(theta)/dz).",
                            "lhs": "H3",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    "ρ_bar",
                                    "K_H",
                                    "dθ_dz"
                                ]
                            }
                        },
                        {
                            "_comment": "Heat-flux divergence term div_H = -div(H) = -(dH1/dx + dH2/dy + dH3/dz).",
                            "lhs": "div_H",
                            "rhs": {
                                "op": "*",
                                "args": [
                                    -1,
                                    {
                                        "op": "+",
                                        "args": [
                                            "dH1_dx",
                                            "dH2_dy",
                                            "dH3_dz"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "_comment": "Clark 1977 Eq. 2.14 — first-law residual rho_bar*(d(theta)/dt) - div_H; zero for an exact energy-conserving solution.",
                            "lhs": "thermo_residual",
                            "rhs": {
                                "op": "-",
                                "args": [
                                    {
                                        "op": "*",
                                        "args": [
                                            "ρ_bar",
                                            "dθ_dt"
                                        ]
                                    },
                                    "div_H"
                                ]
                            }
                        }
                    ]
                },
                "pressure_diag": {
                    "variables": {
                        "g": {
                            "type": "parameter",
                            "units": "m/s^2",
                            "default": 9.81,
                            "description": "Gravitational acceleration"
                        },
                        "C_a": {
                            "type": "parameter",
                            "units": "m/s",
                            "default": 50.0,
                            "description": "Pseudo-compressible acoustic speed (numerical parameter)"
                        },
                        "G_sqrt": {
                            "type": "parameter",
                            "units": "1",
                            "default": 1.0,
                            "description": "G^(1/2) Jacobian factor of the terrain-following coordinates (dimensionless)"
                        },
                        "p_prime": {
                            "type": "parameter",
                            "units": "Pa",
                            "default": 0.0,
                            "description": "Pressure perturbation"
                        },
                        "d2p_dx2": {
                            "type": "parameter",
                            "units": "Pa/m^2",
                            "default": 0.0,
                            "description": "Second derivative of the pressure perturbation in x"
                        },
                        "d2p_dy2": {
                            "type": "parameter",
                            "units": "Pa/m^2",
                            "default": 0.0,
                            "description": "Second derivative of the pressure perturbation in y"
                        },
                        "d2p_dz2": {
                            "type": "parameter",
                            "units": "Pa/m^2",
                            "default": 0.0,
                            "description": "Second derivative of the pressure perturbation in z (terrain-following coordinate)"
                        },
                        "F_source": {
                            "type": "parameter",
                            "units": "Pa/m^2",
                            "default": 0.0,
                            "description": "Pressure equation source F(x) from the momentum-equation divergences (Eq. 4.1)"
                        },
                        "dPFX_dx": {
                            "type": "parameter",
                            "units": "Pa/m^2",
                            "default": 0.0,
                            "description": "Divergence of the x-pressure gradient force term, d(PFX)/dx"
                        },
                        "dPFY_dy": {
                            "type": "parameter",
                            "units": "Pa/m^2",
                            "default": 0.0,
                            "description": "Divergence of the y-pressure gradient force term, d(PFY)/dy"
                        },
                        "dPFZ_dz": {
                            "type": "parameter",
                            "units": "Pa/m^2",
                            "default": 0.0,
                            "description": "Divergence of the z-pressure gradient force term, d(PFZ)/dz (terrain-following coordinate)"
                        },
                        "laplacian_p": {
                            "type": "state",
                            "units": "Pa/m^2",
                            "description": "Pressure-perturbation Laplacian in terrain-following coordinates"
                        },
                        "pressure_residual": {
                            "type": "state",
                            "units": "Pa/m^2",
                            "description": "Diagnostic pressure equation residual (Eq. 4.2); zero when the anelastic constraint is satisfied"
                        },
                        "div_PF": {
                            "type": "state",
                            "units": "Pa/m^2",
                            "description": "Divergence of the pressure gradient forces"
                        }
                    },
                    "equations": [
                        {
                            "lhs": "div_PF",
                            "rhs": {
                                "op": "+",
                                "args": [
                                    "dPFX_dx",
                                    "dPFY_dy",
                                    {
                                        "op": "/",
                                        "args": [
                                            "dPFZ_dz",
                                            "G_sqrt"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "lhs": "laplacian_p",
                            "rhs": {
                                "op": "+",
                                "args": [
                                    "d2p_dx2",
                                    "d2p_dy2",
                                    "d2p_dz2"
                                ]
                            }
                        },
                        {
                            "lhs": "pressure_residual",
                            "rhs": {
                                "op": "+",
                                "args": [
                                    "laplacian_p",
                                    {
                                        "op": "*",
                                        "args": [
                                            -1,
                                            {
                                                "op": "/",
                                                "args": [
                                                    {
                                                        "op": "*",
                                                        "args": [
                                                            "g",
                                                            "p_prime"
                                                        ]
                                                    },
                                                    {
                                                        "op": "^",
                                                        "args": [
                                                            "C_a",
                                                            2
                                                        ]
                                                    }
                                                ]
                                            }
                                        ]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            -1,
                                            "F_source"
                                        ]
                                    }
                                ]
                            }
                        }
                    ]
                }
            },
            "tests": [
                {
                    "id": "composed_default_canonical_all_subsystems",
                    "description": "Canonical default-parameter run of the composed system. Reproduces the intent of the upstream `Clark1977AnelasticSystem Structure` test (test/clark1977_test.jl:246-260, which asserts the composed object is a System carrying the 8 named subsystems base_state/topography/transform/turbulence/momentum/mass_continuity/thermodynamics/pressure_diag) by exercising every output of every one of the 8 subsystems through the dot-namespaced flattened system at default parameters. base_state returns the isentropic profile at z=0 (T_bar=Θ=300 K, p_bar=P_0=1e5 Pa, ρ_bar=1.1614 kg/m^3, H_s=c_p·Θ/g); topography the Witch-of-Agnesi peak (z_s=h_mtn=100 m at x=0); transform the flat-surface metrics (G_sqrt=ω_diag=1); the four diagnostic-residual subsystems (turbulence, momentum, mass_continuity, thermodynamics, pressure_diag) all vanish identically under the quiescent default state.",
                    "parameter_overrides": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "Clark1977AnelasticSystem.base_state.T_bar",
