                            "type": "parameter",
                            "units": "m",
                            "default": 0.0,
                            "description": "Transformed (terrain-following) vertical coordinate"
                        },
                        "dz_s_dx": {
                            "type": "parameter",
                            "units": "1",
                            "default": 0.0,
