                    ]
                },
                {
                    "id": "mass_continuity_all_outputs",
                    "description": "Anelastic mass continuity (Eq. 2.4) with the base-state density, all three velocity components and all three density-weighted-divergence inputs non-zero: the density-weighted velocities ρ̄u, ρ̄v, ρ̄w and the mass-continuity residual. Mirrors the standalone anelastic_mass.esm `all_outputs_nonzero` test.",
                    "parameter_overrides": {
