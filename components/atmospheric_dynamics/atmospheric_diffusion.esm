                            "variable": "K_zz",
                            "time": 0.0,
                            "expected": 6.0
                        }
                    ]
                },
                {
                    "id": "neutral_kzz_mixed_layer",
                    "description": "Neutral K_zz (Eq. 18.122), mixed-layer branch 0.1 <= z/z_i <= 1.1. L_MO = 1.0e6 m selects the neutral profile; at z = 500 m (z/z_i = 0.5) K_zz = kappa*u_star*z*(1.1 - z/z_i) = 0.4*0.3*500*0.6 = 36 m^2/s. Reproduces the mixed-layer assertion of the upstream `Neutral K_zz (Eq. 18.122)` testitem.",
                    "parameter_overrides": {
                        "z": 500.0,
                        "L_MO": 1000000.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "K_zz",
                            "time": 0.0,
                            "expected": 36.00000000000001
                        }
                    ]
                },
                {
                    "id": "neutral_kzz_above_bl_zero",
                    "description": "Neutral K_zz (Eq. 18.122), above-boundary-layer branch z/z_i > 1.1. L_MO = 1.0e6 m selects the neutral profile; at z = 1200 m (z/z_i = 1.2) K_zz collapses to the Kzz_zero fallback (exactly 0). K_yy = K_zz under neutral conditions, so it is 0 as well. Reproduces the above-BL assertion of the upstream `Neutral K_zz (Eq. 18.122)` testitem (`@test sol3[K_zz] approx 0.0 atol = 1e-6`); both assertions use an absolute tolerance to gate the exact-zero output.",
                    "parameter_overrides": {
                        "z": 1200.0,
                        "L_MO": 1000000.0
