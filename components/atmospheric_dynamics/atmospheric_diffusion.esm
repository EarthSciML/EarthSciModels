            ],
            "tests": [
                {
                    "id": "defaults_unstable_z100",
                    "description": "Baseline run at the declared defaults (z = 100 m, L_MO = -100 m unstable, z_i = 1000, u_star = 0.3, u_r = 5, z_r = 10, p_wind = 0.15). z/z_i = 0.1 places K_zz on Eq. 18.121 unstable piece 2 (0.05 <= z/z_i <= 0.6). Pins all three outputs at once: the power-law wind speed u_wind = 5*(100/10)^0.15, the vertical diffusivity K_zz, and the unstable horizontal diffusivity K_yy = 0.1*w_star*z_i. Reproduces the upstream `AtmosphericDiffusion Structure` testitem by exercising every output variable.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "u_wind",
                            "time": 0.0,
                            "expected": 7.062687723113772
                        },
                        {
                            "variable": "K_zz",
                            "time": 0.0,
                            "expected": 62.69386432502207
                        },
                        {
                            "variable": "K_yy",
                            "time": 0.0,
                            "expected": 87.72053214638598
                        }
                    ]
                },
                {
                    "id": "wind_profile_reference_height",
                    "description": "Wind profile (Eq. 18.118) at the reference height z = z_r = 10 m: u_wind/u_r = (z_r/z_r)^p_wind = 1, so u_wind equals the reference wind speed u_r = 5 m/s exactly. Reproduces the first assertion of the upstream `Wind Profile (Eq. 18.118)` testitem.",
                    "parameter_overrides": {
                        "z": 10.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "u_wind",
                            "time": 0.0,
                            "expected": 5.0
                        }
                    ]
                },
                {
                    "id": "wind_profile_z50",
                    "description": "Wind profile (Eq. 18.118) at z = 50 m: u_wind = u_r*(z/z_r)^p_wind = 5*(50/10)^0.15 = 5*5^0.15. Reproduces the z=50 assertion of the upstream `Wind Profile (Eq. 18.118)` testitem.",
                    "parameter_overrides": {
                        "z": 50.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "u_wind",
                            "time": 0.0,
                            "expected": 6.365250577732118
                        }
                    ]
                },
                {
                    "id": "unstable_kzz_piece1_surface_layer",
                    "description": "Unstable K_zz (Eq. 18.121, Lamb & Duran 1977), piece 1 — surface layer z/z_i < 0.05. At z = 30 m, L_MO = -100 m (z/z_i = 0.03) K_zz follows the 2.5*kappa*(z/z_i)^(4/3)*(1-15z/L)^(1/4) branch. Reproduces piece 1 of the upstream `Unstable K_zz (Eq. 18.121)` testitem.",
                    "parameter_overrides": {
                        "z": 30.0,
                        "L_MO": -100.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "K_zz",
                            "time": 0.0,
                            "expected": 12.522381662879011
                        }
                    ]
                },
                {
                    "id": "unstable_kzz_piece2_mixed_layer",
                    "description": "Unstable K_zz (Eq. 18.121), piece 2 — mixed layer 0.05 <= z/z_i <= 0.6. At z = 300 m, L_MO = -100 m (z/z_i = 0.3) K_zz follows the quartic-polynomial branch. Reproduces piece 2 of the upstream `Unstable K_zz (Eq. 18.121)` testitem.",
                    "parameter_overrides": {
                        "z": 300.0,
                        "L_MO": -100.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "K_zz",
                            "time": 0.0,
                            "expected": 153.6284767692516
                        }
                    ]
                },
                {
                    "id": "unstable_kzz_piece3_upper_bl",
                    "description": "Unstable K_zz (Eq. 18.121), piece 3 — upper boundary layer 0.6 < z/z_i <= 1.1. At z = 800 m, L_MO = -100 m (z/z_i = 0.8) K_zz follows the 0.2*exp(6-10 z/z_i) decay branch. Reproduces piece 3 of the upstream `Unstable K_zz (Eq. 18.121)` testitem.",
                    "parameter_overrides": {
                        "z": 800.0,
                        "L_MO": -100.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "K_zz",
                            "time": 0.0,
                            "expected": 23.74336612739507
                        }
                    ]
