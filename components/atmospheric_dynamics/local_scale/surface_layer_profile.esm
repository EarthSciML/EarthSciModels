            "tests": [
                {
                    "id": "default_parameters",
                    "description": "All parameters at their declared defaults (q_z = 0 -> the ε_q heat-flux regularization makes |L| enormous, so the surface layer is effectively neutral). ζ collapses to ~0, φ_m = φ_h -> 1, ψ_m = ψ_h -> 0, and ū reduces to the pure logarithmic profile (u_star/κ)·ln(z/z₀). Guards the serialized parameter defaults.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "L",
                            "time": 0.0,
                            "expected": -24416778974839.395
                        },
                        {
                            "variable": "ζ",
                            "time": 0.0,
                            "expected": -4.095544301852688e-13,
                            "tolerance": {
                                "abs": 1e-06
                            }
                        },
                        {
                            "variable": "φ_m",
                            "time": 0.0,
                            "expected": 0.9999999999984641
                        },
                        {
                            "variable": "φ_h",
                            "time": 0.0,
                            "expected": 0.9999999999969285
                        },
                        {
                            "variable": "ψ_m",
                            "time": 0.0,
                            "expected": 1.535438443056002e-12,
                            "tolerance": {
                                "abs": 1e-06
                            }
                        },
                        {
                            "variable": "ψ_h",
                            "time": 0.0,
                            "expected": 3.0713209753206747e-12,
                            "tolerance": {
                                "abs": 1e-06
                            }
                        },
                        {
                            "variable": "ū",
                            "time": 0.0,
                            "expected": 3.4538776394899164
                        },
                        {
                            "variable": "ū",
                            "time": 1.0,
                            "expected": 3.4538776394899164
                        }
                    ]
                },
                {
                    "id": "monin_obukhov_neutral",
                    "description": "Monin-Obukhov length under near-neutral conditions (q_z = 1e-6 W/m^2, essentially zero heat flux). Upstream \"Monin-Obukhov length\" test 1: |L| must exceed 1e6 m. Here L = -2.44e9 m.",
