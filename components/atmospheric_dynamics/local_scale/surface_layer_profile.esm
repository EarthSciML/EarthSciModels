                        }
                    ]
                },
                {
                    "id": "businger_dyer_stability_functions",
                    "description": "Businger-Dyer stability functions φ_m and φ_h as functions of the stability parameter ζ = z/L, traced by sweeping the surface heat flux q_z over the unstable regime (q_z > 0 -> ζ < 0). Reproduces the unstable branch of the AtmosphericDynamics.jl docs figure \"Businger-Dyer Stability Functions\": both functions fall below 1 as the surface layer becomes more unstable.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
