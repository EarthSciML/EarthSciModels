                {
                    "id": "monin_obukhov_length_vs_heat_flux",
                    "description": "Monin-Obukhov length L as a function of the surface sensible heat flux q_z over the unstable regime (q_z > 0, surface heating), at the default u_star = 0.3 m/s. Reproduces the unstable branch of the AtmosphericDynamics.jl docs figure \"Monin-Obukhov Length vs Heat Flux\": L is negative and grows toward 0 as the heat flux increases.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "q_z",
                                "range": {
                                    "start": 10.0,
                                    "stop": 300.0,
                                    "count": 30,
                                    "scale": "linear"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "L_vs_q_z",
                            "type": "line",
                            "description": "Monin-Obukhov length L vs surface heat flux q_z (Eq. 16.70).",
                            "x": {
                                "variable": "q_z",
                                "label": "Surface sensible heat flux q_z (W/m^2)"
                            },
                            "y": {
                                "variable": "L",
                                "label": "Monin-Obukhov length L (m)"
                            }
                        }
                    ]
                },
                {
                    "id": "logarithmic_wind_profile",
                    "description": "Mean wind speed ū as a function of height z under neutral conditions (default q_z = 0), with u_star = 0.4 m/s and z₀ = 0.1 m. Reproduces the neutral wind profile of the AtmosphericDynamics.jl docs figure \"Wind Profiles for Different Stability Conditions\": ū follows the logarithmic law (u_star/κ)·ln(z/z₀).",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "u_star": 0.4
                    },
                    "time_span": {
