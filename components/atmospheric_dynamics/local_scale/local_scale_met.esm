            ],
            "tests": [
                {
                    "id": "defaults_baseline",
                    "description": "Baseline run at the declared defaults (T = T_below = 288.15 K, p = 101325 Pa, z = 10 m, z₀ = 0.1 m, Δz = 100 m, T₀ = 288.15 K, ρ = 1.225 kg/m^3, u_star = 0.3 m/s, q_z = 0). Pins all 12 outputs at once, reproducing the upstream `LocalScaleMeteorology structure` testitem. At sea level (p = p₀) θ = T = 288.15 K; with T = T_below the actual lapse rate dT_dz is exactly zero and dθ_dz collapses to the dry adiabatic lapse rate Γ_d = 9.76e-3 K/m. With q_z = 0 the ε_q heat-flux regularization makes |L| enormous, so the surface layer is effectively neutral: ζ ≈ 0, φ_m = φ_h → 1, ψ_m = ψ_h → 0, ū reduces to the pure logarithmic profile, and the near-zero L_inv places the atmosphere in Pasquill class D (4, neutral).",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "θ",
                            "time": 0.0,
                            "expected": 288.15
                        },
                        {
                            "variable": "dT_dz",
                            "time": 0.0,
                            "expected": 0.0,
                            "tolerance": {
                                "abs": 1e-12
                            }
                        },
                        {
                            "variable": "dθ_dz",
                            "time": 0.0,
                            "expected": 0.00976
                        },
                        {
                            "variable": "L",
                            "time": 0.0,
                            "expected": -24416778974839.39
                        },
                        {
                            "variable": "L_inv",
                            "time": 0.0,
                            "expected": -4.095544301852689e-14,
                            "tolerance": {
                                "abs": 1e-06
                            }
                        },
                        {
                            "variable": "ζ",
                            "time": 0.0,
                            "expected": -4.0955443018526885e-13,
                            "tolerance": {
                                "abs": 1e-06
                            }
                        },
                        {
                            "variable": "φ_m",
                            "time": 0.0,
                            "expected": 0.9999999999984641
                        },
                        {
                            "variable": "φ_h",
                            "time": 0.0,
                            "expected": 0.9999999999969285
                        },
                        {
                            "variable": "ψ_m",
                            "time": 0.0,
                            "expected": 1.5354384430548228e-12,
                            "tolerance": {
                                "abs": 1e-06
                            }
                        },
                        {
                            "variable": "ψ_h",
                            "time": 0.0,
                            "expected": 3.0713209753206747e-12,
                            "tolerance": {
                                "abs": 1e-06
                            }
                        },
                        {
                            "variable": "ū",
                            "time": 0.0,
                            "expected": 3.4538776394899164
                        },
                        {
                            "variable": "pasquill_class",
                            "time": 0.0,
                            "expected": 4
                        }
                    ]
                },
                {
                    "id": "potential_temp_850hPa",
                    "description": "Potential temperature at the 850 hPa level (p = 85000 Pa, T = 280 K): θ = 280·(101325/85000)^(287/1005) ≈ 294.4 K. Because p < p₀ the (p₀/p) adiabatic-compression factor exceeds 1, so θ > T. Reproduces the lower-pressure assertion of the upstream `Potential temperature` testitem; θ matches the sibling stability.esm potential_temp_850hPa test (shared Eq. 16.14).",
                    "parameter_overrides": {
                        "T": 280.0,
                        "p": 85000.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "θ",
                            "time": 0.0,
                            "expected": 294.40591070177146
                        }
                    ]
                },
                {
                    "id": "potential_temp_cold_low_pressure",
                    "description": "Potential temperature for cold air at low pressure (T = 200 K, p = 50000 Pa): θ = 200·(101325/50000)^(287/1005) ≈ 244.7 K, which stays strictly positive. Reproduces the upstream `Physical constraints` testitem assertion that the potential temperature is always positive.",
                    "parameter_overrides": {
                        "T": 200.0,
                        "p": 50000.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "θ",
                            "time": 0.0,
                            "expected": 244.6967948244097
                        }
                    ]
                },
                {
                    "id": "light_wind_strong_heating_class_A",
                    "description": "Light winds with strong surface heating (u_star = 0.2 m/s, q_z = 110 W/m^2) — the very-unstable regime. The small friction velocity and large upward heat flux give a small-magnitude negative Monin-Obukhov length L ≈ -6.6 m, so L_inv ≈ -0.152 m^-1 falls below the Golder class-A threshold and the Pasquill class is 1 (A, very unstable). Covers the most-unstable end of the classification.",
                    "parameter_overrides": {
                        "u_star": 0.2,
                        "q_z": 110.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
