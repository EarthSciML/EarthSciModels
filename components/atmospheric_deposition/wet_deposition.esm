                        { "variable": "k_othergas", "time": 0.0, "expected": 1.2169971747418382e-05 }
                    ]
                },
                {
                    "id": "full_cloud_cover",
                    "description": "cloudFrac=1.0: both subcloud and in-cloud terms contribute at full strength.",
