            "equations": [],
            "tests": [
                {
                    "id": "default_params_lev1",
                    "description": "Default parameters (cloudFrac=0.5, qrain=0.5, rho_air=1.204, lev=1). Level 1 Dz=123.66503647136699 m from the lev_depth table. Pins all three deposition rate outputs and intermediate observed quantities. Re-asserts k_particle at t=1 to confirm time-invariance (purely algebraic).",
                    "parameter_overrides": {
                        "cloudFrac": 0.5,
                        "qrain": 0.5,
                        "rho_air": 1.204,
                        "lev": 1,
                        "A_wd": 5.2,
                        "rho_water": 1000.0,
                        "Vdr": 5.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "Dz",         "time": 0.0, "expected": 123.66503647136699 },
                        { "variable": "i_rain",     "time": 0.0, "expected": 1.0 },
                        { "variable": "k_particle", "time": 0.0, "expected": 0.3130521699717474 },
                        { "variable": "k_SO2",      "time": 0.0, "expected": 5.476487286338272e-06 },
                        { "variable": "k_othergas", "time": 0.0, "expected": 1.8254957621127573e-05 },
                        { "variable": "k_particle", "time": 1.0, "expected": 0.3130521699717474 }
                    ]
                },
                {
                    "id": "lev3_anchor",
                    "description": "Level 3 (Dz=127.81793001768432 m). Anchors the lev_depth lookup at a different level. The upstream Julia test (test/wetdep_test.jl:48) asserts get_lev_depth(3) ≈ 127.81793001768432, which is the exact interp.linear table entry at knot 3.",
                    "parameter_overrides": {
                        "cloudFrac": 0.5,
                        "qrain": 0.5,
                        "rho_air": 1.204,
                        "lev": 3,
                        "A_wd": 5.2,
                        "rho_water": 1000.0,
                        "Vdr": 5.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "Dz",         "time": 0.0, "expected": 127.81793001768432 },
                        { "variable": "k_particle", "time": 0.0, "expected": 0.31305177456089134 },
                        { "variable": "k_SO2",      "time": 0.0, "expected": 5.29855240110913e-06 },
                        { "variable": "k_othergas", "time": 0.0, "expected": 1.7661841337030432e-05 }
                    ]
                },
                {
                    "id": "no_rain_zero_rates",
                    "description": "qrain=0: the i_rain guard sets all three rates to zero regardless of cloudFrac, rho_air, and Dz.",
                    "parameter_overrides": {
                        "cloudFrac": 0.5,
                        "qrain": 0.0,
                        "rho_air": 1.204,
                        "lev": 1,
                        "A_wd": 5.2,
                        "rho_water": 1000.0,
                        "Vdr": 5.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "i_rain",     "time": 0.0, "expected": 0.0 },
                        { "variable": "k_particle", "time": 0.0, "expected": 0.0, "tolerance": { "abs": 1e-15 } },
                        { "variable": "k_SO2",      "time": 0.0, "expected": 0.0, "tolerance": { "abs": 1e-15 } },
                        { "variable": "k_othergas", "time": 0.0, "expected": 0.0, "tolerance": { "abs": 1e-15 } }
                    ]
                },
                {
                    "id": "no_clouds_subcloud_only",
                    "description": "cloudFrac=0: only the subcloud terms contribute. k_particle = qrain*rho_air*A_wd*E; k_SO2 and k_othergas use wSub*Vdr/rho_water*qrain*rho_air/Dz without the in-cloud addend.",
                    "parameter_overrides": {
                        "cloudFrac": 0.0,
                        "qrain": 0.5,
                        "rho_air": 1.204,
                        "lev": 1,
                        "A_wd": 5.2,
