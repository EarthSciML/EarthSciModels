            "examples": [
                {
                    "id": "deposition_rates_vs_lev",
                    "description": "Wet deposition rates k_particle, k_SO2, and k_othergas as a function of atmospheric level (lev 1-72). Higher levels have greater Dz, reducing the 1/Dz scavenging terms while leaving the subcloud particle term (no 1/Dz) approximately constant.",
                    "initial_state": { "type": "per_variable", "values": {} },
                    "parameters": {
                        "cloudFrac": 0.5,
                        "qrain": 0.5,
                        "rho_air": 1.204,
                        "A_wd": 5.2,
                        "rho_water": 1000.0,
                        "Vdr": 5.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "lev",
                                "range": { "start": 1, "stop": 72, "count": 72, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "particle_rate_vs_lev",
                            "type": "line",
                            "description": "PM2.5 wet deposition rate k_particle versus model level.",
                            "x": { "variable": "lev", "label": "Level index" },
                            "y": { "variable": "k_particle", "label": "k_particle (1/s)" }
                        },
                        {
                            "id": "gas_rates_vs_lev",
                            "type": "line",
                            "description": "SO2 and other-gas wet deposition rates versus model level.",
                            "x": { "variable": "lev", "label": "Level index" },
                            "y": { "variable": "k_SO2", "label": "k_SO2 (1/s)" }
                        }
                    ]
                },
                {
                    "id": "deposition_rates_vs_qrain_and_cloudFrac",
                    "description": "Wet deposition rates as a joint function of rain mixing ratio (qrain) and cloud fraction (cloudFrac) at lev=1. All three rates scale linearly with qrain; the gas rates additionally scale with (1 + cloudFrac) and the particle in-cloud term scales with cloudFrac.",
                    "initial_state": { "type": "per_variable", "values": {} },
                    "parameters": {
                        "rho_air": 1.204,
                        "lev": 1,
                        "A_wd": 5.2,
                        "rho_water": 1000.0,
                        "Vdr": 5.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "qrain",
                                "range": { "start": 0.0, "stop": 1.0, "count": 11, "scale": "linear" }
                            },
                            {
                                "parameter": "cloudFrac",
                                "range": { "start": 0.0, "stop": 1.0, "count": 6, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "particle_heatmap",
                            "type": "heatmap",
                            "description": "PM2.5 wet deposition rate k_particle as a function of qrain and cloudFrac.",
                            "x": { "variable": "qrain",     "label": "Rain mixing ratio" },
                            "y": { "variable": "cloudFrac", "label": "Cloud fraction" },
                            "value": { "variable": "k_particle", "reduce": "final" }
                        }
                    ]
                }
            ]
        }
    }
}
