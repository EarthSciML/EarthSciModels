                    }
                },
                "i_rain": {
                    "type": "observed",
                    "units": "1",
                    "description": "Rain presence indicator: 1 if qrain > 0, else 0. Guards against negative qrain (upstream `i = ifelse(qrain > 0, 1, 0)`, src/wet_deposition.jl:109).",
                    "expression": {
                        "op": "ifelse",
                        "args": [
                            { "op": ">", "args": ["qrain", 0] },
                            1,
                            0
                        ]
                    }
                },
                "k_particle": {
                    "type": "observed",
                    "units": "1/s",
                    "description": "First-order wet deposition rate for PM2.5 (aerosol particles). Subcloud term: A_wd*E*qrain*rho_air (no 1/Dz); in-cloud term: wInParticle*(Vdr/rho_water)*cloudFrac*qrain*rho_air/Dz. With E=0.1, wInParticle=1.0 folded in (src/wet_deposition.jl:123): k_particle = i * qrain * rho_air * (A_wd*0.1 + cloudFrac*(1.0*Vdr/rho_water/Dz)).",
                    "expression": {
                        "op": "*",
                        "args": [
                            "i_rain",
                            "qrain",
                            "rho_air",
                            {
                                "op": "+",
                                "args": [
                                    {
                                        "op": "*",
                                        "args": ["A_wd", 0.1]
                                    },
                                    {
                                        "op": "*",
                                        "args": [
                                            "cloudFrac",
                                            {
                                                "op": "/",
                                                "args": [
                                                    "Vdr",
                                                    {
                                                        "op": "*",
                                                        "args": ["rho_water", "Dz"]
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                },
                "k_SO2": {
                    "type": "observed",
                    "units": "1/s",
                    "description": "First-order wet deposition rate for SO2. Both subcloud and in-cloud terms use wSubSO2=0.15; combined: (wSubSO2*Vdr/rho_water)*(1+cloudFrac)*qrain*rho_air/Dz (src/wet_deposition.jl:124).",
                    "expression": {
                        "op": "*",
                        "args": [
