            "examples": [
                {
                    "id": "resistance_vs_friction_velocity",
                    "description": "Quasi-laminar particle resistance r_b as a function of friction velocity u_star, for the default 1 um particle over grassland. As u_star rises, turbulent transport across the quasi-laminar sublayer strengthens and r_b falls steeply — roughly as 1/u_star, with a weak additional dependence through the Stokes-number terms E_IM and R_1. Reproduces the friction-velocity control on particle dry deposition discussed in Seinfeld & Pandis (2006) Ch. 19.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "nu": 1.5e-05,
                        "A": 0.002,
                        "alpha": 1.2,
                        "gamma": 0.54,
                        "D_p": 1e-06,
                        "g": 9.81,
                        "v_s": 3.5e-05,
                        "D_diff": 2.7e-11
