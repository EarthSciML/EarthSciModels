                            "id": "E_B_vs_D_diff",
                            "type": "line",
                            "description": "Brownian-diffusion collection efficiency E_B versus particle diffusivity D_diff (log-spaced).",
                            "x": {
                                "variable": "D_diff",
                                "label": "Brownian diffusivity (m^2/s)"
                            },
                            "y": {
                                "variable": "E_B",
                                "label": "Brownian diffusion efficiency (dimensionless)"
                            }
                        },
