                    "id": "brownian_term_vs_diffusivity",
                    "description": "Brownian-diffusion collection efficiency E_B and quasi-laminar resistance r_b as a function of the particle Brownian diffusivity D_diff, for the default grassland land-use category at u_star = 0.4 m/s. A larger diffusivity (characteristic of smaller particles) lowers the particle Schmidt number Sc = nu/D_diff and raises E_B = Sc^(-gamma), which in turn lowers r_b. This traces the diffusion-controlled limb of the Zhang et al. (2001) particle deposition curve.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "nu": 1.5e-05,
                        "A": 0.002,
                        "alpha": 1.2,
                        "gamma": 0.54,
                        "D_p": 1e-06,
                        "g": 9.81,
                        "u_star": 0.4,
                        "v_s": 3.5e-05
                    },
