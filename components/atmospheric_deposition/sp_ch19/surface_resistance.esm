                {
                    "id": "bright_light_so2",
                    "description": "SO2 over the deciduous forest at bright solar irradiance G = 900 W/m^2. G_factor approaches its small-irradiance-independent floor (~1.05), the stomatal resistance r_st is near its minimum, and r_c is at the low end of its daytime range.",
                    "parameter_overrides": {
                        "D_ratio": 1.9,
                        "H_star": 100000.0,
                        "f_0": 0.0,
                        "r_i": 70.0,
                        "r_lu": 2000.0,
                        "r_dc": 100.0,
                        "r_cl": 2000.0,
                        "r_ac": 2000.0,
                        "r_gs": 500.0,
                        "G": 900.0,
                        "T_s": 298.15
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "T_s_C",
                            "time": 0.0,
                            "expected": 25.0
                        },
                        {
                            "variable": "G_factor",
                            "time": 0.0,
                            "expected": 1.0493717439412014
                        },
                        {
                            "variable": "T_factor",
                            "time": 0.0,
                            "expected": 1.0666666666666667
                        },
                        {
