                                "label": "Raindrop diameter (m)"
                            },
                            "y": {
                                "variable": "E",
                                "label": "Collection efficiency (dimensionless)"
                            }
                        }
                    ]
                },
                {
                    "id": "efficiency_over_aerosol_and_raindrop_size",
                    "description": "Two-dimensional sweep of the collection efficiency E over aerosol particle diameter (10 nm to 100 µm, log-spaced) and raindrop diameter (0.2 mm to 5 mm, log-spaced) at a fixed fall speed U_t = 6.5 m/s. Surfaces the joint control of particle and raindrop size on below-cloud particle scavenging efficiency.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
