                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                },
                {
                    "_comment": "Stokes-number excess over the critical Stokes number (slinn_collection_efficiency, src line 342): stokes_diff = St - S*",
                    "lhs": "stokes_diff",
                    "rhs": {
                        "op": "-",
                        "args": [
                            "St",
                            "S_star"
                        ]
                    }
                },
                {
                    "_comment": "Clamped impaction ratio (slinn_collection_efficiency, src line 344): max(0, St-S*)/(max(0, St-S*) + 2/3). The max(0, ·) keeps safe_ratio non-negative so the downstream sqrt(safe_ratio) in E_imp_unscaled is real-valued, and makes safe_ratio exactly 0 when St ≤ S*.",
                    "lhs": "safe_ratio",
                    "rhs": {
                        "op": "/",
                        "args": [
                            {
                                "op": "max",
                                "args": [
                                    0,
                                    "stokes_diff"
                                ]
                            },
                            {
                                "op": "+",
                                "args": [
                                    {
                                        "op": "max",
                                        "args": [
                                            0,
                                            "stokes_diff"
                                        ]
                                    },
                                    {
                                        "op": "/",
                                        "args": [
                                            2,
                                            3
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                },
                {
                    "_comment": "Particle-density correction factor for the impaction term (slinn_collection_efficiency, src line 345; Seinfeld & Pandis p. 950): density_scaling = sqrt(ρ_w/ρ_p)",
                    "lhs": "density_scaling",
                    "rhs": {
                        "op": "sqrt",
