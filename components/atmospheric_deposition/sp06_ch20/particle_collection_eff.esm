                        },
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.636198586474696
                        }
                    ]
                },
                {
                    "id": "dense_coarse_aerosol",
                    "description": "Dense coarse-mode aerosol (d_p = 10 µm, ρ_p = 2000 kg/m^3 — roughly mineral dust) collected by a 2 mm raindrop at 6.5 m/s. The doubled density doubles the relaxation time τ and hence the Stokes number relative to coarse_mode_aerosol, raising the unscaled impaction term, but the density correction sqrt(ρ_w/ρ_p) = sqrt(0.5) ≈ 0.707 scales the impaction term back down — exercising the ρ_p ≠ ρ_w branch of the density correction.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 1e-05,
                        "ρ_p": 2000.0,
                        "T": 298.0
