                        }
                    ]
                },
                {
                    "id": "cold_temperature",
                    "description": "Component defaults but at a cold T = 273 K. Brownian diffusivity scales linearly with temperature (Stokes-Einstein), so the colder column has a smaller D_diff and a larger Schmidt number Sc than the 298 K default_parameters case, which lowers the Brownian diffusion term E_diff. The interception and impaction terms are temperature-independent.",
                    "parameter_overrides": {
                        "D_p": 0.001,
                        "U_t": 4.0,
                        "d_p": 1e-06,
                        "ρ_p": 1000.0,
                        "T": 273.0
