                                "variable": "d_p",
                                "label": "Aerosol particle diameter (m)"
                            },
                            "y": {
                                "variable": "E",
                                "label": "Collection efficiency (dimensionless)"
                            }
                        },
                        {
                            "id": "E_diff_vs_dp",
                            "type": "line",
                            "description": "Brownian diffusion term E_diff as a function of aerosol particle diameter.",
                            "x": {
                                "variable": "d_p",
                                "label": "Aerosol particle diameter (m)"
                            },
                            "y": {
                                "variable": "E_diff",
                                "label": "Brownian diffusion term (dimensionless)"
                            }
                        },
                        {
                            "id": "E_int_vs_dp",
                            "type": "line",
                            "description": "Interception term E_int as a function of aerosol particle diameter.",
                            "x": {
                                "variable": "d_p",
                                "label": "Aerosol particle diameter (m)"
                            },
                            "y": {
                                "variable": "E_int",
                                "label": "Interception term (dimensionless)"
                            }
                        },
                        {
                            "id": "E_imp_vs_dp",
                            "type": "line",
                            "description": "Inertial impaction term E_imp as a function of aerosol particle diameter.",
                            "x": {
                                "variable": "d_p",
                                "label": "Aerosol particle diameter (m)"
                            },
                            "y": {
                                "variable": "E_imp",
                                "label": "Inertial impaction term (dimensionless)"
                            }
                        }
                    ]
                },
                {
                    "id": "collection_efficiency_vs_raindrop_size",
                    "description": "Collection efficiency of a 1 µm accumulation-mode aerosol as a function of raindrop diameter, at a fixed fall speed U_t = 6.5 m/s. Smaller raindrops are more efficient collectors per drop (the interception and Brownian terms scale inversely with raindrop size), so E falls as the raindrop diameter grows.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "U_t": 6.5,
                        "d_p": 1e-06,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "D_p",
                                "range": {
                                    "start": 0.0002,
                                    "stop": 0.005,
                                    "count": 25,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
