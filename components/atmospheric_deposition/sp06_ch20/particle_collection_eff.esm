                                "op": "*",
                                "args": [
                                    2,
                                    "μ_air_sp"
                                ]
                            }
                        ]
                    }
                },
                {
                    "_comment": "Brownian diffusivity of the aerosol particle via Stokes-Einstein (particle_diffusivity, src line 291): D_diff = k_B*T/(3*pi*μ_air*d_p)",
                    "lhs": "D_diff",
                    "rhs": {
                        "op": "/",
                        "args": [
                            {
                                "op": "*",
                                "args": [
                                    "kB_sp",
                                    "T"
                                ]
                            },
                            {
                                "op": "*",
                                "args": [
                                    3,
                                    3.141592653589793,
                                    "μ_air_sp",
                                    "d_p"
                                ]
                            }
                        ]
                    }
                },
                {
                    "_comment": "Particle Schmidt number (slinn_collection_efficiency, src line 314): Sc = μ_air/(ρ_air*D_diff)",
                    "lhs": "Sc",
                    "rhs": {
                        "op": "/",
                        "args": [
                            "μ_air_sp",
                            {
                                "op": "*",
                                "args": [
                                    "ρ_air_sp",
                                    "D_diff"
                                ]
