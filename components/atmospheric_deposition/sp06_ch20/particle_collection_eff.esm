                            "expected": 0.0002603198637924316
                        }
                    ]
                },
                {
                    "id": "aitken_mode_aerosol",
                    "description": "Small Aitken-mode aerosol (d_p = 10 nm) collected by a 2 mm raindrop falling at 6.5 m/s — the upstream `Slinn Collection Efficiency` small-particle case. Brownian diffusion dominates (E_diff ≫ E_int); the Stokes number is far below S* so the impaction term is zero. This is the high-efficiency small-particle end of the Slinn curve, with E larger than the accumulation-mode case (upstream assertion E_small > E_medium).",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 1e-08,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "Re",
                            "time": 0.0,
                            "expected": 462.9360465116279
                        },
                        {
                            "variable": "E_diff",
                            "time": 0.0,
                            "expected": 0.000639219579960086
                        },
                        {
                            "variable": "E_int",
                            "time": 0.0,
                            "expected": 3.4840318973093977e-07
                        },
                        {
                            "variable": "E_imp",
