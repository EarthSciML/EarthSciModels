                            "variable": "E_diff",
                            "time": 0.0,
                            "expected": 5.104243173195447e-05
                        },
                        {
                            "variable": "E_int",
                            "time": 0.0,
                            "expected": 7.843189730939726e-05
                        },
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.00012947432904135173
                        }
                    ]
                },
                {
                    "id": "coarse_mode_aerosol",
                    "description": "Coarse-mode aerosol (d_p = 10 µm) collected by a 2 mm raindrop falling at 6.5 m/s — the upstream `Slinn Collection Efficiency` large-particle case. The Stokes number St ≈ 2.1 now exceeds the critical S* ≈ 0.24, so the inertial impaction term switches on (stokes_diff > 0) and dominates E. With ρ_p = ρ_w the density correction sqrt(ρ_w/ρ_p) = 1, so E_imp = E_imp_unscaled.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 1e-05,
                        "ρ_p": 1000.0,
                        "T": 298.0
