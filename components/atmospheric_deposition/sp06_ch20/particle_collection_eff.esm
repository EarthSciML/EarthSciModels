                {
                    "id": "accumulation_mode_aerosol",
                    "description": "Accumulation-mode aerosol (d_p = 1 µm) collected by a 2 mm raindrop falling at 6.5 m/s — the upstream `Slinn Collection Efficiency` medium-particle case. This is the Greenfield gap: Brownian diffusion has weakened and inertial impaction has not yet switched on, so the collection efficiency E is at its minimum — smaller than both the aitken_mode_aerosol and coarse_mode_aerosol cases at the same raindrop.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 1e-06,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
