                            "time": 0.0,
                            "expected": 8.78172093972164e-05
                        },
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.0002560964169230827
                        }
                    ]
                },
                {
                    "id": "efficiency_clamp",
                    "description": "Large light aerosol (d_p = 50 µm, ρ_p = 500 kg/m^3) collected by a 2 mm raindrop at 6.5 m/s. The large relaxation time gives a Stokes number St ≈ 26, and the density correction sqrt(ρ_w/ρ_p) = sqrt(2) ≈ 1.414 amplifies the impaction term so that the unclamped sum E_total ≈ 1.47 exceeds 1. The Eq. 20.53 maximum-of-1 clamp therefore fires and E is pinned to exactly 1.0 — exercising the E_total > 1 branch.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 5e-05,
                        "ρ_p": 500.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "E_imp",
                            "time": 0.0,
                            "expected": 1.3612050562639566
                        },
                        {
                            "variable": "E_total",
                            "time": 0.0,
                            "expected": 1.4730112686254653
                        },
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 1.0
                        }
                    ]
                }
            ],
            "examples": [
                {
                    "id": "collection_efficiency_vs_aerosol_size",
                    "description": "Slinn (1983) collection efficiency and its three mechanisms as a function of aerosol particle diameter, for a 2 mm raindrop falling at 6.5 m/s. This reproduces the canonical below-cloud scavenging figure (Seinfeld & Pandis 2006, Fig. 20.13): Brownian diffusion dominates for d_p below ~0.1 µm, inertial impaction dominates above ~1 µm, and the two leave a minimum — the Greenfield gap — at accumulation-mode sizes.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "d_p",
                                "range": {
                                    "start": 1e-08,
                                    "stop": 0.0001,
                                    "count": 49,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "E_vs_dp",
                            "type": "line",
                            "description": "Total collection efficiency E as a function of aerosol particle diameter (log-spaced).",
