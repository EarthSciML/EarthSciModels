                        ]
                    }
                },
                {
                    "_comment": "Sum of the three collection-efficiency mechanisms before clamping (slinn_collection_efficiency, src line 353): E_total = E_diff + E_int + E_imp",
                    "lhs": "E_total",
                    "rhs": {
                        "op": "+",
                        "args": [
                            "E_diff",
                            "E_int",
                            "E_imp"
                        ]
                    }
                },
                {
                    "_comment": "Collection efficiency clamped to a maximum of 1 (Eq. 20.53; slinn_collection_efficiency, src line 355): E = min(1, E_total). Upstream writes ifelse(E_total > 1, 1, E_total); min(1, E_total) is the identical upper clamp and the spec §4.2-preferred AST encoding of a clamp/limiter.",
                    "lhs": "E",
                    "rhs": {
                        "op": "min",
                        "args": [
                            1,
                            "E_total"
                        ]
                    }
                },
                {
                    "_comment": "Particle scavenging coefficient for monodisperse raindrops (Eq. 20.57; particle_scavenging_coeff, src line 404): Λ_particle = (3/2)*E*p₀/D_p",
                    "lhs": "Λ_particle",
                    "rhs": {
                        "op": "/",
                        "args": [
                            {
                                "op": "*",
                                "args": [
                                    {
                                        "op": "/",
                                        "args": [
                                            3,
                                            2
                                        ]
                                    },
                                    "E",
                                    "p₀"
                                ]
                            },
                            "D_p"
                        ]
                    }
                }
            ],
            "tests": [
                {
                    "id": "default_parameters",
                    "description": "Component defaults: a 1 mm raindrop (D_p = 1e-3 m) falling at U_t = 4 m/s scavenging a 1 µm accumulation-mode aerosol (d_p = 1e-6 m, ρ_p = 1000 kg/m^3) at T = 298 K under a 1 mm/h precipitation rate (p₀ = 2.778e-7 m/s). The Stokes number St ≈ 0.026 is below the critical S* ≈ 0.27, so the impaction term is off and the collection efficiency E (~2.6e-4) is the small Brownian + interception sum — a Greenfield-gap value. Λ_particle follows from Eq. 20.57. The system is algebraic, so Λ_particle is re-asserted at t = 1 to confirm time-invariance; Re and S_star anchor the slinn intermediate chain. E matches particle_collection_eff.esm's default_parameters case.",
                    "parameter_overrides": {
                        "D_p": 0.001,
                        "U_t": 4.0,
                        "d_p": 1e-06,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "Re",
                            "time": 0.0,
                            "expected": 142.4418604651163
                        },
                        {
                            "variable": "S_star",
                            "time": 0.0,
                            "expected": 0.2705072867967095
                        },
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.0002603198637924316
                        },
                        {
                            "variable": "Λ_particle",
                            "time": 0.0,
                            "expected": 1.0847528724230623e-07
                        },
                        {
                            "variable": "Λ_particle",
                            "time": 1.0,
                            "expected": 1.0847528724230623e-07
                        }
                    ]
                },
                {
                    "id": "aitken_mode_aerosol",
                    "description": "Small Aitken-mode aerosol (d_p = 10 nm) collected by a 2 mm raindrop falling at 6.5 m/s — the upstream `Slinn Collection Efficiency` small-particle case. Brownian diffusion dominates the collection efficiency; the Stokes number is far below S* so the impaction term is zero. This is the high-efficiency small-particle end of the Slinn curve, with E larger than the accumulation-mode case (upstream assertion E_small > E_medium). E matches particle_collection_eff.esm's aitken_mode_aerosol case.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 1e-08,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.0006395679831498169
                        },
                        {
                            "variable": "Λ_particle",
                            "time": 0.0,
                            "expected": 1.3325398928926437e-07
                        }
                    ]
                },
                {
                    "id": "accumulation_mode_aerosol",
                    "description": "Accumulation-mode aerosol (d_p = 1 µm) collected by a 2 mm raindrop falling at 6.5 m/s — the upstream `Slinn Collection Efficiency` medium-particle case. This is the Greenfield gap: Brownian diffusion has weakened and inertial impaction has not yet switched on, so the collection efficiency E is at its minimum — smaller than both the aitken_mode and coarse_mode cases at the same raindrop — and Λ_particle is correspondingly small. E matches particle_collection_eff.esm's accumulation_mode_aerosol case.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 1e-06,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.00012947432904135173
                        },
                        {
                            "variable": "Λ_particle",
                            "time": 0.0,
                            "expected": 2.697597645576563e-08
                        }
                    ]
                },
                {
                    "id": "coarse_mode_aerosol",
                    "description": "Coarse-mode aerosol (d_p = 10 µm) collected by a 2 mm raindrop falling at 6.5 m/s — the upstream `Slinn Collection Efficiency` large-particle case. The Stokes number St ≈ 2.1 now exceeds the critical S* ≈ 0.24, so the inertial impaction term switches on (stokes_diff > 0) and dominates E (~0.64), giving a scavenging coefficient three orders of magnitude above the Greenfield-gap value. St is asserted to confirm it exceeds S*. E matches particle_collection_eff.esm's coarse_mode_aerosol case.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 1e-05,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "St",
                            "time": 0.0,
                            "expected": 2.0984597530196507
                        },
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.636198586474696
                        },
                        {
                            "variable": "Λ_particle",
                            "time": 0.0,
                            "expected": 0.00013255197549200292
                        }
                    ]
                },
                {
                    "id": "dense_coarse_aerosol",
                    "description": "Dense coarse-mode aerosol (d_p = 10 µm, ρ_p = 2000 kg/m^3 — roughly mineral dust) collected by a 2 mm raindrop at 6.5 m/s. The doubled density doubles the relaxation time τ and hence the Stokes number relative to coarse_mode_aerosol, but the density correction sqrt(ρ_w/ρ_p) = sqrt(0.5) ≈ 0.707 scales the impaction term back down — exercising the ρ_p ≠ ρ_w branch of the density correction. E matches particle_collection_eff.esm's dense_coarse_aerosol case.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 1e-05,
                        "ρ_p": 2000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.5645328086732871
                        },
                        {
                            "variable": "Λ_particle",
                            "time": 0.0,
                            "expected": 0.00011762041068707937
                        }
                    ]
                },
                {
                    "id": "efficiency_clamp",
                    "description": "Large light aerosol (d_p = 50 µm, ρ_p = 500 kg/m^3) collected by a 2 mm raindrop at 6.5 m/s. The large relaxation time gives a high Stokes number and the density correction sqrt(ρ_w/ρ_p) = sqrt(2) ≈ 1.414 amplifies the impaction term so that the unclamped sum E_total ≈ 1.47 exceeds 1. The Eq. 20.53 maximum-of-1 clamp therefore fires and E is pinned to exactly 1.0; Λ_particle then equals the geometric scavenging limit (3/2)·p₀/D_p. E and E_total match particle_collection_eff.esm's efficiency_clamp case.",
                    "parameter_overrides": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "d_p": 5e-05,
                        "ρ_p": 500.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "E_total",
                            "time": 0.0,
                            "expected": 1.4730112686254653
                        },
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 1.0
                        },
                        {
                            "variable": "Λ_particle",
                            "time": 0.0,
                            "expected": 0.00020835
                        }
                    ]
                },
                {
                    "id": "heavy_precipitation",
                    "description": "Precipitation rate raised tenfold to 10 mm/h (p₀ = 2.778e-6 m/s), all other parameters at the component defaults. The Slinn collection efficiency E depends only on the raindrop/particle geometry and is independent of p₀, so E is unchanged from default_parameters. Λ_particle = (3/2)·E·p₀/D_p scales linearly with p₀ (Eq. 20.57), so it is exactly ten times the default_parameters value — exercising the p₀ dependence that distinguishes this component from ParticleCollectionEfficiency.",
                    "parameter_overrides": {
                        "p₀": 2.778e-06
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "assertions": [
                        {
                            "variable": "E",
                            "time": 0.0,
                            "expected": 0.0002603198637924316
                        },
                        {
                            "variable": "Λ_particle",
                            "time": 0.0,
                            "expected": 1.0847528724230622e-06
                        }
                    ]
                }
            ],
            "examples": [
                {
                    "id": "scavenging_spectrum_vs_aerosol_size",
                    "description": "Slinn (1983) collection efficiency E and the resulting particle scavenging coefficient Λ_particle as a function of aerosol particle diameter, for a 2 mm raindrop falling at 6.5 m/s under a 1 mm/h precipitation rate. Reproduces the canonical below-cloud scavenging spectrum (Seinfeld & Pandis 2006, Fig. 20.13 / Eq. 20.57): Brownian diffusion dominates below ~0.1 µm, inertial impaction above ~1 µm, and the two leave the Greenfield-gap minimum at accumulation-mode sizes.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "D_p": 0.002,
                        "U_t": 6.5,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "d_p",
                                "range": {
                                    "start": 1e-08,
                                    "stop": 0.0001,
                                    "count": 49,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "E_vs_dp",
                            "type": "line",
                            "description": "Collection efficiency E as a function of aerosol particle diameter (log-spaced) — the Greenfield-gap U-shape.",
                            "x": {
                                "variable": "d_p",
                                "label": "Aerosol particle diameter (m)"
                            },
                            "y": {
                                "variable": "E",
                                "label": "Collection efficiency (dimensionless)"
                            }
                        },
                        {
                            "id": "Lambda_vs_dp",
                            "type": "line",
                            "description": "Particle scavenging coefficient Λ_particle as a function of aerosol particle diameter (Eq. 20.57).",
                            "x": {
                                "variable": "d_p",
                                "label": "Aerosol particle diameter (m)"
                            },
                            "y": {
                                "variable": "Λ_particle",
                                "label": "Scavenging coefficient (1/s)"
                            }
                        }
                    ]
                },
                {
                    "id": "scavenging_over_aerosol_and_raindrop_size",
                    "description": "Two-dimensional sweep of the particle scavenging coefficient Λ_particle over aerosol particle diameter (10 nm to 100 µm, log-spaced) and raindrop diameter (0.2 mm to 5 mm, log-spaced) at a fixed fall speed U_t = 6.5 m/s and the default precipitation rate. Surfaces the joint control of particle and raindrop size on below-cloud scavenging: per Eq. 20.57 Λ_particle ∝ E/D_p, so small drizzle drops scavenge a given aerosol more efficiently, and the Greenfield gap runs as a low-Λ valley across the accumulation-mode column.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {
                        "U_t": 6.5,
                        "ρ_p": 1000.0,
                        "T": 298.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "d_p",
                                "range": {
                                    "start": 1e-08,
                                    "stop": 0.0001,
                                    "count": 15,
                                    "scale": "log"
                                }
                            },
                            {
                                "parameter": "D_p",
                                "range": {
                                    "start": 0.0002,
                                    "stop": 0.005,
                                    "count": 15,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "Lambda_heatmap",
                            "type": "heatmap",
                            "description": "Particle scavenging coefficient Λ_particle as a function of aerosol particle diameter and raindrop diameter.",
                            "x": {
                                "variable": "d_p",
                                "label": "Aerosol particle diameter (m)"
                            },
                            "y": {
                                "variable": "D_p",
                                "label": "Raindrop diameter (m)"
                            },
                            "value": {
                                "variable": "Λ_particle",
                                "reduce": "final"
                            }
                        }
                    ]
                }
            ]
        }
    }
