                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                },
                {
                    "_comment": "Particle-density correction factor for the impaction term (slinn_collection_efficiency, src line 345; Seinfeld & Pandis p. 950): density_scaling = sqrt(ρ_w/ρ_p)",
                    "lhs": "density_scaling",
                    "rhs": {
