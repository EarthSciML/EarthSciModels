                                "args": [
                                    2,
                                    "μ_air_sp"
                                ]
                            }
                        ]
                    }
                },
                {
                    "_comment": "Brownian diffusivity of the aerosol particle via Stokes-Einstein (particle_diffusivity, src line 291): D_diff = k_B*T/(3*pi*μ_air*d_p)",
                    "lhs": "D_diff",
                    "rhs": {
