                    "_comment": "Inertial impaction term of the collection efficiency (Eq. 20.53, third line; slinn_collection_efficiency, src line 351): E_imp = E_imp_unscaled*density_scaling",
                    "lhs": "E_imp",
                    "rhs": {
                        "op": "*",
                        "args": [
                            "E_imp_unscaled",
