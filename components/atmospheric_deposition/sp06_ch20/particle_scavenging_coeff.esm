                    "_comment": "Critical Stokes number (Eq. 20.54; slinn_collection_efficiency, src line 328): S* = (1.2 + (1/12)*log(1+Re))/(1 + log(1+Re))",
                    "lhs": "S_star",
                    "rhs": {
                        "op": "/",
                        "args": [
