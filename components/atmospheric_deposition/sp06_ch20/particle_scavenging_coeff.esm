                },
                {
                    "_comment": "Interception term of the collection efficiency (Eq. 20.53, second line; slinn_collection_efficiency, src line 334): E_int = 4*φ*(1/ω + (1 + 2*sqrt(Re))*φ)",
                    "lhs": "E_int",
                    "rhs": {
                        "op": "*",
                        "args": [
