                                            "zeta_0",
                                            "i_unstable"
                                        ]
                                    }
                                ]
                            },
                            0.25
                        ]
                    }
                },
                "eta": {
                    "type": "observed",
                    "units": "1",
                    "description": "Stability correction factor eta = (1 - 15*zeta*i_unstable)^(1/4) for unstable regime.",
