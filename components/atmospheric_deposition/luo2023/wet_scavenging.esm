                    ]
                },
                {
                    "id": "gamma_upper_quarter",
                    "description": "Eq. 15 linear ramp at the upper quarter point: T = 211.75 K gives (220 - T)/(220 - 209) = 0.75, so γ = γ_base + 0.75*γ_delta = 0.006. Exercises the interior of the linear ramp between the midpoint and the cold threshold.",
                    "parameter_overrides": { "T": 211.75 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "γ", "time": 0.0, "expected": 0.006 },
                        { "variable": "R_U", "time": 0.0, "expected": 0.0008000544348260321 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.0727747849032423 }
                    ]
                },
                {
                    "id": "high_turbulence",
                    "description": "Strong turbulent mixing: TKE = 100 m^2/s^2 raises the cloudy-air refreshing rate Kᵢ by a factor sqrt(100/1.5) ~ 8.16 relative to the default. The faster air refreshing relaxes the Eq. 13 limit, so the air-refreshing limited ice uptake rate R_AU and the rainout efficiency F_I both rise.",
                    "parameter_overrides": { "TKE": 100.0 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "Kᵢ", "time": 0.0, "expected": 0.008328265125462805 },
                        { "variable": "R_AU", "time": 0.0, "expected": 0.00018983331995663392 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.10765280669856891 }
                    ]
                },
                {
                    "id": "weak_turbulence",
                    "description": "Weak turbulent mixing: TKE = 0.01 m^2/s^2 lowers the cloudy-air refreshing rate Kᵢ to sqrt(0.01/1.5) ~ 0.082 of the default. Slow air refreshing tightens the Eq. 13 limit, strongly suppressing the rainout efficiency F_I -- the central effect the Luo & Yu (2023) parameterization captures.",
                    "parameter_overrides": { "TKE": 0.01 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "Kᵢ", "time": 0.0, "expected": 8.328265125462806e-05 },
                        { "variable": "R_AU", "time": 0.0, "expected": 2.443227454961941e-05 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.014552439366250502 }
                    ]
                },
                {
                    "id": "rainout_saturation",
                    "description": "Strong-uptake saturation limit: abundant ice surface (N_I = 1e8 m^-3, S_I = 1e-6 m^2) drives a large R_U, strong turbulence (TKE = 100 m^2/s^2) lifts Kᵢ, and a long time step (Δt = 3600 s) lets the Eq. 12 exponential saturate, so F_I approaches 1 (complete cold-cloud rainout). Mirrors the upstream luo2023_test.jl `F_I limits` large-R_AU*Δt branch.",
                    "parameter_overrides": { "N_I": 1.0e8, "S_I": 1.0e-6, "TKE": 100.0, "Δt": 3600.0 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "R_U", "time": 0.0, "expected": 8.150689881718272 },
                        { "variable": "Kᵢ", "time": 0.0, "expected": 0.008328265125462805 },
                        { "variable": "R_AU", "time": 0.0, "expected": 0.002772311427858336 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.9999536978027082 }
                    ]
                },
                {
                    "id": "rainout_weak_uptake",
                    "description": "Weak-uptake floor limit: sparse ice surface (N_I = 1e3 m^-3, S_I = 1e-10 m^2) gives a vanishingly small R_U and a short time step (Δt = 60 s) keeps R_AU*Δt tiny, so F_I -> 0 (negligible cold-cloud rainout). Mirrors the upstream luo2023_test.jl `F_I limits` small-R_AU*Δt branch; the abs=1e-12 tolerance gates this ~1.2e-7 floor value.",
                    "parameter_overrides": { "N_I": 1.0e3, "S_I": 1.0e-10, "Δt": 60.0 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "R_U", "time": 0.0, "expected": 8.150689881718273e-09 },
                        { "variable": "R_AU", "time": 0.0, "expected": 2.037660258417178e-09 },
                        { "variable": "F_I", "time": 0.0, "expected": 1.2225960799305824e-07 }
                    ]
                },
                {
                    "id": "heavy_species",
                    "description": "Molar-mass dependence of the Eq. 14 kinetic term: a heavier species (M = 0.098 kg/mol, e.g. sulfuric acid) increases the kinetic resistance kinetic_prefactor_si*sqrt(M/M_ref)/(γ*sqrt(T/T_ref)), lowering the uptake rate R_U relative to the HNO3 default (M = 0.063). Confirms the sqrt(M/M_ref) factor is wired in.",
                    "parameter_overrides": { "M": 0.098 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "R_U", "time": 0.0, "expected": 0.0007794344280142675 },
                        { "variable": "R_AU", "time": 0.0, "expected": 0.0001238681130184578 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.07162623921120326 }
                    ]
                },
                {
                    "id": "large_ice_crystals",
                    "description": "Diffusion-limited regime of Eq. 14: larger ice crystals (r_ice = 1e-3 m) with D_g = 2e-5 m^2/s make the gas-phase diffusion resistance r_ice/D_g = 50 s/m dominate over the kinetic term, sharply reducing the uptake rate R_U and hence F_I. Confirms the r_ice/D_g diffusion term is wired in.",
                    "parameter_overrides": { "r_ice": 1.0e-3, "D_g": 2.0e-5 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "R_U", "time": 0.0, "expected": 0.0001913183552482547 },
                        { "variable": "R_AU", "time": 0.0, "expected": 4.193094252017475e-05 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.02484472622685796 }
                    ]
                },
                {
                    "id": "coarse_grid",
                    "description": "Grid-resolution dependence of Eq. 11: doubling the horizontal grid spacing (Δx = Δy = 400 km) and vertical spacing (Δz = 2000 m) halves the cloudy-air refreshing rate Kᵢ to 5.1e-4 s^-1, tightening the Eq. 13 air-refreshing limit and reducing F_I. Coarser GCM grids experience stronger refreshing limitation.",
                    "parameter_overrides": { "Δx": 400000.0, "Δy": 400000.0, "Δz": 2000.0 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "Kᵢ", "time": 0.0, "expected": 0.00051 },
                        { "variable": "R_AU", "time": 0.0, "expected": 9.267915332699406e-05 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.05408965958524958 }
                    ]
                }
            ],
            "examples": [
                {
                    "id": "air_refreshing_rate_vs_turbulence",
                    "description": "Air refreshing limited removal rate R_A as a function of turbulence kinetic energy on the GEOS-Chem-like 200 km / 1 km grid at the component defaults (f = 0.25, Rᵢ = 1e-3 s^-1). As TKE grows the subgrid air mixing strengthens and R_A rises toward the standard well-mixed rate f*Rᵢ; as TKE shrinks the air refreshing limitation suppresses R_A.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "TKE",
                                "range": { "start": 0.01, "stop": 100.0, "count": 41, "scale": "log" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "r_a_vs_tke",
                            "type": "line",
                            "description": "Air refreshing limited removal rate R_A as a function of turbulence kinetic energy (log-spaced).",
                            "x": { "variable": "TKE", "label": "Turbulence kinetic energy (m^2/s^2)" },
                            "y": { "variable": "R_A", "label": "Air refreshing limited removal rate (s^-1)" }
                        }
                    ]
                },
                {
                    "id": "rainout_efficiency_vs_turbulence",
                    "description": "Cold-cloud rainout efficiency F_I as a function of turbulence kinetic energy TKE (log-spaced sweep over four decades) at the default cold-cloud scenario. Illustrates the air-refreshing limitation central to Luo & Yu (2023): weak turbulence throttles the cloudy-air refreshing rate Kᵢ and suppresses F_I, while strong turbulence relaxes the Eq. 13 limit and raises F_I.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "TKE",
                                "range": { "start": 0.01, "stop": 100.0, "count": 41, "scale": "log" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "f_i_vs_tke",
                            "type": "line",
                            "description": "Cold cloud rainout efficiency F_I as a function of turbulence kinetic energy (log-spaced).",
                            "x": { "variable": "TKE", "label": "Turbulence kinetic energy (m^2/s^2)" },
                            "y": { "variable": "F_I", "label": "Cold cloud rainout efficiency F_I (dimensionless)" }
                        }
                    ]
                },
                {
                    "id": "uptake_efficiency_vs_temperature",
                    "description": "HNO3-on-ice uptake efficiency γ as a function of temperature (Eq. 15, Hudson et al. 2002). Reproduces the `HNO3 Uptake Efficiency on Ice` figure of the AtmosphericDeposition.jl luo2023 documentation: γ is flat at 0.003 for T >= 220 K, ramps linearly up to 0.007 across 220-209 K, and is flat at 0.007 for T <= 209 K.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T",
                                "range": { "start": 190.0, "stop": 240.0, "count": 51, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "gamma_vs_T",
                            "type": "line",
                            "description": "Uptake efficiency γ as a function of temperature T (Eq. 15).",
                            "x": { "variable": "T", "label": "Temperature (K)" },
                            "y": { "variable": "γ", "label": "HNO3 uptake efficiency γ (dimensionless)" }
                        }
                    ]
                },
                {
                    "id": "rainout_efficiency_vs_timestep",
                    "description": "Cold-cloud rainout efficiency F_I as a function of the model time step Δt (Eq. 12). Reproduces the `Cold Cloud Rainout Efficiency` figure of the luo2023 documentation: F_I = 1 - exp(-R_AU*Δt) rises monotonically from near zero toward saturation as the time step lengthens, at the default cold-cloud R_AU.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "Δt",
                                "range": { "start": 60.0, "stop": 3600.0, "count": 31, "scale": "linear" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "f_i_vs_dt",
                            "type": "line",
                            "description": "Cold cloud rainout efficiency F_I as a function of time step Δt (Eq. 12).",
                            "x": { "variable": "Δt", "label": "Time step Δt (s)" },
                            "y": { "variable": "F_I", "label": "Cold cloud rainout efficiency F_I (dimensionless)" }
                        }
                    ]
                },
                {
                    "id": "rainout_over_temperature_and_turbulence",
                    "description": "Two-dimensional sweep of the cold-cloud rainout efficiency F_I over temperature T (200-240 K, spanning the cold γ plateau, the linear ramp, and the warm plateau) and turbulence kinetic energy TKE (log-spaced, weak to strong mixing). Surfaces the joint control of the temperature-dependent ice uptake efficiency and the turbulence-driven air refreshing rate on cold-cloud scavenging.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T",
                                "range": { "start": 200.0, "stop": 240.0, "count": 15, "scale": "linear" }
                            },
                            {
                                "parameter": "TKE",
                                "range": { "start": 0.01, "stop": 100.0, "count": 15, "scale": "log" }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "f_i_heatmap",
                            "type": "heatmap",
                            "description": "Cold cloud rainout efficiency F_I as a function of temperature T and turbulence kinetic energy TKE.",
                            "x": { "variable": "T", "label": "Temperature (K)" },
                            "y": { "variable": "TKE", "label": "Turbulence kinetic energy (m^2/s^2)" },
                            "value": { "variable": "F_I", "reduce": "final" }
                        }
                    ]
                }
            ]
        }
    }
