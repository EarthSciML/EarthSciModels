                        { "variable": "F_I", "time": 0.0, "expected": 0.07111749961196356 }
                    ]
                },
                {
                    "id": "gamma_lower_quarter",
                    "description": "Eq. 15 linear ramp at the lower quarter point: T = 217.25 K gives (220 - T)/(220 - 209) = 0.25, so γ = γ_base + 0.25*γ_delta = 0.004. Exercises the interior of the linear ramp between the warm threshold and the midpoint.",
                    "parameter_overrides": { "T": 217.25 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "γ", "time": 0.0, "expected": 0.004 },
