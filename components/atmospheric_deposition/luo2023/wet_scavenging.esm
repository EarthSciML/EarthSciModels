                        { "variable": "F_I", "time": 0.0, "expected": 0.06604570151675793 }
                    ]
                },
                {
                    "id": "gamma_warm_threshold",
                    "description": "Eq. 15 upper-threshold boundary: at exactly T = 220 K the ramp argument (220 - T)/(220 - 209) = 0, so γ = γ_base = 0.003. Verifies the warm endpoint of the linear ramp (upstream luo2023_test.jl `Eq. 15` T >= 220 K branch).",
                    "parameter_overrides": { "T": 220.0 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "γ", "time": 0.0, "expected": 0.003 },
                        { "variable": "R_U", "time": 0.0, "expected": 0.000670974977179463 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.06517474310875937 }
                    ]
                },
                {
                    "id": "gamma_cold_plateau",
                    "description": "Eq. 15 cold plateau: at T = 200 K (well below the 209 K lower threshold) the ramp argument exceeds 1, the min clamp saturates at 1, and γ = γ_base + γ_delta = 0.007 -- the maximum HNO3-on-ice uptake efficiency (upstream luo2023_test.jl `Eq. 15` T = 200 K case).",
                    "parameter_overrides": { "T": 200.0 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "γ", "time": 0.0, "expected": 0.007 },
                        { "variable": "R_U", "time": 0.0, "expected": 0.0008193930573499208 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.07383095076384805 }
                    ]
                },
                {
                    "id": "gamma_cold_threshold",
                    "description": "Eq. 15 lower-threshold boundary: at exactly T = 209 K the ramp argument (220 - T)/(220 - 209) = 1, so γ = γ_base + γ_delta = 0.007. Verifies the cold endpoint of the linear ramp (upstream luo2023_test.jl `Eq. 15` T <= 209 K branch).",
                    "parameter_overrides": { "T": 209.0 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "γ", "time": 0.0, "expected": 0.007 },
                        { "variable": "R_U", "time": 0.0, "expected": 0.0008226271801153912 },
                        { "variable": "F_I", "time": 0.0, "expected": 0.07400563743093802 }
                    ]
                },
                {
                    "id": "gamma_linear_midpoint",
                    "description": "Eq. 15 linear-ramp midpoint: at T = 214.5 K the ramp argument (220 - T)/(220 - 209) = 0.5, so γ = γ_base + 0.5*γ_delta = 0.005 (upstream luo2023_test.jl `Eq. 15` T = 214.5 K case). This is the consistent operating point of the upstream Eq. 14 unit test, which used an artificial γ = 0.005.",
                    "parameter_overrides": { "T": 214.5 },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "γ", "time": 0.0, "expected": 0.005 },
