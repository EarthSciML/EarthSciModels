                },
                {
                    "id": "gamma_warm_plateau",
                    "description": "Eq. 15 warm plateau: at T = 250 K (well above the 220 K upper threshold) the max/min clamp saturates at 0 and γ = γ_base = 0.003 -- the minimum HNO3-on-ice uptake efficiency (upstream luo2023_test.jl `Eq. 15` T = 250 K case). R_U, R_AU, F_I follow from the warm-temperature γ.",
                    "parameter_overrides": { "T": 250.0 },
