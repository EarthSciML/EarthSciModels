        "equation_of_time": {
          "type": "observed",
          "units": "1",
          "description": "Equation of time (minutes, dimensionless for TST): 229.18 \u00b7 (0.000075 + 0.001868 cos \u03b3 - 0.032077 sin \u03b3 - 0.014615 cos 2\u03b3 - 0.040849 sin 2\u03b3).",
          "expression": {
            "op": "*",
            "args": [
