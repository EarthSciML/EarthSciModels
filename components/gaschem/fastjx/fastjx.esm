              "time": 0.0,
              "expected": 0.003903262349324107
            },
            {
              "variable": "j_NO3a",
              "time": 0.0,
              "expected": 0.2408349039976541
            },
            {
              "variable": "j_NO3b",
              "time": 0.0,
              "expected": 0.030987786744619147
            },
            {
