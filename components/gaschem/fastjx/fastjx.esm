                            "args": [
                              "solar_declination"
                            ]
                          }
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "cos",
                            "args": [
                              "lat_rad"
                            ]
                          },
                          {
                            "op": "cos",
                            "args": [
                              "solar_declination"
                            ]
                          },
                          {
                            "op": "cos",
                            "args": [
                              "hour_angle"
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
