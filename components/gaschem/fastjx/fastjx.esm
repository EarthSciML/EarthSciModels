        "true_solar_time": {
          "type": "observed",
          "units": "1",
          "description": "True solar time (minutes since midnight at local meridian): hour\u00b760 + minute + second/60 + equation_of_time + 4\u00b7lon.",
          "expression": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "hour",
                  60.0
                ]
              },
              "minute",
              {
                "op": "/",
                "args": [
                  "second",
                  60.0
                ]
              },
              "equation_of_time",
              {
                "op": "*",
                "args": [
                  4.0,
                  "lon"
                ]
              }
            ]
          }
        },
        "hour_angle": {
          "type": "observed",
          "units": "rad",
          "description": "Solar hour angle \u03c9 (radians): (true_solar_time/4 \u2212 180) \u00b7 \u03c0/180. Zero at local solar noon.",
          "expression": {
            "op": "*",
            "args": [
              0.017453292519943295,
