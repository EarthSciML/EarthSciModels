        "lat_rad": {
          "type": "observed",
          "units": "rad",
          "description": "Latitude in radians: lat \u00b7 \u03c0/180.",
          "expression": {
            "op": "*",
            "args": [
              0.017453292519943295,
              "lat"
            ]
          }
        },
        "cos_sza": {
          "type": "observed",
          "units": "1",
          "description": "Cosine of the solar zenith angle (clamped to [-1, 1]): clamp(sin(lat_rad)\u00b7sin(solar_declination) + cos(lat_rad)\u00b7cos(solar_declination)\u00b7cos(hour_angle), -1, 1). Feeds flux_interp_i(P, cos_sza).",
          "expression": {
            "op": "min",
            "args": [
              1.0,
              {
                "op": "max",
                "args": [
                  -1.0,
                  {
                    "op": "+",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "sin",
                            "args": [
