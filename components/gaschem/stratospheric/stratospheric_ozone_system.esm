                {
                    "id": "n2o_destruction_1day",
                    "description": "24-hour integration tracking N2O loss. Reproduces and tightens the upstream 'N2O Destruction in Comprehensive System' test (StratosphericChemistry_test.jl:550-563) \u2014 that test asserts only N2O[end] <= N2O[1], this one pins the monotone N2O decay (photolysis j_N2O plus the two O(1D) channels, with no replenishment source) at four times spanning the day, alongside the co-evolving O3 and NOx.",
                    "time_span": {
                        "start": 0.0,
                        "end": 86400.0
                    },
                    "assertions": [
                        {
                            "variable": "N2O",
                            "time": 0.0,
                            "expected": 9.3e+16
                        },
                        {
