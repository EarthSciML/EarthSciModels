                {
                    "id": "altitude_density_sweep",
                    "description": "Air-density sweep across the stratospheric range, mimicking altitude: M from 1e22 m^-3 (~60 km) to 3e24 m^-3 (~20 km). Each density drives an independent one-hour integration; the plot shows the t=3600 s ozone against M, illustrating how the M-dependent three-body production competes with the bimolecular catalytic sinks.",
                    "time_span": {
                        "start": 0.0,
                        "end": 3600.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
