            "tests": [
                {
                    "id": "initial_conditions_t0",
                    "description": "At t=0 the solver must return the declared species defaults exactly, and each algebraic family must equal the sum of its two members. Tolerance tightened to rel=1e-10 / abs=1e-14: t=0 carries no integration drift, only parser->Float64 conversion and the first-step identity evaluation of the initial state.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "tolerance": {
                        "rel": 1e-10,
                        "abs": 1e-14
                    },
                    "assertions": [
                        {
                            "variable": "O",
                            "time": 0.0,
                            "expected": 9999999999999.998
                        },
                        {
                            "variable": "O1D",
                            "time": 0.0,
                            "expected": 49999999.99999999
                        },
                        {
