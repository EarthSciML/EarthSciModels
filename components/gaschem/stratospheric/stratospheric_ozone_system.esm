                {
                    "id": "temperature_sensitivity_sweep",
                    "description": "Stratospheric temperature sweep over 200-280 K (cold polar vortex to warm sub-tropical mid-stratosphere). Each temperature drives an independent one-hour integration; the plots show the t=3600 s ozone and ClO against T, surfacing the net effect of the temperature-dependent rate coefficients on the catalytic balance.",
                    "time_span": {
                        "start": 0.0,
                        "end": 3600.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T",
                                "values": [
                                    200.0,
                                    210.0,
                                    220.0,
                                    230.0,
                                    240.0,
                                    250.0,
                                    260.0,
                                    270.0,
                                    280.0
                                ]
                            }
                        ]
                    },
                    "plots": [
