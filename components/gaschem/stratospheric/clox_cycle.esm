                {
                    "lhs": "ClOx",
                    "rhs": {"op": "+", "args": ["Cl", "ClO"]}
                },
                {
                    "lhs": "Cly",
                    "rhs": {"op": "+", "args": ["Cl", "ClO", "HCl", "ClONO2"]}
                }
            ],
            "tests": [
                {
                    "id": "default_30km_short_window",
                    "description": "Reference trajectory at upstream default conditions (T = 227 K, M = 3.1e23 m^-3 — 30 km, defaults for all bath species, initial Cl = 1e10, ClO = 1e13, HCl = 1e15, ClONO2 = 1e15). Samples Cl, ClO, HCl, ClONO2, and the algebraic family sums ClOx and Cly at t = 0, 1, 60, 600 s. Pinned from upstream Julia MTK Tsit5 integration at abstol=1e-10, reltol=1e-10. Exercises all four ODE channels (Cl + O3, ClO + O, ClO + NO, Cl + CH4, OH + HCl, ClO + NO2 + M, j_ClONO2) and both algebraic family sums simultaneously.",
                    "time_span": {"start": 0.0, "end": 600.0},
                    "assertions": [
                        {"variable": "Cl",     "time": 0.0,  "expected": 1.0e10},
                        {"variable": "ClO",    "time": 0.0,  "expected": 1.0e13},
                        {"variable": "HCl",    "time": 0.0,  "expected": 1.0e15},
                        {"variable": "ClONO2", "time": 0.0,  "expected": 1.0e15},
                        {"variable": "ClOx",   "time": 0.0,  "expected": 1.001e13},
                        {"variable": "Cly",    "time": 0.0,  "expected": 2.01001e15},
                        {"variable": "Cl",     "time": 1.0,  "expected": 1.1667854808897636e10},
                        {"variable": "ClO",    "time": 1.0,  "expected": 1.009465837903493e13},
                        {"variable": "HCl",    "time": 1.0,  "expected": 1.0000022221414302e15, "tolerance": {"abs": 1.0e9}},
                        {"variable": "ClONO2", "time": 1.0,  "expected": 9.999014516247262e14,  "tolerance": {"abs": 1.0e9}},
                        {"variable": "ClOx",   "time": 1.0,  "expected": 1.0106326233843828e13},
                        {"variable": "Cl",     "time": 60.0, "expected": 1.6190275896757105e10},
                        {"variable": "ClO",    "time": 60.0, "expected": 1.5698213820352043e13},
                        {"variable": "ClOx",   "time": 60.0, "expected": 1.57144040962488e13},
                        {"variable": "Cl",     "time": 600.0, "expected": 5.2499282405076584e10},
                        {"variable": "ClO",    "time": 600.0, "expected": 6.069977424037587e13},
                        {"variable": "HCl",    "time": 600.0, "expected": 1.0044129057386172e15},
                        {"variable": "ClONO2", "time": 600.0, "expected": 9.448448207386024e14},
                        {"variable": "ClOx",   "time": 600.0, "expected": 6.0752273522780945e13}
                    ]
                },
                {
                    "id": "default_30km_long_window_one_hour",
                    "description": "Same upstream-default conditions extended to t = 3600 s (1 hour) — the exact window of the upstream `ClOx Cycle Integration` test (test/StratosphericChemistry_test.jl:182-202). At this point HCl has grown ~8% (~1.08e15) and ClONO2 has dropped ~25% (~7.5e14), as ClO + NO2 + M / ClONO2 + hν has not yet reached steady state and the Cl + CH4 / OH + HCl channel slowly transfers Cl into HCl. Exercises long-window numerical agreement and verifies positivity-preservation (all species ≥ 0) as the upstream test asserts.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "assertions": [
                        {"variable": "Cl",     "time": 3600.0, "expected": 1.4591756347657654e11},
                        {"variable": "ClO",    "time": 3600.0, "expected": 1.767694110367072e14},
                        {"variable": "HCl",    "time": 3600.0, "expected": 1.0824486343246476e15},
                        {"variable": "ClONO2", "time": 3600.0, "expected": 7.506460370751814e14},
                        {"variable": "ClOx",   "time": 3600.0, "expected": 1.7691532860018375e14}
                    ]
                },
                {
                    "id": "cly_conservation_short_window",
                    "description": "Reproduces the upstream `Cly Conservation (ClOx Cycle)` test (test/StratosphericChemistry_test.jl:266-290): integrating 1 s under defaults, total inorganic chlorine Cly = Cl + ClO + HCl + ClONO2 must remain at its initial value 2.01001e15 m^-3 to rtol = 1e-6. Analytically D(Cly) = D(Cl) + D(ClO) + D(HCl) + D(ClONO2) ≡ 0, so any deviation is integrator roundoff. Samples Cly at three points spanning the integration window.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "assertions": [
                        {"variable": "Cly", "time": 0.0, "expected": 2.01001e15},
                        {"variable": "Cly", "time": 0.1, "expected": 2.0100100000000005e15},
                        {"variable": "Cly", "time": 0.5, "expected": 2.0100100000000005e15},
                        {"variable": "Cly", "time": 1.0, "expected": 2.0100100000000005e15}
                    ]
                },
                {
                    "id": "warm_temperature_40km",
                    "description": "Reference trajectory at T = 251 K (40 km conditions, Seinfeld & Pandis Table 5.1) with all other parameters at defaults. Warmer T accelerates the Arrhenius positive-C channels (ClO + O, ClO + NO, OH + HCl) and slows the negative-C channels (Cl + O3, Cl + CH4) — net effect is faster ClOx cycling (ClO at 1 hour ≈ 1.63e14, vs ~1.77e14 at 30 km). Exercises the temperature-dependent rate-law branch at a textbook-relevant altitude. Reference values pinned from upstream Tsit5 integration.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"T": 251.0},
                    "assertions": [
                        {"variable": "Cl",     "time": 600.0,  "expected": 4.217260537589072e10},
                        {"variable": "ClO",    "time": 600.0,  "expected": 5.959277313818142e13},
                        {"variable": "HCl",    "time": 600.0,  "expected": 1.0064495943347608e15},
                        {"variable": "ClONO2", "time": 600.0,  "expected": 9.439254599216819e14},
                        {"variable": "Cl",     "time": 3600.0, "expected": 1.0948492576625302e11},
                        {"variable": "ClO",    "time": 3600.0, "expected": 1.6303934405270762e14},
                        {"variable": "HCl",    "time": 3600.0, "expected": 1.1135238564477112e15},
                        {"variable": "ClONO2", "time": 3600.0, "expected": 7.333373145738068e14}
                    ]
                },
                {
                    "id": "no_methane_channel",
                    "description": "Methane-free scenario (CH4 = 0). Eliminates the Cl + CH4 → HCl reservoir-formation channel, so HCl can only decrease (OH + HCl → Cl is the only HCl term). After 1 hour HCl has dropped ~0.2% (vs growing ~8% at default CH4) because the only HCl source is the externally-prescribed OH + HCl reaction. Exercises the parameter-sweep behavior of the CH4 channel; reference values pinned from upstream Tsit5 integration.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"CH4": 0.0},
                    "assertions": [
                        {"variable": "Cl",     "time": 60.0,   "expected": 1.6488836255480213e10},
                        {"variable": "ClO",    "time": 60.0,   "expected": 1.5897307817018953e13},
                        {"variable": "HCl",    "time": 600.0,  "expected": 9.99666239397679e14,  "tolerance": {"abs": 1.0e10}},
                        {"variable": "HCl",    "time": 3600.0, "expected": 9.979991065847689e14, "tolerance": {"abs": 1.0e10}},
                        {"variable": "ClO",    "time": 3600.0, "expected": 2.4757567995764284e14}
                    ]
                },
                {
                    "id": "no_no2_channel",
                    "description": "NO2-free scenario (NO2 = 0). Eliminates the ClO + NO2 + M → ClONO2 reservoir-formation channel, so ClONO2 can only decrease (ClONO2 + hν → Cl is the only ClONO2 term). After 1 hour ClONO2 has dropped ~30% (vs ~25% at default NO2) because the photolysis loss is no longer balanced by formation. Exercises the parameter-sweep behavior of the termolecular ClO + NO2 + M channel; reference values pinned from upstream Tsit5 integration.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"NO2": 0.0},
                    "assertions": [
                        {"variable": "Cl",     "time": 60.0,   "expected": 1.6279100182742704e10},
                        {"variable": "ClO",    "time": 60.0,   "expected": 1.5808340135467223e13},
                        {"variable": "ClONO2", "time": 600.0,  "expected": 9.417645335842521e14},
                        {"variable": "ClONO2", "time": 3600.0, "expected": 6.976763260710351e14},
                        {"variable": "ClO",    "time": 3600.0, "expected": 2.17428446195968e14}
                    ]
                }
            ],
            "examples": [
                {
                    "id": "clox_cycle_default_one_hour",
                    "description": "Default 30 km stratospheric run (T = 227 K, M = 3.1e23 m^-3, upstream initial conditions) over 1 hour. Surfaces the canonical ClOx-cycle behavior: ClO grows by ~18x as Cl + O3 drives the catalytic cycle, while HCl slowly accumulates and ClONO2 partially photolyzes. Reproduces the upstream `ClOx Cycle Integration` reference run (test/StratosphericChemistry_test.jl:182).",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {
                            "Cl": 1.0e10,
                            "ClO": 1.0e13,
                            "HCl": 1.0e15,
                            "ClONO2": 1.0e15
                        }
                    },
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "plots": [
                        {
                            "id": "active_clox_vs_time",
                            "type": "line",
                            "description": "Active ClOx species (Cl, ClO) vs time at 30 km defaults. Cl tracks ClO via the quasi-steady Cl/ClO ratio set by Eq. 5.30; both grow as Cl + O3 outpaces the reservoir-formation channels in the first hour.",
                            "x": {"variable": "t", "label": "time (s)"},
                            "y": {"variable": "ClO", "label": "ClO (m^-3)"}
                        },
                        {
                            "id": "reservoir_species_vs_time",
                            "type": "line",
                            "description": "Reservoir species (HCl, ClONO2) vs time at 30 km defaults. HCl grows slowly via Cl + CH4, while ClONO2 partially photolyzes — the two reservoirs equilibrate on different timescales because the formation/loss rate constants differ.",
                            "x": {"variable": "t", "label": "time (s)"},
                            "y": {"variable": "ClONO2", "label": "ClONO2 (m^-3)"}
                        },
                        {
                            "id": "cly_conservation_vs_time",
                            "type": "line",
                            "description": "Total inorganic chlorine Cly = Cl + ClO + HCl + ClONO2 vs time at 30 km defaults. Should remain constant at the initial value 2.01001e15 m^-3 — the upstream Cly Conservation test reference plot.",
                            "x": {"variable": "t", "label": "time (s)"},
                            "y": {"variable": "Cly", "label": "Cly (m^-3)"}
                        }
                    ]
                },
                {
                    "id": "clox_cycle_temperature_sweep",
                    "description": "Sweep T over the stratospheric range [200, 270] K at otherwise-default conditions. Surfaces the temperature dependence of the ClOx cycle: ClO at t = 3600 s rises with T (the positive-C Arrhenius channels — ClO + O, ClO + NO, OH + HCl — speed up faster than the negative-C channels — Cl + O3, Cl + CH4 — slow down). The termolecular ClO + NO2 + M → ClONO2 also slows at higher T (k ∝ (T_ref/T)^3.4), shifting the partition away from the ClONO2 reservoir.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {
                            "Cl": 1.0e10,
                            "ClO": 1.0e13,
                            "HCl": 1.0e15,
                            "ClONO2": 1.0e15
                        }
                    },
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T",
                                "range": {"start": 200.0, "stop": 270.0, "count": 8, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "ClO_final_vs_T",
                            "type": "line",
                            "description": "Final ClO at t = 3600 s vs temperature: shows the temperature-dependent saturation of the ClOx cycle as the relative weight of Arrhenius positive-C / negative-C / termolecular channels shifts.",
                            "x": {"variable": "T",   "label": "T (K)"},
                            "y": {"variable": "ClO", "label": "ClO at t=3600 s (m^-3)"}
                        }
                    ]
                }
            ]
        }
    }
}
