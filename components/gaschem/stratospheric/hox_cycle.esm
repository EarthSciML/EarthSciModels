                        {"variable": "HO2", "time": 600.0,  "expected": 2.67511827731158e11},
                        {"variable": "OH",  "time": 3600.0, "expected": 1.074210500283769e13},
                        {"variable": "HO2", "time": 3600.0, "expected": 2.578949971623307e11},
                        {"variable": "HOx", "time": 3600.0, "expected": 1.1e13}
