            "examples": [
                {
                    "id": "default_run_3600s",
                    "description": "One-hour integration under S&P Page 161 mid-stratosphere defaults (OH=1e12, HO2=1e13 m^-3, T=227 K, O=1e13, O3=3e18, NO=1e15 m^-3). Shows OH and HO2 approaching their bimolecular steady state on a ~tens-of-seconds timescale and holding for the rest of the hour. The OH curve illustrates the HO2 → OH recycle through HO2+NO (dominant), HO2+O, and HO2+O3.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "plots": [
