                        {"variable": "HO2", "time": 600.0,  "expected": 9.31093272685800e12},
                        {"variable": "OH",  "time": 3600.0, "expected": 1.689067273107957e12},
                        {"variable": "HO2", "time": 3600.0, "expected": 9.310932726892042e12},
                        {"variable": "HOx", "time": 3600.0, "expected": 1.1e13}
