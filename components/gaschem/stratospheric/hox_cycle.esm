                            "x": {"variable": "t", "label": "time (s)"},
                            "y": {"variable": "OH", "label": "OH (m^-3)"}
                        }
                    ]
                },
                {
                    "id": "temperature_sensitivity_sweep",
                    "description": "Stratospheric temperature sweep over 200 K - 280 K (cold polar vortex to warm sub-tropical mid-stratosphere). At each T the system is integrated for one hour to steady state. The four Arrhenius rate coefficients change exponentially with T, but their net effect on the OH/HO2 ratio is non-monotonic — at low T the HO2+O and HO2+NO channels (positive C) speed up while OH+O3 (negative C) slows down, shifting HOx toward OH. Mirrors the SuperFast temperature_sweep example structure.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
