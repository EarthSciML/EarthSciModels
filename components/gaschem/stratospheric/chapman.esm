                                ]
                            }
                        ]
                    }
                },
                {
                    "lhs": "Ox",
                    "rhs": {"op": "+", "args": ["O", "O3"]}
                }
            ],
            "tests": [
                {
                    "id": "initial_conditions_t0",
                    "description": "At t=0 the solver must return the declared species defaults exactly. Pins O at 1e13 m^-3 (1e6 molec/cm^3, S&P Page 145 reference), O3 at 3e18 m^-3 (3e12 molec/cm^3, same reference), and Ox at the algebraic sum 3.00001e18 m^-3 (= 1e13 + 3e18). Tolerance tightened to rel=1e-10 / abs=1e-14 because at t=0 there is no integration drift — only parser→Float64 conversion and the first-step identity evaluation of the initial state.",
                    "time_span": {"start": 0.0, "end": 1.0},
                    "tolerance": {"rel": 1.0e-10, "abs": 1.0e-14},
                    "assertions": [
                        {"variable": "O",  "time": 0.0, "expected": 1.0e13},
                        {"variable": "O3", "time": 0.0, "expected": 3.0e18},
                        {"variable": "Ox", "time": 0.0, "expected": 3.00001e18}
                    ]
                },
                {
                    "id": "default_short_term_10s",
                    "description": "Captures the fast O radical-equilibrium transient: from the initial O = 1e13 m^-3, atomic oxygen accumulates on a ~0.045 s timescale (lifetime = 1/(k2·O2_mix·M^2 + k4·O3) ≈ 0.045 s) toward the j_O3·O3-dominated quasi-equilibrium O_eq ≈ (2·j_O2·O2_mix·M + j_O3·O3) / (k2·O2_mix·M^2 + k4·O3) ≈ 1.36e14 m^-3 (the j_O3·O3 source channel dominates the production over 2·j_O2·O2·M by ~240×). O is essentially at its equilibrium value by t ≈ 0.5 s and holds it through t = 10 s. O3 is approximately constant on this timescale (Ox drift ~4e-5 over 10 s, see `odd_oxygen_quasi_conservation_short`).",
                    "time_span": {"start": 0.0, "end": 10.0},
                    "assertions": [
                        {"variable": "O",  "time": 0.0,  "expected": 1.0e13},
                        {"variable": "O3", "time": 0.0,  "expected": 3.0e18},
                        {"variable": "O",  "time": 0.1,  "expected": 1.222672944581606e14},
                        {"variable": "O",  "time": 1.0,  "expected": 1.360282269114367e14},
                        {"variable": "O",  "time": 5.0,  "expected": 1.360303673435825e14},
                        {"variable": "O",  "time": 10.0, "expected": 1.360330428384102e14},
                        {"variable": "O3", "time": 1.0,  "expected": 2.999885855433412e18},
                        {"variable": "O3", "time": 10.0, "expected": 2.999992521729438e18}
                    ]
                },
                {
                    "id": "default_long_term_1day",
                    "description": "Headline 24-hour integration under S&P Page 145 mid-stratosphere defaults (O=1e13, O3=3e18 m^-3; T=227 K, M=3e23 m^-3, O2_mix=0.21, j_O2=1e-10 s^-1, j_O3=1e-3 s^-1). Reproduces and tightens the upstream 'Chapman Mechanism Integration' test (StratosphericChemistry_test.jl:136-150) — that test asserts only positivity at retcode=Success over 1 day, this one pins the actual trajectory at four times across the window. The Ox value drifts slowly upward as the j_O2 source (2·j_O2·O2·M = 1.26e13 m^-3/s) modestly exceeds the k4·O·O3 sink at the radical-equilibrium O ≈ 1.36-1.81e14 m^-3 → net Ox growth ~1e13 m^-3/s, giving Ox at t=86400 s ≈ 4.0e18 m^-3 (a ~33% increase over the initial 3.00001e18 m^-3).",
                    "time_span": {"start": 0.0, "end": 86400.0},
                    "assertions": [
                        {"variable": "O",  "time": 0.0,     "expected": 1.0e13},
                        {"variable": "O3", "time": 0.0,     "expected": 3.0e18},
                        {"variable": "O",  "time": 3600.0,  "expected": 1.379523226867756e14},
                        {"variable": "O3", "time": 3600.0,  "expected": 3.042502323795783e18},
                        {"variable": "O",  "time": 21600.0, "expected": 1.475221637023426e14},
                        {"variable": "O3", "time": 21600.0, "expected": 3.254465331388063e18},
                        {"variable": "O",  "time": 86400.0, "expected": 1.811716642589568e14},
                        {"variable": "O3", "time": 86400.0, "expected": 3.999799734606761e18},
                        {"variable": "Ox", "time": 86400.0, "expected": 3.999980906271021e18}
                    ]
                },
                {
                    "id": "odd_oxygen_quasi_conservation_short",
                    "description": "Short-window (10-second) integration pinning Ox at five times spanning the fast O radical-equilibrium transient (0 < t < 1 s) and the early Ox source-sink slow drift (1 s < t < 10 s). Reproduces and tightens the upstream 'Odd Oxygen Conservation (Chapman)' test (StratosphericChemistry_test.jl:248-264) — that test asserts `isapprox(Ox_initial, Ox_final, rtol=1e-4)` over 10 s, this one pins the actual Ox trajectory so the magnitude of the drift (~4e-5 relative over 10 s, from 3.00001e18 to 3.0001286e18) is itself a regression target, not just the upper-bound rtol. Captures both endpoints of the well-known Chapman timescale separation: fast O equilibration (~0.045 s) followed by slow Ox drift (~1.18e13 m^-3/s under default conditions).",
                    "time_span": {"start": 0.0, "end": 10.0},
                    "assertions": [
                        {"variable": "Ox", "time": 0.0,  "expected": 3.00001e18},
                        {"variable": "Ox", "time": 0.1,  "expected": 3.000011213098563e18},
                        {"variable": "Ox", "time": 1.0,  "expected": 3.000021883660323e18},
                        {"variable": "Ox", "time": 5.0,  "expected": 3.000069293122439e18},
                        {"variable": "Ox", "time": 10.0, "expected": 3.000128554772277e18}
                    ]
                },
                {
                    "id": "zero_photolysis_radical_decay",
                    "description": "Zero-photolysis case: with j_O2 = 0 and j_O3 = 0 the only remaining O dynamics are the two sink reactions (O + O2 + M → O3 + M and O + O3 → 2 O2) — both consume O without replenishment. Starting from O = 1e13 m^-3, atomic oxygen collapses to numerical zero on the ~0.045 s timescale set by k2·O2_mix·M^2 + k4·O3. By t = 60 s the integrator has driven O below the abstol=1e-12 floor (sample value ~3e-23 m^-3, effectively zero). O3 has absorbed the initial 1e13 m^-3 of O atoms (one O atom becomes one O3 via the dominant 3-body channel) and holds at 3.000009997518167e18 m^-3 thereafter. Reproduces and tightens the upstream 'Zero Photolysis Rates' test (StratosphericChemistry_test.jl:502-523) — that test asserts only `O[end] < O[1]` over 1 hour, this one pins the numerical collapse of O and the post-collapse steady state of O3 and Ox.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"j_O2": 0.0, "j_O3": 0.0},
                    "tolerance": {"rel": 1.0e-6, "abs": 1.0e-10},
                    "assertions": [
                        {"variable": "O",  "time": 0.0,    "expected": 1.0e13},
                        {"variable": "O",  "time": 60.0,   "expected": 0.0, "tolerance": {"abs": 1.0e-10}},
                        {"variable": "O",  "time": 600.0,  "expected": 0.0, "tolerance": {"abs": 1.0e-10}},
                        {"variable": "O",  "time": 3600.0, "expected": 0.0, "tolerance": {"abs": 1.0e-10}},
                        {"variable": "O3", "time": 60.0,   "expected": 3.000009997518167e18},
                        {"variable": "O3", "time": 600.0,  "expected": 3.000009997518167e18},
                        {"variable": "O3", "time": 3600.0, "expected": 3.000009997518167e18},
                        {"variable": "Ox", "time": 3600.0, "expected": 3.000009997518167e18}
                    ]
                },
                {
                    "id": "cold_temperature_perturbation",
                    "description": "Cold-stratosphere case: drop T from 227 K to 200 K. The two T-dependent rate coefficients change in opposite directions: k2 ∝ (T_ref/T)^2.4 grows from 1.17e-45 to 1.60e-45 m^6/s (1.4× faster), accelerating the O+O2+M sink; k4 ∝ exp(C_k4/T) = exp(-2060/T) drops from 9.2e-22 to 2.65e-22 m^3/s (3.5× slower), decelerating the O+O3 odd-oxygen sink. Net effect on O at radical equilibrium: O_eq ≈ (2·j_O2·O2_mix·M + j_O3·O3) / (k2·O2_mix·M^2 + k4·O3) drops to ~1.02e14 m^-3 (faster sink wins). Ox drift slows (smaller k4·O·O3 sink loses to the unchanged j_O2 source) — Ox at 3600 s rises to 3.0448e18, more than the warm-case value because the source-sink balance shifts slightly toward source.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"T": 200.0},
                    "assertions": [
                        {"variable": "O",  "time": 60.0,   "expected": 1.004135195913270e14},
                        {"variable": "O",  "time": 600.0,  "expected": 1.006373178516833e14},
                        {"variable": "O",  "time": 3600.0, "expected": 1.018804024083936e14},
                        {"variable": "O3", "time": 3600.0, "expected": 3.044675971321667e18},
                        {"variable": "Ox", "time": 3600.0, "expected": 3.044777851724076e18}
                    ]
                },
                {
                    "id": "warm_temperature_perturbation",
                    "description": "Warm-stratosphere case: raise T from 227 K to 270 K. k2 ∝ (T_ref/T)^2.4 drops from 1.17e-45 to 7.6e-46 m^6/s (0.65× slower, weaker O+O2+M sink). k4 ∝ exp(-2060/T) grows from 9.2e-22 to 3.9e-21 m^3/s (4.3× faster, stronger O+O3 odd-oxygen sink). O accumulates higher (~2.06e14 m^-3) at radical equilibrium because the dominant k2 sink is weaker, but Ox drifts upward less than the cold case because the k4 sink eats more of the j_O2 source. Together with `cold_temperature_perturbation`, brackets the dynamic range across the stratospheric temperature range.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"T": 270.0},
                    "assertions": [
                        {"variable": "O",  "time": 60.0,   "expected": 2.061592636089013e14},
                        {"variable": "O",  "time": 600.0,  "expected": 2.064466749053785e14},
                        {"variable": "O",  "time": 3600.0, "expected": 2.080343574124492e14},
                        {"variable": "O3", "time": 3600.0, "expected": 3.027697042944536e18},
                        {"variable": "Ox", "time": 3600.0, "expected": 3.027905077301948e18}
                    ]
                },
                {
                    "id": "dense_M_perturbation",
                    "description": "Lower-altitude (denser) case: raise M from 3e23 to 1e25 m^-3 (~factor 33×, mimicking ~10 km altitude vs ~30 km default). The k2·O·O2_mix·M^2 three-body sink scales as M^2 (3×33² ≈ 3300× stronger), the 2·j_O2·O2_mix·M source scales as M (33× stronger), and the j_O3·O3 source is unchanged — the M^2 sink wins by a factor of ~100, pushing O radical equilibrium to ~1.4e11 m^-3 (factor 970 lower than the default 1.36e14). O3 grows substantially over 1 hour (3e18 → 4.5e18) because the k4·O·O3 sink is essentially shut off (O collapsed) and the j_O2 → k2 → O3 production channel still operates. Ox at 3600 s ≈ 4.5e18 m^-3 (50% increase, much faster Ox growth than the default M case).",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"M": 1.0e25},
                    "assertions": [
                        {"variable": "O",  "time": 60.0,   "expected": 1.400283996483846e11},
                        {"variable": "O",  "time": 600.0,  "expected": 1.492465240434067e11},
                        {"variable": "O",  "time": 3600.0, "expected": 2.004582720442080e11},
                        {"variable": "O3", "time": 3600.0, "expected": 4.512005543330380e18},
                        {"variable": "Ox", "time": 3600.0, "expected": 4.512005743788653e18}
                    ]
                },
                {
                    "id": "thin_M_perturbation",
                    "description": "Higher-altitude (thinner) case: drop M from 3e23 to 1e22 m^-3 (~factor 30× thinner, mimicking ~60 km altitude vs ~30 km default). The k2·O·O2_mix·M^2 sink weakens by ~900×, the 2·j_O2·O2_mix·M source weakens by 30×, so the source/sink ratio favors O accumulation — O climbs to ~8.6e16 m^-3 within a minute, then *declines* over time because the k4·O·O3 odd-oxygen sink (still bimolecular, not weakened by M) is now the dominant Ox loss channel and outpaces the weakened M-dependent production. Ox at 3600 s drops to 1.78e18 m^-3 (a 41% decrease from initial) — the opposite regime from the dense_M case. Demonstrates the model handles wide regime shifts cleanly and produces qualitatively correct altitude-dependent behavior.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"M": 1.0e22},
                    "assertions": [
                        {"variable": "O",  "time": 60.0,   "expected": 8.639600122257584e16},
                        {"variable": "O",  "time": 600.0,  "expected": 9.736078453152483e16},
                        {"variable": "O",  "time": 3600.0, "expected": 6.575602054228018e16},
                        {"variable": "O3", "time": 60.0,   "expected": 2.895970473007935e18},
                        {"variable": "O3", "time": 3600.0, "expected": 1.713430216697002e18},
                        {"variable": "Ox", "time": 3600.0, "expected": 1.779186237239282e18}
                    ]
                },
                {
                    "id": "reduced_jO3_perturbation",
                    "description": "Reduced O3 photolysis case: drop j_O3 from 1e-3 to 4e-4 s^-1 (the value used by the upstream 'Chapman Steady-State [O]/[O3] Ratio' test, StratosphericChemistry_test.jl:365-401). The j_O3·O3 source for O drops by 2.5× (from 3e15 to 1.2e15 m^-3/s) — the dominant O source channel, so O radical equilibrium drops correspondingly to ~5.5e13 m^-3 (about 0.4× the default 1.36e14). O3 drift is slightly faster because more O3 is preserved per unit time (less photolysis loss). This test reproduces the upstream parameter setup at a tighter quantitative level: where the upstream test asserts the steady-state O/O3 ratio to ~10% (its Eq. 5.7 order-of-magnitude check), this one pins both O and O3 at rel=1e-6 across the trajectory.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_overrides": {"j_O3": 4.0e-4},
                    "assertions": [
                        {"variable": "O",  "time": 60.0,   "expected": 5.476724089724273e13},
                        {"variable": "O",  "time": 600.0,  "expected": 5.488717392624235e13},
                        {"variable": "O",  "time": 3600.0, "expected": 5.555323066804884e13},
                        {"variable": "O3", "time": 3600.0, "expected": 3.044215105276009e18},
                        {"variable": "Ox", "time": 3600.0, "expected": 3.044270658506678e18}
                    ]
                },
                {
                    "id": "equal_O_O3_initial",
                    "description": "Initial-condition sensitivity check: start the system with O = O3 = 1e18 m^-3 (so Ox = 2e18 m^-3, different from the default 3.00001e18). The system relaxes the excess O via the fast k2·O·O2_mix·M^2 three-body sink (O collapses from 1e18 to ~9.1e13 m^-3 within ~60 s, depositing the excess O atoms as O3) — by t = 60 s the system is at a quasi-equilibrium with O ≈ 9.1e13 m^-3 and O3 ≈ 2e18 m^-3. The reduced O3 (vs default 3e18) means the O/O3 ratio is different from the default trajectory, but the radical equilibrium structure is the same. Ox at 3600 s ≈ 2.044e18 m^-3 — close to the initial Ox plus the j_O2-driven drift over 1 hour. Verifies the initial-condition machinery works correctly across the full O domain (1e13 to 1e18 m^-3 spans 5 orders of magnitude).",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "initial_conditions": {"O": 1.0e18, "O3": 1.0e18},
                    "assertions": [
                        {"variable": "O",  "time": 0.0,    "expected": 1.0e18},
                        {"variable": "O3", "time": 0.0,    "expected": 1.0e18},
                        {"variable": "O",  "time": 60.0,   "expected": 9.090584756405858e13},
                        {"variable": "O",  "time": 600.0,  "expected": 9.120490382013364e13},
                        {"variable": "O",  "time": 3600.0, "expected": 9.286534037592266e13},
                        {"variable": "O3", "time": 60.0,   "expected": 2.000521044470805e18},
                        {"variable": "O3", "time": 3600.0, "expected": 2.043917930090608e18},
                        {"variable": "Ox", "time": 3600.0, "expected": 2.044010795430983e18}
                    ]
                }
            ],
            "examples": [
                {
                    "id": "default_run_1day",
                    "description": "One-day integration under S&P Page 145 mid-stratosphere defaults (O=1e13, O3=3e18 m^-3, T=227 K, M=3e23 m^-3, O2_mix=0.21, j_O2=1e-10 s^-1, j_O3=1e-3 s^-1). Shows the fast O radical-equilibrium transient (O rises from 1e13 to 1.36e14 m^-3 within ~1 s) and the slow Ox drift over 24 hours (O3 grows from 3e18 to ~4e18 m^-3 as the j_O2 source modestly outpaces the k4·O·O3 sink at the quasi-equilibrium O).",
                    "time_span": {"start": 0.0, "end": 86400.0},
                    "plots": [
                        {
                            "id": "O_vs_time",
                            "type": "line",
                            "description": "Atomic oxygen O concentration over one day of ChapmanMechanism integration.",
                            "x": {"variable": "t", "label": "time (s)"},
                            "y": {"variable": "O", "label": "O (m^-3)"}
                        },
                        {
                            "id": "O3_vs_time",
                            "type": "line",
                            "description": "Ozone O3 concentration over one day of ChapmanMechanism integration.",
                            "x": {"variable": "t", "label": "time (s)"},
                            "y": {"variable": "O3", "label": "O3 (m^-3)"}
                        }
                    ]
                },
                {
                    "id": "temperature_sensitivity_sweep",
                    "description": "Stratospheric temperature sweep over 200 K - 280 K (cold polar vortex to warm sub-tropical mid-stratosphere). At each T the system is integrated for one hour to its quasi-equilibrium plus slow-drift state. The k2 ∝ (T_ref/T)^2.4 and k4 ∝ exp(C_k4/T) rate coefficients change in opposite directions with T (k2 faster at low T, k4 slower at low T) — the net effect on O at radical equilibrium is monotonic: cold T favors lower O via the dominant k2 sink. Mirrors the sibling HOx cycle's temperature_sensitivity_sweep example shape.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "T",
                                "values": [200.0, 210.0, 220.0, 230.0, 240.0, 250.0, 260.0, 270.0, 280.0]
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "O_eq_vs_T",
                            "type": "line",
                            "description": "Quasi-equilibrium O concentration vs. temperature.",
                            "x": {"variable": "T", "label": "Temperature (K)"},
                            "y": {"variable": "O", "label": "O (m^-3)"}
                        },
                        {
                            "id": "O3_eq_vs_T",
                            "type": "line",
                            "description": "O3 concentration at t=3600s vs. temperature.",
                            "x": {"variable": "T", "label": "Temperature (K)"},
                            "y": {"variable": "O3", "label": "O3 (m^-3)"}
                        }
                    ]
                },
                {
                    "id": "altitude_density_sweep",
                    "description": "Air density sweep across the stratospheric range, mimicking altitude effects: M from 1e22 m^-3 (~60 km) to 3e24 m^-3 (~20 km), covering ~2.5 orders of magnitude. At lower altitudes (denser, higher M), the M^2-dependent three-body sink dominates and pushes O to very low quasi-equilibrium (~1e11 m^-3 at M=1e25). At higher altitudes (thinner, lower M), the sink weakens faster than the source and O accumulates to ~1e17 m^-3 at M=1e22. This illustrates the canonical Chapman 'O > O3 above ~60 km / O < O3 below ~60 km' regime crossover that motivates the family-sum Ox variable.",
                    "time_span": {"start": 0.0, "end": 3600.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "M",
                                "values": [1.0e22, 3.0e22, 1.0e23, 3.0e23, 1.0e24, 3.0e24]
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "O_eq_vs_M",
                            "type": "line",
                            "description": "Quasi-equilibrium O concentration vs. air number density M.",
                            "x": {"variable": "M", "label": "M (m^-3)"},
                            "y": {"variable": "O", "label": "O (m^-3)"}
                        }
                    ]
                }
            ]
        }
    }
