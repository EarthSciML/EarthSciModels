                        "a_A": 140.0
                    },
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "t_f",
                                "range": {"start": 157788000.0, "stop": 31557600000.0, "count": 30, "scale": "log"}
