                        {"variable": "AGWP_CO2", "time": 0.0, "expected": 2303308188.662561, "tolerance": {"rel": 1.0e-10}},
                        {"variable": "decay_integral_A", "time": 0.0, "expected": 2303308188.662561, "tolerance": {"rel": 1.0e-10}},
                        {"variable": "decay_integral_CO2", "time": 0.0, "expected": 2303308188.662561, "tolerance": {"rel": 1.0e-10}}
                    ]
