                        },
                        {
                            "expected": 5.443235812673289e-5,
                            "time": 360,
                            "variable": "HO2"
                        },
                        {
                            "expected": 0.0004715825087598686,
                            "time": 60,
                            "variable": "NO2"
                        },
                        {
                            "expected": 0.000310275193341143,
                            "time": 180,
                            "variable": "NO2"
                        },
                        {
                            "expected": 0.00014115184848922932,
                            "time": 360,
                            "variable": "NO2",
                            "tolerance": {
                                "rel": 5.0e-4
                            }
                        }
                    ],
                    "description": "Reference run from upstream GasChem.jl defaults. Integrates 0..360 s with Rosenbrock23 and samples 4 active species at 4 times each. This test is the primary numerical-agreement gate between the serialized .esm and the upstream MTK ReactionSystem.",
                    "tolerance": {
                        "rel": 0.0001
                    }
                },
                {
                    "time_span": {
                        "start": 0,
                        "end": 360
                    },
                    "id": "base_defaults_radical_pool",
                    "assertions": [
                        {
                            "expected": 0.39008430055736243,
                            "time": 360,
                            "variable": "CH3O2",
                            "tolerance": {
                                "rel": 5.0e-4
                            }
                        },
                        {
                            "expected": 0.0006261317967660381,
                            "time": 360,
                            "variable": "CH3OOH",
                            "tolerance": {
                                "rel": 5.0e-4
                            }
                        },
                        {
                            "expected": 0.5116858193267704,
                            "time": 360,
                            "variable": "CH2O",
                            "tolerance": {
                                "rel": 1.0e-3
                            }
                        },
                        {
                            "expected": 2.3348851834355124,
                            "time": 360,
                            "variable": "H2O2"
                        },
                        {
                            "expected": 0.0006401785292033819,
                            "time": 360,
                            "variable": "HNO3"
                        },
                        {
                            "expected": 96.34083103377482,
                            "time": 360,
                            "variable": "CO"
                        },
                        {
                            "expected": 1.3062470823893288e-19,
                            "time": 360,
                            "variable": "ISOP",
                            "tolerance": {
                                "rel": 5.0e-3
                            }
                        }
                    ],
                    "description": "Radical pool values (CH3O2, CH3OOH, CH2O, H2O2, HNO3, CO, ISOP) at t=360 s under default initial conditions. Guards against structural drift in the CH3O2 and HxOy pathways.",
                    "tolerance": {
                        "rel": 0.0001
                    }
                },
                {
                    "tolerance": {
                        "rel": 0.0001
                    },
                    "time_span": {
                        "start": 0,
                        "end": 3600
                    },
                    "id": "high_nox_photostationary_1h",
                    "assertions": [
                        {
                            "expected": 49.01536741710056,
                            "time": 600,
                            "variable": "O3"
                        },
                        {
                            "expected": 24.451817558029266,
                            "time": 3600,
                            "variable": "O3",
                            "tolerance": {
                                "rel": 5.0e-4
                            }
                        },
                        {
                            "expected": 4.931239117484898,
                            "time": 600,
                            "variable": "NO"
                        },
                        {
                            "expected": 0.050174382379650405,
                            "time": 3600,
                            "variable": "NO",
                            "tolerance": {
                                "rel": 2.0e-3
                            }
                        },
                        {
                            "expected": 5.7566861937418325,
                            "time": 600,
                            "variable": "NO2"
                        },
                        {
                            "expected": 0.0971357341685795,
                            "time": 3600,
                            "variable": "NO2",
                            "tolerance": {
                                "rel": 2.0e-3
                            }
                        },
                        {
                            "expected": 9.30708032140729,
                            "time": 600,
                            "variable": "HNO3"
                        },
                        {
                            "expected": 19.843998074464743,
                            "time": 3600,
                            "variable": "HNO3"
                        }
                    ],
                    "description": "High-NOx photochemical-smog-ish regime: initial NO=10, NO2=10, O3=60, ISOP=0.5 ppb. Integrated 0..3600 s. Checks photostationary state of the NO/NO2/O3 triad and build-up of HNO3 via NO2+OH. Failure here indicates the NO2 photolysis / NO+O3 / HO2+NO / NO2+OH+M loop has drifted.",
                    "initial_conditions": {
                        "NO": 10,
                        "O3": 60,
                        "ISOP": 0.5,
                        "NO2": 10
                    }
                },
                {
                    "parameter_overrides": {
                        "jNO2": 0,
                        "jH2COb": 0,
                        "jH2COa": 0,
                        "jH2O2": 0,
                        "jCH3OOH": 0,
                        "jO32OH": 0
                    },
                    "time_span": {
                        "start": 0,
                        "end": 1800
                    },
                    "id": "dark_all_photolysis_zero_30min",
                    "assertions": [
                        {
                            "expected": 39.99959974182895,
                            "time": 1800,
                            "variable": "O3"
                        },
                        {
                            "expected": 1.0314305852209193e-15,
                            "time": 1800,
                            "variable": "NO",
                            "tolerance": {
                                "rel": 1.0e-3,
                                "abs": 1.0e-12
                            }
                        },
                        {
                            "expected": 0.0007972805261944212,
                            "time": 1800,
                            "variable": "NO2"
                        },
                        {
                            "expected": 1.0534552593945216e-12,
                            "time": 1800,
                            "variable": "OH",
                            "tolerance": {
                                "rel": 1.0e-3,
                                "abs": 2.0e-12
                            }
                        },
                        {
                            "expected": 1.748373575923495e-10,
                            "time": 1800,
                            "variable": "HO2",
                            "tolerance": {
                                "rel": 1.0e-2,
                                "abs": 1.0e-12
                            }
                        }
                    ],
                    "description": "Overnight / dark chemistry: all photolysis rates (jO32OH, jH2O2, jNO2, jH2COa, jH2COb, jCH3OOH) forced to 0. Integrated 0..1800 s. Without photolysis, OH/HO2 should relax toward zero while O3 and NO2 decay slowly. This exercises the parameter-override path and guards against runaway radical production without a radical source.",
                    "tolerance": {
                        "rel": 0.0001,
                        "abs": 1.0e-14
                    }
                },
                {
                    "time_span": {
                        "start": 0,
                        "end": 1
                    },
                    "id": "initial_conditions_t0",
                    "assertions": [
                        {
                            "expected": 40,
                            "time": 0,
                            "variable": "O3"
                        },
                        {
                            "expected": 4.0e-6,
                            "time": 0,
                            "variable": "OH"
                        },
                        {
                            "expected": 4.0e-6,
                            "time": 0,
                            "variable": "HO2"
                        },
                        {
                            "expected": 0.0004,
                            "time": 0,
                            "variable": "NO"
                        },
                        {
                            "expected": 0.0004,
                            "time": 0,
                            "variable": "NO2"
                        },
                        {
                            "expected": 4.0e-6,
                            "time": 0,
                            "variable": "CH3O2"
                        },
                        {
                            "expected": 4.0e-6,
                            "time": 0,
                            "variable": "CH2O"
                        },
                        {
                            "expected": 100,
                            "time": 0,
                            "variable": "CO"
                        },
                        {
                            "expected": 4.0e-6,
                            "time": 0,
                            "variable": "CH3OOH"
