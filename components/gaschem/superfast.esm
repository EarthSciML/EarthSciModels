{
    "reaction_systems": {
        "SuperFast": {
            "tests": [
                {
                    "time_span": {
                        "start": 0,
                        "end": 360
                    },
                    "id": "base_defaults_multi_species_multi_time",
                    "assertions": [
                        {
                            "expected": 39.386872008139726,
                            "time": 60,
                            "variable": "O3"
                        },
                        {
                            "expected": 38.19570749487712,
                            "time": 180,
                            "variable": "O3"
                        },
                        {
                            "expected": 36.499626128220804,
                            "time": 360,
                            "variable": "O3"
                        },
                        {
                            "expected": 0.0196710112876177,
                            "time": 60,
                            "variable": "OH"
                        },
                        {
                            "expected": 0.017685270828760827,
                            "time": 180,
                            "variable": "OH"
                        },
                        {
                            "expected": 0.015266525098664305,
                            "time": 360,
                            "variable": "OH",
                            "tolerance": {
                                "rel": 5.0e-4
                            }
                        },
                        {
                            "expected": 5.33748570740643e-5,
                            "time": 60,
                            "variable": "HO2"
                        },
                        {
                            "expected": 5.474526969852731e-5,
                            "time": 180,
