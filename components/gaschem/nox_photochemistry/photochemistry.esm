                    "plots": [
                        {
                            "id": "o3_pss_vs_no2",
                            "type": "line",
                            "description": "Photostationary-state ozone O3_pss vs NOв‚‚ number density at fixed NO = 2.5e16 mвЃ»Ві. A straight line through the origin (the Leighton relationship Eq. 6.6), O3_pss rising from ~8e16 mвЃ»Ві at NO2/NO = 0.1 to ~8e18 mвЃ»Ві at NO2/NO = 10.",
                            "x": {"variable": "NO2", "label": "NOв‚‚ number density (mвЃ»Ві)"},
