                                "parameter": "O3",
                                "range": {"start": 5.0e17, "stop": 3.0e18, "count": 200, "scale": "linear"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "phi_vs_o3",
                            "type": "line",
                            "description": "Photostationary-state parameter О¦ vs measured Oв‚ѓ number density at NO = 1 ppb, NOв‚‚ = 2 ppb. A 1/O3 hyperbola crossing О¦ = 1 at O3 = O3_pss в‰€ 8.42e17 mвЃ»Ві. О¦ > 1 below the crossing (net Oв‚ѓ production), О¦ < 1 above it (net Oв‚ѓ loss).",
                            "x": {"variable": "O3", "label": "Measured Oв‚ѓ number density (mвЃ»Ві)"},
                            "y": {"variable": "О¦", "label": "Photostationary-state parameter О¦ (dimensionless)"}
                        }
                    ]
                },
                {
                    "id": "net_o3_production_vs_o3",
                    "description": "Net ozone production rate P_O3 (Eq. 6.8) as a function of the ambient ozone, at the typical-midday NO/NO2 (2.5e16 and 5.0e16 mвЃ»Ві). The ambient O3 is swept from 5.0e17 to 3.0e18 mвЃ»Ві. P_O3 = j_NO2В·NO2 в€’ k_NO_O3В·NOВ·O3 is an exact straight line decreasing in O3, crossing zero at the photostationary value O3_pss в‰€ 8.42e17 mвЃ»Ві: net ozone production to the left of the crossing, net loss to the right. This is the linear (Eq. 6.8) companion to the `phi_vs_measured_o3` hyperbola вЂ” the same departure from photostationary state viewed as a rate rather than a ratio.",
                    "parameters": {"NO": 2.5e16, "NO2": 5.0e16, "O2": 5.25e24, "M": 2.5e25},
