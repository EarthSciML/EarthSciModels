                    "plots": [
                        {
                            "id": "p_o3_vs_o3",
                            "type": "line",
                            "description": "Net ozone production rate P_O3 vs measured Oв‚ѓ number density at NO = 1 ppb, NOв‚‚ = 2 ppb. A straight line decreasing in O3, crossing zero at O3 = O3_pss в‰€ 8.42e17 mвЃ»Ві вЂ” positive (net production) to the left, negative (net loss) to the right.",
                            "x": {"variable": "O3", "label": "Measured Oв‚ѓ number density (mвЃ»Ві)"},
