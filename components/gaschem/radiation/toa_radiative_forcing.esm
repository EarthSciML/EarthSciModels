                        "S_0": 2643.0,
                        "R_p": 0.77,
                        "F_L": 158.0
                    },
                    "time_span": { "start": 0.0, "end": 1.0 },
                    "assertions": [
                        { "variable": "F_S",   "time": 0.0, "expected": 151.9725 },
                        { "variable": "F_net", "time": 0.0, "expected": -6.0275 }
                    ]
                }
