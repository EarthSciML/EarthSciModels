            ],
            "examples": [
                {
                    "id": "planck_spectrum_solar_5800K",
                    "description": "Planck spectrum F_B_λ vs λ for a 5800 K blackbody (Sun's effective surface temperature) — sweeps λ from 100 nm (UV-C) to 5 μm (mid-IR), spanning the full solar spectral range. Surfaces the canonical solar Planck distribution peaking near 500 nm visible-green with the asymmetric shape characteristic of all Planck spectra (steep rise on the short-wavelength Wien side, gradual decline on the long-wavelength Rayleigh-Jeans side). Integrating this curve gives the Stefan-Boltzmann total flux σT⁴ ≈ 6.42e7 W/m² (see stefan_boltzmann.esm at T=5800 K). Anchors the design observation that the Sun's emission concentrates 80% of its energy in the 0.3-3 μm range (visible + near-IR), with the visible band 380-780 nm carrying ~38% of total emission.",
                    "initial_state": {
                        "type": "per_variable",
                        "values": {}
                    },
                    "parameters": {},
                    "time_span": {"start": 0.0, "end": 1.0},
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "λ",
                                "range": {"start": 1.0e-7, "stop": 5.0e-6, "count": 80, "scale": "log"}
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "F_B_lambda_vs_lambda_5800K_loglog",
                            "type": "line",
                            "description": "Solar Planck spectrum F_B_λ(λ) at T=5800 K on log-log axes — peaks near 500 nm at ~8.5e13 W/m³ with sharp Wien-side rise (steep short-wavelength cutoff at <300 nm where exp(ch/kλT) dominates) and gradual Rayleigh-Jeans decline (λ⁻⁴ asymptotic slope visible at λ > 2 μm). The slope just below the peak is approximately -5 (Wien-tail) and just above the peak is approximately -4 (Rayleigh-Jeans tail) — anchoring the Planck function's two limiting regimes.",
                            "x": {"variable": "λ", "label": "λ (m, log)"},
                            "y": {"variable": "F_B_λ", "label": "F_B_λ (W/m³, log)"}
                        }
                    ]
                },
                {
                    "id": "planck_spectrum_earth_300K",
                    "description": "Planck spectrum F_B_λ vs λ for a 300 K blackbody (Earth surface temperature) — sweeps λ from 3 μm (short thermal-IR) to 100 μm (far-IR) covering the Earth's longwave emission band. Surfaces the canonical Earth-thermal Planck distribution peaking near 10 μm with the asymmetric Planck shape. Integrating this curve gives the Stefan-Boltzmann flux σT⁴ ≈ 460 W/m² (see stefan_boltzmann.esm at T=300 K). The Wien-displacement λ_max ≈ 10 μm anchors the 'atmospheric window' (8-13 μm) where the Earth's longwave emission has its peak and where atmospheric CO2 / H2O absorption is relatively weak — the spectral region where greenhouse-effect modifications most efficiently trap thermal radiation.",
