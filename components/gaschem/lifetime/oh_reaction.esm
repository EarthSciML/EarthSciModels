                                    "stop": 10000000000000.0,
                                    "count": 60,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "tau_oh_vs_oh_conc",
                            "type": "line",
                            "description": "Methane OH-reaction lifetime tau_OH vs ambient OH number density on log-log axes. A straight falling line of slope -1 (tau_OH proportional to 1/[OH]): higher OH shortens the lifetime from ~500 yr in the cleanest air to ~6 months at a polluted daytime OH peak.",
                            "x": {
                                "variable": "OH_conc",
                                "label": "OH number density (m^-3, log)"
