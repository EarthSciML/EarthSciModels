            "examples": [
                {
                    "id": "lifetime_vs_oh_rate_constant_sweep",
                    "description": "OH-reaction lifetime and effective rate constant as functions of the species rate constant k_OH, swept logarithmically from 1.0e-21 to 1.0e-16 m^3/s (upstream CGS 1e-15 to 1e-10 cm^3/molec/s) with OH_conc at the global-mean default 1.0e12 m^-3. The sweep spans the full reactivity range of tropospheric trace gases: methane (k_OH=6.3e-21) near the slow end, carbon monoxide (k_OH=2.4e-19) mid-range, and fast-oxidising alkenes/terpenes near 1e-16. Because tau_OH = 1/(k_OH*[OH]), the lifetime falls as 1/k_OH across five decades \u2014 from decades down to hours \u2014 the continuous form of the textbook species-lifetime table of Seinfeld & Pandis (2006) Ch. 2.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "k_OH",
                                "range": {
                                    "start": 1e-21,
                                    "stop": 1e-16,
                                    "count": 60,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "tau_oh_vs_k_oh",
                            "type": "line",
                            "description": "OH-reaction lifetime tau_OH vs the species rate constant k_OH on log-log axes. A straight falling line of slope -1 (tau_OH proportional to 1/k_OH at fixed OH): the more reactive the species, the shorter its atmospheric persistence, dropping from ~32 yr at k_OH=1e-21 to ~3 hours at k_OH=1e-16.",
                            "x": {
                                "variable": "k_OH",
                                "label": "OH rate constant k_OH (m^3/s, log)"
                            },
                            "y": {
                                "variable": "tau_OH",
                                "label": "OH-reaction lifetime tau_OH (s, log)"
                            }
                        },
                        {
                            "id": "k_eff_vs_k_oh",
                            "type": "line",
                            "description": "Effective pseudo-first-order rate constant k_eff = k_OH*OH_conc vs k_OH. A straight rising line through the origin (k_eff exactly linear in k_OH at fixed OH_conc) \u2014 the loss rate that drives the tau_OH decline.",
                            "x": {
                                "variable": "k_OH",
                                "label": "OH rate constant k_OH (m^3/s, log)"
                            },
                            "y": {
                                "variable": "k_eff",
                                "label": "effective rate constant k_eff (s^-1, log)"
                            }
                        }
                    ]
                },
                {
                    "id": "lifetime_vs_oh_concentration_sweep",
                    "description": "Methane OH-reaction lifetime as a function of the ambient OH concentration, swept logarithmically from 1.0e10 to 1.0e13 m^-3 (upstream CGS 1e4 to 1e7 molec/cm^3) with k_OH at the methane default 6.3e-21 m^3/s. The range runs from a clean remote free-troposphere OH burden up to a daytime polluted-plume peak. tau_OH = 1/(k_OH*[OH]) falls as 1/[OH], so the same molecule's lifetime varies by three orders of magnitude purely with the oxidising capacity of the surrounding air \u2014 the mechanism behind the seasonal and latitudinal spread of the methane lifetime.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
