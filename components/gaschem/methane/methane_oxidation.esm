                            "time": 0.0,
                            "expected": 5000000000.0
                        },
                        {
                            "variable": "R10",
                            "time": 0.0,
                            "expected": 90000000000.0
                        },
                        {
                            "variable": "R11",
                            "time": 0.0,
                            "expected": 300000000000.0
                        },
                        {
                            "variable": "R12",
                            "time": 0.0,
                            "expected": 400000000000.00006
                        },
                        {
                            "variable": "R13",
                            "time": 0.0,
                            "expected": 2.7299999999999997e+17
                        },
                        {
                            "variable": "R14",
                            "time": 0.0,
                            "expected": 748125000000000.1
                        },
                        {
                            "variable": "R15",
                            "time": 0.0,
                            "expected": 2025000000000.0
                        },
                        {
                            "variable": "R16",
                            "time": 0.0,
                            "expected": 200000000000000.0
                        },
                        {
