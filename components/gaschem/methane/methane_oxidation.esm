            "examples": [
                {
                    "id": "ch3o2_radical_fate_vs_no",
                    "description": "The central NOx-regime story of methane oxidation: how the fate of the methylperoxy radical CH₃O₂ — and hence the gross ozone production rate — depends on the nitric oxide concentration. NO is swept logarithmically from 2.5e14 to 2.5e18 m⁻³ (~10 ppt to ~100 ppb at STP), spanning the pristine-to-polluted range, with all other inputs at their defaults. R3 (the O₃-producing CH₃O₂ + NO channel) rises linearly with NO while R4 (the chain-terminating CH₃O₂ + HO₂ channel) stays flat — so the radical's fate crosses over from termination at low NO to ozone production at high NO. Reproduces the `CH₃O₂ Fate: NO vs HO₂` analysis of docs/src/methane_oxidation.md.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
                    },
                    "parameter_sweep": {
                        "type": "cartesian",
                        "dimensions": [
                            {
                                "parameter": "NO",
                                "range": {
                                    "start": 250000000000000.0,
                                    "stop": 2.5e+18,
                                    "count": 60,
                                    "scale": "log"
                                }
                            }
                        ]
                    },
                    "plots": [
                        {
                            "id": "r3_ch3o2_no_vs_no",
