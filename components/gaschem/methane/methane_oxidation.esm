                                "variable": "NO",
                                "label": "NO number density (m^-3)"
                            },
                            "y": {
                                "variable": "P_O3_gross",
                                "label": "Gross O3 production (m^-3 s^-1)"
                            }
                        }
                    ]
                },
                {
                    "id": "methane_sink_vs_oh",
                    "description": "The methane-loss rate as a function of the hydroxyl radical concentration. OH is swept logarithmically from 5.0e10 to 5.0e12 m⁻³, spanning two orders of magnitude of tropospheric oxidizing capacity, with all other inputs at their defaults. Because reaction with OH is the only methane sink in the mechanism, L_CH4 = R1 = k1·CH₄·OH is exactly linear in OH, and the methane chemical lifetime CH₄/L_CH4 is correspondingly inversely proportional to OH — the basis of methane's sensitivity to changes in the tropospheric oxidizing capacity.",
                    "time_span": {
                        "start": 0.0,
                        "end": 1.0
