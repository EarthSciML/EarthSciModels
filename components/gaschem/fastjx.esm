              "time": 0.0,
              "expected": 0.002076004373003029
            },
            {
              "variable": "j_NO3a",
              "time": 0.0,
              "expected": 0.16085204911450918
            },
            {
              "variable": "j_NO3b",
              "time": 0.0,
              "expected": 0.020696539050851066
            },
            {
              "variable": "j_N2O5",
              "time": 0.0,
              "expected": 1.6385436376288572e-05
            },
            {
