      "examples": [
        {
          "id": "diurnal_decay_summer_eq",
          "description": "Decay of NO2 under fixed-conditions photolysis at the noon-summer-equator scenario. Demonstrates that the migrated component runs as a real 0-D ODE driven by AST-composed j_NO2.",
          "initial_state": {
            "type": "per_variable",
            "values": {
              "NO2": 1e-09
            }
          },
          "parameters": {
            "T": 298.0,
            "P": 101325.0,
            "H2O": 450.0,
            "cos_sza": 0.9173780810128263
          },
          "time_span": {
            "start": 0.0,
            "end": 3600.0
          },
          "plots": [
            {
              "id": "NO2_vs_time",
              "type": "line",
              "description": "Tracer NO2 decaying over 1 h under noon-summer-equator photolysis (j_NO2 ≈ const).",
              "x": {
                "variable": "t",
                "label": "time (s)"
              },
              "y": {
                "variable": "NO2",
                "label": "NO2 (mol/mol)"
              }
            }
          ]
        },
        {
          "id": "cos_sza_sweep",
          "description": "Solar-zenith sensitivity of the NO2 photolysis rate. Sweeps cos_sza from 0.1 (low sun) to 1.0 (sub-solar / noon equator) at default T=298 K, P=101325 Pa, H2O=450 ppb. The bilinear actinic-flux interpolation drives F_i upward as the sun rises, so j_NO2 = (Σ_i F_i · σ_NO2_i) · ϕ_NO2 grows monotonically with cos_sza. Each grid point integrates the trivial NO2 ODE for 1 s; the renderer collapses each trajectory to its endpoint (j_NO2 is algebraic, so the value is constant over t) to plot j_NO2 vs cos_sza.",
          "initial_state": {
            "type": "per_variable",
            "values": {
              "NO2": 1e-09
            }
          },
          "parameters": {
            "T": 298.0,
            "P": 101325.0,
            "H2O": 450.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "parameter_sweep": {
