            "tests": [
                {
                    "id": "pollu_benchmark_nox_ozone",
                    "description": "Classic POLLU air-pollution benchmark (Verwer 1994), NOx / odd-oxygen pathways. Initial conditions are the standard POLLU problem state (NO=200, O3=40, CH2O=100, CO=300, ALD=10, SO2=7 ppb; all radicals and secondary products zero), matching GasChem.jl test/pollu_test.jl. Integrated 0..3600 s. O3 climbs from 40 ppb down to ~3.3 ppb and back up to ~5.5 ppb while NO (200 ppb) is converted to NO2 and ultimately to HNO3 / N2O5. The O3 values at 60 s and 3600 s reproduce the published POLLU reference solution (3.299406575662 and 5.52314020747798 ppb) to ~1e-8. Expected values are an upstream reference run of the GasChem.jl Pollu() ReactionSystem (Rosenbrock23, abstol=reltol=1e-12).\n\nTolerance rationale (test-level rel=1e-5): the ESS scipy-BDF integration reproduces the upstream Rosenbrock23 reference to <=1.5e-6 across every assertion in this file; rel=1e-5 leaves ~6x headroom for cross-environment solver-truncation variation.",
                    "initial_conditions": {
                        "NO2": 0.0,
                        "NO": 200.0,
                        "O3P": 0.0,
                        "O3": 40.0,
                        "HO2": 0.0,
                        "OH": 0.0,
                        "CH2O": 100.0,
                        "CO": 300.0,
                        "ALD": 10.0,
                        "MEO2": 0.0,
                        "C2O3": 0.0,
                        "CO2": 0.0,
                        "PAN": 0.0,
                        "CH3O": 0.0,
                        "HNO3": 0.0,
                        "O1D": 0.0,
                        "SO2": 7.0,
                        "SO4": 0.0,
                        "NO3": 0.0,
                        "N2O5": 0.0
                    },
                    "time_span": {
                        "start": 0.0,
                        "end": 3600.0
                    },
                    "tolerance": {
                        "rel": 1e-05
                    },
                    "assertions": [
                        {
                            "variable": "O3",
                            "time": 60.0,
                            "expected": 3.2994065585833074
                        },
                        {
                            "variable": "NO",
                            "time": 60.0,
                            "expected": 162.5132541096391
                        },
                        {
                            "variable": "NO2",
                            "time": 60.0,
                            "expected": 37.326304316021215
                        },
                        {
                            "variable": "HNO3",
                            "time": 60.0,
                            "expected": 0.1395946402838492
                        },
                        {
                            "variable": "O3",
                            "time": 360.0,
                            "expected": 3.3019885626845236
                        },
                        {
                            "variable": "NO",
                            "time": 360.0,
                            "expected": 158.9289939721817
                        },
                        {
                            "variable": "NO2",
                            "time": 360.0,
                            "expected": 40.03870361089256
                        },
                        {
                            "variable": "HNO3",
                            "time": 360.0,
                            "expected": 0.9627454219929577
                        },
                        {
                            "variable": "O3",
                            "time": 1200.0,
                            "expected": 3.974120041890565
                        },
                        {
                            "variable": "NO",
                            "time": 1200.0,
                            "expected": 150.92528896734098
                        },
                        {
                            "variable": "NO2",
                            "time": 1200.0,
                            "expected": 45.72027350810146
                        },
