                    "description": "Arrhenius exponential temperature term. [K]"
                },
                "c0": {
                    "type": "parameter",
                    "default": 100000000.0,
                    "description": "Tunnelling (1/T^3) temperature term. [K^3]"
                },
                "d0": {
                    "type": "parameter",
                    "default": 1.0,
                    "description": "Constant term of the linear pre-factor."
                },
                "e0": {
                    "type": "parameter",
                    "default": 0.0,
                    "description": "Slope of the linear-in-T pre-factor. [K^-1]"
                },
                "k": {
                    "type": "state",
                    "description": "Reaction rate coefficient produced by the tunplus_mlc_1 rate law, output in s^-1. Defined by one algebraic equation; the system carries no time derivative."
                }
            },
