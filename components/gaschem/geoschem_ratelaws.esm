            "tests": [
                {
                    "id": "upstream_rate_RO2NO_b1",
                    "description": "Reproduces the upstream `rate_RO2NO_b1` rate-law test (GasChem.jl test/geoschem_ratelaws_test.jl). All parameters are at their declared defaults \u2014 the exact coefficient values the upstream @testitem passes to `rate_RO2NO_b1` \u2014 and the rate coefficient k is pinned to the upstream expected value 0.21040768863952958.",
                    "parameter_overrides": {},
