                    }
                }
            ],
            "tests": [
                {
                    "id": "upstream_arrhenius_ppb",
                    "description": "Reproduces the upstream `arrhenius_ppb` rate-law test (GasChem.jl test/geoschem_ratelaws_test.jl). All parameters are at their declared defaults \u2014 the exact coefficient values the upstream @testitem passes to `arrhenius_ppb` \u2014 and the rate coefficient k is pinned to the upstream expected value 0.00048432225861535784.",
