            "tests": [
                {
                    "id": "upstream_rate_RO2HO2",
                    "description": "Reproduces the upstream `rate_RO2HO2` rate-law test (GasChem.jl test/geoschem_ratelaws_test.jl). All parameters are at their declared defaults \u2014 the exact coefficient values the upstream @testitem passes to `rate_RO2HO2` \u2014 and the rate coefficient k is pinned to the upstream expected value 0.4147862847681038.",
                    "parameter_overrides": {},
