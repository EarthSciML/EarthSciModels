                            1.1e-12,
                            {
                                "op": "exp",
                                "args": [
                                    {
                                        "op": "/",
                                        "args": [
                                            0.0,
                                            "T"
                                        ]
                                    }
                                ]
                            },
                            {
                                "op": "^",
