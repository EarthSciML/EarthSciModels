{
  "esm": "0.1.0",
  "metadata": {
    "name": "MinimalShimFixture",
    "description": "Minimal single-model ESM fixture used by the EarthSciModels Julia shim tests. Exercises the load_esm(path) -> ModelingToolkit.System path with a trivial first-order decay equation. Real model fixtures land in the top-level models/ tree under Phase-3 migration beads.",
    "authors": ["EarthSciML Authors and Contributors"],
    "created": "2026-04-19T00:00:00Z"
  },
  "models": {
    "MinimalDecay": {
      "variables": {
        "x": { "type": "state", "units": "mol/mol", "default": 1e-6 },
        "k": { "type": "parameter", "units": "1/s", "default": 0.01 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["x"], "wrt": "t" },
          "rhs": { "op": "*", "args": [ { "op": "-", "args": ["k"] }, "x" ] }
        }
      ]
    }
  }
}
